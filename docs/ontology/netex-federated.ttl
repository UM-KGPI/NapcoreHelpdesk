netex:LogicalDisplay a skos:Concept ;
    skos:prefLabel "logical display"@en ;
    skos:altLabel "logicaldisplay"@en ;
    rdfs:comment "Represents a set of data that can be assembled for assignment to a physical PASSENGER INFORMATION EQUIPMENT or to a logical channel such as web or media. It is independent of any physical embodiment LOGICAL DISPLAY corresponds to a SIRI STOP MONITORING point."@en .

netex:LostPropertyService a skos:Concept ;

@prefix nits: <https://napcore.eu/ontology/nits#> .
@prefix netex: <https://napcore.eu/ontology/netex#> .
@prefix opra: <https://napcore.eu/ontology/opra#> .
@prefix siri: <https://napcore.eu/ontology/siri#> .
@prefix datex: <https://napcore.eu/ontology/datex#> .
@prefix transmodel: <https://napcore.eu/ontology/transmodel#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://napcore.eu/ontology/netex-federated>
    a owl:Ontology ;
    dcterms:title "NeTEx Federated Ontology"@en ;
    dcterms:description "NeTEx-focused federated ontology module generated from the local glossary and linked to NAPCORE ITS core concepts."@en ;
    dcterms:created "2026-04-16"^^xsd:date ;
    owl:versionInfo "0.3.0" ;
    owl:imports <https://napcore.eu/ontology/napcore-its> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

netex:AbstractGroupMember a skos:Concept ;
    skos:prefLabel "abstract group member"@en ;
    skos:altLabel "abstract member of a group"@en ;
    skos:altLabel "abstractgroupmember"@en ;
    rdfs:comment "Abstract member of a GROUP OF ENTITY MEMBERs."@en .

netex:AcceptedDriverPermit a skos:Concept ;
    skos:prefLabel "accepted driver permit"@en ;
    skos:altLabel "accepted type of driver permit"@en ;
    skos:altLabel "accepteddriverpermit"@en ;
    rdfs:comment "Accepted TYPE OF DRIVER PERMIT for a given SIMPLE VEHICLE TYPE. +v2.0"@en .

netex:Access a skos:Concept ;
    skos:prefLabel "access"@en ;
    rdfs:comment "The physical (spatial) possibility for a passenger to access or leave the public transport system. This link may be used during a trip for:- the walking movement of a passenger from a PLACE (origin of the trip) to a STOP POINT (origin of the PT TRIP), or- the walking movement from a STOP POINT (destination of the PT TRIP) to a PLACE (destination of the trip)."@en ;
    skos:related netex:Transfer .

netex:AccessEquipment a skos:Concept ;
    skos:prefLabel "access equipment"@en ;
    skos:altLabel "accessequipment"@en ;
    skos:altLabel "specialisation of place equipment dedicated"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT dedicated to access (e.g. lifts, entrances, stairs, ramps, etc.)."@en ;
    skos:related netex:PlaceEquipment .

netex:AccessFacility a skos:Concept ;
    skos:prefLabel "access facility"@en ;
    skos:altLabel "accessfacility"@en ;
    skos:altLabel "classification of site access facility"@en ;
    rdfs:comment "Classification of SITE ACCESS FACILITY."@en .

netex:AccessFacilityList a skos:Concept ;
    skos:prefLabel "access facility list"@en ;
    skos:altLabel "accessfacilitylist"@en ;
    skos:altLabel "list of site access facilities"@en ;
    rdfs:comment "List of SITE ACCESS FACILITies."@en .

netex:AccessMode a skos:Concept ;
    skos:prefLabel "access mode"@en ;
    skos:altLabel "access mode for sites and"@en ;
    skos:altLabel "accessmode"@en ;
    rdfs:comment "Access MODE for SITEs and VEHICLE MEETING POINTs. Also used for TRANSFER and if in OTHER LEG of the TRIP a monomodal non-public transport is used."@en .

netex:AccessRightInProduct a skos:Concept ;
    skos:prefLabel "access right in product"@en ;
    skos:altLabel "accessrightinproduct"@en ;
    rdfs:comment "A VALIDABLE ELEMENT as a part of a PRE-ASSIGNED FARE PRODUCT, including its possible order in the set of all VALIDABLE ELEMENTs grouped together to define the access right assigned to that PRE-ASSIGNED FARE PRODUCT."@en .

netex:AccessRightParameterAssignment a skos:Concept ;
    skos:prefLabel "access right parameter assignment"@en ;
    skos:altLabel "accessrightparameterassignment"@en ;
    skos:altLabel "assignment of a fare"@en ;
    rdfs:comment "The assignment of a fare parameter (referring to geography, time, quality or usage) to an element of a fare system (access right, validated access, control mean, etc.)."@en .

netex:AccessSpace a skos:Concept ;
    skos:prefLabel "access space"@en ;
    skos:altLabel "accessspace"@en ;
    rdfs:comment "An area within a STOP PLACE that does not give direct access to transport vehicles. May be connected to QUAYS by PATH LINKs."@en ;
    skos:related netex:StopPlaceSpace .

netex:AccessSummary a skos:Concept ;
    skos:prefLabel "access summary"@en ;
    skos:altLabel "accesssummary"@en ;
    skos:altLabel "summary of a feature used"@en ;
    rdfs:comment "Summary of a feature used in NAVIGATION PATH."@en .

netex:AccessVehicleEquipment a skos:Concept ;
    skos:prefLabel "access vehicle equipment"@en ;
    skos:altLabel "accessvehicleequipment"@en ;
    skos:altLabel "specialisation of vehicle equipment for"@en ;
    rdfs:comment "Specialisation of VEHICLE EQUIPMENT for ACCESS providing information such as low floor, ramp, access area dimensions, etc."@en ;
    skos:related netex:PassengerEquipment .

netex:AccessZone a skos:Concept ;
    skos:prefLabel "access zone"@en ;
    skos:altLabel "accesszone"@en ;
    rdfs:comment "An identified storey (ground, first, basement, mezzanine, etc) within an interchange building or SITE on which SITE COMPONENTs reside. A PATH LINK may connect components on different ACCESS ZONEs."@en ;
    skos:related netex:Zone .

netex:AccessibilityAssessment a skos:Concept ;
    skos:prefLabel "accessibility assessment"@en ;
    skos:altLabel "accessibilityassessment"@en ;
    rdfs:comment "The accessibility characteristics of an entity used by passengers such as a STOP PLACE, or a STOP PLACE COMPONENT. Described by ACCESSIBILITY LIMITATIONs, and/or a set of SUITABILITies."@en .

netex:AccessibilityInfoFacility a skos:Concept ;
    skos:prefLabel "accessibility info facility"@en ;
    skos:altLabel "accessibilityinfofacility"@en ;
    skos:altLabel "classification of accessibility info facility"@en ;
    rdfs:comment "Classification of ACCESSIBILITY INFO FACILITY type - TPEG pti23."@en .

netex:AccessibilityInfoFacilityList a skos:Concept ;
    skos:prefLabel "accessibility info facility list"@en ;
    skos:altLabel "accessibilityinfofacilitylist"@en ;
    skos:altLabel "list of accessibility info facilities"@en ;
    rdfs:comment "List of ACCESSIBILITY INFO FACILITies."@en .

netex:AccessibilityLimitation a skos:Concept ;
    skos:prefLabel "accessibility limitation"@en ;
    skos:altLabel "accessibilitylimitation"@en ;
    skos:altLabel "categorisation of the accessibility"@en ;
    rdfs:comment "A categorisation of the ACCESSIBILITY characteristics of a STOP PLACE COMPONENT such as a STOP PATH LINK, STOP PLACE or ACCESS SPACE to indicate its usability by passengers with specific needs, for example, those needing wheelchair access, step-free access or wanting to avoid confined spaces such as lifts."@en .

netex:AccessibilityTool a skos:Concept ;
    skos:prefLabel "accessibility tool"@en ;
    skos:altLabel "accessibilitytool"@en ;
    skos:altLabel "classification of accessibility tools"@en ;
    rdfs:comment "Classification of ACCESSIBILITY TOOLs."@en .

netex:AccessibilityToolList a skos:Concept ;
    skos:prefLabel "accessibility tool list"@en ;
    skos:altLabel "accessibilitytoollist"@en ;
    skos:altLabel "list of accessibility tools"@en ;
    rdfs:comment "List of ACCESSIBILITY TOOLs."@en .

netex:Accommodation a skos:Concept ;
    skos:prefLabel "accommodation"@en ;
    skos:altLabel "allowed combinations of accommodation"@en ;
    rdfs:comment "Allowed combinations of accommodation."@en .

netex:AccommodationAccess a skos:Concept ;
    skos:prefLabel "accommodation access"@en ;
    skos:altLabel "accommodationaccess"@en ;
    skos:altLabel "classification of accommodation access type"@en ;
    rdfs:comment "Classification of ACCOMMODATION ACCESS type -"@en .

netex:AccommodationAccessList a skos:Concept ;
    skos:prefLabel "accommodation access list"@en ;
    skos:altLabel "accommodationaccesslist"@en ;
    skos:altLabel "list of accommodation access"@en ;
    rdfs:comment "List of ACCOMMODATION ACCESS."@en .

netex:AccommodationFacility a skos:Concept ;
    skos:prefLabel "accommodation facility"@en ;
    skos:altLabel "accommodationfacility"@en ;
    skos:altLabel "classification of accommodation facility type"@en ;
    rdfs:comment "Classification of ACCOMMODATION FACILITY type - TPEG pti23."@en .

netex:AccommodationFacilityList a skos:Concept ;
    skos:prefLabel "accommodation facility list"@en ;
    skos:altLabel "accommodationfacilitylist"@en ;
    skos:altLabel "list of accommodation facilities"@en ;
    rdfs:comment "List of ACCOMMODATION FACILITies."@en .

netex:AccountableElement a skos:Concept ;
    skos:prefLabel "accountable element"@en ;
    skos:altLabel "accountableelement"@en ;
    rdfs:comment "A period of a driver's DUTY during which (s)he is continuously working without a BREAK. PAUSEs during which (the)he remains responsible for the vehicle may be included."@en .

netex:ActivatedEquipment a skos:Concept ;
    skos:prefLabel "activated equipment"@en ;
    skos:altLabel "activatedequipment"@en ;
    skos:altLabel "equipment activated by the"@en ;
    rdfs:comment "An EQUIPMENT activated by the passage of a vehicle at an ACTIVATION POINT or on an ACTIVATION LINK."@en .

netex:ActivationAssignment a skos:Concept ;
    skos:prefLabel "activation assignment"@en ;
    skos:altLabel "activationassignment"@en ;
    skos:altLabel "assignment of an activation"@en ;
    rdfs:comment "An assignment of an ACTIVATION POINT/LINK to an ACTIVATED EQUIPMENT related on its turn to a TRAFFIC CONTROL POINT. The considered ACTIVATION POINT/LINK will be used to influence the control process for that TRAFFIC CONTROL POINT (e.g. to fix priorities as regards the processing of competing requests from different ACTIVATION POINTs/LINKs)."@en .

netex:ActivationLink a skos:Concept ;
    skos:prefLabel "activation link"@en ;
    skos:altLabel "activationlink"@en ;
    skos:altLabel "link where a control"@en ;
    rdfs:comment "A LINK where a control process is activated when a vehicle passes it."@en ;
    skos:related netex:Link .

netex:ActivationPoint a skos:Concept ;
    skos:prefLabel "activation point"@en ;
    skos:altLabel "activationpoint"@en ;
    skos:altLabel "point where a control"@en ;
    rdfs:comment "A POINT where a control process is activated when a vehicle passes it. EQUIPMENT may be needed for the activation."@en .

netex:ActualVehicleEquipment a skos:Concept ;
    skos:prefLabel "actual vehicle equipment"@en ;
    skos:altLabel "actualvehicleequipment"@en ;
    skos:altLabel "item of equipment of"@en ;
    rdfs:comment "An item of EQUIPMENT of a particular type actually available in an individual VEHICLE."@en ;
    skos:related netex:PassengerEquipment .

netex:AdditionalDriverOption a skos:Concept ;
    skos:prefLabel "additional driver option"@en ;
    skos:altLabel "additionaldriveroption"@en ;
    rdfs:comment "Parameters relating to paying by AdditionalDriverOption for a product. +v1.1"@en .

netex:AddressablePlace a skos:Concept ;
    skos:prefLabel "addressable place"@en ;
    skos:altLabel "addressableplace"@en ;
    skos:altLabel "place which may have"@en ;
    rdfs:comment "A PLACE which may have an address."@en ;
    skos:related netex:Place .

netex:AdministrativeZone a skos:Concept ;
    skos:prefLabel "administrative zone"@en ;
    skos:altLabel "administrativezone"@en ;
    skos:altLabel "zone relating to the"@en ;
    rdfs:comment "A ZONE relating to the management responsibilities of an ORGANISATION. For example to allocate bus stop identifiers for a region."@en .

netex:AllVehicleModes a skos:Concept ;
    skos:prefLabel "all public transport modes including"@en ;
    skos:altLabel "all vehicle modes"@en ;
    skos:altLabel "allvehiclemodes"@en ;
    rdfs:comment "All PUBLIC TRANSPORT MODEs including self drive."@en .

netex:AllowedLineDirection a skos:Concept ;
    skos:prefLabel "allowed line direction"@en ;
    skos:altLabel "allowedlinedirection"@en ;
    skos:altLabel "set of allowed directions"@en ;
    rdfs:comment "A set of allowed DIRECTIONs that can be used on a given ROUTE."@en .

netex:AlternativeModeOfOperation a skos:Concept ;
    skos:prefLabel "alternative mode of operation"@en ;
    skos:altLabel "alternativemodeofoperation"@en ;
    skos:altLabel "any publicly advertised mode of"@en ;
    rdfs:comment "Any publicly advertised mode of operation different from the CONVENTIONAL MODE OF OPERATION, for example: VEHICLE SHARING, VEHICLE RENTAL, VEHICLE POOLING. +v1.2.2"@en .

netex:AlternativeQuayDescriptor a skos:Concept ;
    skos:prefLabel "alternative quay descriptor"@en ;
    skos:altLabel "alternativequaydescriptor"@en ;
    rdfs:comment "An element of a STOP PLACE describing part of its structure."@en .

netex:AmountOfPriceUnitProduct a skos:Concept ;
    skos:prefLabel "amount of price unit product"@en ;
    skos:altLabel "amountofpriceunitproduct"@en ;
    skos:altLabel "fare product consisting in"@en ;
    rdfs:comment "A FARE PRODUCT consisting in a stored value of PRICE UNITs: an amount of money on an electronic purse, amount of units on a value card etc."@en .

netex:Assignment a skos:Concept ;
    skos:prefLabel "assignment"@en ;
    rdfs:comment "A set of properties to be applied to an another element. It has a name and an order."@en .

netex:AssistanceBookingService a skos:Concept ;
    skos:prefLabel "assistance booking service"@en ;
    skos:altLabel "assistancebookingservice"@en ;
    rdfs:comment "Information about how to book assistance for wheelchair and disabled users."@en ;
    skos:related netex:LocalService .

netex:AssistanceFacility a skos:Concept ;
    skos:prefLabel "assistance facility"@en ;
    skos:altLabel "assistancefacility"@en ;
    skos:altLabel "classification of assistance facility"@en ;
    rdfs:comment "Classification of ASSISTANCE FACILITY."@en .

netex:AssistanceFacilityList a skos:Concept ;
    skos:prefLabel "assistance facility list"@en ;
    skos:altLabel "assistancefacilitylist"@en ;
    skos:altLabel "list of assistance facilities"@en ;
    rdfs:comment "List of ASSISTANCE FACILITies."@en .

netex:AssistanceService a skos:Concept ;
    skos:prefLabel "assistance service"@en ;
    skos:altLabel "assistanceservice"@en ;
    skos:altLabel "specialisation of local service for"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE for ASSISTANCE providing information like language, accessibility trained staff, etc."@en ;
    skos:related netex:LocalService .

netex:AudibleSignalsAvailable a skos:Concept ;
    skos:prefLabel "audible signals available"@en ;
    skos:altLabel "audiblesignalsavailable"@en ;
    skos:altLabel "whether a place has audible"@en ;
    rdfs:comment "Whether a PLACE has audible signals for the visually impaired."@en .

netex:Authority a skos:Concept ;
    skos:prefLabel "authority"@en ;
    rdfs:comment "The ORGANISATION under which the responsibility of organising the transport service in a certain area is placed."@en .

netex:AvailabilityCondition a skos:Concept ;
    skos:prefLabel "availability condition"@en ;
    skos:altLabel "availabilitycondition"@en ;
    skos:altLabel "validity condition stated in terms"@en ;
    rdfs:comment "VALIDITY CONDITION stated in terms of DAY TYPES and PROPERTIES OF DAYs."@en .

netex:BatteryEquipment a skos:Concept ;
    skos:prefLabel "battery equipment"@en ;
    skos:altLabel "batteryequipment"@en ;
    skos:altLabel "specialisation of installed equipment for"@en ;
    rdfs:comment "Specialisation of INSTALLED EQUIPMENT for BATTERY. +v1.2.2"@en ;
    skos:related netex:InstalledEquipment .

netex:BeaconPoint a skos:Concept ;
    skos:prefLabel "beacon point"@en ;
    skos:altLabel "beaconpoint"@en ;
    skos:altLabel "point where a beacon"@en ;
    rdfs:comment "A POINT where a beacon or similar device to support the automatic detection of vehicles passing by is located."@en .

netex:BedEquipment a skos:Concept ;
    skos:prefLabel "bed equipment"@en ;
    skos:altLabel "bedequipment"@en ;
    skos:altLabel "specialisation of spot equipment"@en ;
    rdfs:comment "A specialisation of SPOT EQUIPMENT describing the detailed properties of a bed. +v2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:BerthFacility a skos:Concept ;
    skos:prefLabel "berth facility"@en ;
    skos:altLabel "berthfacility"@en ;
    rdfs:comment "Classification of BERTHFACILITY type - TPEG pti23."@en .

netex:Blacklist a skos:Concept ;
    skos:prefLabel "blacklist"@en ;
    rdfs:comment "A list of items (TRAVEL DOCUMENTs, CONTRACTs etc) the validity of which has been cancelled temporarily or permanently, for a specific reason like loss of the document, technical malfunction, no credit on bank account, offences committed by the customer, etc."@en .

netex:Block a skos:Concept ;
    skos:prefLabel "block"@en ;
    rdfs:comment "The work of a vehicle from the time it leaves a PARKING POINT after parking until its next return to park at a PARKING POINT. Any subsequent departure from a PARKING POINT after parking marks the start of a new BLOCK. The period of a BLOCK has to be covered by DUTies."@en .

netex:BoardingPermission a skos:Concept ;
    skos:prefLabel "boarding permission"@en ;
    skos:altLabel "boardingpermission"@en ;
    skos:altLabel "classification of boarding permission"@en ;
    rdfs:comment "Classification of BOARDING PERMISSION - UIC 7161 Code list."@en .

netex:BoardingPosition a skos:Concept ;
    skos:prefLabel "boarding position"@en ;
    skos:altLabel "boardingposition"@en ;
    rdfs:comment "A location within a QUAY from which passengers may directly board, or onto which passengers may directly alight from, a VEHICLE."@en ;
    skos:related netex:StopPlaceSpace .

netex:BookingArrangement a skos:Concept ;
    skos:prefLabel "booking arrangement"@en ;
    skos:altLabel "bookingarrangement"@en ;
    skos:altLabel "details of the booking arrangements"@en ;
    rdfs:comment "Details of the booking arrangements for a given LINE, STOP, SERVICE etc."@en .

netex:BookingDebit a skos:Concept ;
    skos:prefLabel "booking debit"@en ;
    skos:altLabel "bookingdebit"@en ;
    rdfs:comment "A LOG ENTRY recording data about a debiting action for a booking fee."@en .

netex:BookingPolicy a skos:Concept ;
    skos:prefLabel "booking policy"@en ;
    skos:altLabel "bookingpolicy"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer. +v1.2.2"@en .

netex:BookingProcessFacility a skos:Concept ;
    skos:prefLabel "booking process facility"@en ;
    skos:altLabel "bookingprocessfacility"@en ;
    skos:altLabel "classification of booking process facility"@en ;
    rdfs:comment "Classification of BOOKING PROCESS FACILITY type - UIC 7037 Code list."@en .

netex:BookingProcessFacilityList a skos:Concept ;
    skos:prefLabel "booking process facility list"@en ;
    skos:altLabel "bookingprocessfacilitylist"@en ;
    skos:altLabel "list of booking process facilities"@en ;
    rdfs:comment "List of BOOKING PROCESS FACILITies UIC 7037 Code list."@en .

netex:Branding a skos:Concept ;
    skos:prefLabel "branding"@en ;
    rdfs:comment "An arbitrary marketing classification."@en ;
    skos:related netex:TypeOfValue .

netex:Call a skos:Concept ;
    skos:prefLabel "call"@en ;
    rdfs:comment "A visit to a SCHEDULED STOP POINT as part of a VEHICLE JOURNEY. A CALL is a view of a POINT IN JOURNEY PATTERN that adds in derived data."@en .

netex:Cancelling a skos:Concept ;
    skos:prefLabel "cancelling"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer."@en .

netex:CappedDiscountRight a skos:Concept ;
    skos:prefLabel "capped discount right"@en ;
    skos:altLabel "cappeddiscountright"@en ;
    rdfs:comment "A FARE PRODUCT allowing a customer to benefit from discounts when consuming VALIDABLE ELEMENTs."@en .

netex:CappingRule a skos:Concept ;
    skos:prefLabel "capping rule"@en ;
    skos:altLabel "cappingrule"@en ;
    skos:altLabel "rule about capping for a"@en ;
    rdfs:comment "Rule about capping for a mode."@en ;
    skos:related netex:Branding, netex:Extensions, netex:keyList .

netex:CappingRulePrice a skos:Concept ;
    skos:prefLabel "capping rule price"@en ;
    skos:altLabel "cappingruleprice"@en ;
    rdfs:comment "A set of all possible price features of a CAPPING RULE default total price, discount in value or percentage etc."@en .

netex:CarModelProfile a skos:Concept ;
    skos:prefLabel "car model profile"@en ;
    skos:altLabel "carmodelprofile"@en ;
    rdfs:comment "A set of characteristics of equipment installed on-board and characterising a CAR MODEL PROFILE. +v1.2.2"@en .

netex:CarPoolingService a skos:Concept ;
    skos:prefLabel "car pooling service"@en ;
    skos:altLabel "carpoolingservice"@en ;
    skos:altLabel "transport service that connects"@en ;
    rdfs:comment "A transport service that connects users (driver and passenger(s)) for carrying out trips. +v1.2.2"@en .

netex:CarServiceFacility a skos:Concept ;
    skos:prefLabel "car service facility"@en ;
    skos:altLabel "carservicefacility"@en ;
    skos:altLabel "classification of car service facility"@en ;
    rdfs:comment "Classification of CAR SERVICE FACILITY."@en .

netex:CarServiceFacilityList a skos:Concept ;
    skos:prefLabel "car service facility list"@en ;
    skos:altLabel "carservicefacilitylist"@en ;
    skos:altLabel "list of car service facilities"@en ;
    rdfs:comment "List of CAR SERVICE FACILITies."@en .

netex:CateringFacility a skos:Concept ;
    skos:prefLabel "catering facility"@en ;
    skos:altLabel "cateringfacility"@en ;
    skos:altLabel "classification of catering facility type"@en ;
    rdfs:comment "Classification of CATERING FACILITY type - TPEG pti23."@en .

netex:CateringFacilityList a skos:Concept ;
    skos:prefLabel "catering facility list"@en ;
    skos:altLabel "cateringfacilitylist"@en ;
    skos:altLabel "list of catering facilities"@en ;
    rdfs:comment "List of CATERING FACILITies."@en .

netex:CateringService a skos:Concept ;
    skos:prefLabel "catering service"@en ;
    skos:altLabel "cateringservice"@en ;
    skos:altLabel "specialisation of local service dedicated"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE dedicated to catering service."@en ;
    skos:related netex:LocalService .

netex:Cell a skos:Concept ;
    skos:prefLabel "cell"@en ;
    rdfs:comment "An individual combination of features in a FARE TABLE, used to associate a FARE PRICE."@en .

netex:ChargingMoment a skos:Concept ;
    skos:prefLabel "charging moment"@en ;
    skos:altLabel "chargingmoment"@en ;
    rdfs:comment "A classification of FARE PRODUCTs according to the payment method and the account location: pre-payment with cancellation (throw-away), pre-payment with debit on a value card, pre-payment without consumption registration (pass), post-payment etc."@en ;
    skos:related netex:TypeOfValue .

netex:ChargingPolicy a skos:Concept ;
    skos:prefLabel "charging policy"@en ;
    skos:altLabel "chargingpolicy"@en ;
    skos:altLabel "policy regarding different aspects of"@en ;
    rdfs:comment "Policy regarding different aspects of charging such as credit limits."@en .

netex:ChauffeuredVehicleService a skos:Concept ;
    skos:prefLabel "chauffeured vehicle service"@en ;
    skos:altLabel "chauffeuredvehicleservice"@en ;
    skos:altLabel "type of vehicle pooling"@en ;
    rdfs:comment "A type of VEHICLE POOLING SERVICE which can only be used by prior arrangement and where the driver has a commercial agreement with the user. +v1.2.2"@en .

netex:CheckConstraint a skos:Concept ;
    skos:prefLabel "check constraint"@en ;
    skos:altLabel "checkconstraint"@en ;
    rdfs:comment "Characteristics of a SITE COMPONENT representing a process, such as check-in, security screening, ticket control or immigration, that may potentially incur a time penalty that should be allowed for when journey planning. Used to mark PATH LINKs to determine transit routes through interchanges."@en .

netex:CheckConstraintDelay a skos:Concept ;
    skos:prefLabel "check constraint delay"@en ;
    skos:altLabel "checkconstraintdelay"@en ;
    rdfs:comment "Time penalty associated with a CHECK CONSTRAINT."@en .

netex:CheckConstraintThroughput a skos:Concept ;
    skos:prefLabel "check constraint throughput"@en ;
    skos:altLabel "checkconstraintthroughput"@en ;
    skos:altLabel "throughput of a check constraint"@en ;
    rdfs:comment "Throughput of a CHECK CONSTRAINT. the number of passengers who can pass through it."@en .

netex:ClassOfUse a skos:Concept ;
    skos:prefLabel "class of use"@en ;
    skos:altLabel "classofuse"@en ;
    rdfs:comment "Defines an Classification of users who may make use of a component or amenity."@en ;
    skos:related netex:TypeOfValue .

netex:ClimateControl a skos:Concept ;
    skos:prefLabel "classification of climate control facility"@en ;
    skos:altLabel "climate control"@en ;
    skos:altLabel "climatecontrol"@en ;
    rdfs:comment "Classification of climate control FACILITY."@en .

netex:ClimateControlList a skos:Concept ;
    skos:prefLabel "climate control list"@en ;
    skos:altLabel "climatecontrollist"@en ;
    skos:altLabel "list of climate control facilities"@en ;
    rdfs:comment "List of CLIMATE CONTROL FACILITies."@en .

netex:CoachSubmode a skos:Concept ;
    skos:prefLabel "coach submode"@en ;
    skos:altLabel "coachsubmode"@en ;
    skos:altLabel "tpeg pti03 coach submodes"@en ;
    rdfs:comment "TPEG pti03 Coach submodes."@en .

netex:CommercialProfile a skos:Concept ;
    skos:prefLabel "commercial profile"@en ;
    skos:altLabel "commercialprofile"@en ;
    rdfs:comment "A category of users depending on their commercial relations with the operator (frequency of use, amount of purchase etc.), often used for allowing discounts."@en .

netex:CommercialProfileEligibility a skos:Concept ;
    skos:prefLabel "commercial profile eligibility"@en ;
    skos:altLabel "commercialprofileeligibility"@en ;
    rdfs:comment "Whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific COMMERCIAL PROFILE as a validity parameter."@en .

netex:CommonFrame a skos:Concept ;
    skos:prefLabel "common frame"@en ;
    skos:altLabel "commonframe"@en ;
    rdfs:comment "Abstract supertype for explicit VERSION FRAMEs."@en .

netex:CommonSection a skos:Concept ;
    skos:prefLabel "common section"@en ;
    skos:altLabel "commonsection"@en ;
    rdfs:comment "A shared set of LINKS or POINTs. A part of a public transport network where the ROUTEs of several JOURNEY PATTERNs are going in parallel and where the synchronisation of SERVICE JOURNEYs may be planned and controlled with respect to commonly used LINKs and STOP POINTs. COMMON SECTIONs are defined arbitrarily and need not cover the total lengths of topologically bundled sections."@en .

netex:CommonSectionPointMember a skos:Concept ;
    skos:prefLabel "common section point member"@en ;
    skos:altLabel "commonsectionpointmember"@en ;
    rdfs:comment "DEPRECATED - Kept for backwards compatibility POINT Member of a COMMON SECTION.]"@en .

netex:CommonVehicleService a skos:Concept ;
    skos:prefLabel "common vehicle service"@en ;
    skos:altLabel "commonvehicleservice"@en ;
    skos:altLabel "transport service offer related"@en ;
    rdfs:comment "A transport service offer related to VEHICLEs. +v1.2.2"@en .

netex:CommunicationService a skos:Concept ;
    skos:prefLabel "communication service"@en ;
    skos:altLabel "communicationservice"@en ;
    skos:altLabel "specialisation of local service dedicated"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE dedicated to communication services."@en ;
    skos:related netex:LocalService .

netex:CompanionProfile a skos:Concept ;
    skos:prefLabel "companion profile"@en ;
    skos:altLabel "companionprofile"@en ;
    rdfs:comment "The number and characteristics (weight, volume) of luggage that a holder of an access right is entitled to carry."@en .

netex:ComplaintsService a skos:Concept ;
    skos:prefLabel "complaints service"@en ;
    skos:altLabel "complaintsservice"@en ;
    skos:altLabel "specialisation of customer service for"@en ;
    rdfs:comment "Specialisation of CUSTOMER SERVICE for COMPLAINTs."@en ;
    skos:related netex:CustomerService .

netex:ComplexFeature a skos:Concept ;
    skos:prefLabel "complex feature"@en ;
    skos:altLabel "complexfeature"@en ;
    rdfs:comment "An aggregate of SIMPLE FEATUREs and/or other COMPLEX FEATUREs; e.g. a STOP AREA : combination of STOP POINTs ; a train station : combination of SIMPLE FEATUREs (POINTs, LINKs) and COMPLEX FEATUREs (STOP AREAs)."@en .

netex:ComplexFeatureProjection a skos:Concept ;
    skos:prefLabel "complex feature projection"@en ;
    skos:altLabel "complexfeatureprojection"@en ;
    rdfs:comment "An oriented correspondence: from one COMPLEX FEATURE in the source layer, onto an entity in a target layer: e.g. POINT, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."@en ;
    skos:related netex:Projection .

netex:CompositeFrame a skos:Concept ;
    skos:prefLabel "composite frame"@en ;
    skos:altLabel "compositeframe"@en ;
    rdfs:comment "A container VERSION FRAME that groups a set of content VERSION FRAMsE to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:CompoundBlock a skos:Concept ;
    skos:prefLabel "composite block formed of"@en ;
    skos:altLabel "compound block"@en ;
    skos:altLabel "compoundblock"@en ;
    rdfs:comment "A composite BLOCK formed of several BLOCKs coupled together during a certain period. Any coupling or separation action marks the start of a new COMPOUND BLOCK."@en .

netex:CompoundTrain a skos:Concept ;
    skos:prefLabel "compound train"@en ;
    skos:altLabel "compoundtrain"@en ;
    skos:altLabel "vehicle composed of compound"@en ;
    rdfs:comment "A vehicle composed of COMPOUND TRAIN ELEMENTs in a certain order, i.e. of wagons assembled together and propelled by a locomotive or one of the wagons."@en .

netex:ConditionSummary a skos:Concept ;
    skos:prefLabel "condition summary"@en ;
    skos:altLabel "conditionsummary"@en ;
    skos:altLabel "summary description of product"@en ;
    rdfs:comment "Summary description of PRODUCT."@en .

netex:Connection a skos:Concept ;
    skos:prefLabel "connection"@en ;
    rdfs:comment "The physical (spatial) possibility for a passenger to change from one public transport vehicle to another to continue the trip. Different times may be necessary to cover this link, depending on the kind of passenger."@en ;
    skos:related netex:Transfer .

netex:Contact a skos:Concept ;
    skos:prefLabel "contact"@en ;
    skos:altLabel "reusable contact details for an"@en ;
    rdfs:comment "Reusable CONTACT details for an ORGANISATION or other entity. +v1.2.2"@en .

netex:Contract a skos:Concept ;
    skos:prefLabel "contract"@en ;
    skos:altLabel "contract between organisations to"@en ;
    rdfs:comment "A CONTRACT between ORGANISATIONs to supply services or goods."@en .

netex:ControlCentre a skos:Concept ;
    skos:prefLabel "control centre"@en ;
    skos:altLabel "controlcentre"@en ;
    rdfs:comment "An ORGANISATION PART for an operational team who are responsible for issuing commands to control the services."@en .

netex:ControllableElement a skos:Concept ;
    skos:prefLabel "controllable element"@en ;
    skos:altLabel "controllableelement"@en ;
    skos:altLabel "smallest controllable element of"@en ;
    rdfs:comment "The smallest controllable element of public transport consumption, all along which any VALIDITY PARAMETER ASSIGNMENT remains valid."@en .

netex:ControllableElementInSequence a skos:Concept ;
    skos:prefLabel "controllable element as a"@en ;
    skos:altLabel "controllable element in sequence"@en ;
    skos:altLabel "controllableelementinsequence"@en ;
    rdfs:comment "A CONTROLLABLE ELEMENT as a part of a FARE STRUCTURE ELEMENT, including its possible order in the sequence of CONTROLLABLE ELEMENTs grouped together to form that FARE STRUCTURE ELEMENT, and its possible quantitative limitation."@en .

netex:ControllableElementPrice a skos:Concept ;
    skos:prefLabel "controllable element price"@en ;
    skos:altLabel "controllableelementprice"@en ;
    rdfs:comment "A set of all possible price features of a CONTROLLABLE ELEMENT ELEMENT: default total price, discount in value or percentage etc."@en .

netex:ConventionalModeOfOperation a skos:Concept ;
    skos:prefLabel "conventional mode of operation"@en ;
    skos:altLabel "conventionalmodeofoperation"@en ;
    rdfs:comment "Legacy mode of operation which is provided as a scheduled and/or flexible publicly advertised transport offer. +v1.2.2"@en .

netex:CouchetteFacility a skos:Concept ;
    skos:prefLabel "classification of couchette facility type"@en ;
    skos:altLabel "couchette facility"@en ;
    skos:altLabel "couchettefacility"@en ;
    rdfs:comment "Classification of COUCHETTE FACILITY type - TPEG pti23."@en .

netex:CouchetteFacilityList a skos:Concept ;
    skos:prefLabel "couchette facility list"@en ;
    skos:altLabel "couchettefacilitylist"@en ;
    skos:altLabel "list of couchette facilities"@en ;
    rdfs:comment "List of COUCHETTE FACILITies."@en .

netex:Country a skos:Concept ;
    skos:prefLabel "country"@en ;
    rdfs:comment "A sovereign COUNTRY.where entities may be located or domiciled."@en ;
    skos:related netex:Place .

netex:CoupledJourney a skos:Concept ;
    skos:prefLabel "complete journey operated by"@en ;
    skos:altLabel "coupled journey"@en ;
    skos:altLabel "coupledjourney"@en ;
    rdfs:comment "A complete journey operated by a coupled train, composed of two or more VEHICLE JOURNEYs remaining coupled together all along a JOURNEY PATTERN. A COUPLED JOURNEY may be viewed as a single VEHICLE JOURNEY."@en .

netex:CourseOfJourneys a skos:Concept ;
    skos:prefLabel "course of journeys"@en ;
    skos:altLabel "courseofjourneys"@en ;
    rdfs:comment "A part of a BLOCK composed of consecutive VEHICLE JOURNEYs defined for the same DAY TYPE, all operated on the same LINE."@en .

netex:CrewBase a skos:Concept ;
    skos:prefLabel "crew base"@en ;
    skos:altLabel "crewbase"@en ;
    rdfs:comment "A place where operating EMPLOYEEs (e.g. drivers) report on and register their worK."@en .

netex:CrossingEquipment a skos:Concept ;
    skos:prefLabel "crossing equipment"@en ;
    skos:altLabel "crossingequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT for CROSSING EQUIPMENTs (zebra, pedestrian lights, acoustic device sensors, tactile guide strips, etc.)."@en ;
    skos:related netex:AccessEquipment .

netex:Customer a skos:Concept ;
    skos:prefLabel "customer"@en ;
    rdfs:comment "An identified person or organisation involved in a fare process. There may be a FARE CONTRACT between the CUSTOMER and the OPERATOR or the AUTHORITY ruling the consumption of services."@en .

netex:CustomerAccount a skos:Concept ;
    skos:prefLabel "customer account"@en ;
    skos:altLabel "customeraccount"@en ;
    rdfs:comment "A contract with a particular (but possibly anonymous) customer, ruling the consumption of transport services (and joint services). A CUSTOMER ACCOUNT may be designed for a fixed SALES OFFER PACKAGE (e.g. ticket) or to allow successive purchases of SALES OFFER PACKAGEs."@en .

netex:CustomerAccountSecurityListing a skos:Concept ;
    skos:prefLabel "customer account security listing"@en ;
    skos:altLabel "customeraccountsecuritylisting"@en ;
    skos:altLabel "listing of a customer"@en ;
    rdfs:comment "A listing of a CUSTOMER ACCOUNT on a SECURITY LIST."@en .

netex:CustomerAccountStatus a skos:Concept ;
    skos:prefLabel "classification of a customer"@en ;
    skos:altLabel "customer account status"@en ;
    skos:altLabel "customeraccountstatus"@en ;
    rdfs:comment "A classification of a CUSTOMER ACCOUNT."@en ;
    skos:related netex:TypeOfEntity .

netex:CustomerEligibility a skos:Concept ;
    skos:prefLabel "customer eligibility"@en ;
    skos:altLabel "customereligibility"@en ;
    skos:altLabel "whether a specific transport customer"@en ;
    rdfs:comment "Whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific validity Parameter. This may be subject to a particular VALIDITY CONDITION."@en .

netex:CustomerPaymentMeans a skos:Concept ;
    skos:prefLabel "customer payment means"@en ;
    skos:altLabel "customerpaymentmeans"@en ;
    rdfs:comment "A registered means with which a TRANSPORT CUSTOMER wishes to make payments for a CUSTOMER ACCOUNT, e.g. by nominated EMV card. +v1.2.2"@en .

netex:CustomerPurchasePackage a skos:Concept ;
    skos:prefLabel "customer purchase package"@en ;
    skos:altLabel "customerpurchasepackage"@en ;
    skos:altLabel "purchase of a sales"@en ;
    rdfs:comment "A purchase of a SALES OFFER PACKAGE by a CUSTOMER, giving access rights to one or several FARE PRODUCTs materialised as one or several TRAVEL DOCUMENTs."@en .

netex:CustomerPurchasePackageElement a skos:Concept ;
    skos:prefLabel "customer purchase package element"@en ;
    skos:altLabel "customerpurchasepackageelement"@en ;
    rdfs:comment "The assignment of a SALES OFFER PACKAGE ELEMENT, for use in a CUSTOMER SALES PACKAGE."@en ;
    skos:related netex:PriceableObject .

netex:CustomerPurchasePackageElementAccess a skos:Concept ;
    skos:prefLabel "access to a validable element"@en ;
    skos:altLabel "customer purchase package element access"@en ;
    skos:altLabel "customerpurchasepackageelementaccess"@en ;
    rdfs:comment "Access to a VALIDABLE ELEMENT by a specific CUSTOMER PURCHASE PACKAGE through use of CUSTOMER PURCHASE PACKAGE. This is needed for validation of complex SALES OFFER PACKAGEs containing tariffs structures that have FARE STRUCTURE ELEMENTs IN SEQUENCE, in such a case a given SALES PACKAGE ELEMENT may have multiple VALIDABLE ELEMENTs associated with it, each of which can be separately validated and marked. +v1.1"@en .

netex:CustomerPurchasePackagePrice a skos:Concept ;
    skos:prefLabel "customer purchase package price"@en ;
    skos:altLabel "customerpurchasepackageprice"@en ;
    rdfs:comment "A set of all possible price features of a CUSTOMER PURCHASE PACKAGE ELEMENT: default total price, discount in value or percentage etc."@en .

netex:CustomerPurchaseParameterAssignment a skos:Concept ;
    skos:prefLabel "customer purchase parameter assignment"@en ;
    skos:altLabel "customerpurchaseparameterassignment"@en ;
    skos:altLabel "validity parameter assignment specifying"@en ;
    rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying practical parameters for use in a CUSTOMER PURCHASE PACKAGE."@en .

netex:CustomerSecurityListing a skos:Concept ;
    skos:prefLabel "customer security listing"@en ;
    skos:altLabel "customersecuritylisting"@en ;
    skos:altLabel "listing of a customer"@en ;
    rdfs:comment "A listing of a CUSTOMER on a SECURITY LIST."@en .

netex:CustomerService a skos:Concept ;
    skos:prefLabel "customer service"@en ;
    skos:altLabel "customerservice"@en ;
    skos:altLabel "generic specialisation of local service"@en ;
    rdfs:comment "Generic specialisation of LOCAL SERVICE for CUSTOMER SERVICEs (lost properties, meeting point, complaints, etc.)."@en ;
    skos:related netex:LocalService .

netex:CycleModelProfile a skos:Concept ;
    skos:prefLabel "cycle model profile"@en ;
    skos:altLabel "cyclemodelprofile"@en ;
    rdfs:comment "A set of characteristics of equipment installed on-board and characterising a CYCLE MODEL PROFILE. +v1.2.2"@en .

netex:CycleStorageEquipment a skos:Concept ;
    skos:prefLabel "cycle storage equipment"@en ;
    skos:altLabel "cyclestorageequipment"@en ;
    skos:altLabel "specialisation of place equipment for"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for cycle storage."@en ;
    skos:related netex:PlaceEquipment .

netex:DataManagedObject a skos:Concept ;
    skos:prefLabel "data managed object"@en ;
    skos:altLabel "datamanagedobject"@en ;
    rdfs:comment "An ENTITY in VERSION that can be associated with a RESPONSIBILITY SET that describes who has responsibility for managing the data."@en .

netex:DataObjectCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "data object capabilities request"@en ;
    skos:altLabel "dataobjectcapabilitiesrequest"@en ;
    skos:altLabel "request for information about data"@en ;
    rdfs:comment "Request for information about DATA OBJECT Service Capabilities. Answered with DataObjectCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

netex:DataObjectCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities for data object service"@en ;
    skos:altLabel "data object capabilities response"@en ;
    skos:altLabel "dataobjectcapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for DATA OBJECT Service. Answers a DataObjectCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

netex:DataObjectDelivery a skos:Concept ;
    skos:prefLabel "data object delivery"@en ;
    skos:altLabel "dataobjectdelivery"@en ;
    skos:altLabel "delivery for netex service containing"@en ;
    rdfs:comment "Delivery for NeTEx Service containing one or more NeTEx Data Objects,."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

netex:DataObjectPermissions a skos:Concept ;
    skos:prefLabel "data object permissions"@en ;
    skos:altLabel "dataobjectpermissions"@en ;
    skos:altLabel "participants permissions to use the"@en ;
    rdfs:comment "Participants permissions to use the service, Only returned if requested."@en .

netex:DataObjectRequest a skos:Concept ;
    skos:prefLabel "data object request"@en ;
    skos:altLabel "dataobjectrequest"@en ;
    skos:altLabel "service request for one or"@en ;
    rdfs:comment "Service Request for one or more NeTEx Data Objects,."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

netex:DataObjectServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of dataobject service"@en ;
    skos:altLabel "data object service capabilities"@en ;
    skos:altLabel "dataobjectservicecapabilities"@en ;
    rdfs:comment "Capabilities of DataObject Service."@en .

netex:DataObjectSubscriptionRequest a skos:Concept ;
    skos:prefLabel "data object subscription request"@en ;
    skos:altLabel "dataobjectsubscriptionrequest"@en ;
    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to NeTEx Data Object Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

netex:DataSource a skos:Concept ;
    skos:prefLabel "data source"@en ;
    skos:altLabel "datasource"@en ;
    rdfs:comment "Identifies the system which has produced the data. References to a DATA SOURCE are useful in an interoperated computer system."@en ;
    skos:related netex:TypeOfValue .

netex:DatedServiceJourney a skos:Concept ;
    skos:prefLabel "dated service journey"@en ;
    skos:altLabel "datedservicejourney"@en ;
    skos:altLabel "particular service journey of"@en ;
    rdfs:comment "A particular SERVICE JOURNEY of a vehicle on a particular OPERATING DAY including all modifications possibly decided by the control staff. The VIEW includes derived ancillary data from referenced entities."@en .

netex:DatedSpecialService a skos:Concept ;
    skos:prefLabel "dated special service"@en ;
    skos:altLabel "datedspecialservice"@en ;
    rdfs:comment "A particular journey of a vehicle on a particular OPERATING DAY including all modifications possibly decided by the control staff."@en .

netex:DatedVehicleJourney a skos:Concept ;
    skos:prefLabel "dated vehicle journey"@en ;
    skos:altLabel "datedvehiclejourney"@en ;
    rdfs:comment "A particular journey of a vehicle on a particular OPERATING DAY including all modifications possibly decided by the control staff."@en .

netex:DayTypeAssignment a skos:Concept ;
    skos:prefLabel "associates a day type with"@en ;
    skos:altLabel "day type assignment"@en ;
    skos:altLabel "daytypeassignment"@en ;
    rdfs:comment "Associates a DAY TYPE with an OPERATING DAY within a specific Calendar. A specification of a particular DAY TYPE which will be valid during a TIME BAND on an OPERATING DAY."@en .

netex:DeadRun a skos:Concept ;
    skos:prefLabel "dead run"@en ;
    skos:altLabel "deadrun"@en ;
    rdfs:comment "A non-service VEHICLE JOURNEY."@en .

netex:DeadRunJourneyPattern a skos:Concept ;
    skos:prefLabel "dead run journey pattern"@en ;
    skos:altLabel "deadrunjourneypattern"@en ;
    skos:altLabel "journey pattern to be"@en ;
    rdfs:comment "A JOURNEY PATTERN to be used for DEAD RUNs."@en .

netex:Deck a skos:Concept ;
    skos:prefLabel "deck"@en ;
    rdfs:comment "An area within a VEHICLE (i.e. bus, boat, coach, car, plane, etc.) or TRAIN ELEMENT made up of one or more DECK SPACEs. A subdivision of a DECK PLAN. +V2.0"@en ;
    skos:related netex:Zone .

netex:DeckComponent a skos:Concept ;
    skos:prefLabel "deck component"@en ;
    skos:altLabel "deckcomponent"@en ;
    rdfs:comment "An abstract element providing common features for spatially located elements within the DECK PLAN. +v2.0"@en ;
    skos:related netex:OnboardSpace .

netex:DeckEntrance a skos:Concept ;
    skos:prefLabel "deck entrance"@en ;
    skos:altLabel "deckentrance"@en ;
    skos:altLabel "entrance to or within"@en ;
    rdfs:comment "An entrance to or within a DECK. +v2.0"@en ;
    skos:related netex:DeckComponent .

netex:DeckEntranceAssignment a skos:Concept ;
    skos:prefLabel "association of a deck"@en ;
    skos:altLabel "deck entrance assignment"@en ;
    skos:altLabel "deckentranceassignment"@en ;
    rdfs:comment "The association of a DECK ENTRANCE of a VEHICLE's DECK PLAN with a TRAIN and TRAIN COMPONENT and a specific STOP PLACE, QUAY and possibly BOARDING POSITION. NOTE: may indicate which side of VEHICLE door is. +v2.0"@en .

netex:DeckEntranceCouple a skos:Concept ;
    skos:prefLabel "deck entrance couple"@en ;
    skos:altLabel "deckentrancecouple"@en ;
    rdfs:comment "Explicit linking of a pair of DECK ENTRANCEs, e.g. between train carriages. +v2.0"@en .

netex:DeckEntranceUsage a skos:Concept ;
    skos:prefLabel "deck entrance usage"@en ;
    skos:altLabel "deckentranceusage"@en ;
    skos:altLabel "permitted usage of a specific"@en ;
    rdfs:comment "Permitted usage of a specific PASSENGER ENTRANCE to access a particular DECK SPACE. +v2.0"@en .

netex:DeckLevel a skos:Concept ;
    skos:prefLabel "deck level"@en ;
    skos:altLabel "decklevel"@en ;
    skos:altLabel "identified level 1 2"@en ;
    rdfs:comment "An identified level (1, 2 , 3, etc.) within the DECK PLAN of a VEHICLE (boat, train, airplane, etc.) +v2.0"@en .

netex:DeckNavigationPath a skos:Concept ;
    skos:prefLabel "deck navigation path"@en ;
    skos:altLabel "decknavigationpath"@en ;
    skos:altLabel "designated path between two"@en ;
    rdfs:comment "A designated path between two places within a DECK PLAN. May include an ordered sequence of DECK PATH LINKs. +v2.0"@en ;
    skos:related netex:LinkSequence .

netex:DeckPathJunction a skos:Concept ;
    skos:prefLabel "deck path junction"@en ;
    skos:altLabel "deckpathjunction"@en ;
    rdfs:comment "A designated point, inside a DECK SPACE , at which two or more DECK PATH LINKs may connect or branch. +V2.0"@en ;
    skos:related netex:Point .

netex:DeckPathLink a skos:Concept ;
    skos:prefLabel "deck path link"@en ;
    skos:altLabel "deckpathlink"@en ;
    skos:altLabel "link within a deck"@en ;
    rdfs:comment "A link within a DECK PLAN that represents a step in a possible route for pedestrians, wheelchair users or other out-of-vehicle passengers. +V2.0"@en ;
    skos:related netex:Link .

netex:DeckPlaceInSequence a skos:Concept ;
    skos:prefLabel "deck place in sequence"@en ;
    skos:altLabel "deckplaceinsequence"@en ;
    rdfs:comment "Point traversed by a NAVIGATION PATH in sequence. May be a PLACE PATH JUNCTION or ONBOARD SPACE."@en ;
    skos:related netex:PointInLinkSequence .

netex:DeckPlan a skos:Concept ;
    skos:prefLabel "deck plan"@en ;
    skos:altLabel "deckplan"@en ;
    skos:altLabel "plan for the layout"@en ;
    rdfs:comment "A plan for the layout of seating and other areas of use of an entire VEHICLE (train, coach, vessel etc.) or individual TRAIN ELEMENT for all or part of a journey. +v2.0"@en .

netex:DeckPlanAssignment a skos:Concept ;
    skos:prefLabel "allocation of a deck"@en ;
    skos:altLabel "deck plan assignment"@en ;
    skos:altLabel "deckplanassignment"@en ;
    rdfs:comment "The allocation of a DECK PLAN to all or part of a specific VEHICLE JOURNEY and /or VEHICLE TYPE and/or TRAIN ELEMENT. +v2.0"@en .

netex:DeckSpace a skos:Concept ;
    skos:prefLabel "deck space"@en ;
    skos:altLabel "deckspace"@en ;
    rdfs:comment "An area within a VEHICLE (i.e. bus, boat, coach, car) or TRAIN ELEMENT delimiting a particular use such as seating, WC, bar, gangway, etc. May be specialised, e.g. as PASSENGER SPACE; may contain other spaces. Different types of space may overlap. +v2.0."@en ;
    skos:related netex:DeckComponent .

netex:DeckSpaceCapacity a skos:Concept ;
    skos:prefLabel "capacity of a deck"@en ;
    skos:altLabel "deck space capacity"@en ;
    skos:altLabel "deckspacecapacity"@en ;
    rdfs:comment "The capacity of a DECK SPACE for passengers and other payload in terms of TYPES OF LOCATABLE SPOTs. +v2.0"@en .

netex:DeckVehicleEntrance a skos:Concept ;
    skos:prefLabel "deck vehicle entrance"@en ;
    skos:altLabel "deckvehicleentrance"@en ;
    skos:altLabel "normal entrance for passengers"@en ;
    rdfs:comment "A normal entrance for passengers to or within a DECK. +v2.0"@en .

netex:DeckWindow a skos:Concept ;
    skos:prefLabel "deck window"@en ;
    skos:altLabel "deckwindow"@en ;
    skos:altLabel "window onto a deck"@en ;
    rdfs:comment "A window onto a DECK SPACE. +v2.0"@en ;
    skos:related netex:DeckComponent .

netex:DefaultConnection a skos:Concept ;
    skos:prefLabel "default connection"@en ;
    skos:altLabel "defaultconnection"@en ;
    skos:altLabel "specifies the default transfer times"@en ;
    rdfs:comment "Specifies the default transfer times to transfer between MODEs and / or OPERATORs within a region."@en ;
    skos:related netex:Transfer .

netex:DefaultDeadRunRunTime a skos:Concept ;
    skos:prefLabel "default dead run run time"@en ;
    skos:altLabel "defaultdeadrunruntime"@en ;
    skos:altLabel "time taken to traverse"@en ;
    rdfs:comment "The time taken to traverse a TIMING LINK during a DEAD RUN, for a specified TIME DEMAND TYPE. This time may be superseded by the JOURNEY PATTERN RUN TIME or VEHICLE JOURNEY RUN TIME if these exist."@en .

netex:DefaultInterchange a skos:Concept ;
    skos:prefLabel "default interchange"@en ;
    skos:altLabel "defaultinterchange"@en ;
    rdfs:comment "A quality parameter fixing the acceptable duration (standard and maximum) for an INTERCHANGE to be planned between two SCHEDULED STOP POINTs. This parameter will be used to control whether any two SERVICE JOURNEYs serving those points may be in connection."@en .

netex:DefaultServiceJourneyRunTime a skos:Concept ;
    skos:prefLabel "default service journey run time"@en ;
    skos:altLabel "default time taken by"@en ;
    skos:altLabel "defaultservicejourneyruntime"@en ;
    rdfs:comment "The default time taken by a vehicle to traverse a TIMING LINK during a SERVICE JOURNEY, for a specified TIME DEMAND TYPE. This time may be superseded by the JOURNEY PATTERN RUN TIME or VEHICLE JOURNEY RUN TIME if these exist."@en .

netex:DeliveryVariant a skos:Concept ;
    skos:prefLabel "delivery variant"@en ;
    skos:altLabel "deliveryvariant"@en ;
    rdfs:comment "A variant text of a NOTICE for use in a specific media or delivery channel (voice, printed material, etc)."@en .

netex:Delta a skos:Concept ;
    skos:prefLabel "delta"@en ;
    rdfs:comment "A record of the detailed changes of a given ENTITY IN VERSION from one VERSION to the next one. A DELTA contains pairs of attributes' old values - new values."@en .

netex:DeltaValue a skos:Concept ;
    skos:prefLabel "delta value"@en ;
    skos:altLabel "deltavalue"@en ;
    rdfs:comment "A record of the detailed changes of a given ENTITY IN VERSION from one VERSION to the next one. A DELTA contains pairs of attributes' old values - new values."@en .

netex:Department a skos:Concept ;
    skos:prefLabel "department"@en ;
    skos:altLabel "department of an organisation"@en ;
    rdfs:comment "Department of an ORGANISATION."@en .

netex:DestinationDisplay a skos:Concept ;
    skos:prefLabel "destination display"@en ;
    skos:altLabel "destinationdisplay"@en ;
    rdfs:comment "An advertised destination of a specific JOURNEY PATTERN, usually displayed on a head sign or at other on-board locations."@en .

netex:DestinationDisplayVariant a skos:Concept ;
    skos:prefLabel "destination display variant"@en ;
    skos:altLabel "destinationdisplayvariant"@en ;
    rdfs:comment "A variant text of a DESTINATION DISPLAY for informational purposes."@en .

netex:Direction a skos:Concept ;
    skos:prefLabel "direction"@en ;
    rdfs:comment "A classification for the general orientation of ROUTEs."@en ;
    skos:related netex:TypeOfValue .

netex:DiscountingRule a skos:Concept ;
    skos:prefLabel "discounting rule"@en ;
    skos:altLabel "discountingrule"@en ;
    rdfs:comment "A price for which a discount can be offered."@en .

netex:DisplayAssignment a skos:Concept ;
    skos:prefLabel "assignment of one stop"@en ;
    skos:altLabel "display assignment"@en ;
    skos:altLabel "displayassignment"@en ;
    rdfs:comment "The assignment of one STOP POINT and one JOURNEY PATTERN to a PASSENGER INFORMATION EQUIPMENT, specifying that information on this STOP POINT and this JOURNEY PATTERN will be provided (e.g. displayed, printed)."@en .

netex:DistanceMatrixElement a skos:Concept ;
    skos:prefLabel "distance matrix element"@en ;
    skos:altLabel "distancematrixelement"@en ;
    rdfs:comment "A cell of an origin-destination matrix for TARIFF ZONEs or STOP POINTs, expressing a fare distance for the corresponding trip: value in km, number of fare units etc."@en .

netex:DistanceMatrixElementPrice a skos:Concept ;
    skos:prefLabel "distance matrix element price"@en ;
    skos:altLabel "distancematrixelementprice"@en ;
    rdfs:comment "A set of all possible price features of a DISTANCE MATRIX ELEMENT: default total price etc. ."@en .

netex:DistributionAssignment a skos:Concept ;
    skos:prefLabel "assignment of the country"@en ;
    skos:altLabel "distribution assignment"@en ;
    skos:altLabel "distributionassignment"@en ;
    rdfs:comment "An assignment of the COUNTRY and/or DISTRIBUTION CHANNEL through which a product may or may not be distributed."@en .

netex:DistributionChannel a skos:Concept ;
    skos:prefLabel "distribution channel"@en ;
    skos:altLabel "distributionchannel"@en ;
    rdfs:comment "A type of outlet for selling a product."@en .

netex:DriverScheduleFrame a skos:Concept ;
    skos:prefLabel "coherent set of driver"@en ;
    skos:altLabel "driver schedule frame"@en ;
    skos:altLabel "driverscheduleframe"@en ;
    rdfs:comment "A coherent set of Driver Scheduling data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:DriverTrip a skos:Concept ;
    skos:prefLabel "driver trip"@en ;
    skos:altLabel "drivertrip"@en ;
    rdfs:comment "A planned non-driving movement of a driver within a DUTY PART. This may be necessary to reach the first SPELL in a STRETCH, between two SPELLs or after the last SPELL in a STRETCH. It may be entirely on foot or may use a VEHICLE JOURNEY on a vehicle driven by another driver."@en .

netex:DriverTripTime a skos:Concept ;
    skos:prefLabel "driver trip time"@en ;
    skos:altLabel "drivertriptime"@en ;
    rdfs:comment "A part of a BLOCK composed of consecutive VEHICLE JOURNEYs defined for the same DAY TYPE, all operated on the same LINE."@en .

netex:Duty a skos:Concept ;
    skos:prefLabel "duty"@en ;
    rdfs:comment "The work to be performed by a driver on a particular DAY TYPE."@en .

netex:DutyPart a skos:Concept ;
    skos:prefLabel "duty part"@en ;
    skos:altLabel "dutypart"@en ;
    rdfs:comment "A continuous part of a driver DUTY during which (s)he is under the management of the company. A DUTY PART may include BREAKs. ."@en .

netex:DynamicDistanceMatrixElement a skos:Concept ;
    skos:prefLabel "dynamic distance matrix element"@en ;
    skos:altLabel "dynamic freestanding distance matrix"@en ;
    skos:altLabel "dynamicdistancematrixelement"@en ;
    rdfs:comment "A dynamic free-standing distance matrix element. Used when a pre-computed distance matrix element is not feasible."@en .

netex:DynamicStopAssignment a skos:Concept ;
    skos:prefLabel "change to a passenger stop"@en ;
    skos:altLabel "dynamic stop assignment"@en ;
    skos:altLabel "dynamicstopassignment"@en ;
    rdfs:comment "Change to a PASSENGER STOP ASSIGNMENT."@en ;
    skos:related netex:StopAssignment .

netex:DynamicVehicleMeetingPointAssignment a skos:Concept ;
    skos:prefLabel "dynamic allocation of a vehicle"@en ;
    skos:altLabel "dynamic vehicle meeting point assignment"@en ;
    skos:altLabel "dynamicvehiclemeetingpointassignment"@en ;
    rdfs:comment "Dynamic allocation of a VEHICLE MEETING ASSIGNMENT. +v1.2.2"@en .

netex:EligibilityChangePolicy a skos:Concept ;
    skos:prefLabel "eligibility change policy"@en ;
    skos:altLabel "eligibilitychangepolicy"@en ;
    skos:altLabel "policy to apply if"@en ;
    rdfs:comment "The policy to apply if ta user's eligibility as a USER PROFILE changes."@en .

netex:EmergencyService a skos:Concept ;
    skos:prefLabel "classification of emergency service facility"@en ;
    skos:altLabel "emergency service"@en ;
    skos:altLabel "emergencyservice"@en ;
    rdfs:comment "Classification of EMERGENCY SERVICE FACILITY."@en .

netex:EmergencyServiceList a skos:Concept ;
    skos:prefLabel "emergency service list"@en ;
    skos:altLabel "emergencyservicelist"@en ;
    skos:altLabel "list of emergency service facilities"@en ;
    rdfs:comment "List of EMERGENCY SERVICE FACILITies."@en .

netex:EmvCard a skos:Concept ;
    skos:prefLabel "emv card"@en ;
    skos:altLabel "emvcard"@en ;
    skos:altLabel "standardised payment card europay"@en ;
    rdfs:comment "A standardised payment card (Europay MasterCard Visa etc) , capable of being used as token for an ABT system +v1.2.2"@en .

netex:EntitlementGiven a skos:Concept ;
    skos:prefLabel "entitlement given"@en ;
    skos:altLabel "entitlementgiven"@en ;
    rdfs:comment "A right to a SERVICE ACCESS RIGHT is given by a FARE PRODUCT."@en .

netex:EntitlementProduct a skos:Concept ;
    skos:prefLabel "entitlement product"@en ;
    skos:altLabel "entitlementproduct"@en ;
    rdfs:comment "A precondition to access a service or to purchase a FARE PRODUCT issued by an organisation that may not be a PT operator (e.g. military card)."@en .

netex:EntitlementRequired a skos:Concept ;
    skos:prefLabel "entitlement required"@en ;
    skos:altLabel "entitlementrequired"@en ;
    rdfs:comment "A rerirement to a SERVICE ACCESS RIGHT in order to purchase or use PRODUCT."@en .

netex:Entity a skos:Concept ;
    skos:prefLabel "entity"@en ;
    rdfs:comment "Any data instance to be managed in an operational Version Management System. When several DATA SOURCEs coexist (multimodality and/or interoperability), an ENTITY has to be related to a given DATA SYSTEM in which it is defined."@en .

netex:EntityInVersion a skos:Concept ;
    skos:prefLabel "entity in version"@en ;
    skos:altLabel "entityinversion"@en ;
    rdfs:comment "The ENTITies associated to a given VERSION. ENTITY IN VERSION is restricted by ENTITY IN FRAME."@en .

netex:Entity_Entity a skos:Concept ;
    skos:prefLabel "entity entity"@en ;
    skos:altLabel "entity will contain one or"@en ;
    skos:altLabel "entity_entity"@en ;
    rdfs:comment "ENTITY. Will contain one or more ENTITY IN VERSIONs."@en ;
    skos:related netex:Entity .

netex:Entrance a skos:Concept ;
    skos:prefLabel "entrance"@en ;
    skos:altLabel "physical entrance or exit"@en ;
    rdfs:comment "A physical entrance or exit to/from a SITE. May be a door, barrier, gate or other recognizable point of access. The ENTRANCE is an abstract Transmodel object and therefore should not be used as an instance (use specialisations like StopPlaceEntrance, PointOfInterestEntrance, etc.). It still has abstract=\"false\" for backward compatibility, but using it as an instance is DEPRECATED from v2.0 and it will be formally changed to abstract in v3.0. -v2.0"@en ;
    skos:related netex:SiteComponent .

netex:EntranceEquipment a skos:Concept ;
    skos:prefLabel "entrance equipment"@en ;
    skos:altLabel "entranceequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT for ENTRANCEs (door, barrier, revolving door, etc.)."@en ;
    skos:related netex:AccessEquipment .

netex:EntranceSensor a skos:Concept ;
    skos:prefLabel "entrance sensor"@en ;
    skos:altLabel "entrancesensor"@en ;
    rdfs:comment "AN EQUIPMENT used to monitor or count passengers using a PASSENGER ENTRANCE. +v2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:Equipment a skos:Concept ;
    skos:prefLabel "equipment"@en ;
    skos:altLabel "item of equipment of"@en ;
    rdfs:comment "An item of EQUIPMENT of a particular type actually available at a location within a PLACE, such as QUAY, ACCESS SPACE or STOP PATH LINK."@en .

netex:EquipmentPlace a skos:Concept ;
    skos:prefLabel "designated place within a site"@en ;
    skos:altLabel "equipment place"@en ;
    skos:altLabel "equipmentplace"@en ;
    rdfs:comment "Designated Place within a SITE for a locating EQUIPMENT."@en ;
    skos:related netex:Place .

netex:EquipmentPosition a skos:Concept ;
    skos:prefLabel "equipment position"@en ;
    skos:altLabel "equipmentposition"@en ;
    skos:altLabel "precise position within an"@en ;
    rdfs:comment "The precise position within an EQUIPMENT PLACE where particular EQUIPMENT is placed."@en .

netex:EscalatorEquipment a skos:Concept ;
    skos:prefLabel "escalator equipment"@en ;
    skos:altLabel "escalatorequipment"@en ;
    skos:altLabel "specialisation of stair equipment for"@en ;
    rdfs:comment "Specialisation of STAIR EQUIPMENT for ESCALATORs."@en ;
    skos:related netex:AccessEquipment .

netex:EscalatorFreeAccess a skos:Concept ;
    skos:prefLabel "escalator free access"@en ;
    skos:altLabel "escalatorfreeaccess"@en ;
    skos:altLabel "whether a place has escalator"@en ;
    rdfs:comment "Whether a PLACE has escalator free access."@en .

netex:Exchanging a skos:Concept ;
    skos:prefLabel "exchanging"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer."@en .

netex:Extensions a skos:Concept ;
    skos:prefLabel "extensions"@en ;
    skos:altLabel "user defined extensions to entity"@en ;
    rdfs:comment "User defined Extensions to ENTITY in schema. (Wrapper tag used to avoid problems with handling of optional 'any' by some validators)."@en .

netex:FacilityRequirement a skos:Concept ;
    skos:prefLabel "facility requirement"@en ;
    skos:altLabel "facilityrequirement"@en ;
    rdfs:comment "Requirements for carrying passengers."@en .

netex:FacilitySet a skos:Concept ;
    skos:prefLabel "facility set"@en ;
    skos:altLabel "facility set of enumerated facility"@en ;
    skos:altLabel "facilityset"@en ;
    rdfs:comment "Facility. Set of enumerated FACILITY values (names based on TPEG classifications, augmented with UIC etc.)."@en .

netex:FamilyFacility a skos:Concept ;
    skos:prefLabel "classification of family facilities"@en ;
    skos:altLabel "family facility"@en ;
    skos:altLabel "familyfacility"@en ;
    rdfs:comment "Classification of FAMILY FACILITies."@en .

netex:FamilyFacilityList a skos:Concept ;
    skos:prefLabel "family facility list"@en ;
    skos:altLabel "familyfacilitylist"@en ;
    skos:altLabel "list of family facilities"@en ;
    rdfs:comment "List of FAMILY FACILITies."@en .

netex:FareClass a skos:Concept ;
    skos:prefLabel "classification of fare classes"@en ;
    skos:altLabel "fare class"@en ;
    skos:altLabel "fareclass"@en ;
    rdfs:comment "Classification of FARE CLASSes."@en .

netex:FareContract a skos:Concept ;
    skos:prefLabel "contract with a particular"@en ;
    skos:altLabel "fare contract"@en ;
    skos:altLabel "farecontract"@en ;
    rdfs:comment "A contract with a particular (but possibly anonymous) customer, ruling the consumption of transport services (and joint services). A FARE CONTRACT may be designed for a fixed SALES OFFER PACKAGE (e.g. ticket) or to allow successive purchases of SALES OFFER PACKAGEs."@en .

netex:FareContractEntry a skos:Concept ;
    skos:prefLabel "fare contract entry"@en ;
    skos:altLabel "farecontractentry"@en ;
    skos:altLabel "log entry describing an"@en ;
    rdfs:comment "A log entry describing an event referring to the life of a FARE CONTRACT: initial contracting, sales, validation entries, etc. A subset of a FARE CONTRACT ENTRY is often materialised on a TRAVEL DOCUMENT."@en .

netex:FareContractSecurityListing a skos:Concept ;
    skos:prefLabel "fare contract security listing"@en ;
    skos:altLabel "farecontractsecuritylisting"@en ;
    skos:altLabel "listing of a fare"@en ;
    rdfs:comment "A listing of a FARE CONTRACT on a SECURITY LIST."@en .

netex:FareDebit a skos:Concept ;
    skos:prefLabel "fare debit"@en ;
    skos:altLabel "faredebit"@en ;
    rdfs:comment "A LOG ENTRY recording data about a debiting action relating to a fare or use of a fare."@en .

netex:FareDemandFactor a skos:Concept ;
    skos:prefLabel "fare demand factor"@en ;
    skos:altLabel "faredemandfactor"@en ;
    rdfs:comment "The value of a QUALITY INTERVAL or a DISTANCE MATRIX ELEMENT expressed by a QUALITY UNIT."@en .

netex:FareElementInSequence a skos:Concept ;
    skos:prefLabel "fare element in sequence"@en ;
    skos:altLabel "fare structure element as"@en ;
    skos:altLabel "fareelementinsequence"@en ;
    rdfs:comment "A FARE STRUCTURE ELEMENT as a part of a VALIDABLE ELEMENT, including its possible order in the sequence of FARE STRUCTURE ELEMENTs forming that VALIDABLE ELEMENT, and its possible quantitative limitation."@en .

netex:FareFrame a skos:Concept ;
    skos:prefLabel "coherent set of fare"@en ;
    skos:altLabel "fare frame"@en ;
    skos:altLabel "fareframe"@en ;
    rdfs:comment "A coherent set of Fare data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:FareInterval a skos:Concept ;
    skos:prefLabel "fare interval"@en ;
    skos:altLabel "fareinterval"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en ;
    skos:related netex:PriceableObject .

netex:FarePointInPattern a skos:Concept ;
    skos:prefLabel "fare point in pattern"@en ;
    skos:altLabel "farepointinpattern"@en ;
    rdfs:comment "A POINT IN PATTERN which represents the start or end of a FARE SECTION."@en ;
    skos:related netex:PointInLinkSequence .

netex:FarePrice a skos:Concept ;
    skos:prefLabel "fare price"@en ;
    skos:altLabel "fareprice"@en ;
    rdfs:comment "A set of all possible price features for a Fare element."@en .

netex:FarePriceFrame a skos:Concept ;
    skos:prefLabel "coherent set of fare"@en ;
    skos:altLabel "fare price frame"@en ;
    skos:altLabel "farepriceframe"@en ;
    rdfs:comment "A coherent set of Fare Price data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:FareProduct a skos:Concept ;
    skos:prefLabel "fare product"@en ;
    skos:altLabel "fareproduct"@en ;
    rdfs:comment "An immaterial marketable element (access rights, discount rights etc), specific to a CHARGING MOMENT."@en .

netex:FareProductPrice a skos:Concept ;
    skos:prefLabel "fare product price"@en ;
    skos:altLabel "fareproductprice"@en ;
    rdfs:comment "A set of all possible price features of a FARE PRODUCT default total price, discount in value or percentage etc."@en .

netex:FareProductSaleDebit a skos:Concept ;
    skos:prefLabel "fare product sale debit"@en ;
    skos:altLabel "fareproductsaledebit"@en ;
    rdfs:comment "A LOG ENTRY recording data about a debiting action made to purchase a FARE PRODUCT."@en .

netex:FareQuotaFactor a skos:Concept ;
    skos:prefLabel "fare quota factor"@en ;
    skos:altLabel "farequotafactor"@en ;
    rdfs:comment "A named set of parameters defining the number of quota fares available. of a given denomination."@en .

netex:FareScheduledStopPoint a skos:Concept ;
    skos:prefLabel "fare scheduled stop point"@en ;
    skos:altLabel "farescheduledstoppoint"@en ;
    skos:altLabel "point where passengers can"@en ;
    rdfs:comment "A POINT where passengers can board or alight from vehicles."@en ;
    skos:related netex:Point .

netex:FareSection a skos:Concept ;
    skos:prefLabel "fare section"@en ;
    skos:altLabel "faresection"@en ;
    rdfs:comment "A subdivision of a JOURNEY PATTERN consisting of consecutive POINTs IN JOURNEY PATTERN, used to define an element of the fare structure."@en .

netex:FareStructureElement a skos:Concept ;
    skos:prefLabel "fare structure element"@en ;
    skos:altLabel "farestructureelement"@en ;
    rdfs:comment "A sequence or set of CONTROLLABLE ELEMENTs to which rules for limitation of access rights and calculation of prices (fare structure) are applied."@en ;
    skos:related netex:PriceableObject .

netex:FareStructureElementInSequence a skos:Concept ;
    skos:prefLabel "fare structure element as"@en ;
    skos:altLabel "fare structure element in sequence"@en ;
    skos:altLabel "farestructureelementinsequence"@en ;
    rdfs:comment "A FARE STRUCTURE ELEMENT as a part of a VALIDABLE ELEMENT, including its possible order in the sequence of FARE STRUCTURE ELEMENTs forming that VALIDABLE ELEMENT, and its possible quantitative limitation."@en .

netex:FareStructureElementPrice a skos:Concept ;
    skos:prefLabel "fare structure element price"@en ;
    skos:altLabel "farestructureelementprice"@en ;
    rdfs:comment "A set of all possible price features of a FARE STRUCTURE ELEMENT: default total price, discount in value or percentage etc."@en .

netex:FareStructureFactor a skos:Concept ;
    skos:prefLabel "factor influencing access rights"@en ;
    skos:altLabel "fare structure factor"@en ;
    skos:altLabel "farestructurefactor"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en ;
    skos:related netex:PriceableObject .

netex:FareTable a skos:Concept ;
    skos:prefLabel "fare table"@en ;
    skos:altLabel "faretable"@en ;
    rdfs:comment "A grouping of prices that may be associated with a DISTANCE MATRIX ELEMENT, FARE STRUCTURE ELEMENT or other PRICEABLE OBJECT."@en .

netex:FareTableColumn a skos:Concept ;
    skos:prefLabel "fare table column"@en ;
    skos:altLabel "faretablecolumn"@en ;
    rdfs:comment "An individual combination of features in a FARE TABLE, used to associate a FARE PRICE."@en .

netex:FareTableInContext a skos:Concept ;
    skos:prefLabel "fare table in context"@en ;
    skos:altLabel "faretableincontext"@en ;
    rdfs:comment "A grouping of prices that may be associated with a DISTANCE MATRIX ELEMENT, FARE STRUCTURE ELEMENT or other PRICEABLE OBJECT. OPTIMIZATION - Alias for FARE TABLE That does not require an ID to be present."@en .

netex:FareTableRow a skos:Concept ;
    skos:prefLabel "fare table row"@en ;
    skos:altLabel "faretablerow"@en ;
    rdfs:comment "An individual combination of features in a FARE TABLE, used to associate a FARE PRICE."@en .

netex:FareUnit a skos:Concept ;
    skos:prefLabel "fare unit"@en ;
    skos:altLabel "fareunit"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en ;
    skos:related netex:PriceableObject .

netex:FareZone a skos:Concept ;
    skos:prefLabel "fare zone"@en ;
    skos:altLabel "farezone"@en ;
    skos:altLabel "specialization of tariff zone"@en ;
    rdfs:comment "A specialization of TARIFF ZONE to include FARE SECTIONs."@en ;
    skos:related netex:TransportOrganisation .

netex:Fleet a skos:Concept ;
    skos:prefLabel "fleet"@en ;
    rdfs:comment "A set of vehicles of any type. +v1.2.2"@en .

netex:FlexibleArea a skos:Concept ;
    skos:prefLabel "flexible area"@en ;
    skos:altLabel "flexiblearea"@en ;
    skos:altLabel "specialisation of a flexible quay"@en ;
    rdfs:comment "Specialisation of a FLEXIBLE QUAY (which is abstract) to identify what is the catchment area for a flexible service (so that a stop finder can find the nearest available types of transport). It is a named zone visited by a particular mode of transport. It is part of the SITE data set rather than the service data set, since it can be defined and exists independently of an actual service."@en ;
    skos:related netex:Place .

netex:FlexibleLine a skos:Concept ;
    skos:prefLabel "flexible line"@en ;
    skos:altLabel "flexibleline"@en ;
    skos:altLabel "group of flexible routes"@en ;
    rdfs:comment "A group of FLEXIBLE ROUTEs of which is generally known to the public by a similar name or number and which have common booking arrangements. DEPRECATED: please use LINE instead. +v2.0"@en .

netex:FlexibleLinkProperties a skos:Concept ;
    skos:prefLabel "flexible link properties"@en ;
    skos:altLabel "flexible properties of a link"@en ;
    skos:altLabel "flexiblelinkproperties"@en ;
    rdfs:comment "Flexible properties of a LINK."@en .

netex:FlexibleOperation a skos:Concept ;
    skos:prefLabel "flexible operation"@en ;
    skos:altLabel "flexibleoperation"@en ;
    skos:altLabel "passenger transport operation linked to"@en ;
    rdfs:comment "Passenger transport operation linked to a fixed network/schedule but offering flexibility, in order for instance, to optimise the service or to satisfy passenger demand. +v1.2.2"@en .

netex:FlexiblePointProperties a skos:Concept ;
    skos:prefLabel "flexible point properties"@en ;
    skos:altLabel "flexible properties of a point"@en ;
    skos:altLabel "flexiblepointproperties"@en ;
    rdfs:comment "Flexible properties of a POINT."@en .

netex:FlexibleQuay a skos:Concept ;
    skos:prefLabel "flexible quay"@en ;
    skos:altLabel "flexiblequay"@en ;
    rdfs:comment "A ZONE of physical access to public transport vehicles such as a platform."@en ;
    skos:related netex:Place .

netex:FlexibleRoute a skos:Concept ;
    skos:prefLabel "flexible route"@en ;
    skos:altLabel "flexibleroute"@en ;
    skos:altLabel "specialisation of route for flexible"@en ;
    rdfs:comment "Specialisation of ROUTE for flexible service. May include both point and zonal areas and ordered and unordered sections."@en .

netex:FlexibleServiceProperties a skos:Concept ;
    skos:prefLabel "additional characteristics of a flexible"@en ;
    skos:altLabel "flexible service properties"@en ;
    skos:altLabel "flexibleserviceproperties"@en ;
    rdfs:comment "Additional characteristics of a FLEXIBLE SERVICE. A service may be partly fixed, partly flexible."@en .

netex:FlexibleStopAssignment a skos:Concept ;
    skos:prefLabel "assignment of a scheduled stop"@en ;
    skos:altLabel "flexible stop assignment"@en ;
    skos:altLabel "flexiblestopassignment"@en ;
    rdfs:comment "Assignment of a SCHEDULED STOP POINT to a FLEXIBLE STOP PLACE and quay. etc."@en ;
    skos:related netex:StopAssignment .

netex:FlexibleStopPlace a skos:Concept ;
    skos:prefLabel "flexible stop place"@en ;
    skos:altLabel "flexiblestopplace"@en ;
    skos:altLabel "named type of stop"@en ;
    rdfs:comment "A named type of STOP PLACE for DRT comprising one or more flexible zones where vehicles may stop and where passengers may board or leave vehicles."@en ;
    skos:related netex:Place .

netex:FrequencyOfUse a skos:Concept ;
    skos:prefLabel "frequency of use"@en ;
    skos:altLabel "frequencyofuse"@en ;
    skos:altLabel "limits of usage frequency"@en ;
    rdfs:comment "The limits of usage frequency for a FARE PRODUCT (or one of its components) or a SALES OFFER PACKAGE during a specific VALIDITY PERIOD. There may be different tariffs depending on how often the right is consumed during the period."@en .

netex:FulfilmentMethod a skos:Concept ;
    skos:prefLabel "fulfilment method"@en ;
    skos:altLabel "fulfilmentmethod"@en ;
    rdfs:comment "The means by which the ticket is delivered to the Customer. e.g. online, collection, etc."@en .

netex:FulfilmentMethodPrice a skos:Concept ;
    skos:prefLabel "fulfilment method price"@en ;
    skos:altLabel "fulfilmentmethodprice"@en ;
    rdfs:comment "A set of all possible price features of a FULFILMENT METHOD: default total price, discount in value or percentage etc."@en .

netex:FunicularSubmode a skos:Concept ;
    skos:prefLabel "funicular submode"@en ;
    skos:altLabel "funicularsubmode"@en ;
    skos:altLabel "tpeg pti10 funicular submodes"@en ;
    rdfs:comment "TPEG pti10 Funicular submodes."@en .

netex:Garage a skos:Concept ;
    skos:prefLabel "garage"@en ;
    rdfs:comment "A facility used for parking and maintaining vehicles. PARKING POINTs in a GARAGE are called GARAGE POINTs."@en ;
    skos:related netex:Place .

netex:GaragePoint a skos:Concept ;
    skos:prefLabel "garage point"@en ;
    skos:altLabel "garagepoint"@en ;
    skos:altLabel "subtype of parking point"@en ;
    rdfs:comment "A subtype of PARKING POINT located in a GARAGE."@en .

netex:GenderLimitation a skos:Concept ;
    skos:prefLabel "classification gender limitation"@en ;
    skos:altLabel "gender limitation"@en ;
    skos:altLabel "genderlimitation"@en ;
    rdfs:comment "Classification GENDER LIMITATION."@en .

netex:GeneralFrame a skos:Concept ;
    skos:prefLabel "general frame"@en ;
    skos:altLabel "generalframe"@en ;
    rdfs:comment "A General purpose frame that can be used to exchange any NeTEx element. Does not impose any structure."@en .

netex:GeneralFrameMember a skos:Concept ;
    skos:prefLabel "general frame member"@en ;
    skos:altLabel "generalframemember"@en ;
    rdfs:comment "An association of an ENTITY in a GENERAL FRAME."@en .

netex:GeneralGroupOfEntities a skos:Concept ;
    skos:prefLabel "general group of entities"@en ;
    skos:altLabel "generalgroupofentities"@en ;
    rdfs:comment "A grouping of ENTITies which will be commonly referenced for a specific purpose."@en .

netex:GeneralOrganisation a skos:Concept ;
    skos:prefLabel "any type of general organisation"@en ;
    skos:altLabel "general organisation"@en ;
    skos:altLabel "generalorganisation"@en ;
    rdfs:comment "Any type of GENERAL ORGANISATION."@en .

netex:GeneralSection a skos:Concept ;
    skos:prefLabel "general section"@en ;
    skos:altLabel "generalsection"@en ;
    rdfs:comment "A resuable sequence of LINKS or POINTs. +v1.1."@en .

netex:GeneralSign a skos:Concept ;
    skos:prefLabel "general sign"@en ;
    skos:altLabel "generalsign"@en ;
    skos:altLabel "specialisation of sign equipment sor"@en ;
    rdfs:comment "Specialisation of SIGN EQUIPMENT sor signs which are not HEADING SIGNs nor PLACE SIGNs."@en ;
    skos:related netex:SignEquipment .

netex:GeneralZone a skos:Concept ;
    skos:prefLabel "general zone"@en ;
    skos:altLabel "general zone used to"@en ;
    skos:altLabel "generalzone"@en ;
    rdfs:comment "A GENERAL ZONE used to define a zonal fare structure in a zone-counting or zone-matrix system."@en ;
    skos:related netex:Zone .

netex:GenericNavigationPath a skos:Concept ;
    skos:prefLabel "designated path between two"@en ;
    skos:altLabel "generic navigation path"@en ;
    skos:altLabel "genericnavigationpath"@en ;
    rdfs:comment "A designated path between two places. May include an ordered sequence of PATH LINKs. +v2.0"@en ;
    skos:related netex:LinkSequence .

netex:GenericParameterAssignment a skos:Concept ;
    skos:prefLabel "generic parameter assignment"@en ;
    skos:altLabel "genericparameterassignment"@en ;
    skos:altLabel "validity parameter assignment specifying"@en ;
    rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying practical parameters during a TRAVEL GenericATION, within a given fare structure (e.g. the origin or destination zone in a zone-counting system)."@en .

netex:GenericParameterAssignmentInContext a skos:Concept ;
    skos:prefLabel "generic parameter assignment in context"@en ;
    skos:altLabel "genericparameterassignmentincontext"@en ;
    rdfs:comment "Optimisation: Can be used without id constraintA VALIDITY PARAMETER ASSIGNMENT specifying practical parameters during a TRAVEL GenericATION, within a given fare structure (e.g. the origin or destination zone in a zone-counting system)."@en .

netex:GenericPathJunction a skos:Concept ;
    skos:prefLabel "generic path junction"@en ;
    skos:altLabel "genericpathjunction"@en ;
    rdfs:comment "A designated point, inside or outside of a STOP PLACE or POINT OF INTEREST, at which two or more PATH LINKs may connect or branch."@en ;
    skos:related netex:Point .

netex:GenericPathLink a skos:Concept ;
    skos:prefLabel "generic path link"@en ;
    skos:altLabel "genericpathlink"@en ;
    skos:altLabel "link between any two"@en ;
    rdfs:comment "A link between any two places that represents a step in a possible route for pedestrians, cyclists or other out of vehicle passengers . Note: a place may be fixed PLACE, that is STOP PLACEs, ACCESS SPACE or QUAY, BOARDING POSITION, POINTs OF INTEREST etc or PATH JUNCTIONs, or a place within a DECK, e.g. DECK, SPACE, DECK ENTRANCE, DECK PATH JUNCTION etc."@en ;
    skos:related netex:Link .

netex:GeographicalInterval a skos:Concept ;
    skos:prefLabel "geographical interval"@en ;
    skos:altLabel "geographicalinterval"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en .

netex:GeographicalIntervalPrice a skos:Concept ;
    skos:prefLabel "geographical interval price"@en ;
    skos:altLabel "geographicalintervalprice"@en ;
    rdfs:comment "A set of all possible price features of a GEOGRAPHICAL INTERVAL: default total price etc."@en .

netex:GeographicalStructureFactor a skos:Concept ;
    skos:prefLabel "geographical structure factor"@en ;
    skos:altLabel "geographicalstructurefactor"@en ;
    skos:altLabel "value of a geographical"@en ;
    rdfs:comment "The value of a GEOGRAPHICAL INTERVAL or a DISTANCE MATRIX ELEMENT expressed by a GEOGRAPHICAL UNIT."@en ;
    skos:related netex:PriceableObject .

netex:GeographicalUnit a skos:Concept ;
    skos:prefLabel "geographical unit"@en ;
    skos:altLabel "geographicalunit"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en ;
    skos:related netex:PriceableObject .

netex:GeographicalUnitPrice a skos:Concept ;
    skos:prefLabel "geographical unit price"@en ;
    skos:altLabel "geographicalunitprice"@en ;
    rdfs:comment "A set of all possible price features of a GEOGRAPHICAL UNIT: default total price etc."@en .

netex:GroupBookingFacility a skos:Concept ;
    skos:prefLabel "classification of group facility type"@en ;
    skos:altLabel "group booking facility"@en ;
    skos:altLabel "groupbookingfacility"@en ;
    rdfs:comment "Classification of GROUP FACILITY type - TPEG pti23."@en .

netex:GroupConstraintMember a skos:Concept ;
    skos:prefLabel "group constraint member"@en ;
    skos:altLabel "groupconstraintmember"@en ;
    rdfs:comment "Specifies a member of a set."@en .

netex:GroupMember a skos:Concept ;
    skos:prefLabel "group member"@en ;
    skos:altLabel "groupmember"@en ;
    rdfs:comment "General purpose member of a GROUP OF ENTITies."@en .

netex:GroupOfDistanceMatrixElements a skos:Concept ;
    skos:prefLabel "group of distance matrix"@en ;
    skos:altLabel "group of distance matrix elements"@en ;
    skos:altLabel "groupofdistancematrixelements"@en ;
    rdfs:comment "A group of DISTANCE MATRIX ELEMENTs; may set common properties for a given set of origin and destination pairs."@en .

netex:GroupOfDistributionChannels a skos:Concept ;
    skos:prefLabel "group of distribution channels"@en ;
    skos:altLabel "groupofdistributionchannels"@en ;
    rdfs:comment "A package to be sold as a whole, consisting of one or several FARE PRODUCTs materialised thanks to one or several TRAVEL DOCUMENTs. The FARE PRODUCTs may be either directly attached to the TRAVEL DOCUMENTs, or may be reloadable on the TRAVEL DOCUMENTs."@en .

netex:GroupOfEntities a skos:Concept ;
    skos:prefLabel "group of entities"@en ;
    skos:altLabel "groupofentities"@en ;
    rdfs:comment "A grouping of ENTITies which will be commonly referenced for a specific purpose."@en .

netex:GroupOfLines a skos:Concept ;
    skos:prefLabel "group of lines"@en ;
    skos:altLabel "groupoflines"@en ;
    rdfs:comment "A grouping of LINEs which will be commonly referenced for a specific purpose."@en .

netex:GroupOfLinkSequences a skos:Concept ;
    skos:prefLabel "group of link sequences"@en ;
    skos:altLabel "grouping of link sequences"@en ;
    skos:altLabel "groupoflinksequences"@en ;
    rdfs:comment "A grouping of LINK SEQUENCEs."@en .

netex:GroupOfPlaces a skos:Concept ;
    skos:prefLabel "group of places"@en ;
    skos:altLabel "groupofplaces"@en ;
    rdfs:comment "A grouping of PLACEs which will be commonly referenced for a specific purpose."@en .

netex:GroupOfSalesOfferPackages a skos:Concept ;
    skos:prefLabel "group of sales offer packages"@en ;
    skos:altLabel "groupofsalesofferpackages"@en ;
    rdfs:comment "A package to be sold as a whole, consisting of one or several FARE PRODUCTs materialised thanks to one or several TRAVEL DOCUMENTs. The FARE PRODUCTs may be either directly attached to the TRAVEL DOCUMENTs, or may be reloadable on the TRAVEL DOCUMENTs."@en .

netex:GroupOfServices a skos:Concept ;
    skos:prefLabel "group of services"@en ;
    skos:altLabel "group of services often"@en ;
    skos:altLabel "groupofservices"@en ;
    rdfs:comment "A group of SERVICEs, often known to its users by a name or a number."@en .

netex:GroupOfSingleJourneys a skos:Concept ;
    skos:prefLabel "group of single journeys"@en ;
    skos:altLabel "groupofsinglejourneys"@en ;
    rdfs:comment "A GROUP OF SINGLE JOURNEYs, often known to its users by a name or a number. +v1.2.2"@en .

netex:GroupOfSites a skos:Concept ;
    skos:prefLabel "group of sites"@en ;
    skos:altLabel "groupofsites"@en ;
    rdfs:comment "A grouping of SITEs which will be commonly referenced for a specific purpose. +v2.0"@en .

netex:GroupOfTariffZones a skos:Concept ;
    skos:prefLabel "group of tariff zones"@en ;
    skos:altLabel "grouping of tariff zones"@en ;
    skos:altLabel "groupoftariffzones"@en ;
    rdfs:comment "A grouping of TARIFF ZONEs which will be commonly referenced for a specific purpose."@en .

netex:GroupOfTimebands a skos:Concept ;
    skos:prefLabel "group of timebands"@en ;
    skos:altLabel "groupoftimebands"@en ;
    rdfs:comment "A period in a day, significant for some aspect of public transport, e.g. similar traffic conditions or fare category."@en .

netex:GroupOfTimingLinks a skos:Concept ;
    skos:prefLabel "group of timing links"@en ;
    skos:altLabel "groupoftiminglinks"@en ;
    skos:altLabel "set of timing links"@en ;
    rdfs:comment "A set of TIMING LINKs grouped together according to the similarity of TIME BANDs which are relevant to them. There may be a GROUP OF TIMING LINKS which covers all TIMING LINKs, for use when different GROUPs OF TIMING LINKS are not needed."@en .

netex:GroupTicket a skos:Concept ;
    skos:prefLabel "group ticket"@en ;
    skos:altLabel "groupticket"@en ;
    rdfs:comment "The number and characteristics of persons entitled to travel including the holder of the access right."@en .

netex:GuideDogAccess a skos:Concept ;
    skos:prefLabel "guide dog access"@en ;
    skos:altLabel "guidedogaccess"@en ;
    skos:altLabel "whether a place allows guide"@en ;
    rdfs:comment "Whether a PLACE allows guide dog access."@en .

netex:HailAndRideArea a skos:Concept ;
    skos:prefLabel "hail and ride area"@en ;
    skos:altLabel "hailandridearea"@en ;
    rdfs:comment "A section of Road between two points within which one may hail a bus to board it or alight from it or ask it to stop to alight."@en ;
    skos:related netex:Place .

netex:HeadingSign a skos:Concept ;
    skos:prefLabel "heading sign"@en ;
    skos:altLabel "headingsign"@en ;
    skos:altLabel "specialisation of sign equipment for"@en ;
    rdfs:comment "Specialisation of SIGN EQUIPMENT for headings providing information like direction name, line name, etc."@en ;
    skos:related netex:SignEquipment .

netex:HelpPointEquipment a skos:Concept ;
    skos:prefLabel "help point equipment"@en ;
    skos:altLabel "helppointequipment"@en ;
    skos:altLabel "specialisation of passenger equipment for"@en ;
    rdfs:comment "Specialisation of PASSENGER EQUIPMENT for HELP POINT."@en ;
    skos:related netex:PassengerEquipment .

netex:HireFacility a skos:Concept ;
    skos:prefLabel "classification of hire facility"@en ;
    skos:altLabel "hire facility"@en ;
    skos:altLabel "hirefacility"@en ;
    rdfs:comment "Classification of Hire FACILITY."@en .

netex:HireService a skos:Concept ;
    skos:prefLabel "hire service"@en ;
    skos:altLabel "hireservice"@en ;
    skos:altLabel "specialisation of local service dedicated"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE dedicated to hire services (e.g. cycle hire, car hire)."@en ;
    skos:related netex:LocalService .

netex:IndividualPassengerInfo a skos:Concept ;
    skos:prefLabel "individual passenger info"@en ;
    skos:altLabel "individualpassengerinfo"@en ;
    skos:altLabel "information characterising an individual traveller"@en ;
    rdfs:comment "Information characterising an INDIVIDUAL TRAVELLER as a driver of a VEHICLE POOLING SERVICE. +v1.2.2"@en .

netex:IndividualTraveller a skos:Concept ;
    skos:prefLabel "individual traveller"@en ;
    skos:altLabel "individual travelling person v122"@en ;
    skos:altLabel "individualtraveller"@en ;
    rdfs:comment "Individual travelling person. +v1.2.2"@en .

netex:InfoLink a skos:Concept ;
    skos:prefLabel "info link"@en ;
    skos:altLabel "infolink"@en ;
    rdfs:comment "A hyperlink to an external web resource."@en .

netex:InfrastructureFrame a skos:Concept ;
    skos:prefLabel "coherent set of infrastructure"@en ;
    skos:altLabel "infrastructure frame"@en ;
    skos:altLabel "infrastructureframe"@en ;
    rdfs:comment "A coherent set of infrastructure network description data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:InfrastructureLink a skos:Concept ;
    skos:prefLabel "infrastructure link"@en ;
    skos:altLabel "infrastructurelink"@en ;
    rdfs:comment "A supertype including all LINKs of the physical network (e.g. RAILWAY ELEMENT). Infrastructure links are directional - there will be separate links for each direction of a network."@en ;
    skos:related netex:Link .

netex:InfrastructureLinkRestriction a skos:Concept ;
    skos:prefLabel "infrastructure link restriction"@en ;
    skos:altLabel "infrastructurelinkrestriction"@en ;
    skos:altLabel "network restriction on movement"@en ;
    rdfs:comment "A NETWORK RESTRICTION on movement between any two network links."@en ;
    skos:related netex:NetworkRestriction .

netex:InfrastructurePoint a skos:Concept ;
    skos:prefLabel "infrastructure point"@en ;
    skos:altLabel "infrastructurepoint"@en ;
    rdfs:comment "A supertype including all POINTs of the physical network (e.g. RAILWAY JUNCTION)."@en ;
    skos:related netex:Point .

netex:InstalledEquipment a skos:Concept ;
    skos:prefLabel "installed equipment"@en ;
    skos:altLabel "installed equipment describes the different"@en ;
    skos:altLabel "installedequipment"@en ;
    rdfs:comment "INSTALLED EQUIPMENT describes the different types of LOCATED EQUIPMENT that may be associated with the SITE COMPONENTs."@en ;
    skos:related netex:Equipment .

netex:Interchange a skos:Concept ;
    skos:prefLabel "interchange"@en ;
    rdfs:comment "The scheduled possibility for transfer of passengers between two SERVICE JOURNEYs at the same or different STOP POINTs."@en .

netex:InterchangeRule a skos:Concept ;
    skos:prefLabel "interchange rule"@en ;
    skos:altLabel "interchangerule"@en ;
    rdfs:comment "Conditions for considering journeys to meet or not to meet, specified indirectly: by a particular MODE, DIRECTION or LINE. Such conditions may alternatively be specified directly, indicating the corresponding services. In this case they are either a SERVICE JOURNEY PATTERN INTERCHANGE or a SERVICE JOURNEY INTERCHANGE."@en .

netex:InterchangeRuleFilter a skos:Concept ;
    skos:prefLabel "filter for interchange rule filter"@en ;
    skos:altLabel "interchange rule filter"@en ;
    skos:altLabel "interchangerulefilter"@en ;
    rdfs:comment "Filter for INTERCHANGE RULE Filter."@en .

netex:InterchangeRuleTiming a skos:Concept ;
    skos:prefLabel "interchange rule timing"@en ;
    skos:altLabel "interchangeruletiming"@en ;
    rdfs:comment "Conditions for considering journeys to meet or not to meet, specified indirectly: by a particular MODE, DIRECTION or LINE. Such conditions may alternatively be specified directly, indicating the corresponding services. In this case they are either a SERVICE JOURNEY PATTERN INTERCHANGE or a SERVICE JOURNEY INTERCHANGE."@en .

netex:Interchanging a skos:Concept ;
    skos:prefLabel "interchanging"@en ;
    rdfs:comment "Limitations on making changes within a trip."@en .

netex:Journey a skos:Concept ;
    skos:prefLabel "common properties of a journey"@en ;
    skos:altLabel "journey"@en ;
    rdfs:comment "Common properties of a JOURNEY."@en .

netex:JourneyAccounting a skos:Concept ;
    skos:prefLabel "journey accounting"@en ;
    skos:altLabel "journeyaccounting"@en ;
    rdfs:comment "Parameters characterizing VEHICLE JOURNEYs or SPECIAL SERVICEs used for accounting purposes in particular in contracts between ORGANISATIONs."@en .

netex:JourneyDesignator a skos:Concept ;
    skos:prefLabel "journey designator"@en ;
    skos:altLabel "journeydesignator"@en ;
    skos:altLabel "value reference to a journey"@en ;
    rdfs:comment "Value reference to a JOURNEY. Provides an alternative way of identifying a Journey between TIMING POINTS"@en .

netex:JourneyHeadway a skos:Concept ;
    skos:prefLabel "headway interval information that is"@en ;
    skos:altLabel "journey headway"@en ;
    skos:altLabel "journeyheadway"@en ;
    rdfs:comment "Headway interval information that is available for all the VEHICLE JOURNEYs running on the JOURNEY PATTERN for a given TIME DEMAND TYPE, at a given TIMING POINT. This is a default value that can be superseded by VEHICLE JOURNEY HEADWAY. This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."@en ;
    skos:related netex:JourneyTiming .

netex:JourneyLayover a skos:Concept ;
    skos:prefLabel "journey layover"@en ;
    skos:altLabel "journeylayover"@en ;
    rdfs:comment "Time allowance at the end of each journey on a specified JOURNEY PATTERN, to allow for delays and for other purposes. This layover supersedes any global layover and may be superseded by a specific VEHICLE JOURNEY LAYOVER."@en ;
    skos:related netex:JourneyTiming .

netex:JourneyMeeting a skos:Concept ;
    skos:prefLabel "journey meeting"@en ;
    skos:altLabel "journeymeeting"@en ;
    rdfs:comment "A time constraint for one or several SERVICE JOURNEYs fixing interchanges between them and/or an external event (e.g. arrival or departure of a feeder line, opening time of the theatre, etc.)."@en .

netex:JourneyPart a skos:Concept ;
    skos:prefLabel "journey part"@en ;
    skos:altLabel "journeypart"@en ;
    skos:altLabel "part of a vehicle"@en ;
    rdfs:comment "A part of a VEHICLE JOURNEY created according to a specific functional purpose, for instance in situations when vehicle coupling or separating occurs."@en .

netex:JourneyPartCouple a skos:Concept ;
    skos:prefLabel "journey part couple"@en ;
    skos:altLabel "journeypartcouple"@en ;
    skos:altLabel "two or more journey parts"@en ;
    rdfs:comment "Two or more JOURNEY PARTs of different VEHICLE JOURNEYs served simultaneously by a train set up by coupling their single vehicles."@en .

netex:JourneyPartPosition a skos:Concept ;
    skos:prefLabel "journey part position"@en ;
    skos:altLabel "journeypartposition"@en ;
    skos:altLabel "position in train of journey"@en ;
    rdfs:comment "Position in train of JOURNEY PART from a given stop. +v1.1."@en .

netex:JourneyPattern a skos:Concept ;
    skos:prefLabel "journey pattern"@en ;
    skos:altLabel "journeypattern"@en ;
    skos:altLabel "route pattern"@en ;
    rdfs:comment "Defines a repeatable sequence of stops for a vehicle journey"@en ;
    skos:exactMatch nits:journey-pattern ;
    skos:related netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:AverageCommercialSpeed, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExpectedPassengerCount, opra:ExpectedServiceIntensity, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:LoadOverJourneyDistance, opra:MeanCapacityOverJourneyDistance, opra:MeanCapacityOverNetworkDistance, opra:MeanCapacityOverRouteDistance, opra:PlannedCapacity, opra:PreparednessLevel, opra:TransportPerformance, opra:TransportPerformancePerVehicle, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

netex:JourneyPatternHeadway a skos:Concept ;
    skos:prefLabel "headway interval information that is"@en ;
    skos:altLabel "journey pattern headway"@en ;
    skos:altLabel "journeypatternheadway"@en ;
    rdfs:comment "Headway interval information that is available for all the VEHICLE JOURNEYs running on the JOURNEY PATTERN. This is a default value that can be superseded by the VEHICLE JOURNEY HEADWAY on a specific journey. This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."@en .

netex:JourneyPatternLayover a skos:Concept ;
    skos:prefLabel "journey pattern layover"@en ;
    skos:altLabel "journeypatternlayover"@en ;
    rdfs:comment "Time allowance at the end of each journey on a specified JOURNEY PATTERN, to allow for delays and for other purposes. This layover supersedes any global layover and may be superseded by a specific VEHICLE JOURNEY LAYOVER."@en .

netex:JourneyPatternRunTime a skos:Concept ;
    skos:prefLabel "journey pattern run time"@en ;
    skos:altLabel "journeypatternruntime"@en ;
    skos:altLabel "time taken to traverse"@en ;
    rdfs:comment "The time taken to traverse a TIMING LINK in a particular JOURNEY PATTERN, for a specified TIME DEMAND TYPE If it exists, it will override the DEFAULT SERVICE JOURNEY RUN TIME and DEFAULT DEAD RUN RUN TIME."@en .

netex:JourneyPatternWaitTime a skos:Concept ;
    skos:prefLabel "journey pattern wait time"@en ;
    skos:altLabel "journeypatternwaittime"@en ;
    skos:altLabel "time a vehicle has"@en ;
    rdfs:comment "The time a vehicle has to wait at a specific TIMING POINT IN JOURNEY PATTERN, for a specified TIME DEMAND TYPE. This wait time can be superseded by a VEHICLE JOURNEY WAIT TIME."@en .

netex:JourneyRunTime a skos:Concept ;
    skos:prefLabel "journey run time"@en ;
    skos:altLabel "journeyruntime"@en ;
    skos:altLabel "time taken to traverse"@en ;
    rdfs:comment "The time taken to traverse a TIMING LINK in a particular JOURNEY PATTERN, for a specified TIME DEMAND TYPE. If it exists, it will override the DEFAULT SERVICE JOURNEY RUN TIME and DEFAULT DEAD RUN RUN TIME."@en ;
    skos:related netex:JourneyTiming .

netex:JourneyTiming a skos:Concept ;
    skos:prefLabel "journey timing"@en ;
    skos:altLabel "journeytiming"@en ;
    rdfs:comment "A time-related information referring to journey timing whose value depends on the time of use and so can be associated with a TIME DEMAND TYPE, TIME BAND or OPERATIONAL CONTEXT."@en .

netex:JourneyWaitTime a skos:Concept ;
    skos:prefLabel "journey wait time"@en ;
    skos:altLabel "journeywaittime"@en ;
    skos:altLabel "time a vehicle has"@en ;
    rdfs:comment "The time a vehicle has to wait at a specific TIMING POINT IN JOURNEY PATTERN, for a specified TIME DEMAND TYPE. This wait time can be superseded by a VEHICLE JOURNEY WAIT TIME."@en ;
    skos:related netex:JourneyTiming .

netex:Layer a skos:Concept ;
    skos:prefLabel "layer"@en ;
    rdfs:comment "A user-defined GROUP OF ENTITies, specified for a particular functional purpose, associating data referring to a particular LOCATING SYSTEM."@en .

netex:LeftLuggageService a skos:Concept ;
    skos:prefLabel "left luggage service"@en ;
    skos:altLabel "leftluggageservice"@en ;
    skos:altLabel "specialisation of customer service for"@en ;
    rdfs:comment "Specialisation of CUSTOMER SERVICE for left luggage (provides left luggage information like self service locker, locker free, etc.)."@en ;
    skos:related netex:CustomerService .

netex:Level a skos:Concept ;
    skos:prefLabel "level"@en ;
    rdfs:comment "An identified storey (ground, first, basement, mezzanine, etc) within an interchange building or SITE on which SITE COMPONENTs reside. A PATH LINK may connect components on different levels."@en .

netex:LevelAccessIntoVehicle a skos:Concept ;
    skos:prefLabel "level access into vehicle"@en ;
    skos:altLabel "levelaccessintovehicle"@en ;
    rdfs:comment "Whether the platform is high enough and gap is small enough for level access into vehicle. At least at a designated wheelchair door position the gap between platform and vehicle floor (of level access vehicle) does not exceed 75 mm measured horizontally and 50 mm measured vertically including sliding step (according to PRM TSI)."@en .

netex:LiftCallEquipment a skos:Concept ;
    skos:prefLabel "lift call equipment"@en ;
    skos:altLabel "liftcallequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT for calling LIFTs (provides specific characteristics that may differ from floor to floor like button height, door, etc.). +v1.3.1"@en ;
    skos:related netex:AccessEquipment .

netex:LiftEquipment a skos:Concept ;
    skos:prefLabel "lift equipment"@en ;
    skos:altLabel "liftequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT for LIFTs (provides lift characteristics like depth, maximum load, etc.)."@en ;
    skos:related netex:AccessEquipment .

netex:LiftFreeAccess a skos:Concept ;
    skos:prefLabel "lift free access"@en ;
    skos:altLabel "liftfreeaccess"@en ;
    skos:altLabel "whether a place has lift"@en ;
    rdfs:comment "Whether a PLACE has lift free access."@en .

netex:LightingControlFacility a skos:Concept ;
    skos:prefLabel "classification of lighting control facility"@en ;
    skos:altLabel "lighting control facility"@en ;
    skos:altLabel "lightingcontrolfacility"@en ;
    rdfs:comment "Classification of lighting control FACILITY."@en .

netex:LightingControlFacilityList a skos:Concept ;
    skos:prefLabel "lighting control facility list"@en ;
    skos:altLabel "lightingcontrolfacilitylist"@en ;
    skos:altLabel "list of lighting control facilities"@en ;
    rdfs:comment "List of lighting control FACILITies."@en .

netex:LimitingRule a skos:Concept ;
    skos:prefLabel "limiting rule"@en ;
    skos:altLabel "limitingrule"@en ;
    rdfs:comment "A price for which a discount can be offered."@en .

netex:LimitingRuleInContext a skos:Concept ;
    skos:prefLabel "limiting rule in context"@en ;
    skos:altLabel "limitingruleincontext"@en ;
    rdfs:comment "OPTIMISED version whcih can be be used only in line assues ID of comtainign context -no id checking. A price for which a discount can be offered."@en .

netex:Line a skos:Concept ;
    skos:prefLabel "line"@en ;
    skos:altLabel "service line"@en ;
    skos:altLabel "bus line"@en ;
    skos:altLabel "route"@en ;
    rdfs:comment "A grouping of journeys serving the same route with consistent frequency"@en ;
    skos:exactMatch nits:line ;
    skos:related datex:TrafficEvent, netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:JourneyPattern, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:AverageCommercialSpeed, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExpectedServiceIntensity, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:LateDatedVehicleJourneyEntry, opra:LoadOverJourneyDistance, opra:MeanCapacityOverJourneyDistance, opra:MeanCapacityOverNetworkDistance, opra:MeanCapacityOverRouteDistance, opra:PlannedCapacity, opra:PreparednessLevel, opra:TransportPerformance, opra:TransportPerformancePerVehicle, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, siri:VehicleMonitoring, transmodel:Journey .

netex:LineNetwork a skos:Concept ;
    skos:prefLabel "line network"@en ;
    skos:altLabel "linenetwork"@en ;
    rdfs:comment "A description of the topological connectivity of a LINE as a set of LINE SECTIONs. This is sufficient to draw a route map for the whole line including branches and loops."@en .

netex:LineSection a skos:Concept ;
    skos:prefLabel "line section"@en ;
    skos:altLabel "linesection"@en ;
    skos:altLabel "section of a line"@en ;
    rdfs:comment "A section of a LINE NETWORK comprising an edge between two nodes. Not directional."@en .

netex:LineSectionPointMember a skos:Concept ;
    skos:prefLabel "deprecated use point on"@en ;
    skos:altLabel "line section point member"@en ;
    skos:altLabel "linesectionpointmember"@en ;
    rdfs:comment "[DEPRECATED - use POINT ON LINE SECTION INSTEAD] An ordered set of LINKs for a line."@en ;
    skos:related netex:CommonSectionPointMember .

netex:LineShape a skos:Concept ;
    skos:prefLabel "line shape"@en ;
    skos:altLabel "lineshape"@en ;
    rdfs:comment "The graphical shape of a LINK obtained from a formula or other means, using the LOCATION of its limiting POINTs and depending on the LOCATING SYSTEM used for the graphical representation."@en ;
    skos:related netex:Link .

netex:Link a skos:Concept ;
    skos:prefLabel "link"@en ;
    skos:altLabel "link connecting two points an"@en ;
    rdfs:comment "LINK connecting two POINTs. An oriented spatial object of dimension 1 with view to the overall description of a network, describing a connection between two POINTs."@en .

netex:LinkInJourneyPattern a skos:Concept ;
    skos:prefLabel "link in journey pattern"@en ;
    skos:altLabel "linkinjourneypattern"@en ;
    skos:altLabel "service link or timing"@en ;
    rdfs:comment "A SERVICE LINK or TIMING LINK in a JOURNEY PATTERN with its order in that JOURNEY PATTERN."@en ;
    skos:related netex:LinkInLinkSequence .

netex:LinkInLinkSequence a skos:Concept ;
    skos:prefLabel "link in link sequence"@en ;
    skos:altLabel "linkinlinksequence"@en ;
    rdfs:comment "An edge of an abstract LINK SEQUENCE."@en .

netex:LinkProjection a skos:Concept ;
    skos:prefLabel "link projection"@en ;
    skos:altLabel "linkprojection"@en ;
    rdfs:comment "An oriented correspondence from one LINK of a source layer, onto an entity in a target layer: e.g. LINK SEQUENCE, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."@en ;
    skos:related netex:Projection .

netex:LinkSequence a skos:Concept ;
    skos:prefLabel "link sequence"@en ;
    skos:altLabel "link sequence of links"@en ;
    skos:altLabel "linksequence"@en ;
    rdfs:comment "An LINK SEQUENCE of Links and Nodes."@en .

netex:LinkSequenceProjection a skos:Concept ;
    skos:prefLabel "link sequence projection"@en ;
    skos:altLabel "linksequenceprojection"@en ;
    skos:altLabel "projection of a whole"@en ;
    rdfs:comment "A Projection of a whole LINK SEQUENCE as an ordered series of POINTs."@en ;
    skos:related netex:Projection .

netex:LocalService a skos:Concept ;
    skos:prefLabel "local service"@en ;
    skos:altLabel "localservice"@en ;
    skos:altLabel "named service relating to"@en ;
    rdfs:comment "A named service relating to the use of the SITE or transport services at a particular location, for example porterage, assistance for disabled users, booking offices etc."@en ;

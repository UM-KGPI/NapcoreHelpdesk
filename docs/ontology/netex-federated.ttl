    skos:altLabel "normaldatedvehiclejourney"@en ;
    rdfs:comment "A DATED VEHICLE JOURNEY identical to a long-term planned VEHICLE JOURNEY, possibly updated according to short-term modifications of the PRODUCTION PLAN decided by the control staff."@en .

netex:Notice a skos:Concept ;
    skos:prefLabel "notice"@en ;
    rdfs:comment "A note or footnote about any aspect of a service, e.g. an announcement, notice, etc. May have different DELIVERY VARIANTs for different media."@en .

netex:NoticeAssignment a skos:Concept ;
    skos:prefLabel "assignment of a notice"@en ;
    skos:altLabel "notice assignment"@en ;
    skos:altLabel "noticeassignment"@en ;
    rdfs:comment "The assignment of a NOTICE showing an exception in a JOURNEY PATTERN, a COMMON SECTION, or a VEHICLE JOURNEY, possibly specifying at which POINT IN JOURNEY PATTERN the validity of the NOTICE starts and ends respectively."@en .

netex:NuisanceFacility a skos:Concept ;
    skos:prefLabel "classification of nuisance facility type"@en ;
    skos:altLabel "nuisance facility"@en ;
    skos:altLabel "nuisancefacility"@en ;
    rdfs:comment "Classification of NUISANCE FACILITY type - TPEG pti23."@en .

netex:NuisanceFacilityList a skos:Concept ;
    skos:prefLabel "list of nuisance facilities"@en ;
    skos:altLabel "nuisance facility list"@en ;
    skos:altLabel "nuisancefacilitylist"@en ;
    rdfs:comment "List of NUISANCE FACILITies."@en .

netex:OffSitePathLink a skos:Concept ;
    skos:prefLabel "off site path link"@en ;
    skos:altLabel "offsitepathlink"@en ;
    rdfs:comment "A link outside of a SITE between any two PLACEs ( PKACES PATH JUNCTIONs) that represents a step in a possible route for pedestrians, cyclists or other out of vehicle passengers within or between a PLACE. +v2.0"@en ;
    skos:related netex:Link .

netex:OffenceDebit a skos:Concept ;
    skos:prefLabel "offence debit"@en ;
    skos:altLabel "offencedebit"@en ;
    rdfs:comment "A LOG ENTRY recording data about a debiting action for a fine for an OFFENCE or penalty fare."@en .

netex:OfferedTravelSpecification a skos:Concept ;
    skos:prefLabel "offered travel specification"@en ;
    skos:altLabel "offeredtravelspecification"@en ;
    rdfs:comment "A set of parameters giving details of the intended consumption of access rights associated with an offer or a purchase. (e.g. origin and destination of a travel, class of travel, etc.). ."@en .

netex:OnboardSpace a skos:Concept ;
    skos:prefLabel "onboard space"@en ;
    skos:altLabel "onboardspace"@en ;
    rdfs:comment "A place aboard a vehicle where ACTUAL VEHICLE EQUIPMENT may be located. +v2.0"@en ;
    skos:related netex:Zone .

netex:OnboardStay a skos:Concept ;
    skos:prefLabel "onboard stay"@en ;
    skos:altLabel "onboardstay"@en ;
    rdfs:comment "Boarding permission to board early or stay on board late."@en .

netex:OnlineService a skos:Concept ;
    skos:prefLabel "any remotely accessible service providing"@en ;
    skos:altLabel "online service"@en ;
    skos:altLabel "onlineservice"@en ;
    rdfs:comment "Any remotely accessible service providing access to any mode of transportation and/or information related to transportation services. +v1.2.2"@en .

netex:OnlineServiceOperator a skos:Concept ;
    skos:prefLabel "online service operator"@en ;
    skos:altLabel "onlineserviceoperator"@en ;
    skos:altLabel "organisation that provides online"@en ;
    rdfs:comment "An organisation that provides online access to an ONLINE SERVICE without operating transportation services of travellers. +v1.2.2"@en .

netex:OpenTransportMode a skos:Concept ;
    skos:prefLabel "open transport mode"@en ;
    skos:altLabel "open values transport mode allows"@en ;
    skos:altLabel "opentransportmode"@en ;
    rdfs:comment "Open values TRANSPORT MODE. Allows additional named modes to be created. A mode is a characterisation of the operation according to the means of transport (bus, tram, metro, train, ferry, ship). NOTE : To enforce standardisation, enumerated values are generally used in references. In The schema."@en ;
    skos:related netex:TypeOfValue .

netex:OperatingDay a skos:Concept ;
    skos:prefLabel "day of public transport"@en ;
    skos:altLabel "operating day"@en ;
    skos:altLabel "operatingday"@en ;
    rdfs:comment "A day of public transport operation in a specific calendar. An OPERATING DAY may last more than 24 hours."@en .

netex:OperatingDepartment a skos:Concept ;
    skos:prefLabel "operating department"@en ;
    skos:altLabel "operatingdepartment"@en ;
    skos:altLabel "specific department which administers"@en ;
    rdfs:comment "A specific DEPARTMENT which administers certain LINEs."@en .

netex:OperationalContext a skos:Concept ;
    skos:prefLabel "operational context"@en ;
    skos:altLabel "operationalcontext"@en ;
    rdfs:comment "Characterization of a set of operational objects, such as timing or links determined either by a DEPARTMENT or by an ORGANISATIONAL UNIT."@en .

netex:Operator a skos:Concept ;
    skos:prefLabel "operator"@en ;
    skos:altLabel "transport operator"@en ;
    skos:altLabel "service operator"@en ;
    rdfs:comment "An organization responsible for operating vehicle services"@en ;
    skos:related datex:TrafficEvent, netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:AverageCommercialSpeed, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExpectedServiceIntensity, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:LateDatedVehicleJourneyEntry, opra:LoadOverJourneyDistance, opra:MeanCapacityOverJourneyDistance, opra:MeanCapacityOverNetworkDistance, opra:MeanCapacityOverRouteDistance, opra:PlannedCapacity, opra:PlannedServiceIntensity, opra:PreparednessLevel, opra:TransportPerformance, opra:TransportPerformancePerVehicle, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

netex:Organisation a skos:Concept ;
    skos:prefLabel "organisation"@en ;
    rdfs:comment "An legally incorporated body associated with any aspect of the transport system."@en .

netex:OrganisationPart a skos:Concept ;
    skos:prefLabel "organisation part"@en ;
    skos:altLabel "organisationpart"@en ;
    rdfs:comment "A named subdivision of an ORGANISATION."@en .

netex:OrganisationalUnit a skos:Concept ;
    skos:prefLabel "organisational unit"@en ;
    skos:altLabel "organisationalunit"@en ;
    rdfs:comment "OrganisationalUnit of an ORGANISATION."@en .

netex:OtherDebit a skos:Concept ;
    skos:prefLabel "other debit"@en ;
    skos:altLabel "otherdebit"@en ;
    rdfs:comment "A LOG ENTRY recording data about a debiting action for a payment type other than a FARE PRODUCT SALE DEBIT, TRIP DEBIT, OFFENCE DEBIT or BOOKING DEBIT."@en .

netex:OtherDeckEntrance a skos:Concept ;
    skos:prefLabel "entrance to or within"@en ;
    skos:altLabel "other deck entrance"@en ;
    skos:altLabel "otherdeckentrance"@en ;
    rdfs:comment "An entrance to or within a DECK for use for other purposes than normal passenger access. E.g. crew, emergency exit, etc. +v2.0"@en .

netex:OtherDeckSpace a skos:Concept ;
    skos:prefLabel "other deck space"@en ;
    skos:altLabel "otherdeckspace"@en ;
    skos:altLabel "specialisation of deck space"@en ;
    rdfs:comment "A specialisation of DECK SPACE defining an area within a VEHICLE (i.e. bus, boat, coach, car) or TRAIN ELEMENT for restricted use, such as a crew area. +v2.0"@en .

netex:OtherOrganisation a skos:Concept ;
    skos:prefLabel "generic organisation being neither an"@en ;
    skos:altLabel "other organisation"@en ;
    skos:altLabel "otherorganisation"@en ;
    rdfs:comment "Generic ORGANISATION being neither an AUTHORITY, neither a public transport OPERATOR (TRAVEL AGENT, MANAGEMENT AGENT, etc.)."@en .

netex:OtherPlaceEquipment a skos:Concept ;
    skos:prefLabel "equipment that may be in"@en ;
    skos:altLabel "other place equipment"@en ;
    skos:altLabel "otherplaceequipment"@en ;
    rdfs:comment "Equipment that may be in a fixed within a SITE."@en .

netex:OvertakingPossibility a skos:Concept ;
    skos:prefLabel "overtaking possibility"@en ;
    skos:altLabel "overtakingpossibility"@en ;
    rdfs:comment "NETWORK RESTRICTION specifying a POINT or a LINK where vehicles of specified VEHICLE TYPEs are or are not allowed to overtake each other."@en ;
    skos:related netex:NetworkRestriction .

netex:Parking a skos:Concept ;
    skos:prefLabel "named place where parking"@en ;
    skos:altLabel "parking"@en ;
    rdfs:comment "A named place where Parking may be accessed. May be a building complex (e.g. a station) or an on-street location."@en .

netex:ParkingBay a skos:Concept ;
    skos:prefLabel "parking bay"@en ;
    skos:altLabel "parkingbay"@en ;
    rdfs:comment "An individual place to park a VEHICLE."@en .

netex:ParkingBayCondition a skos:Concept ;
    skos:prefLabel "parking bay condition"@en ;
    skos:altLabel "parkingbaycondition"@en ;
    rdfs:comment "A record of the status of the PARKING BAY at a given moment in time. +v1.2.2"@en .

netex:ParkingBayStatus a skos:Concept ;
    skos:prefLabel "parking bay status"@en ;
    skos:altLabel "parkingbaystatus"@en ;
    rdfs:comment "A categorisation of the availability of the parking spot, such as being temporarily closed, unavailable, available. +v1.2.2 . +v1.2.2"@en ;
    skos:related netex:TypeOfValue .

netex:ParkingChargeBand a skos:Concept ;
    skos:prefLabel "parking charge band"@en ;
    skos:altLabel "parking charges that describe the"@en ;
    skos:altLabel "parkingchargeband"@en ;
    rdfs:comment "Parking charges that describe the cost of using a PARKING or PARKING AREA for a given period."@en ;
    skos:related netex:PriceableObject .

netex:ParkingComponent a skos:Concept ;
    skos:prefLabel "component within a parking"@en ;
    skos:altLabel "parking component"@en ;
    skos:altLabel "parkingcomponent"@en ;
    rdfs:comment "Component within a PARKING."@en ;
    skos:related netex:SiteComponent .

netex:ParkingEntranceForVehicles a skos:Concept ;
    skos:prefLabel "designated place within a parking"@en ;
    skos:altLabel "parking entrance for vehicles"@en ;
    skos:altLabel "parkingentranceforvehicles"@en ;
    rdfs:comment "Designated Place within a PARKING for a VEHICLE to enter."@en ;
    skos:related netex:Entrance .

netex:ParkingFacility a skos:Concept ;
    skos:prefLabel "classification of parking facility"@en ;
    skos:altLabel "parking facility"@en ;
    skos:altLabel "parkingfacility"@en ;
    rdfs:comment "Classification of PARKING FACILITY."@en .

netex:ParkingFacilityList a skos:Concept ;
    skos:prefLabel "list of parking facilities"@en ;
    skos:altLabel "parking facility list"@en ;
    skos:altLabel "parkingfacilitylist"@en ;
    rdfs:comment "List of PARKING FACILITies."@en .

netex:ParkingPassengerEntrance a skos:Concept ;
    skos:prefLabel "designated passenger entrance within a"@en ;
    skos:altLabel "parking passenger entrance"@en ;
    skos:altLabel "parkingpassengerentrance"@en ;
    rdfs:comment "Designated Passenger ENTRANCE within a PARKING."@en ;
    skos:related netex:Entrance .

netex:ParkingPoint a skos:Concept ;
    skos:prefLabel "parking point"@en ;
    skos:altLabel "parkingpoint"@en ;
    skos:altLabel "timing point where vehicles"@en ;
    rdfs:comment "A TIMING POINT where vehicles may stay unattended for a long time. A vehicle's return to park at a PARKING POINT marks the end of a BLOCK."@en .

netex:ParkingPrice a skos:Concept ;
    skos:prefLabel "parking price"@en ;
    skos:altLabel "parkingprice"@en ;
    rdfs:comment "A set of all possible price features of a PARKING TARIFF ELEMENT: default total price, discount in value or percentage etc."@en .

netex:ParkingTariff a skos:Concept ;
    skos:prefLabel "parking tariff"@en ;
    skos:altLabel "parkingtariff"@en ;
    skos:altLabel "set of parking charge"@en ;
    rdfs:comment "A set of parking CHARGE BANDS that describe the cost if using a PARKING or PARKING AREA."@en .

netex:PassengerAccessibilityNeeds a skos:Concept ;
    skos:prefLabel "passenger accessibility needs"@en ;
    skos:altLabel "passengeraccessibilityneeds"@en ;
    skos:altLabel "passengers requirement for accessibility"@en ;
    rdfs:comment "A passenger's requirement for accessibility, comprising one or more USER NEEDs. For example, that he is unable to navigate stairs, or lifts, or has visual or auditory impairments. PASSENGER ACCESSIBILITY NEEDS can be used to derive an accessibility constraint for the passenger, allowing the computation of paths for passengers with specifically constrained mobility. Example: Wheelchair, No Lifts, No Stairs."@en .

netex:PassengerAtStopTime a skos:Concept ;
    skos:prefLabel "passenger at stop time"@en ;
    skos:altLabel "passengeratstoptime"@en ;
    skos:altLabel "time at which a passenger"@en ;
    rdfs:comment "Time at which a passenger should be at a stop to commence or finish a process. +v2.0"@en .

netex:PassengerBeaconEquipment a skos:Concept ;
    skos:prefLabel "passenger beacon equipment"@en ;
    skos:altLabel "passengerbeaconequipment"@en ;
    skos:altLabel "specialisation of passenger equipment for"@en ;
    rdfs:comment "Specialisation of PASSENGER EQUIPMENT for Beacons. For SSID or UUID always use PublicCode. Be aware that when using VEHICLE TYPE or VEHICLE PROFILE only the type of the beacon can be described. The information aboutn the relevent real beacon often can only be provided when the actual VEHICLE is known."@en ;
    skos:related netex:PassengerEquipment .

netex:PassengerBoardingPositionAssignment a skos:Concept ;
    skos:prefLabel "passenger boarding position assignment"@en ;
    skos:altLabel "passengerboardingpositionassignment"@en ;
    rdfs:comment "The default allocation of a SCHEDULED STOP POINT to a specific STOP PLACE, and also possibly a QUAY and BOARDING POSITION. NB Rebmed from TRAIN STOP ASSIGNMENT in v2."@en ;
    skos:related netex:StopAssignment .

netex:PassengerCapacity a skos:Concept ;
    skos:prefLabel "passenger capacity"@en ;
    skos:altLabel "passengercapacity"@en ;
    rdfs:comment "Total number of passengers that can be carried by a VEHICLE of this type."@en .

netex:PassengerCarryingRequirement a skos:Concept ;
    skos:prefLabel "passenger carrying requirement"@en ;
    skos:altLabel "passengercarryingrequirement"@en ;
    skos:altLabel "requirements for carrying passengers on"@en ;
    rdfs:comment "Requirements for carrying passengers on a service."@en .

netex:PassengerCommsFacility a skos:Concept ;
    skos:prefLabel "classification of passenger comms facility"@en ;
    skos:altLabel "passenger comms facility"@en ;
    skos:altLabel "passengercommsfacility"@en ;
    rdfs:comment "Classification of PASSENGER COMMS FACILITY type - TPEG pti23."@en .

netex:PassengerCommsFacilityList a skos:Concept ;
    skos:prefLabel "list of passenger comms facilities"@en ;
    skos:altLabel "passenger comms facility list"@en ;
    skos:altLabel "passengercommsfacilitylist"@en ;
    rdfs:comment "List of PASSENGER COMMS FACILITies."@en .

netex:PassengerEntrance a skos:Concept ;
    skos:prefLabel "normal entrance for passengers"@en ;
    skos:altLabel "passenger entrance"@en ;
    skos:altLabel "passengerentrance"@en ;
    rdfs:comment "A normal entrance for passengers to or within a DECK. +v2.0"@en .

netex:PassengerEquipment a skos:Concept ;
    skos:prefLabel "equipment for passengers that may"@en ;
    skos:altLabel "passenger equipment"@en ;
    skos:altLabel "passengerequipment"@en ;
    rdfs:comment "Equipment for passengers that may be in a fixed within a STOP PLACE."@en ;
    skos:related netex:InstalledEquipment .

netex:PassengerInformationEquipment a skos:Concept ;
    skos:prefLabel "passenger information equipment"@en ;
    skos:altLabel "passengerinformationequipment"@en ;
    skos:altLabel "public transport information facility"@en ;
    rdfs:comment "A public transport information facility, as for instance terminals (on street, at information desks, telematic, ...) or printed material (leaflets displayed at stops, booklets, ...)."@en ;
    skos:related netex:PassengerEquipment .

netex:PassengerInformationFacility a skos:Concept ;
    skos:prefLabel "classification of passenger info facility"@en ;
    skos:altLabel "passenger information facility"@en ;
    skos:altLabel "passengerinformationfacility"@en ;
    rdfs:comment "Classification of PASSENGER INFO FACILITY type - TPEG pti23."@en .

netex:PassengerInformationFacilityList a skos:Concept ;
    skos:prefLabel "list of passenger info facilities"@en ;
    skos:altLabel "passenger information facility list"@en ;
    skos:altLabel "passengerinformationfacilitylist"@en ;
    rdfs:comment "List of PASSENGER INFO FACILITies."@en .

netex:PassengerSafetyEquipment a skos:Concept ;
    skos:prefLabel "passenger safety equipment"@en ;
    skos:altLabel "passengersafetyequipment"@en ;
    skos:altLabel "specialisation of passenger equipment for"@en ;
    rdfs:comment "Specialisation of PASSENGER EQUIPMENT for passenger safety features, e.g. panic button, SOS phone."@en ;
    skos:related netex:PassengerEquipment .

netex:PassengerSpace a skos:Concept ;
    skos:prefLabel "passenger space"@en ;
    skos:altLabel "passengerspace"@en ;
    skos:altLabel "specialisation of deck space"@en ;
    rdfs:comment "A specialisation of DECK SPACE defining an area within a VEHICLE (i.e. bus, boat, coach, car) or TRAIN ELEMENT for use by passengers. +v2.0"@en .

netex:PassengerSpot a skos:Concept ;
    skos:prefLabel "passenger spot"@en ;
    skos:altLabel "passengerspot"@en ;
    rdfs:comment "A designated seat or other space for a passenger within a given DECK SPACE. +v2.0."@en ;
    skos:related netex:LocatableSpot .

netex:PassengerSpotAllocation a skos:Concept ;
    skos:prefLabel "passenger spot allocation"@en ;
    skos:altLabel "passengerspotallocation"@en ;
    rdfs:comment "Whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific validity Parameter. This may be subject to a particular VALIDITY CONDITION. +v2.0"@en .

netex:PassengerStopAssignment a skos:Concept ;
    skos:prefLabel "passenger stop assignment"@en ;
    skos:altLabel "passengerstopassignment"@en ;
    rdfs:comment "The default allocation of a SCHEDULED STOP POINT to a specific STOP PLACE, and also possibly a QUAY and BOARDING POSITION."@en ;
    skos:related netex:StopAssignment .

netex:PassengerVehicleCapacity a skos:Concept ;
    skos:prefLabel "passenger vehicle capacity"@en ;
    skos:altLabel "passengervehiclecapacity"@en ;
    skos:altLabel "total number of passenger vehicles"@en ;
    rdfs:comment "Total number of passenger vehicles s that can be carried by a VEHICLE of this type."@en .

netex:PassengerVehicleSpot a skos:Concept ;
    skos:prefLabel "passenger vehicle spot"@en ;
    skos:altLabel "passengervehiclespot"@en ;
    rdfs:comment "A designated space to park a passenger's vehicle onboard.+v2.0."@en ;
    skos:related netex:LocatableSpot .

netex:PathInstruction a skos:Concept ;
    skos:prefLabel "instruction to a passenger"@en ;
    skos:altLabel "path instruction"@en ;
    skos:altLabel "pathinstruction"@en ;
    rdfs:comment "An instruction to a passenger for an individual step when following a PATH LINK. +v2.0"@en .

netex:PathJunction a skos:Concept ;
    skos:prefLabel "deprecated use site path junction"@en ;
    skos:altLabel "path junction"@en ;
    skos:altLabel "pathjunction"@en ;
    rdfs:comment "DEPRECATED: Use SITE PATH JUNCTION. Designated point, inside a SITE ie STOP PLACE or POINT OF INTEREST, at which two or more PATH LINKs may connect or branch. -v2.0"@en ;
    skos:related netex:Point .

netex:PathLink a skos:Concept ;
    skos:prefLabel "deprecated use site path"@en ;
    skos:altLabel "path link"@en ;
    skos:altLabel "pathlink"@en ;
    rdfs:comment "DEPRECATED - use SITE PATH LINK"@en ;
    skos:related netex:Link .

netex:PathLinkInSequence a skos:Concept ;
    skos:prefLabel "path link in sequence"@en ;
    skos:altLabel "pathlinkinsequence"@en ;
    rdfs:comment "A step of a NAVIGATION PATH indicating traversal of a particular PATH LINK as part of a recommended route. The same PATH LINK may occur in different sequences in different NAVIGATION PATHs."@en ;
    skos:related netex:LinkInLinkSequence .

netex:PenaltyPolicy a skos:Concept ;
    skos:prefLabel "penalty policy"@en ;
    skos:altLabel "penaltypolicy"@en ;
    skos:altLabel "policy regarding different aspects of"@en ;
    rdfs:comment "Policy regarding different aspects of penalty charges, for example repeated entry at the same station, no ticket etc."@en .

netex:PersonalModeOfOperation a skos:Concept ;
    skos:prefLabel "nonadvertised mode of operation"@en ;
    skos:altLabel "personal mode of operation"@en ;
    skos:altLabel "personalmodeofoperation"@en ;
    rdfs:comment "A non-advertised mode of operation of vehicles by persons using their own vehicle. +v1.2.2"@en .

netex:Place a skos:Concept ;
    skos:prefLabel "named place a geographic"@en ;
    skos:altLabel "place"@en ;
    rdfs:comment "A named Place. A geographic place of any type which may be specified as the origin or destination of a trip. A PLACE may be of dimension 0 (a POINT), 1 (a Road section) or 2 (a ZONE)."@en ;
    skos:related netex:Zone .

netex:PlaceEquipment a skos:Concept ;
    skos:prefLabel "item of equipment of"@en ;
    skos:altLabel "place equipment"@en ;
    skos:altLabel "placeequipment"@en ;
    rdfs:comment "An item of equipment of a particular type actually available at a location within a PLACE."@en ;
    skos:related netex:InstalledEquipment .

netex:PlaceInSequence a skos:Concept ;
    skos:prefLabel "place in sequence"@en ;
    skos:altLabel "placeinsequence"@en ;
    rdfs:comment "Point traversed by a NAVIGATION PATH in sequence. May be a PLACE PATH JUNCTION or POINT."@en ;
    skos:related netex:PointInLinkSequence .

netex:PlaceLighting a skos:Concept ;
    skos:prefLabel "place lighting"@en ;
    skos:altLabel "placelighting"@en ;
    skos:altLabel "specialisation of place equipment for"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for LIGHTING EQUIPMENT (e.g. lamp post)."@en ;
    skos:related netex:AccessEquipment .

netex:PlaceSign a skos:Concept ;
    skos:prefLabel "place sign"@en ;
    skos:altLabel "placesign"@en ;
    skos:altLabel "sign with place name for"@en ;
    rdfs:comment "Sign with Place name for a PLACE. E.g. 'Waterloo'"@en ;
    skos:related netex:Place, netex:SignEquipment .

netex:Point a skos:Concept ;
    skos:prefLabel "point"@en ;
    rdfs:comment "A 0-dimensional node of the network used for the spatial description of the network. POINTs may be located by a LOCATION in a given LOCATING SYSTEM."@en .

netex:PointInJourneyPattern a skos:Concept ;
    skos:prefLabel "point in journey pattern"@en ;
    skos:altLabel "pointinjourneypattern"@en ;
    skos:altLabel "stop point or timing"@en ;
    rdfs:comment "A STOP POINT or TIMING POINT in a JOURNEY PATTERN with its order in that JOURNEY PATTERN."@en ;
    skos:related netex:PointInLinkSequence .

netex:PointInLinkSequence a skos:Concept ;
    skos:prefLabel "point in link sequence"@en ;
    skos:altLabel "pointinlinksequence"@en ;
    rdfs:comment "An node of an abstract LINK SEQUENCE."@en .

netex:PointOfInterest a skos:Concept ;
    skos:prefLabel "point of interest"@en ;
    skos:altLabel "pointofinterest"@en ;
    rdfs:comment "A type of SITE to or through which passengers may wish to navigate as part of their journey and which is modelled in detail by journey planners."@en ;
    skos:related netex:Site .

netex:PointOfInterestClassification a skos:Concept ;
    skos:prefLabel "classification of a point of"@en ;
    skos:altLabel "point of interest classification"@en ;
    skos:altLabel "pointofinterestclassification"@en ;
    rdfs:comment "Classification of a POINT OF INTEREST."@en ;
    skos:related netex:TypeOfValue .

netex:PointOfInterestClassificationHierarchy a skos:Concept ;
    skos:prefLabel "logical hierarchy for organizing"@en ;
    skos:altLabel "point of interest classification hierarchy"@en ;
    skos:altLabel "pointofinterestclassificationhierarchy"@en ;
    rdfs:comment "A logical hierarchy for organizing POINT OF INTEREST CLASSIFICATIONs. A POINT OF INTEREST CLASSIFICATION can belong to more than one hierarchy."@en .

netex:PointOfInterestComponent a skos:Concept ;
    skos:prefLabel "point of interest component"@en ;
    skos:altLabel "pointofinterestcomponent"@en ;
    rdfs:comment "A part of the physical structure of a POINT OF INTEREST."@en ;
    skos:related netex:SiteElement .

netex:PointOfInterestEntrance a skos:Concept ;
    skos:prefLabel "point of interest entrance"@en ;
    skos:altLabel "pointofinterestentrance"@en ;
    skos:altLabel "specialisation of entrance of entrance"@en ;
    rdfs:comment "Specialisation of ENTRANCE of ENTRANCE for a passenger to a POINT OF INTEREST."@en ;
    skos:related netex:Entrance .

netex:PointOfInterestSpace a skos:Concept ;
    skos:prefLabel "place within a point"@en ;
    skos:altLabel "point of interest space"@en ;
    skos:altLabel "pointofinterestspace"@en ;
    rdfs:comment "A PLACE within a POINT OF INTEREST."@en ;
    skos:related netex:SiteComponent .

netex:PointOfInterestVehicleEntrance a skos:Concept ;
    skos:prefLabel "point of interest vehicle entrance"@en ;
    skos:altLabel "pointofinterestvehicleentrance"@en ;
    skos:altLabel "vehicle entrance to a"@en ;
    rdfs:comment "A VEHICLE ENTRANCE to a POINT OF INTEREST."@en ;
    skos:related netex:Entrance .

netex:PointOnLineSection a skos:Concept ;
    skos:prefLabel "inclusion of a point on"@en ;
    skos:altLabel "point on line section"@en ;
    skos:altLabel "pointonlinesection"@en ;
    rdfs:comment "Inclusion of a POINT on a LINE SECTION. +v1.1"@en ;
    skos:related netex:Link, netex:Point .

netex:PointOnLink a skos:Concept ;
    skos:prefLabel "point on a link"@en ;
    skos:altLabel "point on link"@en ;
    skos:altLabel "pointonlink"@en ;
    rdfs:comment "A POINT on a LINK which is not needed for LINK definition, but may be used for other purposes, e.g. for purposes of AVM or PI, or for driver information."@en .

netex:PointOnRoute a skos:Concept ;
    skos:prefLabel "point on route"@en ;
    skos:altLabel "pointonroute"@en ;
    skos:altLabel "reference to a route"@en ;
    rdfs:comment "A reference to a ROUTE POINT used to define a ROUTE with its order on that ROUTE."@en ;
    skos:related netex:Extensions, netex:LinkSequence, netex:Point, netex:PointInLinkSequence .

netex:PointOnSection a skos:Concept ;
    skos:prefLabel "point on a section v11"@en ;
    skos:altLabel "point on section"@en ;
    skos:altLabel "pointonsection"@en ;
    rdfs:comment "POINT on a SECTION. +v1.1."@en ;
    skos:related netex:Link, netex:Point .

netex:PointProjection a skos:Concept ;
    skos:prefLabel "point projection"@en ;
    skos:altLabel "pointprojection"@en ;
    rdfs:comment "An oriented correspondence from one POINT of a source layer, onto a entity in a target layer: e.g. POINT, LINK, LINK SEQUENCE, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."@en ;
    skos:related netex:Projection .

netex:PoolOfVehicles a skos:Concept ;
    skos:prefLabel "pool of vehicles"@en ;
    skos:altLabel "poolofvehicles"@en ;
    skos:altLabel "set of vehicles assigned"@en ;
    rdfs:comment "A set of vehicles assigned to a specific PARKING, PARKING AREAs, PARKING BAYs, p lace or MOBILITY CONSTRAINT ZONE that must be picked up and returned to the same area. +v1.2.2"@en .

netex:PostalAddress a skos:Concept ;
    skos:prefLabel "postal address"@en ;
    skos:altLabel "postaladdress"@en ;
    rdfs:comment "A POSTAL ADDRESS to which mail can be sent."@en .

netex:PoweredTrain a skos:Concept ;
    skos:prefLabel "powered train"@en ;
    skos:altLabel "poweredtrain"@en ;
    skos:altLabel "train that is able"@en ;
    rdfs:comment "A TRAIN that is able to move under its own power. +v2.0"@en ;
    skos:related netex:TrainSize .

netex:PreassignedFareProduct a skos:Concept ;
    skos:prefLabel "fare product consisting of"@en ;
    skos:altLabel "preassigned fare product"@en ;
    skos:altLabel "preassignedfareproduct"@en ;
    rdfs:comment "A FARE PRODUCT consisting of one or several VALIDABLE ELEMENTs, specific to a CHARGING MOMENT."@en .

netex:PreviousCall a skos:Concept ;
    skos:prefLabel "already completed call of"@en ;
    skos:altLabel "previous call"@en ;
    skos:altLabel "previouscall"@en ;
    rdfs:comment "An already completed CALL of a VEHICLE JOURNEY that occurred earlier in the the JOURNEY PATTERN before the current stop."@en .

netex:PriceUnit a skos:Concept ;
    skos:prefLabel "price unit"@en ;
    skos:altLabel "priceunit"@en ;
    skos:altLabel "unit to express prices"@en ;
    rdfs:comment "A unit to express prices: amount of currency, abstract fare unit, ticket unit or token etc."@en ;
    skos:related netex:TypeOfValue .

netex:PriceableObject a skos:Concept ;
    skos:prefLabel "priceable object"@en ;
    skos:altLabel "priceableobject"@en ;
    rdfs:comment "An element that may have a FARE PRICE."@en .

netex:PricingParameterSet a skos:Concept ;
    skos:prefLabel "pricing parameter set"@en ;
    skos:altLabel "pricingparameterset"@en ;
    rdfs:comment "Parameters governing the calculation of fares."@en .

netex:PricingRule a skos:Concept ;
    skos:prefLabel "pricing rule"@en ;
    skos:altLabel "pricingrule"@en ;
    rdfs:comment "Parameters describing how a fare is to be computed."@en .

netex:PricingService a skos:Concept ;
    skos:prefLabel "pricing service"@en ;
    skos:altLabel "pricingservice"@en ;
    skos:altLabel "web service used to"@en ;
    rdfs:comment "A web service used to provide prices dynamically at time of booking or purchase."@en .

netex:Projection a skos:Concept ;
    skos:prefLabel "projection"@en ;
    rdfs:comment "An oriented correspondence - of the shape of an ENTITY on a source layer, - onto a ENTITY in a target layer: e.g. POINT, LINK, LINK SEQUENCE, COMPLEX FEATURE, - within a defined TYPE OF PROJECTION."@en .

netex:PropertyOfDay a skos:Concept ;
    skos:prefLabel "property of day"@en ;
    skos:altLabel "property which a day"@en ;
    skos:altLabel "propertyofday"@en ;
    rdfs:comment "A property which a day may possess, such as school holiday, weekday, summer, winter etc."@en .

netex:PurchaseWindow a skos:Concept ;
    skos:prefLabel "purchase window"@en ;
    skos:altLabel "purchasewindow"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer."@en .

netex:PurposeOfEquipmentProfile a skos:Concept ;
    skos:prefLabel "functional purpose which requires"@en ;
    skos:altLabel "purpose of equipment profile"@en ;
    skos:altLabel "purposeofequipmentprofile"@en ;
    rdfs:comment "A functional purpose which requires a certain set of EQUIPMENT of different types put together in a VEHICLE EQUIPMENT PROFILE or STOP POINT EQUIPMENT PROFILE."@en ;
    skos:related netex:TypeOfValue .

netex:PurposeOfGrouping a skos:Concept ;
    skos:prefLabel "functional purpose for which groups"@en ;
    skos:altLabel "purpose of grouping"@en ;
    skos:altLabel "purposeofgrouping"@en ;
    rdfs:comment "Functional purpose for which GROUPs of elements are defined. The PURPOSE OF GROUPING may be restricted to one or more types of the given object."@en ;
    skos:related netex:TypeOfValue .

netex:PurposeOfJourneyPartition a skos:Concept ;
    skos:prefLabel "operational purpose changing within"@en ;
    skos:altLabel "purpose of journey partition"@en ;
    skos:altLabel "purposeofjourneypartition"@en ;
    rdfs:comment "An operational purpose changing within a JOURNEY PATTERN and with this subdividing the SERVICE JOURNEY into JOURNEY PARTs."@en ;
    skos:related netex:TypeOfValue .

netex:QualityStructureFactor a skos:Concept ;
    skos:prefLabel "quality structure factor"@en ;
    skos:altLabel "qualitystructurefactor"@en ;
    skos:altLabel "value of a quality"@en ;
    rdfs:comment "The value of a QUALITY INTERVAL or a DISTANCE MATRIX ELEMENT expressed by a QUALITY UNIT."@en .

netex:QualityStructureFactorPrice a skos:Concept ;
    skos:prefLabel "quality structure factor price"@en ;
    skos:altLabel "qualitystructurefactorprice"@en ;
    rdfs:comment "A set of all possible price features of a QUALITY STRUCTURE FACTOR: default total price etc."@en .

netex:Quay a skos:Concept ;
    skos:prefLabel "quay"@en ;
    rdfs:comment "A place such as platform, stance, or quayside where passengers have access to PT vehicles, Taxi cars or other means of transportation. A QUAY may contain other sub QUAYs. A child QUAY must be physically contained within its parent QUAY."@en ;
    skos:related netex:StopPlaceSpace .

netex:QueueingEquipment a skos:Concept ;
    skos:prefLabel "queueing equipment"@en ;
    skos:altLabel "queueingequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT dedicated to queuing."@en ;
    skos:related netex:AccessEquipment .

netex:RailSubmode a skos:Concept ;
    skos:prefLabel "rail submode"@en ;
    skos:altLabel "railsubmode"@en ;
    skos:altLabel "tpeg pti02 rail submodes loc13"@en ;
    rdfs:comment "TPEG pti02 Rail submodes loc13. See also See ERA B.4.7009 - Name: Item description code."@en .

netex:RailwayElement a skos:Concept ;
    skos:prefLabel "railway element"@en ;
    skos:altLabel "railwayelement"@en ;
    rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a RAILWAY network."@en .

netex:RailwayJunction a skos:Concept ;
    skos:prefLabel "railway junction"@en ;
    skos:altLabel "railwayjunction"@en ;
    rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a RAILWAY network."@en ;
    skos:related netex:InfrastructurePoint .

netex:RampEquipment a skos:Concept ;
    skos:prefLabel "ramp equipment"@en ;
    skos:altLabel "rampequipment"@en ;
    skos:altLabel "specialisation of place access equipment"@en ;
    rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT for ramps (provides ramp characteristics like length, gradient, etc.)."@en ;
    skos:related netex:AccessEquipment .

netex:RampFreeAccess a skos:Concept ;
    skos:prefLabel "ramp free access"@en ;
    skos:altLabel "rampfreeaccess"@en ;
    skos:altLabel "whether a place has ramp"@en ;
    rdfs:comment "Whether a PLACE has ramp free access. Ramp free isn't necessary absolute. If a ramp is not steep, then a PLACE can still be considered ramp free."@en .

netex:RechargingBay a skos:Concept ;
    skos:prefLabel "parking bay specifically equipped"@en ;
    skos:altLabel "recharging bay"@en ;
    skos:altLabel "rechargingbay"@en ;
    rdfs:comment "A PARKING BAY specifically equipped for recharging VEHICLEs. +v2.0"@en .

netex:RechargingEquipmentProfile a skos:Concept ;
    skos:prefLabel "recharging equipment profile"@en ;
    skos:altLabel "rechargingequipmentprofile"@en ;
    skos:altLabel "specialisation of vehicle equipment profile"@en ;
    rdfs:comment "Specialisation of VEHICLE EQUIPMENT PROFILE describing vehicle charging features."@en .

netex:RechargingPlan a skos:Concept ;
    skos:prefLabel "plan for periodically charging"@en ;
    skos:altLabel "recharging plan"@en ;
    skos:altLabel "rechargingplan"@en ;
    rdfs:comment "A plan for periodically charging a VEHICLE while executing a BLOCK or BLOCKs. +v2.0"@en .

netex:RechargingPointAssignment a skos:Concept ;
    skos:prefLabel "recharging point assignment"@en ;
    skos:altLabel "rechargingpointassignment"@en ;
    rdfs:comment "The allocation of a TIMING POINT to a SITE COMPONENT such as a PARKING BAY that has VEHICLE CHARGING EQUIPMENT. +v2.0"@en .

netex:RechargingStation a skos:Concept ;
    skos:prefLabel "recharging station"@en ;
    skos:altLabel "rechargingstation"@en ;
    rdfs:comment "A PARKING with bays specifically equipped for recharging VEHICLEs. +v2.0"@en .

netex:RechargingStep a skos:Concept ;
    skos:prefLabel "recharging step"@en ;
    skos:altLabel "rechargingstep"@en ;
    rdfs:comment "The planned charging of a VEHICLE at a PARKING POINT on a specific VEHICLE JOURNEY. +v2.0"@en ;
    skos:related netex:Journey, netex:PointInJourneyPattern, netex:RechargingEquipmentProfile, netex:VehicleChargingEquipment .

netex:RelatedOrganisation a skos:Concept ;
    skos:prefLabel "related organisation"@en ;
    skos:altLabel "relatedorganisation"@en ;
    rdfs:comment "A formal relationship with another ORGANISATION. +v1.2.2"@en .

netex:ReliefOpportunity a skos:Concept ;
    skos:prefLabel "relief opportunity"@en ;
    skos:altLabel "reliefopportunity"@en ;
    rdfs:comment "A time in a BLOCK where a vehicle passes a RELIEF POINT. This opportunity may or may not be actually used for a relief."@en .

netex:ReliefPoint a skos:Concept ;
    skos:prefLabel "relief point"@en ;
    skos:altLabel "reliefpoint"@en ;
    skos:altLabel "timing point where a"@en ;
    rdfs:comment "A TIMING POINT where a relief is possible, i.e. a driver may take on or hand over a vehicle. The vehicle may sometimes be left unattended."@en .

netex:RentalAvailability a skos:Concept ;
    skos:prefLabel "rental availability"@en ;
    skos:altLabel "rentalavailability"@en ;
    rdfs:comment "A summary of the status of the rental at a SITE at a given point on time. +v1.2.2"@en .

netex:RentalOption a skos:Concept ;
    skos:prefLabel "rental option"@en ;
    skos:altLabel "rentaloption"@en ;
    rdfs:comment "Parameters relating to paying by RentalOption for a product. +v1.1"@en .

netex:RentalPenaltyPolicy a skos:Concept ;
    skos:prefLabel "policy regarding different aspects of"@en ;
    skos:altLabel "rental penalty policy"@en ;
    skos:altLabel "rentalpenaltypolicy"@en ;
    rdfs:comment "Policy regarding different aspects of RENTAL service penalty charges, for example loss of vehicle. +v1.2.2"@en .

netex:Replacing a skos:Concept ;
    skos:prefLabel "replacing"@en ;
    rdfs:comment "Whether the product can be replaced if lost or stolen."@en .

netex:RequestedTravelSpecification a skos:Concept ;
    skos:prefLabel "recording of a specification"@en ;
    skos:altLabel "requested travel specification"@en ;
    skos:altLabel "requestedtravelspecification"@en ;
    rdfs:comment "The recording of a specification by a customer of parameters giving details of an intended consumption (e.g. origin and destination of a travel)."@en .

netex:Reselling a skos:Concept ;
    skos:prefLabel "reselling"@en ;
    rdfs:comment "Common resale conditions (i.e. for exchange or refund) attaching to the product"@en .

netex:ReservedSpaceFacility a skos:Concept ;
    skos:prefLabel "classification of reserved space facility"@en ;
    skos:altLabel "reserved space facility"@en ;
    skos:altLabel "reservedspacefacility"@en ;
    rdfs:comment "Classification of RESERVED SPACE FACILITY."@en .

netex:ReservedSpaceFacilityList a skos:Concept ;
    skos:prefLabel "list of reserved space facilities"@en ;
    skos:altLabel "reserved space facility list"@en ;
    skos:altLabel "reservedspacefacilitylist"@en ;
    rdfs:comment "List of RESERVED SPACE FACILITies."@en .

netex:Reserving a skos:Concept ;
    skos:prefLabel "reserving"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer."@en .

netex:ResidentialQualification a skos:Concept ;
    skos:prefLabel "residential qualification"@en ;
    skos:altLabel "residentialqualification"@en ;
    rdfs:comment "The number and characteristics (weight, volume) of luggage that a holder of an access right is entitled to carry."@en .

netex:ResidentialQualificationEligibility a skos:Concept ;
    skos:prefLabel "residential qualification eligibility"@en ;
    skos:altLabel "residentialqualificationeligibility"@en ;
    rdfs:comment "Whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific RESIDENTIAL QUALIFICATION as a validity parameter."@en .

netex:ResourceFrame a skos:Concept ;
    skos:prefLabel "resource frame"@en ;
    skos:altLabel "resourceframe"@en ;
    rdfs:comment "A coherent set of reference values for TYPE OF VALUEs , ORGANISATIONs, VEHICLE TYPEs etc that have a common validity, as specified by a set of frame VALIDITY CONDITIONs. Used to define common resources that will be referenced by other types of FRAME."@en .

netex:ResponsibilitySet a skos:Concept ;
    skos:prefLabel "responsibility set"@en ;
    skos:altLabel "responsibilityset"@en ;
    skos:altLabel "set of responsibility roles"@en ;
    rdfs:comment "A set of responsibility roles assignments that can be associated with a DATA MANAGED OBJECT. A Child ENTITY has the same responsibilities as its parent."@en .

netex:RestrictedManoeuvre a skos:Concept ;
    skos:prefLabel "restricted manoeuvre"@en ;
    skos:altLabel "restrictedmanoeuvre"@en ;
    rdfs:comment "A specification of a move for a certain type of vehicle. It specifies from which INFRASTRUCTURE LINK to which other (adjacent) INFRASTRUCTURE LINK a certain can or cannot VEHICLE TYPE cannot proceed, due to physical restrictions."@en ;
    skos:related netex:NetworkRestriction .

netex:RestrictedServiceFacilitySet a skos:Concept ;
    skos:prefLabel "restricted service facility set"@en ;
    skos:altLabel "restricted service facility the restriction"@en ;
    skos:altLabel "restrictedservicefacilityset"@en ;
    rdfs:comment "Restricted Service FACILITY. The restriction can be an AvailabilityCondition and/or a From - To relation. +v2.0"@en ;
    skos:related netex:FacilitySet .

netex:RetailConsortium a skos:Concept ;
    skos:prefLabel "retail consortium"@en ;
    skos:altLabel "retailconsortium"@en ;
    rdfs:comment "A group of ORGANISATIONs formally incorporated as a retailer of fare products."@en .

netex:RetailDevice a skos:Concept ;
    skos:prefLabel "retail device"@en ;
    skos:altLabel "retail device used to"@en ;
    skos:altLabel "retaildevice"@en ;
    rdfs:comment "A retail device used to sell fare products. Can be used to record fulfilment."@en ;
    skos:related netex:InstalledEquipment .

netex:RetailDeviceSecurityListing a skos:Concept ;
    skos:prefLabel "listing of a retail"@en ;
    skos:altLabel "retail device security listing"@en ;
    skos:altLabel "retaildevicesecuritylisting"@en ;
    rdfs:comment "A listing of a RETAIL DEVICE on a sSECURITY LIST."@en .

netex:RetailFacility a skos:Concept ;
    skos:prefLabel "classification of retail facility"@en ;
    skos:altLabel "retail facility"@en ;
    skos:altLabel "retailfacility"@en ;
    rdfs:comment "Classification of RETAIL FACILITY."@en .

netex:RetailFacilityList a skos:Concept ;
    skos:prefLabel "list of retail facilities"@en ;
    skos:altLabel "retail facility list"@en ;
    skos:altLabel "retailfacilitylist"@en ;
    rdfs:comment "List of RETAIL FACILITies."@en .

netex:RetailService a skos:Concept ;
    skos:prefLabel "retail service"@en ;
    skos:altLabel "retailservice"@en ;
    skos:altLabel "specialisation of local service dedicated"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE dedicated to retail services."@en ;
    skos:related netex:LocalService .

netex:Review a skos:Concept ;
    skos:prefLabel "review"@en ;
    skos:altLabel "review of a diver"@en ;
    rdfs:comment "A review of a diver or of a traveller. +v2.0"@en .

netex:RoadAddress a skos:Concept ;
    skos:prefLabel "road address"@en ;
    skos:altLabel "roadaddress"@en ;
    skos:altLabel "specialisation of address refining it"@en ;
    rdfs:comment "Specialisation of ADDRESS refining it by using the characteristics such as road number, and name used for conventional identification of along a road."@en .

netex:RoadElement a skos:Concept ;
    skos:prefLabel "road element"@en ;
    skos:altLabel "roadelement"@en ;
    rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a ROAD network."@en .

netex:RoadJunction a skos:Concept ;
    skos:prefLabel "road junction"@en ;
    skos:altLabel "roadjunction"@en ;
    rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a ROAD network."@en ;
    skos:related netex:InfrastructurePoint .

netex:RoadVehicleMode a skos:Concept ;
    skos:prefLabel "road vehicle mode"@en ;
    skos:altLabel "road vehicle mode a characterisation"@en ;
    skos:altLabel "roadvehiclemode"@en ;
    rdfs:comment "Road Vehicle MODE: a characterisation of the operation according to the means of transport (bus, tram, coach)."@en .

netex:RollingStockInventory a skos:Concept ;
    skos:prefLabel "collection of rolling stock"@en ;
    skos:altLabel "rolling stock inventory"@en ;
    skos:altLabel "rollingstockinventory"@en ;
    rdfs:comment "A collection of rolling stock of any type used to assemble trains. +v.2.0"@en .

netex:RollingStockItem a skos:Concept ;
    skos:prefLabel "rolling stock item"@en ;
    skos:altLabel "rollingstockitem"@en ;
    rdfs:comment "A specific instance of an elementary unit of rolling stock (e.g., railcar, wagon, locomotive). Its properties are given by a TRAIN ELEMENT TYPE."@en .

netex:RoughSurface a skos:Concept ;
    skos:prefLabel "rough surface"@en ;
    skos:altLabel "roughsurface"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for rough surfaces, giving properties of surface texture, mainly for impaired person information."@en ;
    skos:related netex:AccessEquipment .

netex:RoundTrip a skos:Concept ;
    skos:prefLabel "round trip"@en ;
    skos:altLabel "roundtrip"@en ;
    rdfs:comment "Properties relating to single or return trip use of a fare."@en .

netex:Rounding a skos:Concept ;
    skos:prefLabel "rounding"@en ;
    rdfs:comment "Parameters describing how the results of calculations are to be rounded to the nearest quantum."@en .

netex:RoundingStep a skos:Concept ;
    skos:prefLabel "rounding step"@en ;
    skos:altLabel "rounding step to use"@en ;
    skos:altLabel "roundingstep"@en ;
    rdfs:comment "A rounding step to use to round a range of values. Any value larger than the step key and smaller tha the next step key should be rounded to this value."@en .

netex:Route a skos:Concept ;
    skos:prefLabel "route"@en ;
    rdfs:comment "An ordered list of located POINTs defining one single path through the Road (or rail) network. A ROUTE may pass through the same POINT more than once."@en .

netex:RouteInstruction a skos:Concept ;
    skos:prefLabel "instruction on how to"@en ;
    skos:altLabel "route instruction"@en ;
    skos:altLabel "routeinstruction"@en ;
    rdfs:comment "An Instruction on how to follow a ROUTE through the network."@en .

netex:RouteLink a skos:Concept ;
    skos:prefLabel "oriented link between two"@en ;
    skos:altLabel "route link"@en ;
    skos:altLabel "routelink"@en ;
    rdfs:comment "An oriented link between two ROUTE POINTs allowing the definition of a unique path through the network. Because ROUTE LINKs are directional there will be separate links for each direction of a route."@en ;
    skos:related netex:Link .

netex:RoutePoint a skos:Concept ;
    skos:prefLabel "point used to define"@en ;
    skos:altLabel "route point"@en ;
    skos:altLabel "routepoint"@en ;
    rdfs:comment "A POINT used to define the shape of a ROUTE through the network."@en ;
    skos:related netex:Point .

netex:Routing a skos:Concept ;
    skos:prefLabel "routing"@en ;
    rdfs:comment "Limitations on routing of a fare."@en .

netex:RoutingConstraintZone a skos:Concept ;
    skos:prefLabel "constraint on the use"@en ;
    skos:altLabel "routing constraint zone"@en ;
    skos:altLabel "routingconstraintzone"@en ;
    rdfs:comment "A constraint on the use of a service. The service, on this specific JOURNEY PATTERN (usually a FTS JOURNEY PATTERN) cannot operate when another (regular) service operates. This may occur only on subpart of the JOURNEY PATTERN, or only on one or some specific SCHEDULED STOP POINTs within the pattern."@en ;
    skos:related netex:Zone .

netex:RubbishDisposalEquipment a skos:Concept ;
    skos:prefLabel "equipment for passengers relating to"@en ;
    skos:altLabel "rubbish disposal equipment"@en ;
    skos:altLabel "rubbishdisposalequipment"@en ;
    rdfs:comment "Equipment for Passengers relating to a Rubbish disposal."@en ;
    skos:related netex:PassengerEquipment .

netex:SafetyFacility a skos:Concept ;
    skos:prefLabel "classification of safety facility type"@en ;
    skos:altLabel "safety facility"@en ;
    skos:altLabel "safetyfacility"@en ;
    rdfs:comment "Classification of SAFETY FACILITY type - TPEG pti23."@en .

netex:SafetyFacilityList a skos:Concept ;
    skos:prefLabel "list of safety facilities"@en ;
    skos:altLabel "safety facility list"@en ;
    skos:altLabel "safetyfacilitylist"@en ;
    rdfs:comment "List of SAFETY FACILITies."@en .

netex:SaleDiscountRight a skos:Concept ;
    skos:prefLabel "sale discount right"@en ;
    skos:altLabel "salediscountright"@en ;
    rdfs:comment "A FARE PRODUCT allowing a customer to benefit from discounts when purchasing SALES OFFER PACKAGEs."@en .

netex:SalesNoticeAssignment a skos:Concept ;
    skos:prefLabel "assignment of a notice"@en ;
    skos:altLabel "sales notice assignment"@en ;
    skos:altLabel "salesnoticeassignment"@en ;
    rdfs:comment "The assignment of a NOTICE to a SALES OFFER PACKAGE or a GROUP OF SALES OFFER PACKAGEs."@en .

netex:SalesOfferPackage a skos:Concept ;
    skos:prefLabel "package to be sold"@en ;
    skos:altLabel "sales offer package"@en ;
    skos:altLabel "salesofferpackage"@en ;
    rdfs:comment "A package to be sold as a whole, consisting of one or several FARE PRODUCTs materialised thanks to one or several TRAVEL DOCUMENTs. The FARE PRODUCTs may be either directly attached to the TRAVEL DOCUMENTs, or may be reloadable on the TRAVEL DOCUMENTs."@en .

netex:SalesOfferPackageElement a skos:Concept ;
    skos:prefLabel "sales offer package element"@en ;
    skos:altLabel "salesofferpackageelement"@en ;
    rdfs:comment "The assignment of a FARE PRODUCT to a TYPE OF TRAVEL DOCUMENT in order to define a SALES OFFER PACKAGE, realised as a fixed assignment (printing, magnetic storage etc.) or by the possibility for the FARE PRODUCT to be reloaded on the TYPE OF TRAVEL DOCUMENT."@en ;
    skos:related netex:PriceableObject .

netex:SalesOfferPackageEntitlementGiven a skos:Concept ;
    skos:prefLabel "right to a sales"@en ;
    skos:altLabel "sales offer package entitlement given"@en ;
    skos:altLabel "salesofferpackageentitlementgiven"@en ;
    rdfs:comment "A right to a SALES OFFER PACKAGE given by a SALES OFFER PACKAGE ."@en .

netex:SalesOfferPackageEntitlementRequired a skos:Concept ;
    skos:prefLabel "rerirement to a sales"@en ;
    skos:altLabel "sales offer package entitlement required"@en ;
    skos:altLabel "salesofferpackageentitlementrequired"@en ;
    rdfs:comment "A rerirement to a SALES OFFER PACKAGE in order to purchase or use PRODUCT."@en .

netex:SalesOfferPackagePrice a skos:Concept ;
    skos:prefLabel "sales offer package price"@en ;
    skos:altLabel "salesofferpackageprice"@en ;
    rdfs:comment "A set of all possible price features of a SALES OFFER PACKAGE ELEMENT: default total price, discount in value or percentage etc."@en .

netex:SalesOfferPackageSubstitution a skos:Concept ;
    skos:prefLabel "sales offer package substitution"@en ;
    skos:altLabel "salesofferpackagesubstitution"@en ;
    rdfs:comment "A particular tariff, described by a combination of parameters."@en .

netex:SalesTransaction a skos:Concept ;
    skos:prefLabel "sales transaction"@en ;
    skos:altLabel "salestransaction"@en ;
    rdfs:comment "A SALE OF a FIXED PACKAGE or a SALE OF a RELOADABLE PACKAGE."@en .

netex:SalesTransactionFrame a skos:Concept ;
    skos:prefLabel "sales transaction frame"@en ;
    skos:altLabel "salestransactionframe"@en ;
    rdfs:comment "A coherent set of Vehicle Scheduling data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:SanitaryEquipment a skos:Concept ;
    skos:prefLabel "sanitary equipment"@en ;
    skos:altLabel "sanitary facility eg"@en ;
    skos:altLabel "sanitaryequipment"@en ;
    rdfs:comment "A SANITARY FACILITY , e.g. WC, Shower, baby change."@en ;
    skos:related netex:PassengerEquipment .

netex:SanitaryFacility a skos:Concept ;
    skos:prefLabel "classification of sanitary facility type"@en ;
    skos:altLabel "sanitary facility"@en ;
    skos:altLabel "sanitaryfacility"@en ;
    rdfs:comment "Classification of Sanitary FACILITY type - TPEG pti23."@en .

netex:SanitaryFacilityList a skos:Concept ;
    skos:prefLabel "list of sanitary facilities"@en ;
    skos:altLabel "sanitary facility list"@en ;
    skos:altLabel "sanitaryfacilitylist"@en ;
    rdfs:comment "List of SANITARY FACILITies."@en .

netex:ScheduledOperation a skos:Concept ;
    skos:prefLabel "operation of a transportation"@en ;
    skos:altLabel "scheduled operation"@en ;
    skos:altLabel "scheduledoperation"@en ;
    rdfs:comment "The operation of a transportation using any kind of vehicle with a predefined time table. +v1.2.2"@en .

netex:ScheduledStopPoint a skos:Concept ;
    skos:prefLabel "scheduled stop point"@en ;
    skos:altLabel "stoppoint"@en ;
    skos:altLabel "stop"@en ;
    skos:altLabel "scheduled stop"@en ;
    rdfs:comment "A location where a vehicle is scheduled to stop for passengers"@en ;
    skos:related datex:TrafficEvent, netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:AverageCommercialSpeed, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExpectedPassengerCount, opra:ExpectedServiceIntensity, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:LateDatedVehicleJourneyEntry, opra:LoadOverJourneyDistance, opra:MeanCapacityOverJourneyDistance, opra:MeanCapacityOverNetworkDistance, opra:MeanCapacityOverRouteDistance, opra:PlannedCapacity, opra:PreparednessLevel, opra:TransportPerformance, opra:TransportPerformancePerVehicle, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

netex:SchematicMap a skos:Concept ;
    skos:prefLabel "schematic map"@en ;
    skos:altLabel "schematicmap"@en ;
    rdfs:comment "A projection of a set of ENTITies onto a bitmap image so as to support hyperlinked interactions."@en .

netex:ScopeOfTicket a skos:Concept ;
    skos:prefLabel "classification of scopes of ticket"@en ;
    skos:altLabel "scope of ticket"@en ;
    skos:altLabel "scopeofticket"@en ;
    rdfs:comment "Classification of SCOPEs of TICKET, eg national international."@en .

netex:SeatEquipment a skos:Concept ;
    skos:prefLabel "seat equipment"@en ;
    skos:altLabel "seatequipment"@en ;
    skos:altLabel "specialisation of spot equipment"@en ;
    rdfs:comment "A specialisation of SPOT EQUIPMENT describing the detailed properties of a seat. +v2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:SeatingEquipment a skos:Concept ;
    skos:prefLabel "seating equipment"@en ;
    skos:altLabel "seatingequipment"@en ;
    skos:altLabel "specialisation of waiting equipment describing"@en ;
    rdfs:comment "Specialisation of WAITING EQUIPMENT describing the properties of seating."@en ;
    skos:related netex:SiteEquipment .

netex:Section a skos:Concept ;
    skos:prefLabel "section"@en ;
    rdfs:comment "A shared sequence of LINKS or POINTs. +v1.1."@en .

netex:SecurityList a skos:Concept ;
    skos:prefLabel "list of items whose"@en ;
    skos:altLabel "security list"@en ;
    skos:altLabel "securitylist"@en ;
    rdfs:comment "A list of items whose status is to be accepted or denied for a process such as purchase or validation."@en .

netex:SecurityListing a skos:Concept ;
    skos:prefLabel "security listing"@en ;
    skos:altLabel "securitylisting"@en ;
    rdfs:comment "The presence of an identified Entity on a SECURITY LIST."@en .

netex:SelfDriveSubmode a skos:Concept ;
    skos:prefLabel "self drive submode"@en ;
    skos:altLabel "selfdrivesubmode"@en ;
    rdfs:comment "TPEG pti12 SelfDrive submodes. (NB Use SimpleVehicleType / Vehicle Category to describe specific type)"@en .

netex:SensorEquipment a skos:Concept ;
    skos:prefLabel "equipment used to monitor"@en ;
    skos:altLabel "sensor equipment"@en ;
    skos:altLabel "sensorequipment"@en ;
    rdfs:comment "An EQUIPMENT used to monitor use of a space or entrance. +V2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:SensorInEntrance a skos:Concept ;
    skos:prefLabel "sensor in entrance"@en ;
    skos:altLabel "sensorinentrance"@en ;
    skos:altLabel "use of a specific entrance"@en ;
    rdfs:comment "Use of a specific ENTRANCE SENSOR to monitor a specific DECK ENTRANCE. +v2.0"@en .

netex:SensorInSpot a skos:Concept ;
    skos:prefLabel "sensor in spot"@en ;
    skos:altLabel "sensorinspot"@en ;
    skos:altLabel "use of a specific spot"@en ;
    rdfs:comment "Use of a specific SPOT SENSOR to monitor a specific LOCATABLE SPOT. +v2.0"@en .

netex:SeriesConstraint a skos:Concept ;
    skos:prefLabel "series constraint"@en ;
    skos:altLabel "seriesconstraint"@en ;
    rdfs:comment "A particular tariff, described by a combination of parameters."@en .

netex:SeriesConstraintPrice a skos:Concept ;
    skos:prefLabel "series constraint price"@en ;
    skos:altLabel "seriesconstraintprice"@en ;
    rdfs:comment "A set of all possible price features of a SERIES CONSTRAINT: default total price, discount in value or percentage etc."@en .

netex:ServiceAccessRight a skos:Concept ;
    skos:prefLabel "service access right"@en ;
    skos:altLabel "serviceaccessright"@en ;
    rdfs:comment "An immaterial marketable element dedicated to accessing some services."@en .

netex:ServiceBookingArrangement a skos:Concept ;
    skos:prefLabel "service booking arrangement"@en ;
    skos:altLabel "servicebookingarrangement"@en ;
    rdfs:comment "Type for a SERVICE BOOKING ARRANGEMENT."@en .

netex:ServiceCalendar a skos:Concept ;
    skos:prefLabel "service calendar"@en ;
    skos:altLabel "service calendar a collection"@en ;
    skos:altLabel "servicecalendar"@en ;
    rdfs:comment "A SERVICE CALENDAR. A collection of DAY TYPE ASSIGNMENTs."@en .

netex:ServiceCalendarFrame a skos:Concept ;
    skos:prefLabel "service calendar a coherent"@en ;
    skos:altLabel "service calendar frame"@en ;
    skos:altLabel "servicecalendarframe"@en ;
    rdfs:comment "A SERVICE CALENDAR. A coherent set of OPERATING DAYS and DAY TYPES comprising a Calendar. That may be used to state the temporal VALIDITY of other NeTEx entities such as Timetables, STOP PLACEs, etc. Covers a PERIOD with a collection of assignments of OPERATING DAYS to DAY TYPES."@en .

netex:ServiceDesignator a skos:Concept ;
    skos:prefLabel "service designator"@en ;
    skos:altLabel "servicedesignator"@en ;
    skos:altLabel "value reference to a service"@en ;
    rdfs:comment "Value reference to a SERVICE JOURNEY. Provides an alternative way of identifying a Journey between SCHEDULED STOP POINTS"@en .

netex:ServiceExclusion a skos:Concept ;
    skos:prefLabel "service exclusion"@en ;
    skos:altLabel "serviceexclusion"@en ;
    rdfs:comment "A constraint on the use of a service. The service, on this specific JOURNEY PATTERN (usually a FTS JOURNEY PATTERN) cannot operate when another (regular) service operates. This may occur only on subpart of the JOURNEY PATTERN, or only on one or some specific SCHEDULED STOP POINTs within the pattern."@en .

netex:ServiceFacilitySet a skos:Concept ;
    skos:prefLabel "service facility set"@en ;
    skos:altLabel "service facility set of enumerated"@en ;
    skos:altLabel "servicefacilityset"@en ;
    rdfs:comment "Service FACILITY. Set of enumerated FACILITY values (Where available names are based on TPEG classifications, augmented with UIC etc.)."@en ;
    skos:related netex:FacilitySet .

netex:ServiceFrame a skos:Concept ;
    skos:prefLabel "coherent set of service"@en ;
    skos:altLabel "service frame"@en ;
    skos:altLabel "serviceframe"@en ;
    rdfs:comment "A coherent set of Service data to which the same frame VALIDITY CONDITIONs have been assigned."@en .

netex:ServiceJourney a skos:Concept ;
    skos:prefLabel "passenger carrying vehicle journey"@en ;
    skos:altLabel "service journey"@en ;
    skos:altLabel "servicejourney"@en ;
    rdfs:comment "A passenger carrying VEHICLE JOURNEY for one specified DAY TYPE. The pattern of working is in principle defined by a SERVICE JOURNEY PATTERN. The VIEW includes derived ancillary data from referenced entities."@en .

netex:ServiceJourneyInterchange a skos:Concept ;
    skos:prefLabel "service journey interchange"@en ;
    skos:altLabel "servicejourneyinterchange"@en ;
    rdfs:comment "The scheduled possibility for transfer of passengers between two SERVICE JOURNEYs at the same or different STOP POINTs."@en .

netex:ServiceJourneyPattern a skos:Concept ;
    skos:prefLabel "journey pattern for a"@en ;
    skos:altLabel "service journey pattern"@en ;
    skos:altLabel "servicejourneypattern"@en ;
    rdfs:comment "The JOURNEY PATTERN for a (passenger carrying) SERVICE JOURNEY."@en .

netex:ServiceJourneyPatternInterchange a skos:Concept ;
    skos:prefLabel "service journey pattern interchange"@en ;
    skos:altLabel "servicejourneypatterninterchange"@en ;
    rdfs:comment "A recognised/organised possibility for passengers to change public transport vehicles using two STOP POINTs (which may be identical) on two particular SERVICE JOURNEY PATTERNs, including the maximum wait duration allowed and the standard to be aimed at. These may supersede the times given for the DEFAULT INTERCHANGE. Schedulers may use this entity for synchronisation of journeys."@en .

netex:ServiceLink a skos:Concept ;
    skos:prefLabel "link between an ordered"@en ;
    skos:altLabel "service link"@en ;
    skos:altLabel "servicelink"@en ;
    rdfs:comment "A LINK between an ordered pair of STOP POINTs. Service links are directional - there will be separate links for each direction of a route."@en ;
    skos:related netex:Link .

netex:ServiceLinkInJourneyPattern a skos:Concept ;
    skos:prefLabel "service link in journey pattern"@en ;
    skos:altLabel "servicelinkinjourneypattern"@en ;
    skos:altLabel "use of a service"@en ;
    rdfs:comment "The use of a SERVICE LINK in a specified order. within a JOURNEY PATTERN or SERVICE PATTERN."@en ;
    skos:related netex:LinkInLinkSequence .

netex:ServicePattern a skos:Concept ;
    skos:prefLabel "service pattern"@en ;
    skos:altLabel "servicepattern"@en ;
    rdfs:comment "The subset of a JOURNEY PATTERN made up only of STOP POINTs IN JOURNEY PATTERN."@en ;
    skos:related netex:LinkSequence .

netex:ServiceReservationFacility a skos:Concept ;
    skos:prefLabel "classification of reservation facility type"@en ;
    skos:altLabel "service reservation facility"@en ;
    skos:altLabel "servicereservationfacility"@en ;
    rdfs:comment "Classification of RESERVATION FACILITY type - UIC 7037 Code list."@en .

netex:ServiceReservationFacilityList a skos:Concept ;
    skos:prefLabel "list of reservation facilities uic"@en ;
    skos:altLabel "service reservation facility list"@en ;
    skos:altLabel "servicereservationfacilitylist"@en ;
    rdfs:comment "List of RESERVATION FACILITies UIC 7037 Code list."@en .

netex:ServiceSite a skos:Concept ;
    skos:prefLabel "service site"@en ;
    skos:altLabel "servicesite"@en ;
    rdfs:comment "A sub-type of SITE which is of specific interest for the operator (e.g. where a joint service or a joint fee is proposed)."@en ;
    skos:related netex:Site .

netex:ServicedOrganisation a skos:Concept ;
    skos:prefLabel "organisation for which service is"@en ;
    skos:altLabel "serviced organisation"@en ;
    skos:altLabel "servicedorganisation"@en ;
    rdfs:comment "ORGANISATION for which Service is provided, e.g. school college."@en .

netex:ShelterEquipment a skos:Concept ;
    skos:prefLabel "shelter equipment"@en ;
    skos:altLabel "shelterequipment"@en ;
    skos:altLabel "specialisation of waiting equipment for"@en ;
    rdfs:comment "Specialisation of WAITING EQUIPMENT for a SHELTER."@en ;
    skos:related netex:SiteEquipment .

netex:SignEquipment a skos:Concept ;
    skos:prefLabel "sign equipment"@en ;
    skos:altLabel "signequipment"@en ;
    skos:altLabel "specialisation of place equipment for"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for signs (heading signs, etc.)."@en ;
    skos:related netex:PlaceEquipment .

netex:SimpleAvailabilityCondition a skos:Concept ;
    skos:prefLabel "simple availability condition"@en ;
    skos:altLabel "simple version of an availability"@en ;
    skos:altLabel "simpleavailabilitycondition"@en ;
    rdfs:comment "Simple version of an AVAILABILITY CONDITION used in order to characterise a given VERSION of a VERSION FRAME. Comprises a simple period and DAY TYPE."@en .

netex:SimpleFeature a skos:Concept ;
    skos:prefLabel "simple feature"@en ;
    skos:altLabel "simplefeature"@en ;
    rdfs:comment "An abstract representation of elementary objects related to the spatial representation of the network POINTs (0-dimensional objects), LINKs (1-dimensional objects) and ZONEs (2-dimensional objects) may be viewed as SIMPLE FEATUREs."@en ;
    skos:related netex:Zone .

netex:SimpleValidityCondition a skos:Concept ;
    skos:prefLabel "simple validity condition"@en ;
    skos:altLabel "simplevaliditycondition"@en ;
    rdfs:comment "OPTIMISATION Simple version of a VALIDITY CONDITION used in order to characterise a given VERSION of a VERSION FRAME. Comprises a simple period.Deprecated."@en .

netex:SingleJourney a skos:Concept ;
    skos:prefLabel "single journey"@en ;
    skos:altLabel "singlejourney"@en ;
    rdfs:comment "The planned movement of a public transport vehicle on a DAY TYPE from the start point to the end point of a JOURNEY PATTERN on a specified ROUTE. +v1.2.2"@en .

netex:SingleJourneyPath a skos:Concept ;
    skos:prefLabel "single journey path"@en ;
    skos:altLabel "singlejourneypath"@en ;
    rdfs:comment "The planned movement of a public transport vehicle on a DAY TYPE from the start point to the end point of a JOURNEY PATTERN on a specified ROUTE. +v1.2.2"@en ;
    skos:related netex:LinkSequence .

netex:Site a skos:Concept ;
    skos:prefLabel "site"@en ;
    rdfs:comment "A type of PLACE, such as a STOP PLACE, POINT OF INTEREST or ADDRESS, to which passengers may wish to travel."@en ;
    skos:related netex:SiteElement .

netex:SiteComponent a skos:Concept ;
    skos:prefLabel "element of a site"@en ;
    skos:altLabel "site component"@en ;
    skos:altLabel "sitecomponent"@en ;
    rdfs:comment "An element of a SITE describing part of its structure. SITE COMPONENTs share common properties for accessibility and other features."@en ;
    skos:related netex:SiteElement .

netex:SiteConnection a skos:Concept ;
    skos:prefLabel "site connection"@en ;
    skos:altLabel "siteconnection"@en ;
    rdfs:comment "The physical (spatial) possibility to connect from one point to another in a SITE."@en ;
    skos:related netex:Transfer .

netex:SiteElement a skos:Concept ;
    skos:prefLabel "site element"@en ;
    skos:altLabel "siteelement"@en ;
    rdfs:comment "A physical PLACE to which passengers may go. May have ACCESSIBILITY ASSESMENT and other properties to describe it."@en ;
    skos:related netex:Place .

netex:SiteEquipment a skos:Concept ;
    skos:prefLabel "site equipment"@en ;
    skos:altLabel "siteequipment"@en ;
    skos:altLabel "specialisation of place equipment for"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for SITEs (e.g. LUGGAGE LOCKER, WAITING EQUIPMENT, TROLLEY STAND, etc.)"@en ;
    skos:related netex:PlaceEquipment .

netex:SiteFacilitySet a skos:Concept ;
    skos:prefLabel "set of enumerated facility values"@en ;
    skos:altLabel "site facility set"@en ;
    skos:altLabel "sitefacilityset"@en ;
    rdfs:comment "Set of enumerated FACILITY values that are relevant to a SITE (names based on TPEG classifications, augmented with UIC etc.)."@en ;
    skos:related netex:FacilitySet .

netex:SiteFrame a skos:Concept ;
    skos:prefLabel "coherent set of site"@en ;
    skos:altLabel "site frame"@en ;
    skos:altLabel "siteframe"@en ;
    rdfs:comment "A coherent set of SITE data to which the same frame VALIDITY CONDITIONs have been assigned."@en .

netex:SiteNavigationPath a skos:Concept ;
    skos:prefLabel "designated path between two"@en ;
    skos:altLabel "site navigation path"@en ;
    skos:altLabel "sitenavigationpath"@en ;
    rdfs:comment "A designated path between two places. May include an ordered sequence of PATH LINKs."@en ;
    skos:related netex:LinkSequence .

netex:SitePathJunction a skos:Concept ;
    skos:prefLabel "site path junction"@en ;
    skos:altLabel "sitepathjunction"@en ;
    rdfs:comment "A designated point, inside a SITE ie STOP PLACE or POINT OF INTEREST, at which two or more PATH LINKs may connect or branch."@en ;
    skos:related netex:Point .

netex:SitePathLink a skos:Concept ;
    skos:prefLabel "path link between two"@en ;
    skos:altLabel "site path link"@en ;
    skos:altLabel "sitepathlink"@en ;
    rdfs:comment "A PATH LINK between two nodes that are SITE components, i.e. within a STOP PLACE or POINT OF INTEREST."@en ;
    skos:related netex:Link .

netex:Smartcard a skos:Concept ;
    skos:prefLabel "smartcard"@en ;
    rdfs:comment "A smart card with the necessary facilities (hardware and software) are) to host a MEDIUM APPLICATION INSTANCE and communicate with a control device. +v1.2.2"@en .

netex:SpecialService a skos:Concept ;
    skos:prefLabel "special service"@en ;
    skos:altLabel "specialservice"@en ;
    rdfs:comment "A passenger carrying VEHICLE JOURNEY for one specified DAY TYPE. The pattern of working is in principle defined by a SERVICE JOURNEY PATTERN."@en .

netex:SpecificParameterAssignment a skos:Concept ;
    skos:prefLabel "specific parameter assignment"@en ;
    skos:altLabel "specificparameterassignment"@en ;
    skos:altLabel "validity parameter assignment specifying"@en ;
    rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying practical parameters during a TRAVEL SPECIFICATION, within a given fare structure (e.g. the origin or destination zone in a zone-counting system)."@en .

netex:SpotAffinity a skos:Concept ;
    skos:prefLabel "spot affinity"@en ;
    skos:altLabel "spotaffinity"@en ;
    rdfs:comment "A group of proximate seats suitable for selection for use by a group of travellers, for example, as being side by side, face to face, around a table, near a wheelchair spot, etc. +v2.0"@en .

netex:SpotColumn a skos:Concept ;
    skos:prefLabel "spot column"@en ;
    skos:altLabel "spotcolumn"@en ;
    rdfs:comment "A designated File of LOCATABLE SPOTs within a PASSENGER SPACE, For example Column A, B, C, D. +v2.0"@en .

netex:SpotEquipment a skos:Concept ;
    skos:prefLabel "abstract equipment in a"@en ;
    skos:altLabel "spot equipment"@en ;
    skos:altLabel "spotequipment"@en ;
    rdfs:comment "An abstract EQUIPMENT in a LOCATABLE SPOT providing a onboard seat, bed or other amenity. +V2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:SpotRow a skos:Concept ;
    skos:prefLabel "designated row of locatable"@en ;
    skos:altLabel "spot row"@en ;
    skos:altLabel "spotrow"@en ;
    rdfs:comment "A designated row of LOCATABLE SPOTs, e.g. seats, within a PASSENGER SPACE. v2.0"@en .

netex:SpotSensor a skos:Concept ;
    skos:prefLabel "spot sensor"@en ;
    skos:altLabel "spotsensor"@en ;
    rdfs:comment "An EQUIPMENT used to monitor use of a LOCATABLE SPOT such as a passenger seat. +v2.0"@en ;
    skos:related netex:InstalledEquipment .

netex:SrsName a skos:Concept ;
    skos:prefLabel "name of gml spatial coordinate"@en ;
    skos:altLabel "srs name"@en ;
    skos:altLabel "srsname"@en ;
    rdfs:comment "Name of GML Spatial coordinate Reference system."@en .

netex:Staffing a skos:Concept ;
    skos:prefLabel "classification of staffing"@en ;
    skos:altLabel "staffing"@en ;
    rdfs:comment "Classification of STAFFING."@en .

netex:StairEquipment a skos:Concept ;
    skos:prefLabel "specialisation of access equipment for"@en ;
    skos:altLabel "stair equipment"@en ;
    skos:altLabel "stairequipment"@en ;
    rdfs:comment "Specialisation of ACCESS EQUIPMENT for stairs (stair, escalator, staircase, etc.)."@en ;
    skos:related netex:AccessEquipment .

netex:StairFlight a skos:Concept ;
    skos:prefLabel "stair flight"@en ;
    skos:altLabel "stairflight"@en ;
    rdfs:comment "SAn individual flight of a STAIR CASE."@en .

netex:StairFreeAccess a skos:Concept ;
    skos:prefLabel "stair free access"@en ;
    skos:altLabel "stairfreeaccess"@en ;
    skos:altLabel "whether a place has stair"@en ;
    rdfs:comment "Whether a PLACE has stair free access, in comparison with step free access one single step in the route is allowed. +v2.0"@en .

netex:StaircaseEquipment a skos:Concept ;
    skos:prefLabel "specialisation of stair equipment for"@en ;
    skos:altLabel "staircase equipment"@en ;
    skos:altLabel "staircaseequipment"@en ;
    rdfs:comment "Specialisation of STAIR EQUIPMENT for stair cases."@en ;
    skos:related netex:AccessEquipment .

netex:StandardFareTable a skos:Concept ;
    skos:prefLabel "standard fare table"@en ;
    skos:altLabel "standardfaretable"@en ;
    rdfs:comment "A set of price for a combination of price features in a Tariff."@en .

netex:StartTimeAtStopPoint a skos:Concept ;
    skos:prefLabel "start time at stop point"@en ;
    skos:altLabel "starttimeatstoppoint"@en ;
    skos:altLabel "time at which a"@en ;
    rdfs:comment "A time at which a Fare demand time band ( peak, off peak, etc ) is deemed to begin or end for trips at a particular SCHEDULED STOP POINT."@en .

netex:StepFreeAccess a skos:Concept ;
    skos:prefLabel "step free access"@en ;
    skos:altLabel "stepfreeaccess"@en ;
    skos:altLabel "whether a place has step"@en ;
    rdfs:comment "Whether a PLACE has step free access."@en .

netex:StepLimit a skos:Concept ;
    skos:prefLabel "step limit"@en ;
    skos:altLabel "steplimit"@en ;
    rdfs:comment "Geographical parameter limiting the access rights by counts of stops, sections or zones."@en .

netex:StopArea a skos:Concept ;
    skos:prefLabel "group of stop points"@en ;
    skos:altLabel "stop area"@en ;
    skos:altLabel "stoparea"@en ;
    rdfs:comment "A group of STOP POINTs close to each other."@en ;
    skos:related netex:Zone .

netex:StopAssignment a skos:Concept ;
    skos:prefLabel "assignment of a scheduled stop"@en ;
    skos:altLabel "stop assignment"@en ;
    skos:altLabel "stopassignment"@en ;
    rdfs:comment "Assignment of a SCHEDULED STOP POINT to a STOP PLACE and QUAY, etc."@en .

netex:StopPlace a skos:Concept ;
    skos:prefLabel "stop place"@en ;
    skos:altLabel "stopplace"@en ;
    skos:altLabel "version of a named place"@en ;
    rdfs:comment "Version of a named place where public transport may be accessed. May be a building complex (e.g. a station) or an on-street location. Can be a STOP PLACE, VEHICLE MEETING POINT, TAXI RANK. Note: If a master id exists for a StopPlace (must be stable and globally unique), then it is best used in the id. Optimally it would be built according IFOPT. It can also be put into one of the privateCodes in addition. If it is stored in KeyValue, then it should be documented well, so that importing systems know, which id is the relevant one."@en .

netex:StopPlaceComponent a skos:Concept ;
    skos:prefLabel "element of a stop"@en ;
    skos:altLabel "stop place component"@en ;
    skos:altLabel "stopplacecomponent"@en ;
    rdfs:comment "An element of a STOP PLACE describing part of its structure."@en ;
    skos:related netex:SiteElement .

netex:StopPlaceEntrance a skos:Concept ;
    skos:prefLabel "passenger entrance to a stop"@en ;
    skos:altLabel "stop place entrance"@en ;
    skos:altLabel "stopplaceentrance"@en ;
    rdfs:comment "Passenger Entrance to a STOP PLACE."@en ;
    skos:related netex:Entrance .

netex:StopPlaceSpace a skos:Concept ;
    skos:prefLabel "stop place space"@en ;
    skos:altLabel "stopplacespace"@en ;
    rdfs:comment "A physical area within a STOP PLACE, for example, a QUAY, BOARDING POSITION, ACCESS SPACE or EQUIPMENT PLACE."@en ;
    skos:related netex:StopPlaceComponent .

netex:StopPlaceVehicleEntrance a skos:Concept ;
    skos:prefLabel "physical entrance or exit"@en ;
    skos:altLabel "stop place vehicle entrance"@en ;
    skos:altLabel "stopplacevehicleentrance"@en ;
    rdfs:comment "A physical entrance or exit to/from a SITE for a VEHICLE. May be a door, barrier, gate or other recognizable point of access."@en ;
    skos:related netex:Entrance .

netex:StopPointInJourneyPattern a skos:Concept ;
    skos:prefLabel "stop point in journey pattern"@en ;
    skos:altLabel "stoppointinjourneypattern"@en ;
    rdfs:comment "The use of a SCHEDULED STOP POINT in a specified order. within a JOURNEY PATTERN or SERVICE PATTERN."@en ;
    skos:related netex:LinkSequence, netex:PointInLinkSequence .

netex:Submode a skos:Concept ;
    skos:prefLabel "open values transport submode allows"@en ;
    skos:altLabel "submode"@en ;
    rdfs:comment "Open values TRANSPORT SUBMODE. Allows named sub mod s to be created. A mode is a characterisation of the operation according to the means of transport (bus, tram, metro, train, ferry, ship). NOTE : To enforce standardisation, enumerated values are generally used in references. In The schema."@en ;
    skos:related netex:TypeOfValue .

netex:Subscribing a skos:Concept ;
    skos:prefLabel "subscribing"@en ;
    rdfs:comment "Parameters relating to paying by Subscribing for a product. +v1.1"@en .

netex:Suitability a skos:Concept ;
    skos:prefLabel "suitability"@en ;
    rdfs:comment "The SUITABILTY of a component to meet a specific USER NEED."@en .

netex:SupplementProduct a skos:Concept ;
    skos:prefLabel "fare product consisting of"@en ;
    skos:altLabel "supplement product"@en ;
    skos:altLabel "supplementproduct"@en ;
    rdfs:comment "A FARE PRODUCT consisting of one or several VALIDABLE ELEMENTs, specific to a CHARGING MOMENT."@en .

netex:Suspending a skos:Concept ;
    skos:prefLabel "suspending"@en ;
    rdfs:comment "Conditions governing suspension of a FARE PRODUCT, e.g. period pass or subscription."@en .

netex:TactileGuidanceAvailable a skos:Concept ;
    skos:prefLabel "tactile guidance available"@en ;
    skos:altLabel "tactileguidanceavailable"@en ;
    skos:altLabel "whether the place has tactile"@en ;
    rdfs:comment "Whether the Place has tactile guidance."@en .

netex:Tariff a skos:Concept ;
    skos:prefLabel "particular tariff described by"@en ;
    skos:altLabel "tariff"@en ;
    rdfs:comment "A particular tariff, described by a combination of parameters."@en .

netex:TariffZone a skos:Concept ;
    skos:prefLabel "tariff zone"@en ;
    skos:altLabel "tariffzone"@en ;
    skos:altLabel "zone used to define"@en ;
    rdfs:comment "A ZONE used to define a zonal fare structure in a zone-counting or zone-matrix system."@en .

netex:TaxiParkingArea a skos:Concept ;
    skos:prefLabel "specific area where any"@en ;
    skos:altLabel "taxi parking area"@en ;
    skos:altLabel "taxiparkingarea"@en ;
    rdfs:comment "A specific area where any taxi is able to safely park for a long period. +v1.2.2"@en .

netex:TaxiRank a skos:Concept ;
    skos:prefLabel "taxi rank"@en ;
    skos:altLabel "taxirank"@en ;
    rdfs:comment "A place comprising one or more locations where taxis may stop to pick up or set down passengers. +v1.2.2"@en .

netex:TaxiService a skos:Concept ;
    skos:prefLabel "taxi service"@en ;
    skos:altLabel "taxiservice"@en ;
    rdfs:comment "A type of VEHICLE POOLING SERVICE where the service may be regulated according to a particular taxi policy. . +v1.2.2"@en .

netex:TaxiServicePlaceAssignment a skos:Concept ;
    skos:prefLabel "allocation of a taxi"@en ;
    skos:altLabel "taxi service place assignment"@en ;
    skos:altLabel "taxiserviceplaceassignment"@en ;
    rdfs:comment "The allocation of a TAXI SERVICE to a TAXI PARKING or a TAXI STAND. +V1.2.2"@en .

netex:TaxiStand a skos:Concept ;
    skos:prefLabel "taxi stand"@en ;
    skos:altLabel "taxistand"@en ;
    rdfs:comment "A set of spots where any taxi is able to safely stop for a short period of time to load passengers. +v1.2.2"@en ;
    skos:related netex:AccessibilityAssessment, netex:StopPlaceComponent .

netex:TelecabinSubmode a skos:Concept ;
    skos:prefLabel "telecabin submode"@en ;
    skos:altLabel "telecabinsubmode"@en ;
    skos:altLabel "tpeg pti09 telecabin submodes"@en ;
    rdfs:comment "TPEG pti09 Telecabin submodes."@en .

netex:TemplateServiceJourney a skos:Concept ;
    skos:prefLabel "template service journey"@en ;
    skos:altLabel "templateservicejourney"@en ;
    skos:altLabel "vehicle journey with a"@en ;
    rdfs:comment "A VEHICLE JOURNEY with a set of frequencies that may be used to represent a set of similar journeys differing only by their time of departure."@en .

netex:TemplateVehicleJourney a skos:Concept ;
    skos:prefLabel "repeating vehicle journey for"@en ;
    skos:altLabel "template vehicle journey"@en ;
    skos:altLabel "templatevehiclejourney"@en ;
    rdfs:comment "A repeating VEHICLE JOURNEY for which a frequency has been specified, either as a HEADWAY JOURNEY GROUP (e.g. every 20 minutes) or a RHYTHMICAL JOURNEY GROUP (e.g. at 15, 27 and 40 minutes past the hour). It may thus represent multiple journeys."@en .

netex:ThirdPartyProduct a skos:Concept ;
    skos:prefLabel "fare product that is"@en ;
    skos:altLabel "third party product"@en ;
    skos:altLabel "thirdpartyproduct"@en ;
    rdfs:comment "A FARE PRODUCT that is marketed together with a Public Transport Fare Product."@en .

netex:TicketValidatorEquipment a skos:Concept ;
    skos:prefLabel "specialisation of installed equipment describing"@en ;
    skos:altLabel "ticket validator equipment"@en ;
    skos:altLabel "ticketvalidatorequipment"@en ;
    rdfs:comment "Specialisation of INSTALLED EQUIPMENT describing a ticket validator."@en ;
    skos:related netex:PassengerEquipment .

netex:TicketingEquipment a skos:Concept ;
    skos:prefLabel "specialisation of passenger equipment for"@en ;
    skos:altLabel "ticketing equipment"@en ;
    skos:altLabel "ticketingequipment"@en ;
    rdfs:comment "Specialisation of PASSENGER EQUIPMENT for ticketing."@en ;
    skos:related netex:PassengerEquipment .

netex:TicketingFacility a skos:Concept ;
    skos:prefLabel "classification of ticketing facility type"@en ;
    skos:altLabel "ticketing facility"@en ;
    skos:altLabel "ticketingfacility"@en ;
    rdfs:comment "Classification of TICKETING FACILITY type - eg TicketOffice, Machine, etc."@en .

netex:TicketingFacilityList a skos:Concept ;
    skos:prefLabel "list of ticketing facilities"@en ;
    skos:altLabel "ticketing facility list"@en ;
    skos:altLabel "ticketingfacilitylist"@en ;
    rdfs:comment "List of TICKETING FACILITies."@en .

netex:TicketingService a skos:Concept ;
    skos:prefLabel "specialisation of local service for"@en ;
    skos:altLabel "ticketing service"@en ;
    skos:altLabel "ticketingservice"@en ;
    rdfs:comment "Specialisation of LOCAL SERVICE for ticketing, providing ticket counter and online purchase information, also associated with payment method and TYPE OF TICKET."@en ;
    skos:related netex:LocalService .

netex:TicketingServiceFacility a skos:Concept ;
    skos:prefLabel "classification of ticketing facility type"@en ;
    skos:altLabel "ticketing service facility"@en ;
    skos:altLabel "ticketingservicefacility"@en ;
    rdfs:comment "Classification of TICKETING FACILITY type - TPEG pti23."@en .

netex:TicketingServiceFacilityList a skos:Concept ;
    skos:prefLabel "list of ticketing service facilities"@en ;
    skos:altLabel "ticketing service facility list"@en ;
    skos:altLabel "ticketingservicefacilitylist"@en ;
    rdfs:comment "List of TICKETING SERVICE FACILITies, e.g. purchase, collection. top up."@en .

netex:TimeDemandProfileMember a skos:Concept ;
    skos:prefLabel "time demand profile member"@en ;
    skos:altLabel "timedemandprofilemember"@en ;
    rdfs:comment "TIME DEMAND PROFILE member."@en .

netex:TimeDemandTypeAssignment a skos:Concept ;
    skos:prefLabel "assignment of a time"@en ;
    skos:altLabel "time demand type assignment"@en ;
    skos:altLabel "timedemandtypeassignment"@en ;
    rdfs:comment "The assignment of a TIME DEMAND TYPE to a TIME BAND depending on the DAY TYPE and GROUP OF TIMING LINKS."@en .

netex:TimeInterval a skos:Concept ;
    skos:prefLabel "time interval"@en ;
    skos:altLabel "timeinterval"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en .

netex:TimeIntervalPrice a skos:Concept ;
    skos:prefLabel "time interval price"@en ;
    skos:altLabel "timeintervalprice"@en ;
    rdfs:comment "A set of all possible price features of a TIME INTERVAL: default total price etc."@en .

netex:TimeStructureFactor a skos:Concept ;
    skos:prefLabel "time structure factor"@en ;
    skos:altLabel "timestructurefactor"@en ;
    skos:altLabel "value of a time"@en ;
    rdfs:comment "The value of a TIME INTERVAL or a DISTANCE MATRIX ELEMENT expressed by a TIME UNIT."@en ;
    skos:related netex:PriceableObject .

netex:TimeUnit a skos:Concept ;
    skos:prefLabel "time unit"@en ;
    skos:altLabel "timeunit"@en ;
    rdfs:comment "A factor influencing access rights definition or calculation of prices."@en ;
    skos:related netex:PriceableObject .

netex:TimeUnitPrice a skos:Concept ;
    skos:prefLabel "time unit price"@en ;
    skos:altLabel "timeunitprice"@en ;
    rdfs:comment "A set of all possible price features of a TIME UNIT: default total price etc."@en .

netex:Timeband a skos:Concept ;
    skos:prefLabel "timeband"@en ;
    rdfs:comment "A period in a day, significant for some aspect of public transport, e.g. similar traffic conditions or fare category."@en .

netex:TimetableFrame a skos:Concept ;
    skos:prefLabel "coherent set of timetable"@en ;
    skos:altLabel "timetable frame"@en ;
    skos:altLabel "timetableframe"@en ;
    rdfs:comment "A coherent set of timetable data (VEHICLE JOURNEYs and BLOCKs) to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:TimetabledPassingTime a skos:Concept ;
    skos:prefLabel "timetabled passing time"@en ;
    skos:altLabel "passingtime"@en ;
    skos:altLabel "arrival time"@en ;
    skos:altLabel "departure time"@en ;
    skos:altLabel "scheduled time"@en ;
    rdfs:comment "The scheduled arrival and departure times of a vehicle at a stop"@en ;
    skos:related datex:TrafficEvent, netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:LateDatedVehicleJourneyEntry, opra:PlannedCapacity, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

netex:TimingLink a skos:Concept ;
    skos:prefLabel "ordered pair of timing"@en ;
    skos:altLabel "timing link"@en ;
    skos:altLabel "timinglink"@en ;
    rdfs:comment "An ordered pair of TIMING POINTs for which run times may be recorded. Timing links are directional - there will be separate links for each direction of a route."@en ;
    skos:related netex:Link .

netex:TimingLinkInJourneyPattern a skos:Concept ;
    skos:prefLabel "position of a timing"@en ;
    skos:altLabel "timing link in journey pattern"@en ;
    skos:altLabel "timinglinkinjourneypattern"@en ;
    rdfs:comment "The position of a TIMING LINK in a JOURNEY PATTERN. This ENTITY is needed if a TIMING LINK is repeated in the same JOURNEY PATTERN, and separate information is to be stored about each iteration of the TIMING LINK."@en ;
    skos:related netex:LinkInLinkSequence .

netex:TimingPattern a skos:Concept ;
    skos:prefLabel "timing pattern"@en ;
    skos:altLabel "timingpattern"@en ;
    rdfs:comment "The subset of a JOURNEY PATTERN made up only of TIMING POINTs IN JOURNEY PATTERN."@en ;
    skos:related netex:LinkSequence .

netex:TimingPoint a skos:Concept ;
    skos:prefLabel "point against which the"@en ;
    skos:altLabel "timing point"@en ;
    skos:altLabel "timingpoint"@en ;
    rdfs:comment "A POINT against which the timing information necessary to build schedules may be recorded."@en .

netex:TimingPointInJourneyPattern a skos:Concept ;
    skos:prefLabel "node in a journey"@en ;
    skos:altLabel "timing point in journey pattern"@en ;
    skos:altLabel "timingpointinjourneypattern"@en ;
    rdfs:comment "A NODE in a JOURNEY PATTERN which is a TIMING POINT."@en ;
    skos:related netex:PointInLinkSequence .

netex:TopographicPlace a skos:Concept ;
    skos:prefLabel "topographic place"@en ;
    skos:altLabel "topographicplace"@en ;
    rdfs:comment "A town, city, village, suburb, quarter or other name settlement within a country. Provides a Gazetteer of Transport related place names."@en ;
    skos:related netex:Place .

netex:TopographicProjection a skos:Concept ;
    skos:prefLabel "topographic projection"@en ;
    skos:altLabel "topographical projection allows any zone"@en ;
    skos:altLabel "topographicprojection"@en ;
    rdfs:comment "TOPOGRAPHICAL PROJECTION allows any ZONE to be directly mapped to a TOPOGRAPHICAL PLACE, e.g. a TARIFF ZONE, ADMINISTRATIVE ZONE can be stated as having the same bounds as another zone. +v1.1"@en ;
    skos:related netex:Projection .

netex:Trace a skos:Concept ;
    skos:prefLabel "trace"@en ;
    rdfs:comment "A record of the detailed changes of a given ENTITY IN VERSION from one VERSION to the next one. A TRACE contains pairs of attributes' old values - new values."@en .

netex:TractiveRollingStockItem a skos:Concept ;
    skos:prefLabel "powered item of rolling"@en ;
    skos:altLabel "tractive rolling stock item"@en ;
    skos:altLabel "tractiverollingstockitem"@en ;
    rdfs:comment "A powered item of rolling stock, such as a specific locomotive or powered railcar. +v2.0"@en .

netex:TrafficControlPoint a skos:Concept ;
    skos:prefLabel "point where the traffic"@en ;
    skos:altLabel "traffic control point"@en ;
    skos:altLabel "trafficcontrolpoint"@en ;
    rdfs:comment "A POINT where the traffic flow can be influenced. Examples are: traffic lights (lanterns), barriers."@en ;
    skos:related netex:Point .

netex:TrailingRollingStockItem a skos:Concept ;
    skos:prefLabel "trailing rolling stock item"@en ;
    skos:altLabel "trailingrollingstockitem"@en ;
    skos:altLabel "unpowered item of rolling"@en ;
    rdfs:comment "An unpowered item of rolling stock such as a specific passenger carriage, luggage van, passenger vehicle carrier wagon or freight wagon. +v2.0"@en .

netex:Train a skos:Concept ;
    skos:prefLabel "train"@en ;
    skos:altLabel "vehicle composed of train"@en ;
    rdfs:comment "A vehicle composed of TRAIN ELEMENTs in a certain order, i.e. of wagons assembled together and propelled by a locomotive or one of the wagons."@en .

netex:TrainBlock a skos:Concept ;
    skos:prefLabel "train block"@en ;
    skos:altLabel "trainblock"@en ;
    rdfs:comment "The vehicle work required by a train-based JOURNEY or sequence of JOURNEYs, from the time it leaves a PARKING POINT after parking until its next return to park at a PARKING POINT."@en .

netex:TrainBlockPart a skos:Concept ;
    skos:prefLabel "part of a train block"@en ;
    skos:altLabel "train block part"@en ;
    skos:altLabel "trainblockpart"@en ;
    rdfs:comment "Part of a TRAIN BLOCK corresponding to a specific JOURNEY PART of the relevant JOURNEY of a TRAIN BLOCK. Note: Any train reversal, splitting, or joining operation marks the start of a new TRAIN BLOCK PART."@en .

netex:TrainComponent a skos:Concept ;
    skos:prefLabel "train component"@en ;
    skos:altLabel "traincomponent"@en ;
    rdfs:comment "A specification of the order of TRAIN ELEMENTs in a TRAIN."@en .

netex:TrainComponentLabelAssignment a skos:Concept ;
    skos:prefLabel "train component label assignment"@en ;
    skos:altLabel "traincomponentlabelassignment"@en ;
    rdfs:comment "The allocation of an advertised designation for a vehicle or vehicle element for passengers."@en .

netex:TrainComponentStopAssignment a skos:Concept ;
    skos:prefLabel "train component stop assignment"@en ;
    skos:altLabel "traincomponentstopassignment"@en ;
    rdfs:comment "The association of a DECK ENTRANCE of a VEHICLE's DECK PLAN with a TRAIN and TRAIN COMPONENT and a specific STOP PLACE, QUAY and possibly BOARDING POSITION. NOTE: may indicate which side of VEHICLE door is. +v2.0"@en ;
    skos:related netex:StopAssignment .

netex:TrainElement a skos:Concept ;
    skos:prefLabel "train element"@en ;
    skos:altLabel "trainelement"@en ;
    rdfs:comment "According to Transmodel 6.2 This shoud really be called TRAIN ELEMENT TYPE and be abstract . Use as concrete element DEPRECATED - use more specific TRAILING ELEMENT TYPE or TRACTIVE ELEMENT TYPE subtypes, Shoul dbe renmaed and removed in V3.0"@en .

netex:TrainNumber a skos:Concept ;
    skos:prefLabel "train number"@en ;
    skos:altLabel "trainnumber"@en ;
    rdfs:comment "Specification of codes assigned to particular VEHICLE JOURNEYs when operated by TRAINs of COMPOUND TRAINs according to a functional purpose (passenger information, operation follow-up, etc)."@en .

netex:TrainSize a skos:Concept ;
    skos:prefLabel "requirements for train size"@en ;
    skos:altLabel "train size"@en ;
    skos:altLabel "trainsize"@en ;
    rdfs:comment "Requirements for TRAIN SIZe."@en .

netex:TrainStopAssignment a skos:Concept ;
    skos:prefLabel "train stop assignment"@en ;
    skos:altLabel "trainstopassignment"@en ;
    rdfs:comment "DEPRECATED - Use PASSENGER BOARDING POSITION ASSIGNMENT."@en ;
    skos:related netex:StopAssignment .

netex:Transfer a skos:Concept ;
    skos:prefLabel "transfer"@en ;
    rdfs:comment "The possibility of a passenger to transfer between two PLACEs. May have times associated for the transfer."@en .

netex:TransferDuration a skos:Concept ;
    skos:prefLabel "times for transfer between two"@en ;
    skos:altLabel "transfer duration"@en ;
    skos:altLabel "transferduration"@en ;
    rdfs:comment "Times for TRANSFER between two Points."@en .

netex:TransferRestriction a skos:Concept ;
    skos:prefLabel "transfer restriction"@en ;
    skos:altLabel "transferrestriction"@en ;
    rdfs:comment "A CONSTRAINT that can be applied on a CONNECTION or INTERCHANGE between two SCHEDULED STOP POINT, preventing or forbidding the passenger to use it."@en .

netex:Transferability a skos:Concept ;
    skos:prefLabel "transferability"@en ;
    rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original customer."@en .

netex:TransportAdministrativeZone a skos:Concept ;
    skos:prefLabel "transport administrative zone"@en ;
    skos:altLabel "transportadministrativezone"@en ;
    skos:altLabel "zone relating to the"@en ;
    rdfs:comment "A ZONE relating to the management responsibilities of an ORGANISATION. For example to allocate bus stop identifiers for a region."@en .

netex:TransportOrganisation a skos:Concept ;
    skos:prefLabel "company providing transport services"@en ;
    skos:altLabel "transport organisation"@en ;
    skos:altLabel "transportorganisation"@en ;
    rdfs:comment "A company providing transport services."@en .

netex:TransportSubmode a skos:Concept ;
    skos:prefLabel "submode of a public"@en ;
    skos:altLabel "transport submode"@en ;
    skos:altLabel "transportsubmode"@en ;
    rdfs:comment "A submode of a public or private TRANSPORT MODE."@en .

netex:TravelAgent a skos:Concept ;
    skos:prefLabel "travel agent"@en ;
    skos:altLabel "travel agent who can"@en ;
    skos:altLabel "travelagent"@en ;
    rdfs:comment "A travel agent who can retail travel products."@en .

netex:TravelDocument a skos:Concept ;
    skos:prefLabel "travel document"@en ;
    skos:altLabel "traveldocument"@en ;
    rdfs:comment "A particular physical support (ticket, card...) to be held by a customer, allowing the right to travel or to consume joint-services, to proof a payment (including possible discount rights), to store a subset of the FARE CONTRACT liabilities or a combination of those."@en .

netex:TravelDocumentSecurityListing a skos:Concept ;
    skos:prefLabel "listing of a travel"@en ;
    skos:altLabel "travel document security listing"@en ;
    skos:altLabel "traveldocumentsecuritylisting"@en ;
    rdfs:comment "A listing of a TRAVEL DOCUMENT on a SECURITY LIST."@en .

netex:TravelSpecification a skos:Concept ;
    skos:prefLabel "recording of a specification"@en ;
    skos:altLabel "travel specification"@en ;
    skos:altLabel "travelspecification"@en ;

    skos:prefLabel "validable element"@en ;
    skos:altLabel "validableelement"@en ;
    rdfs:comment "A sequence or set of FARE STRUCTURE ELEMENTs, grouped together to be validated in one go."@en .

netex:ValidableElementPrice a skos:Concept ;
    skos:prefLabel "validable element price"@en ;
    skos:altLabel "validableelementprice"@en ;
    rdfs:comment "A set of all possible price features of a VALIDABLE ELEMENT ELEMENT: default total price, discount in value or percentage etc."@en .

netex:ValidityCondition a skos:Concept ;
    skos:prefLabel "condition used in order to"@en ;
    skos:altLabel "validity condition"@en ;
    skos:altLabel "validitycondition"@en ;
    rdfs:comment "Condition used in order to characterise a given VERSION of a VERSION FRAME. A VALIDITY CONDITION consists of a parameter (e.g. date, triggering event, etc) and its type of application (e.g. for, from, until, etc.)."@en .

netex:ValidityParameterAssignment a skos:Concept ;
    skos:prefLabel "access right parameter assignment"@en ;
    skos:altLabel "validity parameter assignment"@en ;
    skos:altLabel "validityparameterassignment"@en ;
    rdfs:comment "An ACCESS RIGHT PARAMETER ASSIGNMENT relating a fare collection parameter to a theoretical FARE PRODUCT (or one of its components) or a SALES OFFER PACKAGE."@en .

netex:ValidityRuleParameter a skos:Concept ;
    skos:prefLabel "user defined validity condition"@en ;
    skos:altLabel "validity rule parameter"@en ;
    skos:altLabel "validityruleparameter"@en ;
    rdfs:comment "A user defined VALIDITY CONDITION used by a rule for selecting versions. E.g. river level > 1,5 m and bad weather."@en .

netex:ValidityTrigger a skos:Concept ;
    skos:prefLabel "external event defining a validity"@en ;
    skos:altLabel "validity trigger"@en ;
    skos:altLabel "validitytrigger"@en ;
    rdfs:comment "External event defining a VALIDITY CONDITION. E.g. exceptional flow of a river, bad weather, Road closure for works."@en .

netex:ValueSet a skos:Concept ;
    skos:prefLabel "extensible set of code"@en ;
    skos:altLabel "value set"@en ;
    skos:altLabel "valueset"@en ;
    rdfs:comment "An extensible set of code values which may be added to by user applications and is used to validate the properties of Entities."@en .

netex:Vehicle a skos:Concept ;
    skos:prefLabel "public transport vehicle used"@en ;
    skos:altLabel "vehicle"@en ;
    rdfs:comment "A public transport vehicle used for carrying passengers."@en .

netex:VehicleAccessCredentialsAssignment a skos:Concept ;
    skos:prefLabel "vehicle access credentials assignment"@en ;
    skos:altLabel "vehicleaccesscredentialsassignment"@en ;
    rdfs:comment "The allocation of a MEDIUM ACCESS DEVICE to a specific VEHICLE, to allow the user (TRANSPORT CUSTOMER) to access the vehicle (tyically for VEHICLE SHARING or VEHICLE RENTAL). This allocation may have validity limitations. +V1.2.2"@en .

netex:VehicleAccessFacility a skos:Concept ;
    skos:prefLabel "classification of vehicle access facility"@en ;
    skos:altLabel "vehicle access facility"@en ;
    skos:altLabel "vehicleaccessfacility"@en ;
    rdfs:comment "Classification of VEHICLE ACCESS FACILITY."@en .

netex:VehicleAccessFacilityList a skos:Concept ;
    skos:prefLabel "list of vehicle access facilities"@en ;
    skos:altLabel "vehicle access facility list"@en ;
    skos:altLabel "vehicleaccessfacilitylist"@en ;
    rdfs:comment "List of VEHICLE ACCESS FACILITies."@en .

netex:VehicleChargingEquipment a skos:Concept ;
    skos:prefLabel "specialisation of place equipment for"@en ;
    skos:altLabel "vehicle charging equipment"@en ;
    skos:altLabel "vehiclechargingequipment"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for vehicle charging."@en ;
    skos:related netex:PlaceEquipment .

netex:VehicleEntrance a skos:Concept ;
    skos:prefLabel "physical entrance or exit"@en ;
    skos:altLabel "vehicle entrance"@en ;
    skos:altLabel "vehicleentrance"@en ;
    rdfs:comment "A physical entrance or exit to/from a SITE for a VEHICLE. May be a door, barrier, gate or other recognizable point of access."@en ;
    skos:related netex:Entrance .

netex:VehicleEquipmentProfile a skos:Concept ;
    skos:prefLabel "vehicle equipment profile"@en ;
    skos:altLabel "vehicleequipmentprofile"@en ;
    rdfs:comment "Each instantiation of this ENTITY gives the number of items of one TYPE OF EQUIPMENT a VEHICLE MODEL should contain for a given PURPOSE OF EQUIPMENT PROFILE. The set of instantiations for one VEHICLE MODEL and one purpose gives one complete 'profile'."@en .

netex:VehicleEquipmentProfileMember a skos:Concept ;
    skos:prefLabel "element within a vehicle"@en ;
    skos:altLabel "vehicle equipment profile member"@en ;
    skos:altLabel "vehicleequipmentprofilemember"@en ;
    rdfs:comment "A element within a VEHICLE EQUIPMENT PROFILE specifying the number of units of a given a TYPE OF EQUIPMENT."@en .

netex:VehicleJourney a skos:Concept ;
    skos:prefLabel "vehicle journey"@en ;
    skos:altLabel "vehiclejourney"@en ;
    skos:altLabel "journey"@en ;
    skos:altLabel "scheduled journey"@en ;
    skos:altLabel "service journey"@en ;
    rdfs:comment "A single journey of a vehicle following a predetermined route on a specific schedule"@en ;
    skos:exactMatch nits:vehicle-journey ;
    skos:broader transmodel:Journey ;
    skos:related netex:AllowedLineDirection, netex:DestinationDisplay, netex:DestinationDisplayVariant, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, opra:ActualCapacity, opra:AverageCommercialSpeed, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:ExpectedPassengerCount, opra:ExpectedServiceIntensity, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:LoadOverJourneyDistance, opra:MeanCapacityOverJourneyDistance, opra:MeanCapacityOverNetworkDistance, opra:MeanCapacityOverRouteDistance, opra:PlannedCapacity, opra:PreparednessLevel, opra:TransportPerformance, opra:TransportPerformancePerVehicle, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

netex:VehicleJourneyHeadway a skos:Concept ;
    skos:prefLabel "headway interval information that is"@en ;
    skos:altLabel "vehicle journey headway"@en ;
    skos:altLabel "vehiclejourneyheadway"@en ;
    rdfs:comment "Headway interval information that is available for a VEHICLE JOURNEY (to be understood as the delay between the previous and the next VEHICLE JOURNEY). This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."@en ;
    skos:related netex:JourneyTiming .

netex:VehicleJourneyLayover a skos:Concept ;
    skos:prefLabel "vehicle journey layover"@en ;
    skos:altLabel "vehiclejourneylayover"@en ;
    rdfs:comment "A time allowance at the end of a specified VEHICLE JOURNEY. This time supersedes any global layover or JOURNEY PATTERN LAYOVER."@en ;
    skos:related netex:JourneyTiming .

netex:VehicleJourneyRunTime a skos:Concept ;
    skos:prefLabel "time taken to traverse"@en ;
    skos:altLabel "vehicle journey run time"@en ;
    skos:altLabel "vehiclejourneyruntime"@en ;
    rdfs:comment "The time taken to traverse a specified TIMING LINK IN JOURNEY PATTERN on a specified VEHICLE JOURNEY. This gives the most detailed control over times and overrides the DEFAULT SERVICE JOURNEY RUN TIME and JOURNEY PATTERN RUN TIME and the DEFAULT DEAD RUN RUN TIME. There may be different times for different TIME DEMAND TYPES."@en ;
    skos:related netex:JourneyTiming .

netex:VehicleJourneySpotAllocation a skos:Concept ;
    skos:prefLabel "vehicle journey spot allocation"@en ;
    skos:altLabel "vehiclejourneyspotallocation"@en ;
    rdfs:comment "An identified person or organisation involved in a fare process. There may be a FARE CONTRACT between the VEHICLE JOURNEY SPOT ALLOCATION and the OPERATOR or the AUTHORITY ruling the consumption of services. +v2.0"@en .

netex:VehicleJourneyStopAssignment a skos:Concept ;
    skos:prefLabel "change to a passenger stop"@en ;
    skos:altLabel "vehicle journey stop assignment"@en ;
    skos:altLabel "vehiclejourneystopassignment"@en ;
    rdfs:comment "Change to a PASSENGER STOP ASSIGNMENT for a specific VEHICLE JOURNEY +v1.1"@en ;
    skos:related netex:StopAssignment .

netex:VehicleJourneyWaitTime a skos:Concept ;
    skos:prefLabel "time for a vehicle"@en ;
    skos:altLabel "vehicle journey wait time"@en ;
    skos:altLabel "vehiclejourneywaittime"@en ;
    rdfs:comment "The time for a vehicle to wait at a particular TIMING POINT IN JOURNEY PATTERN on a specified VEHICLE JOURNEY. This wait time will override the JOURNEY PATTERN WAIT TIME."@en ;
    skos:related netex:JourneyTiming .

netex:VehicleManoeuvringRequirement a skos:Concept ;
    skos:prefLabel "vehicle manoeuvring requirement"@en ;
    skos:altLabel "vehiclemanoeuvringrequirement"@en ;
    rdfs:comment "Requirements for carrying passengers."@en .

netex:VehicleMeetingLink a skos:Concept ;
    skos:prefLabel "link between an ordered"@en ;
    skos:altLabel "vehicle meeting link"@en ;
    skos:altLabel "vehiclemeetinglink"@en ;
    rdfs:comment "A LINK between an ordered pair of STOP POINTs. VEHICLE MEETING LINKs are directional - there will be separate links for each direction of a route. +v1.2.2"@en ;
    skos:related netex:Link .

netex:VehicleMeetingPlace a skos:Concept ;
    skos:prefLabel "place where vehiclespassengers meet"@en ;
    skos:altLabel "vehicle meeting place"@en ;
    skos:altLabel "vehiclemeetingplace"@en ;
    rdfs:comment "A place where vehicles/passengers meet to change mode of transportation, for boarding, alighting, pick-up, drop-off, etc. +v1.2.2"@en ;
    skos:related netex:Place .

netex:VehicleMeetingPoint a skos:Concept ;
    skos:prefLabel "point where passengers can"@en ;
    skos:altLabel "vehicle meeting point"@en ;
    skos:altLabel "vehiclemeetingpoint"@en ;
    rdfs:comment "A POINT where passengers can board or alight from vehicles. +v1.2.2"@en ;
    skos:related netex:Point .

netex:VehicleMeetingPointAssignment a skos:Concept ;
    skos:prefLabel "allocation of a vehicle"@en ;
    skos:altLabel "vehicle meeting point assignment"@en ;
    skos:altLabel "vehiclemeetingpointassignment"@en ;
    rdfs:comment "The allocation of a VEHICLE MEETING POINT to a SITE COMPONENT or ADDRESSABLE PLACE (for vehicle pooling or vehicle sharing purposes). +v1.2.2"@en .

netex:VehicleMeetingPointInPath a skos:Concept ;
    skos:prefLabel "vehicle meeting point in path"@en ;
    skos:altLabel "vehiclemeetingpointinpath"@en ;
    rdfs:comment "The planned movement of a public transport vehicle on a DAY TYPE from the start point to the end point of a JOURNEY PATTERN on a specified ROUTE. +v1.2.2"@en ;
    skos:related netex:PointInLinkSequence .

netex:VehicleMode a skos:Concept ;
    skos:prefLabel "public transport mode a characterisation"@en ;
    skos:altLabel "vehicle mode"@en ;
    skos:altLabel "vehiclemode"@en ;
    rdfs:comment "PUBLIC TRANSPORT MODE: a characterisation of the operation according to the means of transport (bus, tram, metro, train, ferry, ship)."@en .

netex:VehicleModel a skos:Concept ;
    skos:prefLabel "vehicle model"@en ;
    skos:altLabel "vehiclemodel"@en ;
    rdfs:comment "A classification of public transport vehicles according to the vehicle scheduling requirements in MODE and capacity (e.g. standard bus, double-deck, ...)."@en .

netex:VehicleModelProfile a skos:Concept ;
    skos:prefLabel "vehicle model profile"@en ;
    skos:altLabel "vehiclemodelprofile"@en ;
    rdfs:comment "A set of characteristics of equipment installed on-board and characterising a VEHICLE MODEL PROFILE. +v1.2.2"@en .

netex:VehiclePoolerProfile a skos:Concept ;
    skos:prefLabel "vehicle pooler profile"@en ;
    skos:altLabel "vehiclepoolerprofile"@en ;
    rdfs:comment "A set of USER PARAMETERS characterising access rights to VEHICLE POOLING SERVICE. +v1.2.2"@en .

netex:VehiclePooling a skos:Concept ;
    skos:prefLabel "vehicle pooling"@en ;
    skos:altLabel "vehiclepooling"@en ;
    rdfs:comment "An ALTERNATIVE MODE OF OPERATION of a privately-owned vehicle consisting in sharing the vehicle for a trip between the driver who is at the same time performing a trip and at least another traveller. +v1.2.2"@en .

netex:VehiclePoolingDriverInfo a skos:Concept ;
    skos:prefLabel "vehicle pooling driver info"@en ;
    skos:altLabel "vehiclepoolingdriverinfo"@en ;
    rdfs:comment "Information characterising an INDIVIDUAL TRAVELLER as a driver of a VEHICLE POOLING SERVICE. +v1.2.2"@en .

netex:VehiclePoolingMeetingPlace a skos:Concept ;
    skos:prefLabel "place where vehiclespassengers meet"@en ;
    skos:altLabel "vehicle pooling meeting place"@en ;
    skos:altLabel "vehiclepoolingmeetingplace"@en ;
    rdfs:comment "A place where vehicles/passengers meet to change mode of transportation, for boarding, alighting, pick-up, drop-off, etc. +v1.2.2"@en .

netex:VehiclePoolingParkingArea a skos:Concept ;
    skos:prefLabel "vehicle pooling parking area"@en ;
    skos:altLabel "vehiclepoolingparkingarea"@en ;
    rdfs:comment "A dedicated space of a PARKING AREA for either vehicles active in a pooling service or vehicles of a pooling service users where vehicles are left for a longer time. +v1.2.2"@en .

netex:VehiclePoolingParkingBay a skos:Concept ;
    skos:prefLabel "vehicle pooling parking bay"@en ;
    skos:altLabel "vehiclepoolingparkingbay"@en ;
    rdfs:comment "A dedicated space of a PARKING AREA for either vehicles active in a pooling service or vehicles of a pooling service users where vehicles are left for a longer time. +v1.2.2"@en .

netex:VehiclePoolingPlaceAssignment a skos:Concept ;
    skos:prefLabel "allocation of a vehicle"@en ;
    skos:altLabel "vehicle pooling place assignment"@en ;
    skos:altLabel "vehiclepoolingplaceassignment"@en ;
    rdfs:comment "The allocation of a VEHICLE POOLING SERVICE to a VEHICLE POOLING PARKING AREA or a VEHICLE POOLING MEETING PLACE. +V1.2.2"@en .

netex:VehiclePoolingService a skos:Concept ;
    skos:prefLabel "transport service that connects"@en ;
    skos:altLabel "vehicle pooling service"@en ;
    skos:altLabel "vehiclepoolingservice"@en ;
    rdfs:comment "A transport service that connects users (driver and passenger(s)) for carrying out trips. +v1.2.2"@en .

netex:VehiclePositionAlignment a skos:Concept ;
    skos:prefLabel "designated position within a vehicle"@en ;
    skos:altLabel "vehicle position alignment"@en ;
    skos:altLabel "vehiclepositionalignment"@en ;
    rdfs:comment "Designated Position within a VEHICLE STOPPING PLACE for a Vehicle to stop."@en .

netex:VehicleQuayAlignment a skos:Concept ;
    skos:prefLabel "designated position within a vehicle"@en ;
    skos:altLabel "vehicle quay alignment"@en ;
    skos:altLabel "vehiclequayalignment"@en ;
    rdfs:comment "Designated Position within a VEHICLE STOPPING PLACE for a Vehicle to stop."@en .

netex:VehicleReleaseEquipment a skos:Concept ;
    skos:prefLabel "specialisation of place equipment for"@en ;
    skos:altLabel "vehicle release equipment"@en ;
    skos:altLabel "vehiclereleaseequipment"@en ;
    rdfs:comment "Specialisation of PLACE EQUIPMENT for VEHICLE RELEASE. +v1.2.2"@en ;
    skos:related netex:InstalledEquipment .

netex:VehicleRental a skos:Concept ;
    skos:prefLabel "vehicle rental"@en ;
    skos:altLabel "vehiclerental"@en ;
    rdfs:comment "An ALTERNATIVE MODE OF OPERATION of a vehicle, part of a FLEET (in general privately owned), available for use for a certain period of time and fee, with the constraint to bring it back at specified agencies. +v1.2.2"@en .

netex:VehicleRentalService a skos:Concept ;
    skos:prefLabel "transport service offer related"@en ;
    skos:altLabel "vehicle rental service"@en ;
    skos:altLabel "vehiclerentalservice"@en ;
    rdfs:comment "A transport service offer related to VEHICLE RENTAL. +v1.2.2"@en .

netex:VehicleScheduleFrame a skos:Concept ;
    skos:prefLabel "coherent set of vehicle"@en ;
    skos:altLabel "vehicle schedule frame"@en ;
    skos:altLabel "vehiclescheduleframe"@en ;
    rdfs:comment "A coherent set of Vehicle Scheduling data to which the same VALIDITY CONDITIONs have been assigned."@en .

netex:VehicleService a skos:Concept ;
    skos:prefLabel "vehicle service"@en ;
    skos:altLabel "vehicleservice"@en ;
    rdfs:comment "A work plan for a vehicle for a whole day, planned for a specific DAY TYPE. A VEHICLE SERVICE includes one or several VEHICLE SERVICE PARTs."@en .

netex:VehicleServicePart a skos:Concept ;
    skos:prefLabel "part of a vehicle"@en ;
    skos:altLabel "vehicle service part"@en ;
    skos:altLabel "vehicleservicepart"@en ;
    rdfs:comment "A part of a VEHICLE SERVICE composed of one or more BLOCKs and limited by periods spent at the GARAGE managing the vehicle in question."@en .

netex:VehicleServicePlaceAssignment a skos:Concept ;
    skos:prefLabel "allocation of a place"@en ;
    skos:altLabel "vehicle service place assignment"@en ;
    skos:altLabel "vehicleserviceplaceassignment"@en ;
    rdfs:comment "The allocation of a place to a MOBILITY SERVICE. +V1.2.2"@en .

netex:VehicleSharing a skos:Concept ;
    skos:prefLabel "short term vehicle rental where"@en ;
    skos:altLabel "vehicle sharing"@en ;
    skos:altLabel "vehiclesharing"@en ;
    rdfs:comment "Short term VEHICLE RENTAL where the vehicle can be taken from and parked at different places in the urban area, possibly without the constraint to bring back the vehicle to a specific location. +v1.2.2"@en .

netex:VehicleSharingParkingArea a skos:Concept ;
    skos:prefLabel "vehicle sharing parking area"@en ;
    skos:altLabel "vehiclesharingparkingarea"@en ;
    rdfs:comment "A dedicated part of the PARKING AREA for vehicle sharing or rental which is composed of one or more VEHICLE SHARING PARKING BAYs. +v1.2.2"@en .

netex:VehicleSharingParkingBay a skos:Concept ;
    skos:prefLabel "spot in the parking"@en ;
    skos:altLabel "vehicle sharing parking bay"@en ;
    skos:altLabel "vehiclesharingparkingbay"@en ;
    rdfs:comment "A spot in the PARKING AREA dedicated to vehicle sharing or rental. +v1.2.2"@en .

netex:VehicleSharingPlaceAssignment a skos:Concept ;
    skos:prefLabel "allocation of a vehicle"@en ;
    skos:altLabel "vehicle sharing place assignment"@en ;
    skos:altLabel "vehiclesharingplaceassignment"@en ;
    rdfs:comment "The allocation of a VEHICLE SHARING AREA to any vehicle sharing or rental service. +V1.2.2"@en .

netex:VehicleSharingService a skos:Concept ;
    skos:prefLabel "transport service offer related"@en ;
    skos:altLabel "vehicle sharing service"@en ;
    skos:altLabel "vehiclesharingservice"@en ;
    rdfs:comment "A transport service offer related to VEHICLE SHARING. +v1.2.2"@en .

netex:VehicleStoppingPlace a skos:Concept ;
    skos:prefLabel "designated place within a stop"@en ;
    skos:altLabel "vehicle stopping place"@en ;
    skos:altLabel "vehiclestoppingplace"@en ;
    rdfs:comment "Designated PLACE within a STOP PLACE for a VEHICLE to stop."@en ;
    skos:related netex:StopPlaceSpace .

netex:VehicleStoppingPosition a skos:Concept ;
    skos:prefLabel "designated position within a vehicle"@en ;
    skos:altLabel "vehicle stopping position"@en ;
    skos:altLabel "vehiclestoppingposition"@en ;
    rdfs:comment "Designated Position within a VEHICLE STOPPING PLACE for a Vehicle to stop."@en ;
    skos:related netex:AccessibilityAssessment, netex:SiteComponent .

netex:VehicleTypeAtPoint a skos:Concept ;
    skos:prefLabel "vehicle type at point"@en ;
    skos:altLabel "vehicletypeatpoint"@en ;
    rdfs:comment "NETWORK RESTRICTION. specifying whether a vehicle of a specified VEHICLE TYPE may visit a point."@en ;
    skos:related netex:NetworkRestriction .

netex:VehicleTypePreference a skos:Concept ;
    skos:prefLabel "preference for the use"@en ;
    skos:altLabel "vehicle type preference"@en ;
    skos:altLabel "vehicletypepreference"@en ;
    rdfs:comment "The preference for the use of a particular VEHICLE TYPE for a SERVICE JOURNEY PATTERN, depending on the DAY TYPE and TIME DEMAND TYPE. The rank of preferences must be recorded. Different VEHICLE TYPEs may be given the same rank."@en .

netex:VehicleTypeStopAssignment a skos:Concept ;
    skos:prefLabel "vehicle type stop assignment"@en ;
    skos:altLabel "vehicletypestopassignment"@en ;
    rdfs:comment "The allocation of a stopping position of a VEHICLE TYPE for a particular VEHICLE JOURNEY."@en ;
    skos:related netex:StopAssignment .

netex:VehicleTypeZoneRestriction a skos:Concept ;
    skos:prefLabel "vehicle type zone restriction"@en ;
    skos:altLabel "vehicletypezonerestriction"@en ;
    rdfs:comment "Restriction on use of a MOBILITY SERVICE CONSTRAINT ZONE for a specific TRANSPORT TYPE. +v1.2.2"@en .

netex:Version a skos:Concept ;
    skos:prefLabel "version"@en ;
    rdfs:comment "DEPRECATED: A group of operational data instances which share the same VALIDITY CONDITIONs. A VERSION belongs to a unique VERSION FRAME and is characterized by a unique TYPE OF VERSION. E.g. NETWORK VERSION for Line 12 starting from 2000-01-01. -v2.0"@en .

netex:VersionFrame a skos:Concept ;
    skos:prefLabel "version frame"@en ;
    skos:altLabel "versionframe"@en ;
    rdfs:comment "A set of VERSIONS referring to a same DATA SYSTEM and belonging to the same TYPE OF FRAME. A FRAME may be restricted by VALIDITY CONDITIONs. Container for a coherent set of versions of objects."@en .

netex:VersionedChild a skos:Concept ;
    skos:prefLabel "child entiity whose responsibility"@en ;
    skos:altLabel "versioned child"@en ;
    skos:altLabel "versionedchild"@en ;
    rdfs:comment "A child ENTIITY whose RESPONSIBILITY SET must be the same as its containing parent object, and which cannot exist independently of its parent."@en .

netex:VisualSignsAvailable a skos:Concept ;
    skos:prefLabel "visual signs available"@en ;
    skos:altLabel "visualsignsavailable"@en ;
    skos:altLabel "whether a place has visual"@en ;
    rdfs:comment "Whether a PLACE has visual signals available for the free access."@en .

netex:WaitingEquipment a skos:Concept ;
    skos:prefLabel "specialisation of site equipment for"@en ;
    skos:altLabel "waiting equipment"@en ;
    skos:altLabel "waitingequipment"@en ;
    rdfs:comment "Specialisation of SITE EQUIPMENT for WAITING EQUIPMENTs (shelter, waiting room, etc.)."@en ;
    skos:related netex:SiteEquipment .

netex:WaitingRoomEquipment a skos:Concept ;
    skos:prefLabel "specialisation of waiting equipment for"@en ;
    skos:altLabel "waiting room equipment"@en ;
    skos:altLabel "waitingroomequipment"@en ;
    rdfs:comment "Specialisation of WAITING EQUIPMENT for WAITING ROOMs, classified by TYPE OF WAITING ROOM."@en ;
    skos:related netex:SiteEquipment .

netex:WaterSubmode a skos:Concept ;
    skos:prefLabel "tpeg pti07 water submodes"@en ;
    skos:altLabel "water submode"@en ;
    skos:altLabel "watersubmode"@en ;
    rdfs:comment "TPEG pti07 Water submodes."@en .

netex:WheelchairAccess a skos:Concept ;
    skos:prefLabel "wheelchair access"@en ;
    skos:altLabel "wheelchairaccess"@en ;
    skos:altLabel "whether a place is wheelchair"@en ;
    rdfs:comment "Whether a PLACE is wheelchair accessible."@en .

netex:WheelchairVehicleEquipment a skos:Concept ;
    skos:prefLabel "specialisation of vehicle equipment for"@en ;
    skos:altLabel "wheelchair vehicle equipment"@en ;
    skos:altLabel "wheelchairvehicleequipment"@en ;
    rdfs:comment "Specialisation of VEHICLE EQUIPMENT for Wheel chair accessibility on board a VEHICLE providing information such as the number of wheel chair areas and the access dimensions."@en ;
    skos:related netex:PassengerEquipment .

netex:Whitelist a skos:Concept ;
    skos:prefLabel "whitelist"@en ;
    rdfs:comment "A list of items (TRAVEL DOCUMENTs, CONTRACTs, etc) explicitly approved for processing.+v1.1"@en .

netex:WireElement a skos:Concept ;
    skos:prefLabel "wire element"@en ;
    skos:altLabel "wireelement"@en ;
    rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a WIRE network."@en .

netex:WireJunction a skos:Concept ;
    skos:prefLabel "wire junction"@en ;
    skos:altLabel "wirejunction"@en ;
    rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a WIRE network."@en ;
    skos:related netex:InfrastructurePoint .

netex:Zone a skos:Concept ;
    skos:prefLabel "zone"@en ;
    rdfs:comment "A two-dimensional PLACE within the service area of a public transport operator (administrative zone, TARIFF ZONE, ACCESS ZONE, etc.)."@en .

netex:ZoneInSeries a skos:Concept ;
    skos:prefLabel "use of a zone in"@en ;
    skos:altLabel "zone in series"@en ;
    skos:altLabel "zoneinseries"@en ;
    rdfs:comment "Use of a ZONE in sequence within a SERIES CONSTRAINT, for example to indicate that a series must route through a given sequence of TARIFF ZONEs, +v2.0"@en .

netex:ZoneProjection a skos:Concept ;
    skos:prefLabel "zone projection"@en ;
    skos:altLabel "zoneprojection"@en ;
    rdfs:comment "An oriented correspondence from one ZONE in a source layer, onto a target entity : e.g. POINT, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."@en ;
    skos:related netex:Projection .

netex:keyList a skos:Concept ;
    skos:prefLabel "key list"@en ;
    skos:altLabel "keylist"@en ;
    skos:altLabel "list of alternative key"@en ;
    rdfs:comment "A list of alternative Key values for an element."@en .

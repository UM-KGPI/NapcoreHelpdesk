@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix nits:  <https://napcore.eu/ontology/nits#> .
@prefix netex: <https://netex.org.uk/netex/2.0#> .

#################################################################
# Ontology Header
#################################################################

<https://napcore.eu/ontology/nits/align/netex>
    a owl:Ontology ;
    dct:title "NITS–NeTEx Alignment Ontology"@en ;
    dct:description "Alignment ontology connecting NeTEx concepts to abstract core concepts defined in the NAPCORE ITS Core Ontology. Enables cross-standard reasoning and question routing."@en ;
    dct:creator "NAPCORE Working Group" ;
    dct:created "2026-04-17"^^xsd:date ;
    owl:versionIRI <https://napcore.eu/ontology/nits/align/netex/0.1> ;
    owl:versionInfo "0.1-draft" ;
    owl:imports <https://napcore.eu/ontology/nits/core> ;
    owl:imports <https://netex.org.uk/netex/2.0> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Core Transport Concept Alignments
#################################################################

netex:NeTEx
    owl:equivalentClass nits:NeTExSpecification .

netex:Service
    owl:equivalentClass nits:Service .

netex:Journey
    owl:equivalentClass nits:Journey .

netex:ServiceJourney
    rdfs:subClassOf nits:Journey .

netex:ServiceJourneyPattern
    rdfs:subClassOf nits:JourneyPattern .

netex:JourneyPattern
    owl:equivalentClass nits:JourneyPattern .

netex:Timetable
    owl:equivalentClass nits:Timetable .

netex:StopPlace
    rdfs:subClassOf nits:Stop .

netex:ScheduledStopPoint
    owl:equivalentClass nits:Stop .

netex:Quay
    rdfs:subClassOf nits:Stop .

netex:Route
    rdfs:subClassOf nits:Journey .

netex:Line
    owl:equivalentClass nits:Line ;
    rdfs:subClassOf nits:Service .

netex:Network
    owl:equivalentClass nits:Network .

#################################################################
# Spatial Concept Alignments
#################################################################

netex:Location
    owl:equivalentClass nits:Location .

#################################################################
# Actor & Governance Alignments
#################################################################

netex:Organisation
    owl:equivalentClass nits:Organisation .

netex:Authority
    owl:equivalentClass nits:Authority .

netex:Operator
    rdfs:subClassOf nits:Actor ;
    rdfs:subClassOf nits:Organisation .

netex:AffiliatedProvider
    rdfs:subClassOf nits:Organisation .

#################################################################
# Temporal Concept Alignments
#################################################################

netex:DayType
    rdfs:subClassOf nits:TemporalEntity .

netex:OperatingPeriod
    rdfs:subClassOf nits:TemporalEntity .

netex:ServiceCalendar
    rdfs:subClassOf nits:DataArtifact .

#################################################################
# Accessibility & Facility Alignments
#################################################################

netex:AccessibilityAssessment
    rdfs:subClassOf nits:DataArtifact .

netex:AccessEquipment
    rdfs:subClassOf nits:DataArtifact .

netex:PassengerEquipment
    rdfs:subClassOf nits:DataArtifact .

#################################################################
# Fare & Product Alignments
#################################################################

netex:FareProduct
    rdfs:subClassOf nits:DataArtifact .

netex:FareZone
    rdfs:subClassOf nits:SpatialEntity .

#################################################################
# Property Alignments
#################################################################

netex:operatedBy
    rdfs:subPropertyOf nits:involves .

netex:hasTimetable
    rdfs:subPropertyOf nits:involves .

netex:followsRoute
    rdfs:subPropertyOf nits:involves .

netex:visitsStop
    rdfs:subPropertyOf nits:involves .

netex:isPartOfService
    rdfs:subPropertyOf nits:involves .

netex:usesJourneyPattern
    rdfs:subPropertyOf nits:involves .

netex:hasAccessibility
    rdfs:subPropertyOf nits:involves .

netex:offersProduct
    rdfs:subPropertyOf nits:involves .

netex:inNetwork
    rdfs:subPropertyOf nits:involves .

#################################################################
# XSD-Grounded Extended Alignments
#################################################################

netex:Platform
    rdfs:subClassOf nits:Stop .

netex:StopArea
    rdfs:subClassOf nits:SpatialEntity .

netex:DeadRun
    rdfs:subClassOf nits:Journey .

netex:MonitoredVehicleJourney
    rdfs:subClassOf nits:RealTimeInformation .

netex:Vehicle
    rdfs:subClassOf nits:System .

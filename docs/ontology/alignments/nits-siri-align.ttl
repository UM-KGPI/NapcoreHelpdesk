@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix nits: <https://napcore.eu/ontology/nits#> .
@prefix siri: <http://www.siri.org.uk/siri/2.1#> .

#################################################################
# Ontology Header
#################################################################

<https://napcore.eu/ontology/nits/align/siri>
    a owl:Ontology ;
    dct:title "NITS–SIRI Alignment Ontology"@en ;
    dct:description "Alignment ontology connecting XSD-derived SIRI concepts to abstract core concepts defined in the NAPCORE ITS Core Ontology. Enables cross-standard reasoning and real-time information discovery."@en ;
    dct:creator "NAPCORE Working Group" ;
    dct:created "2026-04-17"^^xsd:date ;
    owl:versionIRI <https://napcore.eu/ontology/nits/align/siri/0.1> ;
    owl:versionInfo "0.1-draft" ;
    owl:imports <https://napcore.eu/ontology/nits/core> ;
    owl:imports <http://www.siri.org.uk/siri/2.1> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Delivery Artifact Alignments
#################################################################

siri:EstimatedTimetableDelivery
    rdfs:subClassOf nits:DataArtifact .

siri:VehicleMonitoringDelivery
    rdfs:subClassOf nits:DataArtifact .

siri:StopMonitoringDelivery
    rdfs:subClassOf nits:DataArtifact .

#################################################################
# Situation & Event Alignments
#################################################################

siri:PtSituationElement
    owl:equivalentClass nits:Situation ;
    rdfs:subClassOf nits:Event .

siri:SituationExchangeDelivery
    rdfs:subClassOf nits:DataArtifact .

#################################################################
# Journey & Stop Alignments
#################################################################

siri:EstimatedVehicleJourney
    owl:equivalentClass nits:Journey .

siri:DatedCall
    rdfs:subClassOf nits:JourneyComponent .

siri:EstimatedCall
    rdfs:subClassOf nits:JourneyComponent .

siri:RecordedCall
    rdfs:subClassOf nits:JourneyComponent .

siri:MonitoredStopVisit
    rdfs:subClassOf nits:Event .

siri:StopPointName
    rdfs:subClassOf nits:DataArtifact .

#################################################################
# Vehicle & Position Alignments
#################################################################

siri:ExpectedDepartureTime
    rdfs:subClassOf nits:TemporalEntity .

#################################################################
# Status & Operational Alignments
#################################################################

siri:DepartureStatus
    rdfs:subClassOf nits:DataArtifact .

siri:JourneyNote
    rdfs:subClassOf nits:DataArtifact .


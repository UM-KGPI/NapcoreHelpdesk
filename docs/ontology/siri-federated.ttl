@prefix nits: <https://napcore.eu/ontology/nits#> .
@prefix netex: <https://napcore.eu/ontology/netex#> .
@prefix opra: <https://napcore.eu/ontology/opra#> .
@prefix siri: <https://napcore.eu/ontology/siri#> .
@prefix datex: <https://napcore.eu/ontology/datex#> .
@prefix transmodel: <https://napcore.eu/ontology/transmodel#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://napcore.eu/ontology/siri-federated>
    a owl:Ontology ;
    dcterms:title "SIRI Federated Ontology"@en ;
    dcterms:description "SIRI-focused federated ontology module generated from the local glossary and linked to NAPCORE ITS core concepts."@en ;
    dcterms:created "2026-04-16"^^xsd:date ;
    owl:versionInfo "0.3.0" ;
    owl:imports <https://napcore.eu/ontology/napcore-its> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

siri:AbstractDiscoveryDelivery a skos:Concept ;
    skos:prefLabel "abstract discovery delivery"@en ;
    skos:altLabel "abstract type for a discovery"@en ;
    skos:altLabel "abstractdiscoverydelivery"@en ;
    rdfs:comment "Abstract type for a discovery delivery."@en ;
    skos:related siri:AbstractResponse .

siri:AbstractDiscoveryRequest a skos:Concept ;
    skos:prefLabel "abstract discovery request"@en ;
    skos:altLabel "abstractdiscoveryrequest"@en ;
    rdfs:comment "Abstract Discovery request."@en ;
    skos:related siri:AuthenticatedRequest .

siri:AbstractFunctionalServiceCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "abstract functional service capabilities request"@en ;
    skos:altLabel "abstractfunctionalservicecapabilitiesrequest"@en ;
    rdfs:comment "Subsititutable type for a SIRI Functional Service Capabiloitiesequest."@en ;
    skos:related siri:AbstractServiceRequest .

siri:AbstractFunctionalServiceCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "abstract functional service capabilities response"@en ;
    skos:altLabel "abstractfunctionalservicecapabilitiesresponse"@en ;
    rdfs:comment "Subsititutable type for a SIRI Functional Service Capabiloitiesequest."@en ;
    skos:related siri:AbstractResponse .

siri:AbstractFunctionalServiceDelivery a skos:Concept ;
    skos:prefLabel "abstract functional service delivery"@en ;
    skos:altLabel "abstractfunctionalservicedelivery"@en ;
    rdfs:comment "Subsititutable type for a SIRI Functional Service request."@en ;
    skos:related siri:AbstractResponse .

siri:AbstractFunctionalServiceRequest a skos:Concept ;
    skos:prefLabel "abstract functional service request"@en ;
    skos:altLabel "abstractfunctionalservicerequest"@en ;
    rdfs:comment "Subsititutable type for a SIRI Functional Service request."@en ;
    skos:related siri:AbstractServiceRequest .

siri:AbstractFunctionalServiceSubscriptionRequest a skos:Concept ;
    skos:prefLabel "abstract functional service subscription request"@en ;
    skos:altLabel "abstractfunctionalservicesubscriptionrequest"@en ;
    rdfs:comment "Subsititutable type for a SIRI Functional Service subscription request."@en .

siri:AbstractRequest a skos:Concept ;
    skos:prefLabel "abstract request"@en ;
    skos:altLabel "abstractrequest"@en ;
    rdfs:comment "Subsititutable type for a timestamped SIRI request."@en .

siri:AbstractResponse a skos:Concept ;
    skos:prefLabel "abstract response"@en ;
    skos:altLabel "abstractresponse"@en ;
    rdfs:comment "Subsititutable type for a SIRI response."@en .

siri:AbstractServiceRequest a skos:Concept ;
    skos:prefLabel "abstract service request"@en ;
    skos:altLabel "abstractservicerequest"@en ;
    rdfs:comment "Substitutable type for a SIRI Functional Service request."@en ;
    skos:related siri:AbstractRequest .

siri:AbstractTrackedRequest a skos:Concept ;
    skos:prefLabel "abstract tracked request"@en ;
    skos:altLabel "abstracttrackedrequest"@en ;
    rdfs:comment "Subsititutable type for a SIRI request with requestor dteials tracked."@en .

siri:AccessFacility a skos:Concept ;
    skos:prefLabel "access facility"@en ;
    skos:altLabel "accessfacility"@en ;
    skos:altLabel "classification of access facility"@en ;
    rdfs:comment "Classification of Access Facility."@en .

siri:AccessNotAllowedError a skos:Concept ;
    skos:prefLabel "access not allowed error"@en ;
    skos:altLabel "accessnotallowederror"@en ;
    skos:altLabel "error requestor is not authorised"@en ;
    rdfs:comment "Error: Requestor is not authorised to the service or data requested."@en .

siri:AccommodationFacility a skos:Concept ;
    skos:prefLabel "accommodation facility"@en ;
    skos:altLabel "accommodationfacility"@en ;
    skos:altLabel "classification of accomodation facility type"@en ;
    rdfs:comment "Classification of Accomodation Facility type - Tpeg pti23."@en .

siri:ActualArrivalTime a skos:Concept ;
    skos:prefLabel "actual arrival time"@en ;
    skos:altLabel "actualarrivaltime"@en ;
    skos:altLabel "observed time of arrival of"@en ;
    rdfs:comment "Observed time of arrival of VEHICLE at stop."@en .

siri:ActualDepartureTime a skos:Concept ;
    skos:prefLabel "actual departure time"@en ;
    skos:altLabel "actualdeparturetime"@en ;
    skos:altLabel "observed time of departure of"@en ;
    rdfs:comment "Observed time of departure of VEHICLE from stop."@en .

siri:ActualHeadwayInterval a skos:Concept ;
    skos:prefLabel "actual headway interval"@en ;
    skos:altLabel "actualheadwayinterval"@en ;
    rdfs:comment "For frequency based services, observed interval between vehicles at stop."@en .

siri:AimedArrivalTime a skos:Concept ;
    skos:prefLabel "aimed arrival time"@en ;
    skos:altLabel "aimedarrivaltime"@en ;
    skos:altLabel "target arrival time of vehicle"@en ;
    rdfs:comment "Target arrival time of VEHICLE at stop according to latest working timetable."@en .

siri:AimedArrivalTimeOfFeeder a skos:Concept ;
    skos:prefLabel "aimed arrival time of feeder"@en ;
    skos:altLabel "aimedarrivaltimeoffeeder"@en ;
    skos:altLabel "planned time at which feeder"@en ;
    rdfs:comment "Planned time at which feeder VEHICLE is scheduled to arrive. (since SIRI 2.1)"@en .

siri:AimedDepartureTime a skos:Concept ;
    skos:prefLabel "aimed departure time"@en ;
    skos:altLabel "aimeddeparturetime"@en ;
    skos:altLabel "target departure time of vehicle"@en ;
    rdfs:comment "Target departure time of VEHICLE from stop according to latest working timetable."@en .

siri:AimedDepartureTimeOfDistributor a skos:Concept ;
    skos:prefLabel "aimed departure time of distributor"@en ;
    skos:altLabel "aimeddeparturetimeofdistributor"@en ;
    skos:altLabel "planned time at which distributor"@en ;
    rdfs:comment "Planned time at which distributor VEHICLE is scheduled to depart. (since SIRI 2.1)"@en .

siri:AimedFlexibleArea a skos:Concept ;
    skos:prefLabel "aimed flexible area"@en ;
    skos:altLabel "aimedflexiblearea"@en ;
    skos:altLabel "area that encompasses the scheduled"@en ;
    rdfs:comment "Area that encompasses the scheduled flexible stop locations according to the planned timetable. (since SIRI 2.1)"@en .

siri:AimedHeadwayInterval a skos:Concept ;
    skos:prefLabel "aimed headway interval"@en ;
    skos:altLabel "aimedheadwayinterval"@en ;
    rdfs:comment "For frequency based services, target interval between vehicles at stop."@en .

siri:AimedLatestPassengerAccessTime a skos:Concept ;
    skos:prefLabel "aimed latest passenger access time"@en ;
    skos:altLabel "aimedlatestpassengeraccesstime"@en ;
    rdfs:comment "Latest target time at which a PASSENGER should aim to arrive at the STOP PLACE containing the stop. This time may be earlier than the VEHICLE departure times and may include time for processes such as checkin, security, etc.(As specified by CHECK CONSTRAINT DELAYs in the underlying data). If absent assume to be the same as Earliest expected departure time. (since SIRI 2.0)"@en .

siri:AimedLocationName a skos:Concept ;
    skos:prefLabel "aimed location name"@en ;
    skos:altLabel "aimedlocationname"@en ;
    skos:altLabel "name or description eg address"@en ;
    rdfs:comment "Name or description (e.g. address) of the scheduled location or flexible area. (since SIRI 2.1)"@en .

siri:AirSubmode a skos:Concept ;
    skos:prefLabel "air submode"@en ;
    skos:altLabel "airsubmode"@en ;
    rdfs:comment "TPEG Pti08 and Pts108 \"AirService\" submodes."@en .

siri:AllowAll a skos:Concept ;
    skos:prefLabel "allow access to all topics"@en ;
    skos:altLabel "allow all"@en ;
    skos:altLabel "allowall"@en ;
    rdfs:comment "Allow access to all topics known to the service."@en .

siri:AllowedResourceUsageExceededError a skos:Concept ;
    skos:prefLabel "allowed resource usage exceeded error"@en ;
    skos:altLabel "allowedresourceusageexceedederror"@en ;
    skos:altLabel "error valid request was made"@en ;
    rdfs:comment "Error: Valid request was made but request would exceed the permitted resource usage of the client."@en .

siri:ArrivalBoardingActivity a skos:Concept ;
    skos:prefLabel "arrival boarding activity"@en ;
    skos:altLabel "arrivalboardingactivity"@en ;
    rdfs:comment "Type of alighting allowed at stop. Default is 'Alighting'."@en .

siri:ArrivalCancellationReason a skos:Concept ;
    skos:prefLabel "arrival cancellation reason"@en ;
    skos:altLabel "arrivalcancellationreason"@en ;
    rdfs:comment "Text annotation to be used in cases where ArrivalStatus is set to 'cancelled'. (since SIRI 2.1)"@en .

siri:ArrivalFormationAssignment a skos:Concept ;
    skos:prefLabel "arrival formation assignment"@en ;
    skos:altLabel "arrivalformationassignment"@en ;
    skos:altLabel "assignment of a train formation"@en ;
    rdfs:comment "Assignment of a TRAIN formation to a physical QUAY (platform or sectors thereof). If not given, assume same as for departure. (since SIRI 2.1)"@en .

siri:ArrivalOrientationRelativeToQuay a skos:Concept ;
    skos:prefLabel "arrival orientation relative to quay"@en ;
    skos:altLabel "arrivalorientationrelativetoquay"@en ;
    rdfs:comment "Indication of the direction of travel of the vehicle (e.g. TRAIN formation) with respect to the platform, or more precisely the QUAY. Unbounded to allow multiple languages. (since SIRI 2.1) Examples: - \"towards A\" or \"towards sector A\" if the QUAY is separated into sub-QUAYs or so called sectors. This would be equivalent to the vehicle arriving at sector A first when approaching the QUAY with sectors A-B-C-D. If the arriving vehicle is represented as an arrow, \"towards A\" would be abstracted as \"=> A-B-C-D\". - \"towards 0\" or \"towards reference point 0\" if sectors are not available or the QUAY has a reference point, e.g. for measuring the length of the QUAY, identified by \"0\". This would be equivalent to the vehicle arriving at this reference point first when approaching the QUAY. If the arriving vehicle is represented as an arrow, \"towards 0\" would be abstracted as \"=> 0...100\". \"100\" (as in percent) could denote the opposite side of the QUAY (measured at the full length of the QUAY with respect to the reference point). It is advised to specify a reference point that is meaningful for passengers on location."@en .

siri:ArrivalPlatformName a skos:Concept ;
    skos:prefLabel "arrival platform name"@en ;
    skos:altLabel "arrivalplatformname"@en ;
    skos:altLabel "bay or platform quay name"@en ;
    rdfs:comment "Bay or platform (QUAY) name to show passenger i.e. expected platform for vehicle to arrive at. Inheritable property. Can be omitted if the same as the DeparturePlatformName If there no arrival platform name separate from the departure platform name, the precedence is: (i) any arrival platform on any related dated timetable element, (ii) any departure platform name on this estimated element; (iii) any departure platform name on any related dated timetable CALL."@en .

siri:ArrivalProximityText a skos:Concept ;
    skos:prefLabel "arbitrary text string to show"@en ;
    skos:altLabel "arrival proximity text"@en ;
    skos:altLabel "arrivalproximitytext"@en ;
    rdfs:comment "Arbitrary text string to show to indicate the status of the departure of the VEHICLE for example, “Enroute”, “5 Km”, “Approaching”. May depend on the policy of the OPERATOR, for example show “Approaching” if less than 200metres away from stop. (since SIRI 2.0)"@en .

siri:ArrivalStatus a skos:Concept ;
    skos:prefLabel "arrival status"@en ;
    skos:altLabel "arrivalstatus"@en ;
    rdfs:comment "Classification of the timeliness of the visit according to a fixed list of values. If not specified, same as DepartureStatus."@en .

siri:AssistanceFacility a skos:Concept ;
    skos:prefLabel "assistance facility"@en ;
    skos:altLabel "assistancefacility"@en ;
    skos:altLabel "classification of assistance facility"@en ;
    rdfs:comment "Classification of Assistance Facility."@en .

siri:AuthenticatedRequest a skos:Concept ;
    skos:prefLabel "authenticated request"@en ;
    skos:altLabel "authenticatedrequest"@en ;
    skos:altLabel "subsititutable type for an authenticated"@en ;
    rdfs:comment "Subsititutable type for an authenticated request Authenticated."@en .

siri:BeyondDataHorizon a skos:Concept ;
    skos:prefLabel "beyond data horizon"@en ;
    skos:altLabel "beyonddatahorizon"@en ;
    skos:altLabel "error data period or subscription"@en ;
    rdfs:comment "Error: Data period or subscription period is outside of period covered by service."@en .

siri:BusSubmode a skos:Concept ;
    skos:prefLabel "bus submode"@en ;
    skos:altLabel "bussubmode"@en ;
    rdfs:comment "TPEG Pti05 and Pts105 \"BusService\" submodes."@en .

siri:CapabilitiesRequest a skos:Concept ;
    skos:prefLabel "capabilities request"@en ;
    skos:altLabel "capabilitiesrequest"@en ;
    skos:altLabel "requests a the current capabilities"@en ;
    rdfs:comment "Requests a the current capabilities of the server. Answred with a CpabailitiesResponse."@en .

siri:CapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities response"@en ;
    skos:altLabel "capabilitiesresponse"@en ;
    skos:altLabel "responses with the capabilities of"@en ;
    rdfs:comment "Responses with the capabilities of an implementation."@en .

siri:CapabilityNotSupportedError a skos:Concept ;
    skos:prefLabel "capability not supported error"@en ;
    skos:altLabel "capabilitynotsupportederror"@en ;
    skos:altLabel "error service does not support"@en ;
    rdfs:comment "Error: Service does not support the requested capability."@en .

siri:CheckStatusRequest a skos:Concept ;
    skos:prefLabel "check status request"@en ;
    skos:altLabel "checkstatusrequest"@en ;
    skos:altLabel "request from consumer to producer"@en ;
    rdfs:comment "Request from Consumer to Producer to check whether services is working. Answers a CheckStatusRequest."@en ;
    skos:related siri:AbstractTrackedRequest .

siri:CheckStatusResponse a skos:Concept ;
    skos:prefLabel "check status response"@en ;
    skos:altLabel "checkstatusresponse"@en ;
    skos:altLabel "response from producer to consumer"@en ;
    rdfs:comment "Response from Producer to Consumer to inform whether services is working. Answers a CheckStatusRequest."@en ;
    skos:related siri:AbstractResponse .

siri:CoachSubmode a skos:Concept ;
    skos:prefLabel "coach submode"@en ;
    skos:altLabel "coachsubmode"@en ;
    rdfs:comment "TPEG Pti03 and Pts103 \"CoachService\" submodes."@en .

siri:CompoundTrain a skos:Concept ;
    skos:prefLabel "compound train"@en ;
    skos:altLabel "compoundtrain"@en ;
    rdfs:comment "Groups of carriages may be managed as sections by composing TRAINs into a COMPOUND TRAIN, for example if a TRAIN joins (or splits from) another TRAIN. (since SIRI 2.1) TRAINs within a COMPOUND TRAIN may have different origins and destinations due to joining/splitting. A COMPOUND TRAIN may be stable for one or multiple JOURNEY PARTs and change at a certain STOP POINT due to planned joining/splitting, despatching alterations or a situation."@en .

siri:Condition a skos:Concept ;
    skos:prefLabel "condition"@en ;
    rdfs:comment "Classification of effect on service. TPEG PTS043 ServiceStatus"@en .

siri:ConnectionLinkPermissions a skos:Concept ;
    skos:prefLabel "connection link permissions"@en ;
    skos:altLabel "connection links that the"@en ;
    skos:altLabel "connectionlinkpermissions"@en ;
    rdfs:comment "The CONNECTION links that the participant may access."@en ;
    skos:related siri:AllowAll .

siri:ConnectionLinksDelivery a skos:Concept ;
    skos:prefLabel "connection links delivery"@en ;
    skos:altLabel "connectionlinksdelivery"@en ;
    skos:altLabel "returns the connection links covered"@en ;
    rdfs:comment "Returns the CONNECTION LINKs covered by a web service. Answers a LINEsRequest. (since SIRI 2.0)"@en ;
    skos:related siri:AbstractDiscoveryDelivery .

siri:ConnectionLinksRequest a skos:Concept ;
    skos:prefLabel "connection links request"@en ;
    skos:altLabel "connectionlinksrequest"@en ;
    rdfs:comment "Requests a list of the CONNECTION LINKs covered by a Producer. (since SIRI 2.0)"@en ;
    skos:related siri:AbstractDiscoveryRequest .

siri:ConnectionMonitoringCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "connection monitoring capabilities request"@en ;
    skos:altLabel "connectionmonitoringcapabilitiesrequest"@en ;
    skos:altLabel "request for information about connection"@en ;
    rdfs:comment "Request for information about Connection Monitoring Service Capabilities. Answered with a ConnectionMontoringCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

siri:ConnectionMonitoringCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities for connection monitoring service"@en ;
    skos:altLabel "connection monitoring capabilities response"@en ;
    skos:altLabel "connectionmonitoringcapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for Connection Monitoring Service. Answers a ConnectionMontoringCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

siri:ConnectionMonitoringDistributorDelivery a skos:Concept ;
    skos:prefLabel "connection monitoring distributor delivery"@en ;
    skos:altLabel "connectionmonitoringdistributordelivery"@en ;
    skos:altLabel "distributor delivery for connection monitoring"@en ;
    rdfs:comment "Distributor Delivery for Connection Monitoring Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:ConnectionMonitoringFeederDelivery a skos:Concept ;
    skos:prefLabel "connection monitoring feeder delivery"@en ;
    skos:altLabel "connectionmonitoringfeederdelivery"@en ;
    skos:altLabel "feeder delivery for connection monitoring"@en ;
    rdfs:comment "Feeder Delivery for Connection Monitoring Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:ConnectionMonitoringPermissions a skos:Concept ;
    skos:prefLabel "connection monitoring permissions"@en ;
    skos:altLabel "connectionmonitoringpermissions"@en ;
    skos:altLabel "participants permissions to use the"@en ;
    rdfs:comment "Participants permissions to use the service."@en .

siri:ConnectionMonitoringRequest a skos:Concept ;
    skos:prefLabel "connection monitoring request"@en ;
    skos:altLabel "connectionmonitoringrequest"@en ;
    skos:altLabel "request for information about changes"@en ;
    rdfs:comment "Request for information about changes to connections at a stop for Connection Monitoring service."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:ConnectionMonitoringServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of connection monitoring service"@en ;
    skos:altLabel "connection monitoring service capabilities"@en ;
    skos:altLabel "connectionmonitoringservicecapabilities"@en ;
    rdfs:comment "Capabilities of Connection Monitoring Service."@en .

siri:ConnectionMonitoringSubscriptionRequest a skos:Concept ;
    skos:prefLabel "connection monitoring subscription request"@en ;
    skos:altLabel "connectionmonitoringsubscriptionrequest"@en ;
    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to Connection Monitoring Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:ConnectionTimetableCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "connection timetable capabilities request"@en ;
    skos:altLabel "connectiontimetablecapabilitiesrequest"@en ;
    skos:altLabel "request for information about connection"@en ;
    rdfs:comment "Request for information about Connection Timetable Service Capabilities. Answered with a ConnectionTimetableCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

siri:ConnectionTimetableCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities for connection timetable service"@en ;
    skos:altLabel "connection timetable capabilities response"@en ;
    skos:altLabel "connectiontimetablecapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for Connection Timetable Service. Answers a ConnectionTimetableCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

siri:ConnectionTimetableDelivery a skos:Concept ;
    skos:prefLabel "connection timetable delivery"@en ;
    skos:altLabel "connectiontimetabledelivery"@en ;
    skos:altLabel "delivery for connection timetable service"@en ;
    rdfs:comment "Delivery for Connection Timetable Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:ConnectionTimetableRequest a skos:Concept ;
    skos:prefLabel "connection timetable request"@en ;
    skos:altLabel "connectiontimetablerequest"@en ;
    skos:altLabel "request for information about timetabled"@en ;
    rdfs:comment "Request for information about timetabled connections at a stop."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:ConnectionTimetableServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of connection timetable service"@en ;
    skos:altLabel "connection timetable service capabilities"@en ;
    skos:altLabel "connectiontimetableservicecapabilities"@en ;
    rdfs:comment "Capabilities of Connection Timetable Service."@en .

siri:ConnectionTimetableSubscriptionRequest a skos:Concept ;
    skos:prefLabel "connection timetable subscription request"@en ;
    skos:altLabel "connectiontimetablesubscriptionrequest"@en ;
    skos:altLabel "subscription request for information about"@en ;
    rdfs:comment "Subscription Request for information about Timetabled connections at a stop."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:ControlActionCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "control action capabilities request"@en ;
    skos:altLabel "controlactioncapabilitiesrequest"@en ;
    skos:altLabel "request for information about control"@en ;
    rdfs:comment "Request for information about Control Action Service Capabilities. Answered with ControlActionCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

siri:ControlActionCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities for control action service"@en ;
    skos:altLabel "control action capabilities response"@en ;
    skos:altLabel "controlactioncapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for Control Action Service. Answers a ControlActionCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

siri:ControlActionDelivery a skos:Concept ;
    skos:prefLabel "control action delivery"@en ;
    skos:altLabel "controlactiondelivery"@en ;
    skos:altLabel "delivery for control action service"@en ;
    rdfs:comment "Delivery for Control Action Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:ControlActionMultipleRequest a skos:Concept ;
    skos:prefLabel "control action multiple request"@en ;
    skos:altLabel "controlactionmultiplerequest"@en ;
    skos:altLabel "request for information about stop"@en ;
    rdfs:comment "Request for information about Stop Visits, i.e. arrivals and departures at multiple stops stop. SIRI 1.3"@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:ControlActionPermissions a skos:Concept ;
    skos:prefLabel "control action permissions"@en ;
    skos:altLabel "controlactionpermissions"@en ;
    skos:altLabel "participants permissions to use the"@en ;
    rdfs:comment "Participants permissions to use the service, Only returned if requested."@en .

siri:ControlActionRequest a skos:Concept ;
    skos:prefLabel "control action request"@en ;
    skos:altLabel "controlactionrequest"@en ;
    skos:altLabel "request for information about control"@en ;
    rdfs:comment "Request for information about Control Actions."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:ControlActionServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of controlaction service"@en ;
    skos:altLabel "control action service capabilities"@en ;
    skos:altLabel "controlactionservicecapabilities"@en ;
    rdfs:comment "Capabilities of controlAction Service."@en .

siri:ControlActionSubscriptionRequest a skos:Concept ;
    skos:prefLabel "control action subscription request"@en ;
    skos:altLabel "controlactionsubscriptionrequest"@en ;
    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to Control Action Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:DataReadyAcknowledgement a skos:Concept ;
    skos:prefLabel "data ready acknowledgement"@en ;
    skos:altLabel "datareadyacknowledgement"@en ;
    rdfs:comment "Response from Consumer to Producer to acknowledge to Producer that a DataReadyRequest has been received."@en ;
    skos:related siri:AbstractResponse .

siri:DataReadyNotification a skos:Concept ;
    skos:prefLabel "data ready notification"@en ;
    skos:altLabel "datareadynotification"@en ;
    rdfs:comment "Request from Producer to Consumer to notify that data update is ready to fetch. Answered with a DataReadyResponse."@en .

siri:DataReceivedAcknowledgement a skos:Concept ;
    skos:prefLabel "data received acknowledgement"@en ;
    skos:altLabel "datareceivedacknowledgement"@en ;
    rdfs:comment "Response from Consumer to Producer to acknowledge that data hase been received. Used as optioanl extra step if reliable delivery is needed. Answers a ServiceDelivery."@en ;
    skos:related siri:AbstractResponse .

siri:DataSupplyRequest a skos:Concept ;
    skos:prefLabel "data supply request"@en ;
    skos:altLabel "datasupplyrequest"@en ;
    skos:altLabel "request from consumer to producer"@en ;
    rdfs:comment "Request from Consumer to Producer to fetch update previously notified by a Data ready message. Answered with a Service Delivery."@en ;
    skos:related siri:AbstractRequest .

siri:DatedCall a skos:Concept ;
    skos:prefLabel "dated call"@en ;
    skos:altLabel "datedcall"@en ;
    rdfs:comment "Complete sequence of stops along the route path, in calling order."@en .

siri:DatedTimetableVersionFrame a skos:Concept ;
    skos:prefLabel "dated timetable version frame"@en ;
    skos:altLabel "datedtimetableversionframe"@en ;
    skos:altLabel "timetable frame to run"@en ;
    rdfs:comment "A TIMETABLE FRAME to run on a specified date."@en .

siri:DatedVehicleJourney a skos:Concept ;
    skos:prefLabel "dated vehicle journey"@en ;
    skos:altLabel "datedvehiclejourney"@en ;
    skos:altLabel "planned vehicle journey taking"@en ;
    rdfs:comment "A planned VEHICLE JOURNEY taking place on a particular date."@en .

siri:DepartureBoardingActivity a skos:Concept ;
    skos:prefLabel "departure boarding activity"@en ;
    skos:altLabel "departureboardingactivity"@en ;
    skos:altLabel "nature of boarding allowed at"@en ;
    rdfs:comment "Nature of boarding allowed at stop. Default is 'Boarding'."@en .

siri:DepartureCancellationReason a skos:Concept ;
    skos:prefLabel "departure cancellation reason"@en ;
    skos:altLabel "departurecancellationreason"@en ;
    rdfs:comment "Text annotation to be used in cases where DepartureStatus is set to 'cancelled'. (since SIRI 2.1)"@en .

siri:DepartureFormationAssignment a skos:Concept ;
    skos:prefLabel "assignment of a train formation"@en ;
    skos:altLabel "departure formation assignment"@en ;
    skos:altLabel "departureformationassignment"@en ;
    rdfs:comment "Assignment of a TRAIN formation to a physical QUAY (platform or sectors thereof). (since SIRI 2.1)"@en .

siri:DepartureOrientationRelativeToQuay a skos:Concept ;
    skos:prefLabel "departure orientation relative to quay"@en ;
    skos:altLabel "departureorientationrelativetoquay"@en ;
    rdfs:comment "Indication of the direction of travel of the vehicle (e.g. TRAIN formation) with respect to the platform, or more precisely the QUAY. Unbounded to allow multiple languages. (since SIRI 2.1) Examples: - \"towards A\" or \"towards sector A\" if the QUAY is separated into sub-QUAYs or so called sectors. This would be equivalent to the vehicle departing in the direction of sector A on a QUAY with sectors A-B-C-D. If the departing vehicle is represented as an arrow, \"towards A\" would be abstracted as \"<= A-B-C-D\". - \"towards 0\" or \"towards reference point 0\" if sectors are not available or the QUAY has a reference point, e.g. for measuring the length of the QUAY, identified by \"0\". This would be equivalent to the vehicle departing in the direction of this reference point. If the departing vehicle is represented as an arrow, \"towards 0\" would be abstracted as \"<= 0...100\". \"100\" (as in percent) could denote the opposite side of the QUAY (measured at the full length of the QUAY with respect to the reference point). It is advised to specify a reference point that is meaningful for passengers on location."@en .

siri:DeparturePlatformName a skos:Concept ;
    skos:prefLabel "departure platform name"@en ;
    skos:altLabel "departure quay bay or platform"@en ;
    skos:altLabel "departureplatformname"@en ;
    rdfs:comment "Departure QUAY (bay or platform) name. Default taken from planned timetable."@en .

siri:DepartureProximityText a skos:Concept ;
    skos:prefLabel "arbitrary text string to show"@en ;
    skos:altLabel "departure proximity text"@en ;
    skos:altLabel "departureproximitytext"@en ;
    rdfs:comment "Arbitrary text string to show to indicate the status of the departure of the vehicle, for example, “Boarding”, “GatesClosed”. (since SIRI 2.0)"@en .

siri:DepartureStatus a skos:Concept ;
    skos:prefLabel "departure status"@en ;
    skos:altLabel "departurestatus"@en ;
    rdfs:comment "Classification of the timeliness of the departure part of the CALL, according to a fixed list of values. This may reflect a presentation policy, for example CALLs less than one minute behind target time are still classified as on-time. Applications may use this to guide their own presentation of times."@en .

siri:Destination a skos:Concept ;
    skos:prefLabel "description of a destination"@en ;
    skos:altLabel "destination"@en ;
    rdfs:comment "Description of a DESTINATION."@en .

siri:DestinationName a skos:Concept ;
    skos:prefLabel "destination name"@en ;
    skos:altLabel "destinationname"@en ;
    skos:altLabel "name of the destination"@en ;
    rdfs:comment "The name of the DESTINATION of the journey; used to help identify the VEHICLE to the public. Note when used in a CALL, this is the Dynamic Destination Display: since vehicles can change their destination during a journey, the destination included here should be what the VEHICLE will display when it reaches the stop."@en .

siri:Direction a skos:Concept ;
    skos:prefLabel "description of a direction"@en ;
    skos:altLabel "direction"@en ;
    rdfs:comment "Description of a DIRECTION."@en .

siri:DistributorStopOrder a skos:Concept ;
    skos:prefLabel "distributor stop order"@en ;
    skos:altLabel "distributorstoporder"@en ;
    rdfs:comment "For implementations in which the overall order is not defined by VISIT NUMBER, i.e. in case VisitNumberIsOrder is set to false, ORDER can be used to associate the stop order instead. ORDER is also used together with VISIT NUMBER in scenarios where an extra CALL is inserted as a result of despatching alterations. Because such an extra CALL may have the same VisitNumber as another (cancelled) CALL, the STOP ORDER is needed. (since SIRI 2.1)"@en .

siri:DistributorVisitNumber a skos:Concept ;
    skos:prefLabel "distributor visit number"@en ;
    skos:altLabel "distributorvisitnumber"@en ;
    skos:altLabel "sequence of visit to distributor"@en ;
    rdfs:comment "Sequence of visit to Distributor stop within Distributor JOURNEY PATTERN."@en .

siri:EndpointDeniedAccessError a skos:Concept ;
    skos:prefLabel "endpoint denied access error"@en ;
    skos:altLabel "endpointdeniedaccesserror"@en ;
    rdfs:comment "Error:Endpoint to which a message is to be distributed did not allow access by the client. (since SIRI 2.0)"@en .

siri:EndpointNotAvailableAccessError a skos:Concept ;
    skos:prefLabel "endpoint not available access error"@en ;
    skos:altLabel "endpointnotavailableaccesserror"@en ;
    rdfs:comment "Error:Recipient of a message to be distributed is not available. (since SIRI 2.0)"@en .

siri:EnvironmentReason a skos:Concept ;
    skos:prefLabel "environment reason"@en ;
    skos:altLabel "environmentreason"@en ;
    rdfs:comment "DEPRECATED and changed to nmtoken since SIRI 2.1 (TPEG Pti22 - Environment Event Reason)"@en .

siri:EnvironmentSubReason a skos:Concept ;
    skos:prefLabel "environment sub reason"@en ;
    skos:altLabel "environmentsubreason"@en ;
    rdfs:comment "DEPRECATED and changed to nmtoken since SIRI 2.1 (TPEG Pti22 - Environment Event Reason)"@en .

siri:EquipmentReason a skos:Concept ;
    skos:prefLabel "equipment reason"@en ;
    skos:altLabel "equipmentreason"@en ;
    rdfs:comment "DEPRECATED and changed to nmtoken since SIRI 2.1 (TPEG Pti21 - Equipment Event Reason)"@en .

siri:EquipmentSubReason a skos:Concept ;
    skos:prefLabel "equipment sub reason"@en ;
    skos:altLabel "equipmentsubreason"@en ;
    rdfs:comment "DEPRECATED and changed to nmtoken since SIRI 2.1 (TPEG Pti21 - Equipment Event Reason)"@en .

siri:ErrorCondition a skos:Concept ;
    skos:prefLabel "description of error or warning"@en ;
    skos:altLabel "error condition"@en ;
    skos:altLabel "errorcondition"@en ;
    rdfs:comment "Description of error or warning condition associated with response."@en .

siri:ErrorConditionElement a skos:Concept ;
    skos:prefLabel "element fror an error condition"@en ;
    skos:altLabel "error condition element"@en ;
    skos:altLabel "errorconditionelement"@en ;
    rdfs:comment "Element fror an error condition (for use in WSDL.)"@en .

siri:EstimatedCall a skos:Concept ;
    skos:prefLabel "estimated call"@en ;
    skos:altLabel "estimatedcall"@en ;
    rdfs:comment "Ordered sequence of SCHEDULED STOP POINTs called at by the VEHICLE JOURNEY. If IsCompleteStopSequence is false, may be just those stops that are altered."@en .

siri:EstimatedServiceJourneyInterchange a skos:Concept ;
    skos:prefLabel "estimated service journey interchange"@en ;
    skos:altLabel "estimatedservicejourneyinterchange"@en ;
    skos:altLabel "realtime service journey interchange"@en ;
    rdfs:comment "A real-time SERVICE JOURNEY INTERCHANGE that may be made between the stops of two monitored journeys. It includes the current real-time predicted transfer and wait times. (since SIRI 2.0)"@en .

siri:EstimatedTimetable a skos:Concept ;
    skos:prefLabel "estimated timetable"@en ;
    skos:altLabel "estimatedtimetable"@en ;
    skos:altLabel "realtime timetable"@en ;
    skos:altLabel "real-time schedule"@en ;
    skos:altLabel "estimated times"@en ;
    rdfs:comment "Real-time estimated arrival and departure times for a vehicle journey"@en .

siri:EstimatedTimetableCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "estimated timetable capabilities request"@en ;
    skos:altLabel "estimatedtimetablecapabilitiesrequest"@en ;
    skos:altLabel "request for information about estimated"@en ;
    rdfs:comment "Request for information about Estimated Timetable Service Capabilities. Answered with a EstimatedTimetableCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

siri:EstimatedTimetableCapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities for estimated timetable service"@en ;
    skos:altLabel "estimated timetable capabilities response"@en ;
    skos:altLabel "estimatedtimetablecapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for Estimated Timetable Service. Answers a EstimatedTimetableCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

siri:EstimatedTimetableDelivery a skos:Concept ;
    skos:prefLabel "delivery for estimated timetable service"@en ;
    skos:altLabel "estimated timetable delivery"@en ;
    skos:altLabel "estimatedtimetabledelivery"@en ;
    rdfs:comment "Delivery for Estimated Timetable Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:EstimatedTimetablePermissions a skos:Concept ;
    skos:prefLabel "estimated timetable permissions"@en ;
    skos:altLabel "estimatedtimetablepermissions"@en ;
    skos:altLabel "participants permissions to use the"@en ;
    rdfs:comment "Participant's permissions to use the service."@en .

siri:EstimatedTimetableRequest a skos:Concept ;
    skos:prefLabel "estimated timetable request"@en ;
    skos:altLabel "estimatedtimetablerequest"@en ;
    skos:altLabel "request for information about the"@en ;
    rdfs:comment "Request for information about the estimated timetable."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:EstimatedTimetableServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of estimated timetableservice"@en ;
    skos:altLabel "estimated timetable service capabilities"@en ;
    skos:altLabel "estimatedtimetableservicecapabilities"@en ;
    rdfs:comment "Capabilities of Estimated TimetableService."@en .

siri:EstimatedTimetableSubscriptionRequest a skos:Concept ;
    skos:prefLabel "estimated timetable subscription request"@en ;
    skos:altLabel "estimatedtimetablesubscriptionrequest"@en ;
    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to the Estimated Timetable Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:EstimatedVehicleJourney a skos:Concept ;
    skos:prefLabel "estimated vehicle journey"@en ;
    skos:altLabel "estimatedvehiclejourney"@en ;
    skos:altLabel "vehicle journey taking place"@en ;
    rdfs:comment "A VEHICLE JOURNEY taking place on a particular date that will be managed by an AVMs."@en .

siri:ExpectedArrivalTime a skos:Concept ;
    skos:prefLabel "estimated time of arriival of"@en ;
    skos:altLabel "expected arrival time"@en ;
    skos:altLabel "expectedarrivaltime"@en ;
    rdfs:comment "Estimated time of arriival of VEHICLE at stop ."@en .

siri:ExpectedDepartureCapacities a skos:Concept ;
    skos:prefLabel "expected departure capacities"@en ;
    skos:altLabel "expecteddeparturecapacities"@en ;
    skos:altLabel "expectedpredicted realtime capacities number of"@en ;
    rdfs:comment "Expected/Predicted real-time capacities (number of available seats) of a VEHICLE after departing from a given stop. Alternative way to communicate occupancy measurements. (since SIRI 2.1)"@en .

siri:ExpectedDepartureOccupancy a skos:Concept ;
    skos:prefLabel "expected departure occupancy"@en ;
    skos:altLabel "expecteddepartureoccupancy"@en ;
    rdfs:comment "Expected/Predicted real-time occupancies of a VEHICLE and reservations after departing from a given stop. (since SIRI 2.1)"@en .

siri:ExpectedDepartureTime a skos:Concept ;
    skos:prefLabel "estimated time of departure of"@en ;
    skos:altLabel "expected departure time"@en ;
    skos:altLabel "expecteddeparturetime"@en ;
    rdfs:comment "Estimated time of departure of VEHICLE from stop, most likely taking into account all control actions such as waiting."@en .

siri:ExpectedHeadwayInterval a skos:Concept ;
    skos:prefLabel "expected headway interval"@en ;
    skos:altLabel "expectedheadwayinterval"@en ;
    skos:altLabel "for frequency based services expected"@en ;
    rdfs:comment "For frequency based services, expected interval between vehicles at stop."@en .

siri:ExpectedLatestPassengerAccessTime a skos:Concept ;
    skos:prefLabel "expected latest passenger access time"@en ;
    skos:altLabel "expectedlatestpassengeraccesstime"@en ;
    rdfs:comment "Latest expected time at which a PASSENGER should aim to arrive at the STOP PLACE containing the stop. This time may be earlier than the VEHICLE departure times and may include time for processes such as checkin, security, etc.(As specified by CHECK CONSTRAINT DELAYs in the underlying data). If absent assume to be the same as Earliest expected departure time. (since SIRI 2.0)"@en .

siri:Extensions a skos:Concept ;
    skos:prefLabel "extensions"@en ;
    skos:altLabel "extensions to schema wrapper tag"@en ;
    rdfs:comment "Extensions to schema. (Wrapper tag used to avoid problems with handling of optional 'any' by some validators)."@en .

siri:ExtraCall a skos:Concept ;
    skos:prefLabel "extra call"@en ;
    skos:altLabel "extracall"@en ;
    skos:altLabel "this call is an addition"@en ;
    rdfs:comment "This CALL is an addition to the respective journey in the production timetable or to the previously sent prediction. If omitted: CALL is planned."@en .

siri:ExtraInterchange a skos:Concept ;
    skos:prefLabel "extra interchange"@en ;
    skos:altLabel "extrainterchange"@en ;
    skos:altLabel "whether this interchange is an"@en ;
    rdfs:comment "Whether this interchange is an addition to the plan. Can only be used when both participants recognise the same schedule version. If omitted, defaults to 'false': the interchange is not an addition. (since SIRI 2.1)"@en .

siri:FacilityChangeElement a skos:Concept ;
    skos:prefLabel "change to the availaibility"@en ;
    skos:altLabel "facility change element"@en ;
    skos:altLabel "facilitychangeelement"@en ;
    rdfs:comment "A change to the availaibility of EQUIPMENT. Basic structure defined in the first 1.0 SIRI XSd."@en .

siri:FacilityCondition a skos:Concept ;
    skos:prefLabel "facility condition"@en ;
    skos:altLabel "facilitycondition"@en ;
    rdfs:comment "Condition of a Facility that is being monitored."@en .

siri:FacilityConditionElement a skos:Concept ;
    skos:prefLabel "facility condition element"@en ;
    skos:altLabel "facilityconditionelement"@en ;
    rdfs:comment "Description of any change concerning a MONITORED FACILITY New structure defined in SIRI XSD 1.1 for Facilities Management."@en .

siri:FacilityDelivery a skos:Concept ;
    skos:prefLabel "facility delivery"@en ;
    skos:altLabel "facilitydelivery"@en ;
    rdfs:comment "Returns the Facilities covered by a service. Answers a StopPointsRequest."@en ;
    skos:related siri:AbstractDiscoveryDelivery .

siri:FacilityMonitoringCapabilitiesRequest a skos:Concept ;
    skos:prefLabel "facility monitoring capabilities request"@en ;
    skos:altLabel "facilitymonitoringcapabilitiesrequest"@en ;
    skos:altLabel "request for information about vehicle"@en ;
    rdfs:comment "Request for information about Vehicle Monitoring Service Capabilities. Answered with a VehicleMontoringCapabilitiesResponse."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesRequest .

siri:FacilityMonitoringCapabilitiesResponse a skos:Concept ;

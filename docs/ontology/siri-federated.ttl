    skos:altLabel "facility monitoring capabilities response"@en ;
    skos:altLabel "facilitymonitoringcapabilitiesresponse"@en ;
    rdfs:comment "Capabilities for Vehicle Monitoring Service. Answers a VehicleMontoringCapabilitiesRequest."@en ;
    skos:related siri:AbstractFunctionalServiceCapabilitiesResponse .

siri:FacilityMonitoringDelivery a skos:Concept ;
    skos:prefLabel "delivery for vehicle monitoring service"@en ;
    skos:altLabel "facility monitoring delivery"@en ;
    skos:altLabel "facilitymonitoringdelivery"@en ;
    rdfs:comment "Delivery for Vehicle Monitoring Service."@en ;
    skos:related siri:AbstractFunctionalServiceDelivery .

siri:FacilityMonitoringPermissions a skos:Concept ;
    skos:prefLabel "facility monitoring permissions"@en ;
    skos:altLabel "facilitymonitoringpermissions"@en ;
    skos:altLabel "participants permissions to use the"@en ;
    rdfs:comment "Participant's permissions to use the service."@en .

siri:FacilityMonitoringRequest a skos:Concept ;
    skos:prefLabel "facility monitoring request"@en ;
    skos:altLabel "facilitymonitoringrequest"@en ;
    skos:altLabel "request for information about facilities"@en ;
    rdfs:comment "Request for information about Facilities status."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:FacilityMonitoringServiceCapabilities a skos:Concept ;
    skos:prefLabel "capabilities of vehicle monitoring service"@en ;
    skos:altLabel "facility monitoring service capabilities"@en ;
    skos:altLabel "facilitymonitoringservicecapabilities"@en ;
    rdfs:comment "Capabilities of Vehicle Monitoring Service."@en .

siri:FacilityMonitoringSubscriptionRequest a skos:Concept ;
    skos:prefLabel "facility monitoring subscription request"@en ;
    skos:altLabel "facilitymonitoringsubscriptionrequest"@en ;
    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to the Vehicle Monitoring Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:FacilityRequest a skos:Concept ;
    skos:prefLabel "facility request"@en ;
    skos:altLabel "facilityrequest"@en ;
    rdfs:comment "Requests a list of the Facilities covered by a Producer."@en ;
    skos:related siri:AbstractDiscoveryRequest .

siri:FareClass a skos:Concept ;
    skos:prefLabel "classification of fare classes since"@en ;
    skos:altLabel "fare class"@en ;
    skos:altLabel "fareclass"@en ;
    rdfs:comment "Classification of FARE CLASSes. (since SIRI 2.1)"@en .

siri:FareClassFacility a skos:Concept ;
    skos:prefLabel "classification of fareclass facility type"@en ;
    skos:altLabel "fare class facility"@en ;
    skos:altLabel "fareclassfacility"@en ;
    rdfs:comment "Classification of FareClass Facility type - Tpeg pti23."@en .

siri:FareClasses a skos:Concept ;
    skos:prefLabel "fare classes"@en ;
    skos:altLabel "fareclasses"@en ;
    skos:altLabel "list of fare classes since"@en ;
    rdfs:comment "List of FARE CLASSes. (since SIRI 2.1)"@en .

siri:FeederItem a skos:Concept ;
    skos:prefLabel "feeder item"@en ;
    skos:altLabel "feederitem"@en ;
    rdfs:comment "Fedder/Fetcher SERVICE JOURNEY INTERCHANGE Activity."@en .

siri:FeederStopOrder a skos:Concept ;
    skos:prefLabel "feeder stop order"@en ;
    skos:altLabel "feederstoporder"@en ;
    rdfs:comment "For implementations in which the overall order is not defined by VISIT NUMBER, i.e. in case VisitNumberIsOrder is set to false, ORDER can be used to associate the stop order instead. ORDER is also used together with VISIT NUMBER in scenarios where an extra CALL is inserted as a result of despatching alterations. Because such an extra CALL may have the same VisitNumber as another (cancelled) CALL, the STOP ORDER is needed. (since SIRI 2.1)"@en .

siri:FeederVisitNumber a skos:Concept ;
    skos:prefLabel "feeder visit number"@en ;
    skos:altLabel "feedervisitnumber"@en ;
    skos:altLabel "sequence of visit to feeder"@en ;
    rdfs:comment "Sequence of visit to Feeder stop within Feeder JOURNEY PATTERN."@en .

siri:FilterByDestination a skos:Concept ;
    skos:prefLabel "filter by destination"@en ;
    skos:altLabel "filterbydestination"@en ;
    rdfs:comment "Whether results can be filtered by DESTINATION. Default is 'false'."@en .

siri:FilterByVehicleMode a skos:Concept ;
    skos:prefLabel "filter by vehicle mode"@en ;
    skos:altLabel "filterbyvehiclemode"@en ;
    rdfs:comment "Whether results can be filtered by VEHICLE MODE. Default is 'true'. (since SIRI 2.1)"@en .

siri:FirstOrLastJourney a skos:Concept ;
    skos:prefLabel "first or last journey"@en ;
    skos:altLabel "firstorlastjourney"@en ;
    skos:altLabel "whether journey is first or"@en ;
    rdfs:comment "Whether journey is first or last journey of day. (since SIRI 2.0)"@en .

siri:FormationCondition a skos:Concept ;
    skos:prefLabel "formation condition"@en ;
    skos:altLabel "formationcondition"@en ;
    rdfs:comment "Information about a change of the formation (e.g. TRAIN composition) or changes of vehicles within the formation. (since SIRI 2.1)"@en .

siri:FunicularSubmode a skos:Concept ;
    skos:prefLabel "funicular submode"@en ;
    skos:altLabel "funicularsubmode"@en ;
    skos:altLabel "tpeg pti10 funicular submodes"@en ;
    rdfs:comment "TPEG pti10 Funicular submodes."@en .

siri:GeneralMessageCancellation a skos:Concept ;
    skos:prefLabel "general message cancellation"@en ;
    skos:altLabel "generalmessagecancellation"@en ;

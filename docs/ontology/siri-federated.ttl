    skos:altLabel "request for information about general"@en ;
    rdfs:comment "Request for information about general information messages affecting stops, vehicles or services."@en ;
    skos:related siri:AbstractFunctionalServiceRequest .

siri:GeneralMessageServiceCapabilities a skos:Concept ;

    skos:altLabel "request for a subscription to"@en ;
    rdfs:comment "Request for a subscription to General Message Service."@en ;
    skos:related siri:AbstractFunctionalServiceSubscriptionRequest .

siri:HeartbeatNotification a skos:Concept ;
    skos:prefLabel "heartbeat notification"@en ;
    skos:altLabel "heartbeatnotification"@en ;
    skos:altLabel "notification from producer to consumer"@en ;

opra:IndicatorFrame a skos:Concept ;
    skos:prefLabel "indicator frame"@en ;
    skos:altLabel "indicatorframe"@en ;
    rdfs:comment "A coherent set of OpRa indicators to which the same frame VALIDITY CONDITIONs have been assigned."@en .

opra:JourneyEventsExample a skos:Concept ;
    skos:prefLabel "delayedandcancelledjourneyswithevents"@en ;
    skos:altLabel "journeys with events"@en ;
    skos:altLabel "journey events"@en ;
    skos:altLabel "delay events"@en ;
    skos:altLabel "cancellation events"@en ;
    rdfs:comment "Example data showing delayed and cancelled journeys with real-time event information"@en ;
    skos:related netex:JourneyPattern, netex:VehicleJourney, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:DelayStatistics, opra:DelayedJourney, opra:IndicatorFrame, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:PreparednessLevel, opra:TypeOfDelay, transmodel:Journey .

opra:LateDatedVehicleJourneyCount a skos:Concept ;
    skos:prefLabel "late dated vehicle journey count"@en ;
    skos:altLabel "latedatedvehiclejourneycount"@en ;
    rdfs:comment "Implementation of a LATE DATED VEHICLE JOURNEY COUNT."@en .


opra:AverageCommercialSpeed a skos:Concept ;
    skos:prefLabel "average commercial speed"@en ;
    skos:altLabel "averagecommercialspeed"@en ;
    skos:altLabel "speed value calculated from difference"@en ;
    rdfs:comment "Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."@en .

opra:CancelledDatedVehicleJourneyCount a skos:Concept ;
    skos:prefLabel "cancelled dated vehicle journey count"@en ;
    skos:altLabel "cancelleddatedvehiclejourneycount"@en ;
    rdfs:comment "Implementation of a CANCELLED DATED VEHICLE JOURNEY COUNT."@en .

opra:CancelledDatedVehicleJourneyDiscoveryDelivery a skos:Concept ;
    skos:prefLabel "cancelled dated vehicle journey discovery delivery"@en ;
    skos:altLabel "cancelleddatedvehiclejourneydiscoverydelivery"@en ;
    skos:altLabel "discovery delivery element to"@en ;
    rdfs:comment "A discovery delivery element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:CancelledDatedVehicleJourneyDiscoveryRequest a skos:Concept ;
    skos:prefLabel "cancelled dated vehicle journey discovery request"@en ;
    skos:altLabel "cancelleddatedvehiclejourneydiscoveryrequest"@en ;
    skos:altLabel "discovery request element to"@en ;
    rdfs:comment "A discovery request element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:CancelledDatedVehicleJourneysRequest a skos:Concept ;
    skos:prefLabel "cancelled dated vehicle journeys request"@en ;
    skos:altLabel "cancelleddatedvehiclejourneysrequest"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "A request element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:CancelledJourney a skos:Concept ;
    skos:prefLabel "cancelled journey"@en ;
    skos:altLabel "cancelled journeys"@en ;
    skos:altLabel "canceled journey"@en ;
    skos:altLabel "canceled journeys"@en ;
    skos:altLabel "journey cancellation"@en ;
    skos:altLabel "cancelled vehicle journey"@en ;
    rdfs:comment "A vehicle journey that has been cancelled and will not operate"@en ;
    skos:exactMatch nits:vehicle-journey ;
    skos:closeMatch netex:VehicleJourney ;
    skos:related netex:DestinationDisplay, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:CancelledDatedVehicleJourneyCount, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:PreparednessLevel, opra:TypeOfDelay, opra:VehicleTypeCapacity, transmodel:Journey .

opra:CapabilitiesRequest a skos:Concept ;
    skos:prefLabel "capabilities request"@en ;
    skos:altLabel "capabilitiesrequest"@en ;
    skos:altLabel "requests a the current capabilities"@en ;
    rdfs:comment "Requests a the current capabilities of the server. Answered with a CapabilitiesResponse. Reserved for future use."@en .

opra:CapabilitiesResponse a skos:Concept ;
    skos:prefLabel "capabilities response"@en ;
    skos:altLabel "capabilitiesresponse"@en ;
    skos:altLabel "responses with the capabilities of"@en ;
    rdfs:comment "Responses with the capabilities of an implementation. Reserved for future use."@en .

opra:CapacitySpecification a skos:Concept ;
    skos:prefLabel "capacity specification"@en ;
    skos:altLabel "capacityspecification"@en ;
    rdfs:comment "Element providing capability to specify methods and capacity values for VEHICLE TYPEs."@en .

opra:ContextualIndicatorDiscoveryDelivery a skos:Concept ;
    skos:prefLabel "contextual indicator discovery delivery"@en ;
    skos:altLabel "contextualindicatordiscoverydelivery"@en ;
    rdfs:comment "A request element to get CONTEXTUAL INDICATORs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:ContextualIndicatorDiscoveryRequest a skos:Concept ;
    skos:prefLabel "contextual indicator discovery request"@en ;
    skos:altLabel "contextualindicatordiscoveryrequest"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "A request element to get KPIs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:ContextualIndicatorFrame a skos:Concept ;
    skos:prefLabel "coherent set of contextual"@en ;
    skos:altLabel "contextual indicator frame"@en ;
    skos:altLabel "contextualindicatorframe"@en ;
    rdfs:comment "A coherent set of CONTEXTUAL INDICATORs to which the same frame VALIDITY CONDITIONs have been assigned."@en .

opra:ContextualIndicatorRequest a skos:Concept ;
    skos:prefLabel "contextual indicator request"@en ;
    skos:altLabel "contextualindicatorrequest"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "A request element to get KPIs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:DelayStatistics a skos:Concept ;
    skos:prefLabel "delay statistic"@en ;
    skos:altLabel "delay statistics"@en ;
    skos:altLabel "delayedjourneycount"@en ;
    skos:altLabel "journey delay count"@en ;
    skos:altLabel "delay occurrence"@en ;
    rdfs:comment "Statistical information aggregating journey delays over time"@en ;
    skos:exactMatch nits:delay ;
    skos:related netex:DestinationDisplay, netex:JourneyPattern, netex:Line, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:VehicleJourney, opra:ActualCapacity, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:DelayedJourney, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:PreparednessLevel, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

opra:DelayedJourney a skos:Concept ;
    skos:prefLabel "delayed journey"@en ;
    skos:altLabel "delayed vehicle journey"@en ;
    skos:altLabel "delayed vehicle journeys"@en ;
    skos:altLabel "delayed journeys"@en ;
    skos:altLabel "late journey"@en ;
    skos:altLabel "late vehicle journey"@en ;
    skos:altLabel "late journeys"@en ;
    skos:altLabel "vehicle journey delay"@en ;
    rdfs:comment "A vehicle journey experiencing time delays from the scheduled timetable"@en ;
    skos:exactMatch nits:vehicle-journey ;
    skos:closeMatch netex:VehicleJourney ;
    skos:related netex:DestinationDisplay, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:ActualCapacity, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:DelayStatistics, opra:ExternalPassengerCount, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:LateDatedVehicleJourneyEntry, opra:PlannedCapacity, opra:PreparednessLevel, opra:TypeOfDelay, opra:VehicleLoadEntry, opra:VehicleTypeCapacity, transmodel:Journey .

opra:DurationInterval a skos:Concept ;
    skos:prefLabel "duration interval"@en ;
    skos:altLabel "durationinterval"@en ;
    rdfs:comment "Element for basic occurrence statistics of a DURATION INTERVAL."@en .


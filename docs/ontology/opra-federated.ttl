@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://napcore.eu/ontology/opra-federated>
    a owl:Ontology ;
    dcterms:title "OpRa Federated Ontology"@en ;
    dcterms:description "OpRa-focused federated ontology module generated from the local glossary and linked to NAPCORE ITS core concepts."@en ;
    dcterms:created "2026-04-16"^^xsd:date ;
    owl:versionInfo "0.3.0" ;
    owl:imports <https://napcore.eu/ontology/napcore-its> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

opra:AbstractCtxIndicator a skos:Concept ;
    skos:prefLabel "abstract ctx indicator"@en ;
    skos:altLabel "abstractctxindicator"@en ;
    rdfs:comment "Dummy Supertype for a CONTEXTUAL INDICATOR."@en .

opra:AbstractLogEntry a skos:Concept ;
    skos:prefLabel "abstract log entry"@en ;
    skos:altLabel "abstractlogentry"@en ;
    skos:altLabel "dummy supertype for log entry"@en ;
    rdfs:comment "Dummy Supertype for LOG ENTRY."@en .

opra:AbstractLoggableObject a skos:Concept ;
    skos:prefLabel "abstract loggable object"@en ;
    skos:altLabel "abstractloggableobject"@en ;
    skos:altLabel "dummy supertype for loggable object"@en ;
    rdfs:comment "Dummy Supertype for LOGGABLE OBJECT."@en .

opra:ActualCapacity a skos:Concept ;
    skos:prefLabel "actual capacity"@en ;
    skos:altLabel "actualcapacity"@en ;
    rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording ACTUAL CAPACITY information."@en .

opra:ActualCapacityDiscoveryDelivery a skos:Concept ;
    skos:prefLabel "actual capacity discovery delivery"@en ;
    skos:altLabel "actualcapacitydiscoverydelivery"@en ;
    skos:altLabel "discovery delivery element to"@en ;
    rdfs:comment "A discovery delivery element to get ACTUAL CAPACITIes."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:ActualCapacityDiscoveryRequest a skos:Concept ;
    skos:prefLabel "actual capacity discovery request"@en ;
    skos:altLabel "actualcapacitydiscoveryrequest"@en ;
    skos:altLabel "discovery request element to"@en ;

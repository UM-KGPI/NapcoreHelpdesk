opra:GeneralLogEntry a skos:Concept ;
    skos:prefLabel "general log entry"@en ;
    skos:altLabel "generallogentry"@en ;
    rdfs:comment "A time-stamped record of an event or change of state."@en ;
    skos:related opra:AbstractLogEntry .

opra:GenericContextualIndicator a skos:Concept ;
    skos:prefLabel "generic contextual indicator"@en ;
    skos:altLabel "genericcontextualindicator"@en ;
    rdfs:comment "Representation of a generic CONTEXTUAL INDICATOR."@en ;

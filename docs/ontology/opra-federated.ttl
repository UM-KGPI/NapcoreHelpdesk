    rdfs:comment "A discovery delivery element to get LATE DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:LateDatedVehicleJourneyDiscoveryRequest a skos:Concept ;
    skos:prefLabel "discovery request element to"@en ;
    skos:altLabel "late dated vehicle journey discovery request"@en ;
    skos:altLabel "latedatedvehiclejourneydiscoveryrequest"@en ;
    rdfs:comment "A discovery request element to get LATE DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:LateDatedVehicleJourneyEntry a skos:Concept ;
    skos:prefLabel "latedatedvehiclejourneyentry"@en ;
    skos:altLabel "late dated vehicle journey entry"@en ;
    skos:altLabel "dated vehicle journey entry"@en ;
    skos:altLabel "late journey entry"@en ;
    rdfs:comment "A timetabled vehicle journey record with recorded delay information"@en ;
    skos:exactMatch nits:vehicle-journey ;
    skos:related netex:AllowedLineDirection, netex:DestinationDisplay, netex:GroupOfLines, netex:JourneyPattern, netex:Line, netex:Network, netex:Operator, netex:ScheduledStopPoint, netex:TimetabledPassingTime, netex:TypeOfLine, netex:VehicleJourney, opra:CancelledDatedVehicleJourneyCount, opra:CancelledJourney, opra:CapacitySpecification, opra:DelayStatistics, opra:DelayedJourney, opra:IndicatorFrame, opra:JourneyEventsExample, opra:LateDatedVehicleJourneyCount, opra:PreparednessLevel, opra:TypeOfDelay, opra:VehicleTypeCapacity, transmodel:Journey .

opra:LateDatedVehicleJourneysRequest a skos:Concept ;
    skos:prefLabel "late dated vehicle journeys request"@en ;
    skos:altLabel "latedatedvehiclejourneysrequest"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "A request element to get LATE DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:LoadOverJourneyDistance a skos:Concept ;
    skos:prefLabel "load over journey distance"@en ;
    skos:altLabel "loadoverjourneydistance"@en ;
    rdfs:comment "Mean passenger (and other transported unit) count per total journey distance unit [capita/m] or [capita/km] depending on DefaultSystemOfUnits for the FRAME."@en .

opra:LogEntryValue a skos:Concept ;
    skos:prefLabel "log entry value"@en ;
    skos:altLabel "logentryvalue"@en ;
    rdfs:comment "A time-stamped record of an event or change of state - new values/state."@en .

opra:LoggableObject a skos:Concept ;
    skos:prefLabel "loggable object"@en ;
    skos:altLabel "loggableobject"@en ;
    rdfs:comment "An entity for which LOG ENTRies may be made."@en ;
    skos:related opra:AbstractLoggableObject .

opra:MeanCapacityOverJourneyDistance a skos:Concept ;
    skos:prefLabel "mean capacity over journey distance"@en ;
    skos:altLabel "meancapacityoverjourneydistance"@en ;
    rdfs:comment "Average passenger (and other transported unit) capacity values provided per VEHICLE JOURNEY distance unit (see DefaultSystemOfUnits for the FRAME)"@en .

opra:MeanCapacityOverNetworkDistance a skos:Concept ;
    skos:prefLabel "mean capacity over network distance"@en ;
    skos:altLabel "meancapacityovernetworkdistance"@en ;
    rdfs:comment "Average passenger (and other transported unit) capacity values provided for a distance unit (see DefaultSystemOfUnits for the FRAME) of a NETWORK."@en .

opra:MeanCapacityOverRouteDistance a skos:Concept ;
    skos:prefLabel "mean capacity over route distance"@en ;
    skos:altLabel "meancapacityoverroutedistance"@en ;
    rdfs:comment "Average passenger (and other transported unit) capacity values provided for a distance unit (see DefaultSystemOfUnits for the FRAME) of all ROUTEs considered."@en .

opra:OnboardDeviceBasedPassengerCount a skos:Concept ;
    skos:prefLabel "onboard device based passenger count"@en ;
    skos:altLabel "onboarddevicebasedpassengercount"@en ;
    rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording ONBOARD DEVICE BASED PASSENGER COUNT information."@en .

opra:OnboardDeviceBasedPassengerCountDiscoveryDelivery a skos:Concept ;
    skos:prefLabel "discovery delivery element to"@en ;
    skos:altLabel "onboard device based passenger count discovery delivery"@en ;
    skos:altLabel "onboarddevicebasedpassengercountdiscoverydelivery"@en ;
    rdfs:comment "A discovery delivery element to get ONBOARD DEVICE BASED PASSENGER COUNTs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:OnboardDeviceBasedPassengerCountDiscoveryRequest a skos:Concept ;

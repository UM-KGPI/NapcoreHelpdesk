  .

tm:VEHICLE_USE_EVENT a owl:Class ;
  rdfs:label "VEHICLE USE EVENT"
  ; rdfs:comment "An event associated with a VEHICLE USE by a customer."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_EVENT
  .

tm:VEHICLE_USE_ENTRY a owl:Class ;
  rdfs:label "VEHICLE USE ENTRY"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording use of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:DETECT_DAMAGE_TO_VEHICLE_EVENT a owl:Class ;

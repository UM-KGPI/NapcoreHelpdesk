  .

tm:REPORT_DAMAGE_TO_VEHICLE_EVENT a owl:Class ;
  rdfs:label "REPORT DAMAGE TO VEHICLE EVENT"
  ; rdfs:comment "A VEHICLE USE EVENT occurring when a customer reports damage or loss of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_USE_EVENT
  .

tm:REPORT_DAMAGE_TO_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "REPORT DAMAGE TO VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE SHARING ENTRY recording damage or loss of a VEHICLE.  ."
  ; rdfs:subClassOf tm:VEHICLE_USE_ENTRY
  .


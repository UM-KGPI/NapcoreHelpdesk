  rdfs:label "PUBLISH JOURNEY OFFER ENTRY"
  ; rdfs:comment "A SINGLE JOURNEY ENTRY recording the posing of a journey wanted description."
  ; rdfs:subClassOf tm:JOURNEY_OFFER_ENTRY
  .

tm:MODIFY_JOURNEY_OFFER_ENTRY a owl:Class ;

tm:TAXI_METER_ENTRY a owl:Class ;
  rdfs:label "TAXI METER ENTRY"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording use of a meter for a RIDE."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:ACCEPT_RIDER_BID_EVENT a owl:Class ;
  rdfs:label "ACCEPT RIDER BID EVENT"
  ; rdfs:comment "A JOURNEY OFFER EVENT occurring when a driver accepts a riders's bid to use the driver's journey offer."
  ; rdfs:subClassOf tm:JOURNEY_OFFER_EVENT
  .

tm:ACCEPT_RIDER_BID_ENTRY a owl:Class ;
  rdfs:label "ACCEPT RIDER BID ENTRY"
  ; rdfs:comment "A VEHICLE POOLING ENTRY recording the successful hailing of a TAXI,"
  ; rdfs:subClassOf tm:JOURNEY_OFFER_ENTRY
  .

tm:JOURNEY_OFFER_EVENT a owl:Class ;
  rdfs:label "JOURNEY OFFER EVENT"
  ; rdfs:comment "An abstract VEHICLE SERVICE EVENT relating to a drivers provision of a JOURNEY OFFER."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_EVENT
  .

tm:JOURNEY_OFFER_ENTRY a owl:Class ;
  rdfs:label "JOURNEY OFFER ENTRY"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording use of a VEHICLE for a SINGLE JOURNEY."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:START_METER_EVENT a owl:Class ;
  rdfs:label "START METER EVENT"
  ; rdfs:comment "A TAXI RIDE EVENT occurring when a meter in a VEHICLE is started at the beginning of the ride."
  ; rdfs:subClassOf tm:TAXI_METER_EVENT
  .

tm:START_METER_ENTRY a owl:Class ;
  rdfs:label "START METER ENTRY"
  ; rdfs:comment "A TAXI METER ENTRY recording when a meter in a VEHICLE is started at the beginning of the ride."
  ; rdfs:subClassOf tm:TAXI_METER_ENTRY
  .

tm:PAUSE_METER_EVENT a owl:Class ;
  rdfs:label "PAUSE METER EVENT"
  ; rdfs:comment "A TAXI RIDE EVENT occurring when a meter in a VEHICLE is paused during the ride."
  ; rdfs:subClassOf tm:TAXI_METER_EVENT
  .

tm:PAUSE_METER_ENTRY a owl:Class ;
  rdfs:label "PAUSE METER ENTRY"
  ; rdfs:comment "TAXI METER ENTRY recording when a meter in a VEHICLE is paused during the ride."
  ; rdfs:subClassOf tm:TAXI_METER_ENTRY
  .

tm:PROVIDE_VEHICLE_EVENT a owl:Class ;
  rdfs:label "PROVIDE VEHICLE EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT when the operator provides a VEHICLE to a specified place."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:PROVIDE_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "PROVIDE VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the provision of a VEHICLE to a specified place."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:TRAVELLER_VALIDITY_PARAMETER a owl:Class ;
  rdfs:label "TRAVELLER VALIDITY PARAMETER"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to the specific traveller."
  .

tm:STOP_METER_EVENT a owl:Class ;
  rdfs:label "STOP METER EVENT"
  ; rdfs:comment "A TAXI RIDE EVENT occurring when a meter in a VEHICLE is stopped at the end of the ride."
  ; rdfs:subClassOf tm:TAXI_METER_EVENT
  .

tm:STOP_METER_ENTRY a owl:Class ;
  rdfs:label "STOP METER ENTRY"
  ; rdfs:comment "TAXI METER ENTRY recording when a meter in a VEHICLE is stopped at the end of the ride."
  ; rdfs:subClassOf tm:TAXI_METER_ENTRY
  .

tm:RIDE_PROVISION_ENTRY a owl:Class ;
  rdfs:label "RIDE PROVISION ENTRY"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording some aspect of providing a RIDE."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:RIDE_PROVISION_EVENT a owl:Class ;
  rdfs:label "RIDE PROVISION EVENT"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording some aspect provision of ride."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_EVENT
  .

tm:BEGIN_JOURNEY_EVENT a owl:Class ;
  rdfs:label "BEGIN JOURNEY EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the journey begins."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:BEGIN_JOURNEY_ENTRY a owl:Class ;
  rdfs:label "BEGIN JOURNEY ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the start of a journey."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:PICK_UP_RIDER_EVENT a owl:Class ;
  rdfs:label "PICK UP RIDER EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the rider is collected begins."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:PICK_UP_RIDER_ENTRY a owl:Class ;
  rdfs:label "PICK UP RIDER ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the pick-up of a passenger."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:COMPLETE_JOURNEY_EVENT a owl:Class ;
  rdfs:label "COMPLETE JOURNEY EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the journey is completed."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:COMPLETE_JOURNEY_ENTRY a owl:Class ;
  rdfs:label "COMPLETE JOURNEY ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the completion of a journey."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:SET_DOWN_RIDER_EVENT a owl:Class ;
  rdfs:label "SET DOWN RIDER EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the rider is set down.  ."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:SET_DOWN_RIDER_ENTRY a owl:Class ;
  rdfs:label "SET DOWN RIDER ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the set down of a passenger."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:LOG_DRIVERS_FEEDBACK_EVENT a owl:Class ;
  rdfs:label "LOG DRIVERS FEEDBACK EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the driver logs feedback about the passenger."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:LOG_DRIVERS_FEEDBACK_ENTRY a owl:Class ;
  rdfs:label "LOG DRIVERS FEEDBACK ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the entry of feedback about the passenger by the driver."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:RIDER_NO_SHOW_EVENT a owl:Class ;
  rdfs:label "RIDER NO SHOW EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when the rider fails to show up at the appointed time."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:RIDER_NO_SHOW_ENTRY a owl:Class ;
  rdfs:label "RIDER NO SHOW ENTRY"
  ; rdfs:comment "A RIDE PROVISION ENTRY recording the failure of a rider to turn up for a journey."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:ABORT_JOURNEY_EVENT a owl:Class ;
  rdfs:label "ABORT JOURNEY EVENT"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when a journey is terminated early."
  ; rdfs:subClassOf tm:RIDE_PROVISION_EVENT
  .

tm:ABORT_JOURNEY_ENTRY a owl:Class ;
  rdfs:label "ABORT JOURNEY ENTRY"
  ; rdfs:comment "A RIDE PROVISION EVENT occurring when a journey is terminated early."
  ; rdfs:subClassOf tm:RIDE_PROVISION_ENTRY
  .

tm:LOG_PASSENGERS_FEEDBACK_EVENT a owl:Class ;
  rdfs:label "LOG PASSENGERS FEEDBACK EVENT"
  ; rdfs:comment "A RIDING EVENT occurring when the rider logs feedback about the driver."
  ; rdfs:subClassOf tm:RIDING_EVENT
  .

tm:LOG_PASSENGERS_FEEDBACK_ENTRY a owl:Class ;
  rdfs:label "LOG PASSENGERS FEEDBACK ENTRY"
  ; rdfs:comment "A RIDING ENTRY recording the entry of feedback by the rider about the driver."
  ; rdfs:subClassOf tm:RIDING_ENTRY
  .

tm:RIDING_ENTRY a owl:Class ;
  rdfs:label "RIDING ENTRY"
  ; rdfs:comment "An abstract VEHICLE SERVICE ENTRY recording some aspect of providing a RIDE."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:RIDING_EVENT a owl:Class ;
  rdfs:label "RIDING EVENT"
  ; rdfs:comment "An abstract event associated with making a ride with a VEHICLE SERVICE."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_EVENT
  .

tm:BEGIN_RIDE_EVENT a owl:Class ;
  rdfs:label "BEGIN RIDE EVENT"
  ; rdfs:comment "A RIDING EVENT occurring when the journey begins."
  ; rdfs:subClassOf tm:RIDING_EVENT
  .

tm:BEGIN_RIDE_ENTRY a owl:Class ;
  rdfs:label "BEGIN RIDE ENTRY"
  ; rdfs:comment "A RIDING ENTRY recording the start of a ride."
  ; rdfs:subClassOf tm:RIDING_ENTRY
  .

tm:COMPLETE_RIDE_EVENT a owl:Class ;
  rdfs:label "COMPLETE RIDE EVENT"
  ; rdfs:comment "A RIDING EVENT occurring when the journey is completed."
  ; rdfs:subClassOf tm:RIDING_EVENT
  .

tm:COMPLETE_RIDE_ENTRY a owl:Class ;
  rdfs:label "COMPLETE RIDE ENTRY"
  ; rdfs:comment "A RIDING ENTRY recording the completion of a ride."
  ; rdfs:subClassOf tm:RIDING_ENTRY
  .

tm:DRIVER_NO_SHOW_EVENT a owl:Class ;
  rdfs:label "DRIVER NO SHOW EVENT"
  ; rdfs:comment "A RIDING EVENT when the driver fails to show up at the appointed time."
  ; rdfs:subClassOf tm:RIDING_EVENT
  .

tm:DRIVER_NO_SHOW_ENTRY a owl:Class ;
  rdfs:label "DRIVER NO SHOW ENTRY"
  ; rdfs:comment "A RIDING ENTRY recording the failure of a driver to turn up to give a ride."
  ; rdfs:subClassOf tm:RIDING_ENTRY
  .

tm:ABORT_RIDE_EVENT a owl:Class ;
  rdfs:label "ABORT RIDE EVENT"
  ; rdfs:comment "A RIDING EVENT occurring when the ride is terminated early."
  ; rdfs:subClassOf tm:RIDING_EVENT
  .

tm:ABORT_RIDE_ENTRY a owl:Class ;
  rdfs:label "ABORT RIDE ENTRY"
  ; rdfs:comment "A RIDING ENTRY recording the early termination of a ride."
  ; rdfs:subClassOf tm:RIDING_ENTRY
  .

tm:TYPE_OF_ROLLING_STOCK a owl:Class ;
  rdfs:label "TYPE OF ROLLING STOCK"
  ; rdfs:comment "Classification for a ROLLING STOCK ITEM as say, locomotive, powered railcar, railway carriage, freight wagon, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_POWER_COUPLING a owl:Class ;
  rdfs:label "TYPE OF POWER COUPLING"
  ; rdfs:comment "Type of electrical coupling."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_CURRENT a owl:Class ;
  rdfs:label "TYPE OF CURRENT"
  ; rdfs:comment "Classification of electrical current; AC, DC, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RECHARGING_EQUIPMENT_PROFILE a owl:Class ;
  rdfs:label "RECHARGING EQUIPMENT PROFILE"
  ; rdfs:comment "Specialisation of VEHICLE EQUIPMENT PROFILE describing vehicle charging features."
  ; rdfs:subClassOf tm:VEHICLE_EQUIPMENT_PROFILE
  .

tm:TYPE_OF_PROPULSION a owl:Class ;
  rdfs:label "TYPE OF PROPULSION"
  ; rdfs:comment "Classification of the method of Propulsion, e.g., electric, steam, internal combustion, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:BATTERY_EQUIPMENT a owl:Class ;
  rdfs:label "BATTERY EQUIPMENT"
  ; rdfs:comment "VEHICLE battery EQUIPMENT."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:TYPE_OF_BATTERY_CHEMISTRY a owl:Class ;
  rdfs:label "TYPE OF BATTERY CHEMISTRY"
  ; rdfs:comment "Type of Battery Chemistry used, e.g., Lip."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_PLUG a owl:Class ;
  rdfs:label "TYPE OF PLUG"
  ; rdfs:comment "Classification of electrical plugs."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:POOL_OF_VEHICLES a owl:Class ;
  rdfs:label "POOL OF VEHICLES"
  ; rdfs:comment "A set of vehicles assigned to a specific PARKING, PARKING AREAs, PARKING BAYs, or to a MOBILITY CONSTRAINT ZONE, that must be picked up and returned to the same area."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:PASSENGER_SPOT a owl:Class ;
  rdfs:label "PASSENGER SPOT"
  ; rdfs:comment "A designated seat or other onboard space for a passenger within a given PASSENGER SPACE."
  ; rdfs:subClassOf tm:LOCATABLE_SPOT
  .

tm:DECK_PLAN a owl:Class ;
  rdfs:label "DECK PLAN"
  ; rdfs:comment "A plan for the layout of seating and other areas of use of an entire VEHICLE (train, coach, vessel etc.) or individual TRAIN ELEMENT for all or part of a journey."
  .

tm:DECK_SPACE a owl:Class ;
  rdfs:label "DECK SPACE"
  ; rdfs:comment "An area within a DECK PLAN for a VEHICLE (i.e., bus, boat, coach, car) or TRAIN ELEMENT TYPE delimiting a particular use, such as seating, WC, bar, gangway, etc.  NOTE1: DECK SPACEs may be specialised, e.g., as PASSENGER SPACEs and; may contain other DECK SPACEs.  NOTE2: Different types of DECK SPACE may overlap."
  ; rdfs:subClassOf tm:DECK_COMPONENT
  .

tm:SPOT_ALLOCATION_METHOD a owl:Class ;
  rdfs:label "SPOT ALLOCATION METHOD"
  ; rdfs:comment "Method for allocating seating, and other bookable spots (for example; open seating, system assigned, self assigned from available, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DECK_COMPONENT a owl:Class ;
  rdfs:label "DECK COMPONENT"
  ; rdfs:comment "<font color=\"#445469\">An abstract element providing common features for spatially located elements within the DECK PLAN.</font>"
  ; rdfs:subClassOf tm:ONBOARD_SPACE
  .

tm:SPOT_ROW a owl:Class ;
  rdfs:label "SPOT ROW"
  ; rdfs:comment "Designated row of LOCATABLE SPOTs, e.g., seats, within a <font color=\"#445469\">PASSENGER SPACE.</font>"
  .

tm:SPOT_COLUMN a owl:Class ;
  rdfs:label "SPOT COLUMN"
  ; rdfs:comment "Designated file of LOCATABLE SPOTs within a <font color=\"#445469\">PASSENGER SPACE, For example </font>Column A, B, C, D."
  .

tm:DECK a owl:Class ;
  rdfs:label "DECK"
  ; rdfs:comment "An area within a VEHICLE (i.e., bus, boat, coach, car, plan, etc.) or TRAIN ELEMENT TYPE made up of one or more DECK SPACEs; a subdivision of a DECK PLAN."
  ; rdfs:subClassOf tm:ZONE
  .

tm:SPOT_AVAILABILITY_STATUS a owl:Class ;
  rdfs:label "SPOT AVAILABILITY STATUS"
  ; rdfs:comment "Current status of allocation of PASSENGER SEAT, e.g., Available, Reserved, Booked, Blocked, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PASSENGER_SPOT_ALLOCATION a owl:Class ;
  rdfs:label "PASSENGER SPOT ALLOCATION"
  ; rdfs:comment "Current ALLOCATION of a LOCATABLE SPOT such as a passenger seat or on-board vehicle space to a customer <font color=\"#445469\">between two STOP POINTs. </font>"
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:VEHICLE_JOURNEY_SPOT_ALLOCATION a owl:Class ;
  rdfs:label "VEHICLE JOURNEY SPOT ALLOCATION"
  ; rdfs:comment "The set of current allocations of on-board LOCATABLE SPOTs (i.e., seats, vehicle berths, etc.) for a given NORMAL DATED VEHICLE JOURNEY."
  .

tm:DECK_ENTRANCE a owl:Class ;
  rdfs:label "DECK ENTRANCE"
  ; rdfs:comment "An entrance to or within a DECK."
  ; rdfs:subClassOf tm:DECK_COMPONENT
  .

tm:TYPE_OF_DECK_ENTRANCE a owl:Class ;
  rdfs:label "TYPE OF DECK ENTRANCE"
  ; rdfs:comment "Classification for a DECK ENTRANCE."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_LOCATABLE_SPOT a owl:Class ;
  rdfs:label "TYPE OF LOCATABLE SPOT"
  ; rdfs:comment "Classification for a LOCATABLE SPOT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_DECK_SPACE a owl:Class ;
  rdfs:label "TYPE OF DECK SPACE"
  ; rdfs:comment "Classification for DECK SPACE, e.g., as WC, restaurant, luggage area, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ORGANISATION_REQUEST a owl:Class ;
  rdfs:label "ORGANISATION REQUEST"
  ; rdfs:comment "A PI REQUEST to find information about one or more ORGANISATIONs."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:ORGANISATION_DELIVERY a owl:Class ;
  rdfs:label "ORGANISATION DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to respond to one or more ORGANISATION REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:ORGANISATION_REQUEST_POLICY a owl:Class ;
  rdfs:label "ORGANISATION REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Criteria to be used to when computing and decorating results for an ORGANISATION </font>REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:TYPE_OF_WHEELCHAIR a owl:Class ;
  rdfs:label "TYPE OF WHEELCHAIR"
  ; rdfs:comment "Classification of Wheelchair"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MOBILITY_SERVICE_REQUEST_POLICY a owl:Class ;
  rdfs:label "MOBILITY SERVICE REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Criteria to be used to when computing and decorating results for a MOBILITY SERVICE REQUEST.</font>"
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:MOBILITY_SERVICE_DELIVERY a owl:Class ;
  rdfs:label "MOBILITY SERVICE DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to respond to a <font color=\"#0f0f0f\">MOBILITY SERVICE REQUEST.</font>"
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:MOBILITY_SERVICE_REQUEST a owl:Class ;
  rdfs:label "MOBILITY SERVICE REQUEST"
  ; rdfs:comment "A PI REQUEST to find available <font color=\"#0f0f0f\">MOBILITY SERVICEs.</font>"
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:MOBILITY_SERVICE_GEOMETRY_RESTRICTION a owl:Class ;
  rdfs:label "MOBILITY SERVICE GEOMETRY RESTRICTION"
  ; rdfs:comment "Filter parameters used to limit the spatial results of the MOBILITY SERVICE REQUEST."
  .

tm:TYPE_OF_TOPOGRAPHIC_PLACE a owl:Class ;
  rdfs:label "TYPE OF TOPOGRAPHIC PLACE"
  ; rdfs:comment "A classification for the ORGANISATIONs according to their activity, e.g., a public transport company, an IT company, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:VEHICLE_JOURNEY_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE JOURNEY STOP ASSIGNMENT"
  ; rdfs:comment "The association of a SCHEDULED STOP POINT with a specific STOP PLACE and also possibly a QUAY, for a specific VEHICLE JOURNEY.  NOTE: Overrides any PASSENGER STOP ASSIGNMENT for the SCHEDULED STOP POINT."
  ; rdfs:subClassOf tm:PASSENGER_STOP_ASSIGNMENT
  .

tm:ACCOUNTABLE_ACTIVITY a owl:Class ;
  rdfs:label "ACCOUNTABLE ACTIVITY"
  ; rdfs:comment "<font color=\"#445469\">An activity to which accounting factors may be assigned.</font>"
  .

tm:TIME_ACCOUNTABLE_ACTIVITY a owl:Class ;
  rdfs:label "TIME ACCOUNTABLE ACTIVITY"
  ; rdfs:comment "<font color=\"#445469\">An activity which may have a TIME ALLOWANCE.</font>"
  ; rdfs:subClassOf tm:ACCOUNTABLE_ACTIVITY
  .

tm:PATH_LINK a owl:Class ;
  rdfs:label "PATH LINK"
  ; rdfs:comment "A path within a SITE connecting between any two SITE COMPONENTs (e.g., a STOP PLACE ENTRANCE, ACCESS SPACE, QUAY, BOARDING POSITIONs, etc.), or PATH JUNCTIONs.  NOTE: Each link represents a step in a possible route for pedestrians, cyclists or other out-of-vehicle passengers within or between two places."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_PATH_LINK
  .

tm:DECK_PATH_LINK a owl:Class ;
  rdfs:label "DECK PATH LINK"
  ; rdfs:comment "A PATH LINK within a DECK PLAN."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_PATH_LINK
  .

tm:SINGLE_JOURNEY_REQUEST_POLICY a owl:Class ;
  rdfs:label "SINGLE JOURNEY REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Criteria to be used to when computing and decorating results for a SINGLE JOURNEY </font>REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:SINGLE_JOURNEY_DELIVERY a owl:Class ;
  rdfs:label "SINGLE JOURNEY DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to respond to one or more <font color=\"#0f0f0f\">SINGLE JOURNEY </font>REQUESTs"
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:SINGLE_JOURNEY_REQUEST a owl:Class ;
  rdfs:label "SINGLE JOURNEY REQUEST"
  ; rdfs:comment "A PI REQUEST to make an trip proposal of possible SINGLE JOURNEYs, according to a specified SINGLE JOURNEY TRIP REQUEST POLICY."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:VEHICLE_TYPE_REQUEST_POLICY a owl:Class ;
  rdfs:label "VEHICLE TYPE REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Criteria to be used to when computing and decorating results for a VEHICLE TYPE REQUEST.</font>"
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:VEHICLE_TYPE_DELIVERY a owl:Class ;
  rdfs:label "VEHICLE TYPE DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to respond to a <font color=\"#0f0f0f\">VEHICLE TYPE REQUEST.</font><u> </u>"
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:VEHICLE_TYPE_REQUEST a owl:Class ;
  rdfs:label "VEHICLE TYPE REQUEST"
  ; rdfs:comment "A PI REQUEST to find the available VEHICLE TYPEs<font color=\"#0f0f0f\"> and their features.</font>"
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:DECK_ENTRANCE_USAGE a owl:Class ;
  rdfs:label "DECK ENTRANCE USAGE"
  ; rdfs:comment "<font color=\"#445469\">Permitted usage of a specific PASSENGER ENTRANCE to access a particular DECK SPACE. </font>For example, entry only, exit only, both ways."
  .

tm:DECK_ENTRANCE_COUPLE a owl:Class ;
  rdfs:label "DECK ENTRANCE COUPLE"
  ; rdfs:comment "Explicit linking of a pair of DECK ENTRANCEs, e.g., between train carriages."
  .

tm:OCCUPANCY_COUNT a owl:Class ;
  rdfs:label "OCCUPANCY COUNT"
  ; rdfs:comment "A record of occupancy of a given DECK SPACE for a given period."
  ; rdfs:subClassOf tm:DECK_SENSOR_ENTRY
  .

tm:DECK_SPACE_ACTIVITY_COUNT a owl:Class ;
  rdfs:label "DECK SPACE ACTIVITY COUNT"
  ; rdfs:comment "A record of activity in a DECK SPACE for a given period."
  ; rdfs:subClassOf tm:DECK_ACTIVITY_COUNT
  .

tm:DECK_ENTRANCE_ACTIVITY_COUNT a owl:Class ;
  rdfs:label "DECK ENTRANCE ACTIVITY COUNT"
  ; rdfs:comment "A record of activity through a DECK ENTRANCE for a given period."
  ; rdfs:subClassOf tm:DECK_ACTIVITY_COUNT
  .

tm:ENTRANCE_SENSOR a owl:Class ;
  rdfs:label "ENTRANCE SENSOR"
  ; rdfs:comment "An EQUIPMENT used to monitor or count passengers using a PASSENGER ENTRANCE."
  ; rdfs:subClassOf tm:SENSOR_EQUIPMENT
  .

tm:SENSOR_IN_ENTRANCE a owl:Class ;
  rdfs:label "SENSOR IN ENTRANCE"
  ; rdfs:comment "Use of a specific ENTRANCE SENSOR to monitor a specific DECK ENTRANCE."
  .

tm:SPOT_SENSOR a owl:Class ;
  rdfs:label "SPOT SENSOR"
  ; rdfs:comment "An EQUIPMENT used to monitor use of a LOCATABLE SPOT such as a passenger seat."
  ; rdfs:subClassOf tm:SENSOR_EQUIPMENT
  .

tm:SENSOR_IN_SPOT a owl:Class ;
  rdfs:label "SENSOR IN SPOT"
  ; rdfs:comment "Use of a specific SPOT SENSOR to monitor a specific LOCATABLE SPOT."
  .

tm:DECK_ACTIVITY_COUNT a owl:Class ;
  rdfs:label "DECK ACTIVITY COUNT"
  ; rdfs:comment "A record of activity of a DECK COMPONENT for a given period."
  ; rdfs:subClassOf tm:DECK_SENSOR_ENTRY
  .

tm:DECK_SPACE_CAPACITY a owl:Class ;
  rdfs:label "DECK SPACE CAPACITY"
  ; rdfs:comment "The capacity of a DECK SPACE for passengers and other payload in terms of TYPES OF LOCATABLE SPOTs."
  .

tm:TYPE_OF_ACTIVITY_COUNT a owl:Class ;
  rdfs:label "TYPE OF ACTIVITY COUNT"
  ; rdfs:comment "Classification of ACTIVITY COUNT."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DECK_SENSOR_ENTRY a owl:Class ;
  rdfs:label "DECK SENSOR ENTRY"
  ; rdfs:comment "A specialisation of LOG ENTRY recording a measurement made for a DECK COMPONENT or an ACTUAL VEHICLE EQUIPMENT by a SENSOR EQUIPMENT."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:SPOT_OCCUPANCY a owl:Class ;
  rdfs:label "SPOT OCCUPANCY"
  ; rdfs:comment "A record of activity at a LOCATABLE SPOT at a given time."
  ; rdfs:subClassOf tm:DECK_SENSOR_ENTRY
  .

tm:DECK_ENTRANCE_ASSIGNMENT a owl:Class ;
  rdfs:label "DECK ENTRANCE ASSIGNMENT"
  ; rdfs:comment "<font color=\"#445469\">The association of a DECK ENTRANCE of a VEHICLE TYPE or TRAIN COMPONENT's DECK PLAN with a specific STOP PLACE, QUAY and possibly BOARDING POSITION.</font>"
  ; rdfs:subClassOf tm:PASSENGER_BOARDING_POSITION_ASSIGNMENT
  .

tm:TYPE_OF_ENTRANCE_USAGE a owl:Class ;
  rdfs:label "TYPE OF ENTRANCE USAGE"
  ; rdfs:comment "Classification for ENTRANCE USAGE, e.g., public, private, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ORIENTATION_TO_TRAVEL a owl:Class ;
  rdfs:label "ORIENTATION TO TRAVEL"
  ; rdfs:comment "Orientation status of element relative to direction of travel, or to containing vehicle;  e.g., forwards, backwards, to port, to starboard."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DECK_LEVEL a owl:Class ;
  rdfs:label "DECK LEVEL"
  ; rdfs:comment "An identified level (1, 2, 3, etc.) within the DECK PLAN of a VEHICLE (boat, air plane, etc.)."
  .

tm:PASSENGER_SPACE a owl:Class ;
  rdfs:label "PASSENGER SPACE"
  ; rdfs:comment "A specialisation of DECK SPACE defining an area within a VEHICLE (i.e., bus, boat, coach, car) or TRAIN ELEMENT TYPE (i.e., carriage, etc.) for use by passengers."
  ; rdfs:subClassOf tm:DECK_SPACE
  .

tm:PASSENGER_ENTRANCE a owl:Class ;
  rdfs:label "PASSENGER ENTRANCE"
  ; rdfs:comment "A normal entrance for passengers to or within a DECK."
  ; rdfs:subClassOf tm:DECK_ENTRANCE
  .

tm:OTHER_DECK_SPACE a owl:Class ;
  rdfs:label "OTHER DECK SPACE"
  ; rdfs:comment "A specialisation of DECK SPACE defining an area within a VEHICLE (i.e., bus, boat, coach, car) or TRAIN ELEMENT TYPE for restricted use, such as a crew area."
  ; rdfs:subClassOf tm:DECK_SPACE
  .

tm:OTHER_DECK_ENTRANCE a owl:Class ;
  rdfs:label "OTHER DECK ENTRANCE"
  ; rdfs:comment "An entrance to or within a DECK for use for other purposes than normal passenger access, e.g., crew, emergency exit, etc."
  ; rdfs:subClassOf tm:DECK_ENTRANCE
  .

tm:TYPE_OF_ACCOMMODATION a owl:Class ;
  rdfs:label "TYPE OF ACCOMMODATION"
  ; rdfs:comment "A classification of an ACCOMMODATION, e.g., seat, couchette etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:PASSENGER_VEHICLE_SPOT a owl:Class ;
  rdfs:label "PASSENGER VEHICLE SPOT"
  ; rdfs:comment "A designated onboard space in which to carry a vehicle (car, motorcycle, cycle, etc.) within a given DECK SPACE."
  ; rdfs:subClassOf tm:LOCATABLE_SPOT
  .

tm:LOCATABLE_SPOT a owl:Class ;
  rdfs:label "LOCATABLE SPOT"
  ; rdfs:comment "An identifiable individual area within a given PASSENGER SPACE, which may potentially be allocated to a single passenger or vehicle"
  ; rdfs:subClassOf tm:ONBOARD_SPACE
  .

tm:LUGGAGE_SPOT a owl:Class ;
  rdfs:label "LUGGAGE SPOT"
  ; rdfs:comment "A designated onboard space to stow passenger luggage."
  ; rdfs:subClassOf tm:LOCATABLE_SPOT
  .

tm:DECK_PLAN_ASSIGNMENT a owl:Class ;
  rdfs:label "DECK PLAN ASSIGNMENT"
  ; rdfs:comment "The allocation of a DECK PLAN to the whole or part of a specific VEHICLE JOURNEY and /or VEHICLE TYPE and/or TRAIN ELEMENT TYPE."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:ColourKey a owl:Class ;
  rdfs:label "ColourKey"
  .

tm:SENSOR_EQUIPMENT a owl:Class ;
  rdfs:label "SENSOR EQUIPMENT"
  ; rdfs:comment "An EQUIPMENT used to measure values relevant for some monitoring function, for example to monitor use of a space or entrance."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:BED_EQUIPMENT a owl:Class ;
  rdfs:label "BED EQUIPMENT"
  ; rdfs:comment "A specialisation of SPOT EQUIPMENT describing the detailed properties of a bed."
  ; rdfs:subClassOf tm:SPOT_EQUIPMENT
  .

tm:SPOT_EQUIPMENT a owl:Class ;
  rdfs:label "SPOT EQUIPMENT"
  ; rdfs:comment "An abstract EQUIPMENT in a LOCATABLE SPOT providing an onboard seat, bed or other amenity."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:SEAT_EQUIPMENT a owl:Class ;
  rdfs:label "SEAT EQUIPMENT"
  ; rdfs:comment "A specialisation of SPOT EQUIPMENT describing the detailed properties of a seat onboard a vehicle."
  ; rdfs:subClassOf tm:SPOT_EQUIPMENT
  .

tm:LUGGAGE_SPOT_EQUIPMENT a owl:Class ;
  rdfs:label "LUGGAGE SPOT EQUIPMENT"
  ; rdfs:comment "A specialisation of SPOT EQUIPMENT describing the detailed properties of a luggage bay."
  ; rdfs:subClassOf tm:SPOT_EQUIPMENT
  .

tm:DECK_WINDOW a owl:Class ;
  rdfs:label "DECK WINDOW"
  ; rdfs:comment "A window onto a DECK SPACE."
  ; rdfs:subClassOf tm:DECK_COMPONENT
  .

tm:SCHEMATIC_MAP_MEMBER a owl:Class ;
  rdfs:label "SCHEMATIC MAP MEMBER"
  ; rdfs:comment "A projection of an individual ENTITY onto a SCHEMATIC MAP."
  .

tm:VEHICLE_OCCUPANCY_COUNT a owl:Class ;
  rdfs:label "VEHICLE OCCUPANCY COUNT"
  ; rdfs:comment "A record of occupancy of a vehicle and optionally categorized by type of OCCUPANT for a DATED VEHICLE JOURNEY and/or VEHICLE, at or directly after leaving a specified POINT IN JOURNEY PATTERN."
  .

tm:VEHICLE_ENTRANCE_ACTIVITY_COUNT a owl:Class ;
  rdfs:label "VEHICLE ENTRANCE ACTIVITY COUNT"
  ; rdfs:comment "A record (or estimate) of boarding and alighting activity during the time the entrances are open at a stop, at a DECK ENTRANCE that is used to enter or exit a vehicle.  NOTE: The DECK ENTRANCE may be a PASSENGER ENTRANCE, in which case the count is of passengers, or a DECK VEHICLE ENTRANCE, in which case the count is of vehicles being loaded or unloaded."
  .

tm:VEHICLE_LOAD_ENTRY a owl:Class ;
  rdfs:label "VEHICLE LOAD ENTRY"
  ; rdfs:comment "The observed or estimated load levels for a DATED VEHICLE JOURNEY and/or VEHICLE, at or directly after leaving a specified POINT IN JOURNEY PATTERN."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:TYPE_OF_OCCUPANT a owl:Class ;
  rdfs:label "TYPE OF OCCUPANT"
  ; rdfs:comment "Classification of VEHICLE OCCUPANCY, e.g., as wheelchair, pram, cycle, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TRAVEL_PREFERENCES a owl:Class ;
  rdfs:label "TRAVEL PREFERENCES"
  ; rdfs:comment "Explicit or implicit preferences for travel of the actual TRANSPORT CUSTOMER to be used when making requests."
  .

tm:CONVENTIONAL_MODE_TRAVEL_PREFERENCES a owl:Class ;
  rdfs:label "CONVENTIONAL MODE TRAVEL PREFERENCES"
  ; rdfs:comment "Preferences for trip optimisation, e.g., least changes, fastest, least walking, etc."
  ; rdfs:subClassOf tm:TRAVEL_PREFERENCES
  .

tm:FAVOURITE_PLACE a owl:Class ;
  rdfs:label "FAVOURITE PLACE"
  ; rdfs:comment "A designated favourite place for the user that will be used repeatedly on requests, such as Home, Work, Gym, etc"
  .

tm:ALTERNATIVE_MODE_TRAVEL_PREFERENCES a owl:Class ;
  rdfs:label "ALTERNATIVE MODE TRAVEL PREFERENCES"
  ; rdfs:comment "Preferences of the TRANSPORT CUSTOMER that may be used when making requests for trips that include ALTERNATIVE MODE LEGs."
  ; rdfs:subClassOf tm:TRAVEL_PREFERENCES
  .

tm:CYCLING_TRAVEL_PREFERENCES a owl:Class ;
  rdfs:label "CYCLING TRAVEL PREFERENCES"
  ; rdfs:comment "Preferences the TRANSPORT CUSTOMER may use when making trip requests that include cycling legs."
  ; rdfs:subClassOf tm:TRAVEL_PREFERENCES
  .

tm:HIKING_TRAVEL_PREFERENCES a owl:Class ;
  rdfs:label "HIKING TRAVEL PREFERENCES"
  ; rdfs:comment "Preferences the TRANSPORT CUSTOMER to be used when making requests that include hiking legs."
  ; rdfs:subClassOf tm:TRAVEL_PREFERENCES
  .

tm:VEHICLE_EQUIPMENT_PROFILE_MEMBER a owl:Class ;
  rdfs:label "VEHICLE EQUIPMENT PROFILE MEMBER"
  ; rdfs:comment "An element within a VEHICLE EQUIPMENT PROFILE specifying the number of units of a given TYPE OF EQUIPMENT."
  .

tm:RENTAL_VEHICLE_FEATURE_OPTION a owl:Class ;
  rdfs:label "RENTAL VEHICLE FEATURE OPTION"
  ; rdfs:comment "A specialisation of USAGE PARAMETER summarising vehicle features for a RENTAL SERVICE."
  ; rdfs:subClassOf tm:RENTAL_OPTION
  .

tm:ROUTE_INSTRUCTION a owl:Class ;
  rdfs:label "ROUTE INSTRUCTION"
  ; rdfs:comment "A view providing Information for a human readable instruction as to how to follow a step on the ROUTE.  NOTE: Data may be derived from underlying route link and spatial PROJECTION of ROUTE LINK and ROUTE POINTs."
  .

tm:TYPE_OF_TRANSITION a owl:Class ;
  rdfs:label "TYPE OF TRANSITION"
  ; rdfs:comment "Nature of transition between the two ends of a path, e.g., up, down, level, up or down."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DECK_PATH_LINK_END a owl:Class ;
  rdfs:label "DECK PATH LINK END"
  ; rdfs:comment "Beginning or end of a DECK PATH LINK, referencing a DECK COMPONENT or LOCATABLE SPOT within a DECK; may be linked to a specific DECK LEVEL."
  ; rdfs:subClassOf tm:PATH_LINK_END
  .

tm:PATH_HEADING a owl:Class ;
  rdfs:label "PATH HEADING"
  ; rdfs:comment "Heading to take when following path, e.g., left, right, forward, reverse."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PATH_INSTRUCTION a owl:Class ;
  rdfs:label "PATH INSTRUCTION"
  ; rdfs:comment "An instruction to a passenger for an individual step when following a path."
  .

tm:SITE_STRUCTURE a owl:Class ;
  rdfs:label "SITE STRUCTURE"
  ; rdfs:comment "A building or a separate part thereof within a SITE."
  .

tm:LEVEL_IN_STRUCTURE a owl:Class ;
  rdfs:label "LEVEL IN STRUCTURE"
  ; rdfs:comment "<font color=\"#445469\">A LEVEL, i.e., storey in a building, that is accessible in a SITE STRUCTURE with its relative lateral order in that SITE STRUCTURE counted from the bottom and upwards.</font>"
  .

tm:PARKING_ACCESS_SPACE a owl:Class ;
  rdfs:label "PARKING ACCESS SPACE"
  ; rdfs:comment "An area for pedestrian access within a PARKING."
  ; rdfs:subClassOf tm:PARKING_COMPONENT
  .

tm:TYPE_OF_DRIVER_PERMIT a owl:Class ;
  rdfs:label "TYPE OF DRIVER PERMIT"
  ; rdfs:comment "<font color=\"#24292f\">A type of driving license that mau be requited to drive a given VEHICLE type.</font>  <font color=\"#24292f\">Note:  For standard classifcations see e.g. </font><a href=\"https://en.wikipedia.org/wiki/European_driving_licence\"><font color=\"#0000ff\"><u>https://en.wikipedia.org/wiki/European_driving_licence</u></font></a><font color=\"#24292f\">. </font>"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ACCEPTED_DRIVER_PERMIT a owl:Class ;
  rdfs:label "ACCEPTED DRIVER PERMIT"
  ; rdfs:comment "<font color=\"#24292f\">Accepted TYPE OF DRIVER PERMIT for a given SIMPLE VEHICLE TYPE.</font>"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CONTRACT a owl:Class ;
  rdfs:label "CONTRACT"
  ; rdfs:comment "A contract between ORGANISATIONs to supply services or goods."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:TYPE_OF_CONTRACT a owl:Class ;
  rdfs:label "TYPE OF CONTRACT"
  ; rdfs:comment "A classification of a CONTRACT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TRIP_MONITORING_LOG_ENTRY a owl:Class ;
  rdfs:label "TRIP MONITORING LOG ENTRY"
  ; rdfs:comment "A record of computed information describing some aspect of how a certain LOGICAL VEHICLE performs in relation to the latest operation plan based on comparing information from detection devices with operational data."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:PREFERRED_MODE a owl:Class ;
  rdfs:label "PREFERRED MODE"
  ; rdfs:comment "A preference by the user to travel by a specific mode and/or submode."
  .

tm:FARE_PRICE_FRAME a owl:Class ;
  rdfs:label "FARE PRICE FRAME"
  ; rdfs:comment "A set of FARE PRICE data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:PASSENGER_AT_STOP_TIME a owl:Class ;
  rdfs:label "PASSENGER AT STOP TIME"
  ; rdfs:comment "Time at which a boarding passenger should be at a stop to leave room for necessary pre-boarding processes and/or time at which an alighting passenger can expect to be able to leave a stop after completing necessary post-alighting processes."
  ; rdfs:subClassOf tm:PASSING_TIME
  .

tm:CHANGE_OF_STOP_POINT_STATUS a owl:Class ;
  rdfs:label "CHANGE OF STOP POINT STATUS"
  ; rdfs:comment "Change of the status of a SCHEDULED STOP POINT, a STOP PLACE or a QUAY, impacting all the DATED VEHICLE JOURNEYs in a certain period of time.  NOTE: This CONTROL ACTION is mainly used for stop closing or opening, and will give rise to further actions such as CHANGE OF JOURNEY PATTERNs or PARTIAL JOURNEY CANCELLATIONs."
  ; rdfs:subClassOf tm:INTERCHANGE_CONTROL_ACTION
  .

tm:GROUP_OF_CONTROL_ACTIONS a owl:Class ;
  rdfs:label "GROUP OF CONTROL ACTIONS"
  ; rdfs:comment "A grouping of related CONTROL ACTIONs, usually either triggered by one \"master\" CONTROL ACTION (for example the closing of a stop point) or by a SITUATION (weather condition, road traffic, etc.)."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:GROUP_OF_SITES a owl:Class ;
  rdfs:label "GROUP OF SITES"
  ; rdfs:comment "A grouping of SITEs for a particular functional purpose, usually the SITEs will be non-contiguous, such as the airports for a CITY."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:DECK_VEHICLE_ENTRANCE a owl:Class ;
  rdfs:label "DECK VEHICLE ENTRANCE"
  ; rdfs:comment "An entrance for passenger vehicles to or within a DECK."
  ; rdfs:subClassOf tm:DECK_ENTRANCE
  .

tm:ONBOARD_SPACE a owl:Class ;
  rdfs:label "ONBOARD SPACE"
  ; rdfs:comment "<font color=\"#445469\">A space aboard a vehicle, in which also ACTUAL VEHICLE EQUIPMENT may be located.</font>  <font color=\"#445469\">NOTE: the coordinates will be relative to the DECK containing the space.</font>"
  ; rdfs:subClassOf tm:ZONE
  .

tm:TIME_AGREEMENT a owl:Class ;
  rdfs:label "TIME AGREEMENT"
  ; rdfs:comment "A wage agreement under which a set of TIME ALLOWANCEs for specific DUTIEs and SPELLs have been agreed."
  .

tm:RECHARGING_POINT_ASSIGNMENT a owl:Class ;
  rdfs:label "RECHARGING POINT ASSIGNMENT"
  ; rdfs:comment "The allocation of a TIMING POINT to a SITE COMPONENT such as a PARKING BAY that has VEHICLE CHARGING EQUIPMENT."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:GROUP_OF_PLACES a owl:Class ;
  rdfs:label "GROUP OF PLACES"
  ; rdfs:comment "A grouping of PLACEs which will be commonly referenced for a specific purpose."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:RECHARGING_STEP a owl:Class ;
  rdfs:label "RECHARGING STEP"
  ; rdfs:comment "A planned charging of a VEHICLE, possibly at a PARKING POINT indicated by a POINT IN JOURNEY PATTERN on a specific VEHICLE JOURNEY."
  .

tm:RECHARGING_PLAN a owl:Class ;
  rdfs:label "RECHARGING PLAN"
  ; rdfs:comment "A plan for periodically charging a VEHICLE while executing a BLOCK or BLOCKs."
  .

tm:TYPE_OF_RECHARGING_PROCESS a owl:Class ;
  rdfs:label "TYPE OF RECHARGING PROCESS"
  ; rdfs:comment "Classification of a RECHARGING PROCESS."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RULE_STEP_RESULT a owl:Class ;
  rdfs:label "RULE STEP RESULT"
  ; rdfs:comment "Interim calculation step amounts for any pricing rules applied when deriving one price from another, for example discounts, VAT or other tax amount charged."
  .

tm:GENERAL_GROUP_OF_ENTITIES a owl:Class ;
  rdfs:label "GENERAL GROUP OF ENTITIES"
  ; rdfs:comment "An arbitrary grouping of entities of any type."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:SITE_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "SITE VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to the sites in the network."
  .

tm:PRODUCT_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "PRODUCT VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER linked to fare products and/or their distribution."
  .

tm:TARIFF_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "TARIFF VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER linked to tariff structures."
  .

tm:SEATING_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "SEATING VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to seating characteristics (e.g., coach or passenger seat)."
  .

tm:PLACE_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "PLACE VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to the sites in the network."
  .

tm:VEHICLE_MEETING_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "VEHICLE MEETING VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to the sites in the network."
  .

tm:CELL_SPECIFIC_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC GROUP"
  ; rdfs:comment "Specific assignments to other parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_ROUTING_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC ROUTING GROUP"
  ; rdfs:comment "Specific assignments to routing parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_NETWORK_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC NETWORK GROUP"
  ; rdfs:comment "Specific assignments to Network parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_TRANSPORT_TYPE_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC TRANSPORT TYPE GROUP"
  ; rdfs:comment "Specific assignments to transport type parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_SERVICE_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC SERVICE GROUP"
  ; rdfs:comment "Specific assignments to service parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_DISTRIBUTION_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC DISTRIBUTION GROUP"
  ; rdfs:comment "Specific assignments to distribution parameters affecting the price of the CELL."
  .

tm:CELL_SPECIFIC_EQUIPMENT_GROUP a owl:Class ;
  rdfs:label "CELL SPECIFIC EQUIPMENT GROUP"
  ; rdfs:comment "Specific assignments to equipment parameters affecting the price of the CELL."
  .

tm:VEHICLE_PREASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE PREASSIGNMENT"
  ; rdfs:comment "The default allocation of a VEHICLE to a NORMAL DATED JOURNEY, for example where a specific ship is used for a specific journey."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:PASSENGER_VEHICLE_ACCOMMODATION a owl:Class ;
  rdfs:label "PASSENGER VEHICLE ACCOMMODATION"
  ; rdfs:comment "Accommodation characteristics for passenger vehicles available on a service,"
  .

tm:REVERTING a owl:Class ;
  rdfs:label "REVERTING"
  ; rdfs:comment "Conditions governing the reversion of access rights for a FARE PRODUCT, e.g., the restoration of access rights after accidental activation or false start."
  ; rdfs:subClassOf tm:RESELLING
  .

tm:CONTROL_FARE_REVERSION_ENTRY a owl:Class ;
  rdfs:label "CONTROL FARE REVERSION ENTRY"
  ; rdfs:comment "<font color=\"#0f0f0f\">A PASSENGER TRAVEL ENTRY recording the reversal of the consumption of access rights, </font>usually at the start of a trip, for example by restoring the validity of a ticket that has been accidentally marked as used.  NOTE: Usually done by a ticket controller."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:CONTROL_REVERT_FARE_EVENT a owl:Class ;
  rdfs:label "CONTROL REVERT FARE EVENT"
  ; rdfs:comment "A control action to reverse the consumption of access rights, usually at the start of a trip, for example by restoring the validity of a ticket that has been accidentally marked as used.  NOTE: Usually done by a ticket controller."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:RIDE_LEG a owl:Class ;
  rdfs:label "RIDE LEG"
  ; rdfs:comment "<font color=\"#0f0f0f\">A part of a TRIP PATTERN corresponding to the movement of a user on one single vehicle in any public transport.</font>"
  ; rdfs:subClassOf tm:LEG
  .

tm:JOURNEY_PATTERN_TIMING a owl:Class ;
  rdfs:label "JOURNEY PATTERN TIMING"
  ; rdfs:comment "Abstract Time allowance applying to a specified JOURNEY PATTERN."
  .

tm:TYPE_OF_FARE_STRUCTURE_ELEMENT a owl:Class ;
  rdfs:label "TYPE OF FARE STRUCTURE ELEMENT"
  ; rdfs:comment "A classification of FARE STRUCTURE ELEMENT to indicate the nature of its use."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TRANSFER_LEG a owl:Class ;
  rdfs:label "TRANSFER LEG"
  ; rdfs:comment "<font color=\"#0f0f0f\">A part of a TRIP PATTERN corresponding to the TRANSFER of a user between two points located sufficiently close to include in a trip plan, e.g., for access or to make a connection.</font>"
  ; rdfs:subClassOf tm:LEG
  .

tm:VEHICLE_TRAVEL_MEANS a owl:Class ;
  rdfs:label "VEHICLE TRAVEL MEANS"
  ; rdfs:comment "Any vehicle-based TRAVEL MEANS (e.g., bus, tram, train, metro, ferry, ship, car, air plane)  NOTE: The same VEHICLE TRAVEL MEANS may be used by public transport and for personal use"
  ; rdfs:subClassOf tm:TRAVEL_MEANS
  .

tm:TRAVEL_MEANS a owl:Class ;
  rdfs:label "TRAVEL MEANS"
  ; rdfs:comment "Physical means of movement, disregarding any ownership or operational aspects."
  .

tm:OTHER_TRAVEL_MEANS a owl:Class ;
  rdfs:label "OTHER TRAVEL MEANS"
  ; rdfs:comment "Any specific TRAVEL MEANS that does not involve a vehicle (e.g., foot, skis, skates)"
  ; rdfs:subClassOf tm:TRAVEL_MEANS
  .

tm:ZONE_IN_SERIES a owl:Class ;
  rdfs:label "ZONE IN SERIES"
  ; rdfs:comment "Use of a ZONE in an ordered sequence within a SERIES CONSTRAINT, for example to indicate that a series must route through a given sequence of TARIFF ZONEs."
  ; rdfs:subClassOf tm:ZONE_IN_LINK_SEQUENCE
  .

tm:USAGE_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "USAGE VALIDITY PARAMETERS"
  ; rdfs:comment "A type of SCOPING VALIDITY PARAMETER linked to FARE PRODUCTS and/ their limitations through USAGE PARAMETERs"
  .

tm:CUSTOMER_RESERVATION_CANCELLATION_EVENT a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION CANCELLATION EVENT"
  ; rdfs:comment "The cancellation of a reservation by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_EVENT
  .

tm:CUSTOMER_RESERVATION_EVENT a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION EVENT"
  ; rdfs:comment "An event relating to reservations"
  ; rdfs:subClassOf tm:SALES_EVENT
  .

tm:CUSTOMER_RESERVATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION ENTRY"
  ; rdfs:comment "An abstract SALES TRANSACTION recording the reservation of an access right for a customer."
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:GROUP_OF_TRAVEL_MEANS a owl:Class ;
  rdfs:label "GROUP OF TRAVEL MEANS"
  ; rdfs:comment "A restricted list of TRAVEL MEANS that are allowed for a particular purpose, for example to board a motor rail train."
  .

tm:LIFT_CALL_EQUIPMENT a owl:Class ;
  rdfs:label "LIFT CALL EQUIPMENT"
  ; rdfs:comment "Specialisation of PLACE ACCESS EQUIPMENT describing means of calling a lift (button height, buttons, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:SALES_OFFER_ENTITLEMENT_REQUIRED a owl:Class ;
  rdfs:label "SALES OFFER ENTITLEMENT REQUIRED"
  ; rdfs:comment "SALES OFFER ENTITLEMENT required to use SALES OFFER PACKAGE."
  ; rdfs:subClassOf tm:ENTITLEMENT
  .

tm:SALES_OFFER_ENTITLEMENT_GIVEN a owl:Class ;
  rdfs:label "SALES OFFER ENTITLEMENT GIVEN"
  ; rdfs:comment "SALES OFFER ENTITLEMENT given to use SALES OFFER PACKAGE."
  ; rdfs:subClassOf tm:ENTITLEMENT
  .

tm:ENTITLEMENT a owl:Class ;
  rdfs:label "ENTITLEMENT"
  ; rdfs:comment "A USAGE PARAMETER indicating whether a particular FARE PRODUCT is required or gives an entitlement to use another product."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TOPOGRAPHIC_PROJECTION a owl:Class ;
  rdfs:label "TOPOGRAPHIC PROJECTION"
  ; rdfs:comment "A correspondence from one ZONE in a source layer, onto a target named place, e.g., COUNTRY, TOPOGRAPHICAL PLACE."
  ; rdfs:subClassOf tm:PROJECTION
  .

tm:ZONE_IN_LINK_SEQUENCE a owl:Class ;
  rdfs:label "ZONE IN LINK SEQUENCE"
  ; rdfs:comment "The order of a ZONE in a LINK SEQUENCE to which it is associated."
  .

tm:TYPE_OF_BED a owl:Class ;
  rdfs:label "TYPE OF BED"
  ; rdfs:comment "A classification of a BED EQUIPMENT, e.g., as single, double, bottom bunk, middle bunk, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:DECK_PATH_JUNCTION a owl:Class ;
  rdfs:label "DECK PATH JUNCTION"
  ; rdfs:comment "A designated point within a DECK PLAN, at which two or more DECK PATH LINKs may connect or branch."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_PATH_JUNCTION
  .

tm:REVOKE_FULFILMENT_ENTRY a owl:Class ;
  rdfs:label "REVOKE FULFILMENT ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the revoking of a previous fulfilment so that a TRAVEL DOCUMENT may be reissued.  NOTE: Authentication Tokens may be cancelled."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:CUSTOMER_REVOKE_FULFILMENT_EVENT a owl:Class ;
  rdfs:label "CUSTOMER REVOKE FULFILMENT EVENT"
  ; rdfs:comment "The revoking  of a TRAVEL DOCUMENT and/or MEDIUM ACCESS DEVICE from any fulfilment means"
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:ORGANISATION_REQUEST_FILTER a owl:Class ;
  rdfs:label "ORGANISATION REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the ORGANISATION REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:SERVICE_JOURNEY_REQUEST_FILTER a owl:Class ;
  rdfs:label "SERVICE JOURNEY REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the EXCHANGE POINTS REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:VEHICLE_TYPE_REQUEST_FILTER a owl:Class ;
  rdfs:label "VEHICLE TYPE REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the VEHICLE TYPE REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:MOBILITY_SERVICE_REQUEST_FILTER a owl:Class ;
  rdfs:label "MOBILITY SERVICE REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the MOBILITY SERVICE REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:STOP_FARE_REQUEST_FILTER a owl:Class ;
  rdfs:label "STOP FARE REQUEST FILTER"
  ; rdfs:comment "Parameters controlling the type of fares returned by a STOP FARE REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:STOP_FARE_REQUEST_POLICY a owl:Class ;
  rdfs:label "STOP FARE REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used when computing and decorating TRIP FARE REQUEST results."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:FARE_OFFER_PRICE a owl:Class ;
  rdfs:label "FARE OFFER PRICE"
  ; rdfs:comment "A set of all possible price features of a FARE OFFER, discount in value or percentage, etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:FARE_PRODUCT_CANCELLATION_ENTRY a owl:Class ;
  rdfs:label "FARE PRODUCT CANCELLATION ENTRY"
  ; rdfs:comment "<font color=\"#0f0f0f\">A CUSTOMER PRODUCT PURCHASE ENTRY recording the cancellation / rollback of a partially completed purchase </font>"
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:LEG_IN_TRAVEL_SPECIFICATION a owl:Class ;
  rdfs:label "LEG IN TRAVEL SPECIFICATION"
  ; rdfs:comment "RIDE LEG offered by TRAVEL SPECIFICATION, in Sequence"
  .

tm:TRIP_SPOT_AVAILABILITY_ENTRY a owl:Class ;
  rdfs:label "TRIP SPOT AVAILABILITY ENTRY"
  ; rdfs:comment "A CUSTOMER RESERVATION ENTRY recording the availability of spots for given TRIP at a given moment in time."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_ENTRY
  .

tm:CUSTOMER_SPOT_AVAILABILITY_EVENT a owl:Class ;
  rdfs:label "CUSTOMER SPOT AVAILABILITY EVENT"
  ; rdfs:comment "An action to check the availability of a SPOT for reservation to a TRANSPORT CUSTOMER for a given trip."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_EVENT
  .

tm:ENVIRONMENT_PROPERTIES a owl:Class ;
  rdfs:label "ENVIRONMENT PROPERTIES"
  ; rdfs:comment "Common properties of the physical environment relevant for SITE and path elements."
  .

tm:NAVIGATION_PATH a owl:Class ;
  rdfs:label "NAVIGATION PATH"
  ; rdfs:comment "A designated path between two SITES or SITE COMPONENTs."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_NAVIGATION_PATH
  .

tm:SITE_PATH_LINK_END a owl:Class ;
  rdfs:label "SITE PATH LINK END"
  ; rdfs:comment "Beginning or end for a SITE PATH LINK, associated with a given SITE ELEMENT, PATH JUNCTION or DECK COMPONENT; may also be linked to a specific LEVEL of a SITE."
  ; rdfs:subClassOf tm:PATH_LINK_END
  .

tm:PATH_JUNCTION a owl:Class ;
  rdfs:label "PATH JUNCTION"
  ; rdfs:comment "A designated point, inside or outside of a STOP PLACE or POINT OF INTEREST, at which two or more PATH LINKs may connect or branch."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_PATH_JUNCTION
  .

tm:DECK_NAVIGATION_PATH a owl:Class ;
  rdfs:label "DECK NAVIGATION PATH"
  ; rdfs:comment "A designated path between two points within a DECK PLAN; may include an ordered sequence of DECK PATH LINKs."
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  ; rdfs:subClassOf tm:GENERIC_NAVIGATION_PATH
  .

tm:DECK_PLACE_IN_SEQUENCE a owl:Class ;
  rdfs:label "DECK PLACE IN SEQUENCE"
  ; rdfs:comment "Point traversed by a DECK NAVIGATION PATH in sequence, connected by a DECK PATH LINK to the next point; may be an ONBOARD SPACE (i.e., PASSENGER SPACE, DECK ENTRANCE, etc), or DECK PATH JUNCTION."
  ; rdfs:subClassOf tm:PLACE_IN_SEQUENCE
  .

tm:CELL_PRICE a owl:Class ;
  rdfs:label "CELL PRICE"
  ; rdfs:comment "Price features for a CELL"
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TRAIN_COMPONENT_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "TRAIN COMPONENT STOP ASSIGNMENT"
  ; rdfs:comment "The association of a TRAIN COMPONENT at a SCHEDULED STOP POINT with a specific STOP PLACE and also possibly a QUAY and BOARDING POSITION."
  ; rdfs:subClassOf tm:PASSENGER_BOARDING_POSITION_ASSIGNMENT
  .

tm:FLEXIBLE_POINT_IN_PATTERN_PROPERTIES a owl:Class ;
  rdfs:label "FLEXIBLE POINT IN PATTERN PROPERTIES"
  ; rdfs:comment "Additional characteristics of a point in a flexible JOURNEY PATTERN."
  .

tm:ESTIMATED_VEHICLE_LOAD_ENTRY a owl:Class ;
  rdfs:label "ESTIMATED VEHICLE LOAD ENTRY"
  ; rdfs:comment "The estimated load levels for a VEHICLE on a journey, at a specified stop."
  ; rdfs:subClassOf tm:VEHICLE_LOAD_ENTRY
  .

tm:ESTIMATED_VEHICLE_OCCUPANCY_COUNT a owl:Class ;
  rdfs:label "ESTIMATED VEHICLE OCCUPANCY COUNT"
  ; rdfs:comment "An estimate of occupancy of a vehicle and optionally categorized by type of OCCUPANT for a DATED VEHICLE JOURNEY and/or VEHICLE, at or directly after leaving a specified POINT IN JOURNEY PATTERN."
  ; rdfs:subClassOf tm:VEHICLE_OCCUPANCY_COUNT
  .

tm:access_right a owl:Class ;
  rdfs:label "access right"
  ; rdfs:comment "right to consume a Public Transport service or other service provided along with the transport"
  .

tm:account_based_ticketing a owl:Class ;
  rdfs:label "account based ticketing"
  ; rdfs:comment "fare collection paradigm which manages ticket issuing and validation through individual customer accounts held online and controlled by means of a token used on paper or electronic materialisations of a travel document"
  .

tm:activation a owl:Class ;
  rdfs:label "activation"
  ; rdfs:comment "triggering of the use of access rights and initiation of consumption"
  .

tm:anonymous_customer a owl:Class ;
  rdfs:label "anonymous customer"
  ; rdfs:comment "CUSTOMER whose identity is not visible from their TRAVEL DOCUMENT, but who may be nevertheless be a registered customer using an anonymous token, in contrast to an impersonal customer, of whom the service operator has no individual knowledge"
  .

tm:automated_fare_collection_system a owl:Class ;
  rdfs:label "automated fare collection system"
  ; rdfs:comment "fare collection system capable of automatically determining which products the customer must purchase according to the travel he consumes"
  .

tm:base_price a owl:Class ;
  rdfs:label "base price"
  ; rdfs:comment "price that is provided as a fixed absolute amount and from which other prices may be derived"
  .

tm:booking a owl:Class ;
  rdfs:label "booking"
  ; rdfs:comment "placing of a reservation to use a specific transport service, but not necessarily entailing a purchase of a ticket"
  .

tm:blacklist a owl:Class ;
  rdfs:label "blacklist"
  ; rdfs:comment "revenue protection mechanism taking the form of a security list identifying travel documents, media, etc. for which the validity has been cancelled temporarily (denial) or permanently (refusal) and which will be used to block access to services for customers bearing documents associated with items on the list"
  .

tm:cancellation a owl:Class ;
  rdfs:label "cancellation"
  ; rdfs:comment "marking of a TRAVEL DOCUMENT as having been used"
  .

tm:capping a owl:Class ;
  rdfs:label "capping"
  ; rdfs:comment "setting of an upper limit on the price of the consumption of access rights within a certain period"
  .

tm:card_centric a owl:Class ;
  rdfs:label "card-centric"
  ; rdfs:comment "form of media centric ticketing where the media is a smart card"
  .

tm:classical_ticketing a owl:Class ;
  rdfs:label "classical ticketing"
  ; rdfs:comment "non-electronic fare management and ticketing using paper and passive media travel documents, usually for a single operator and for simple products such as single tips, return trips or period passes."
  .

tm:control a owl:Class ;
  rdfs:label "control"
  ; rdfs:comment "checking of a passenger’s entitlement to consume access rights, involving identification of the traveller and/or the travel rights"
  .

tm:consumption a owl:Class ;
  rdfs:label "consumption"
  ; rdfs:comment "using up of access right by a transport customer as a result of travel"
  .

tm:credentials a owl:Class ;
  rdfs:label "credentials"
  ; rdfs:comment "data or other mechanisms used to authenticate an actor to a system as a legitimate participant"
  .

tm:derived_price a owl:Class ;
  rdfs:label "derived price"
  ; rdfs:comment "price that can be computed from another base price using pricing parameters and a pricing rule"
  .

tm:distributor a owl:Class ;
  rdfs:label "distributor"
  ; rdfs:comment "party who sells products on behalf of other product owners"
  .

tm:dynamic_price a owl:Class ;
  rdfs:label "dynamic price"
  ; rdfs:comment "price that is fetched at run time from a pricing engine as opposed to a static or derived price"
  .

tm:easement a owl:Class ;
  rdfs:label "easement"
  ; rdfs:comment "change to the normal access rights given to passengers because of a disruption to the network"
  .

tm:embargo_date a owl:Class ;
  rdfs:label "embargo date"
  ; rdfs:comment "date before which information about a price or product is not to be released to the public"
  .

tm:fare a owl:Class ;
  rdfs:label "fare"
  ; rdfs:comment "from the customer perspective, the amount that a customer has to pay for a journey or for acquiring a specific fare product"
  .

tm:fare_set a owl:Class ;
  rdfs:label "fare set"
  ; rdfs:comment "particular version of all aspects of the fare structure, i.e., of the rules and associated parameter values, also called a ‘tariff"
  .

tm:fare_structure a owl:Class ;
  rdfs:label "fare structure"
  ; rdfs:comment "set of parameters that determine the basic tariffs"
  .

tm:fare_token a owl:Class ;
  rdfs:label "fare token"
  ; rdfs:comment "materialisation of a travel document, i.e. ticket, as an anonymous physical object, such as a coin-like object that is captured at validation and subsequently reused; or an ephemeral paper representation that is cancelled"
  .

tm:flat_faret a owl:Class ;
  rdfs:label "flat faret"
  ; rdfs:comment "fare that does not increase in proportion to distance or other measure of consumption (and so typically cannot be derived by calculation)"
  .

tm:fulfilment a owl:Class ;
  rdfs:label "fulfilment"
  ; rdfs:comment "delivery of a TRAVEL DOCUMENT to the customer once it has been ordered or purchased"
  .

tm:graduated_fare a owl:Class ;
  rdfs:label "graduated fare"
  ; rdfs:comment "type of progressive fare, i.e., one that increases in proportion to consumption, where the increase is based in a distance increment"
  .

tm:identity_token a owl:Class ;
  rdfs:label "identity token"
  ; rdfs:comment "secure, machine-readable instantiation in media of an identity"
  .

tm:impersonal_customer a owl:Class ;
  rdfs:label "impersonal customer"
  ; rdfs:comment "CUSTOMER whose identity is not known in any way to the operator, for example the purchaser of a paper metro ticket"
  .

tm:interlining_trip a owl:Class ;
  rdfs:label "interlining trip"
  ; rdfs:comment "customer trip made using a single medium and/or fare product that starts in one PT network and ends in another, in contrast to a local trip or a roaming trip"
  .

tm:interoperable_fare_management_system a owl:Class ;
  rdfs:label "interoperable fare management system"
  ; rdfs:comment "fare system which is interoperable with other fare systems, possessing all the functions involved in the fare management process such as management of application, products, security and certification, registration, and identification to enable customers to travel with participating service operators using a single portable electronic medium"
  .

tm:inventory_controlled_product a owl:Class ;
  rdfs:label "inventory controlled product"
  ; rdfs:comment "FARE PRODUCT whose supply is constrained by the service provider, such that only a set quota of capacity is available on a given journey"
  .

tm:local_trip a owl:Class ;
  rdfs:label "local trip"
  ; rdfs:comment "trip made entirely within the home network of a fare product"
  .

tm:local_use_fare_product a owl:Class ;
  rdfs:label "local use fare product"
  ; rdfs:comment "fare product&#160;&#160;which can only be used on the operator&#8217;s own network, in contrast to a roaming product"
  .

tm:marking a owl:Class ;
  rdfs:label "marking"
  ; rdfs:comment "stamping or defacing a travel document to indicate that it has been activated and its rights consumed or partially consumed"
  .

tm:media a owl:Class ;
  rdfs:label "media"
  ; rdfs:comment "physical support containing a machine readable/writable data/processor application, such as transport industry smartcards, payment industry contactless cards, public sector issued cards, mobile phones or paper (for barcodes), new formats such as watches and key fobs, plus NFC mobile"
  .

tm:media_centric_ticketing a owl:Class ;
  rdfs:label "media centric ticketing"
  ; rdfs:comment "ticketing paradigm under which the product sold is held entirely on some form of local media and any validation and charging is done immediately against the card’s contents"
  .

tm:pay_as_you_go a owl:Class ;
  rdfs:label "pay as you go"
  ; rdfs:comment "type of reusable fare product giving the right to travel where the user is charged for access rights at the point of consumption or sometime after completing consumption,"
  .

tm:post_paid_ticketing a owl:Class ;
  rdfs:label "post-paid ticketing"
  ; rdfs:comment "type of fare management according to which the user is charged at some time after using the transport service"
  .

tm:prepaid_ticketing a owl:Class ;
  rdfs:label "prepaid ticketing"
  ; rdfs:comment "type of fare management according to which the user is charged for either a fare product (ticket) or a deposit prior to riding"
  .

tm:price a owl:Class ;
  rdfs:label "price"
  ; rdfs:comment "value of fare or tariff"
  .

tm:progressive_fare a owl:Class ;
  rdfs:label "progressive fare"
  ; rdfs:comment "fare that increases in proportion to consumption of space and/or time"
  .

tm:registration a owl:Class ;
  rdfs:label "registration"
  ; rdfs:comment "enrolment of a customer as a user of a fare system"
  .

tm:retailer a owl:Class ;
  rdfs:label "retailer"
  ; rdfs:comment "actor who sells products directly to the end customer (as opposed to a distributor)"
  .

tm:roaming_trip a owl:Class ;
  rdfs:label "roaming trip"
  ; rdfs:comment "customer trip using a single medium and/or fare product from one operator made entirely inside another operator’s PT network, in contrast to a local trip or an interlining"
  .

tm:roaming_fare_product a owl:Class ;
  rdfs:label "roaming fare product"
  ; rdfs:comment "fare product that is issued by one operator but valid on the network of another operator (in contrast to a local product)"
  .

tm:static_price a owl:Class ;
  rdfs:label "static price"
  ; rdfs:comment "price that is precomputed and explicitly distributed, as opposed to a derived or dynamic price"
  .

tm:status_of_consumption a owl:Class ;
  rdfs:label "status of consumption"
  ; rdfs:comment "status indicating whether a given access right included in a customer purchase has been activated, consumed, etc."
  .

tm:tap a owl:Class ;
  rdfs:label "tap"
  ; rdfs:comment "industry term for the record of a customer’s interaction with the system that may be collected for interoperable fare management including, in particular, any sort of validation entry returned with specific data from validation devices to the back office in an Account Based System"
  .

tm:tap_in_out a owl:Class ;
  rdfs:label "tap in / out"
  ; rdfs:comment "the process of using a mobile device or EMV card to interact with a NFC wireless validation device to check in or out (or at a waypoint) of a fare control system"
  .

tm:validation a owl:Class ;
  rdfs:label "validation"
  ; rdfs:comment "verification that an access right is valid, has been or is being consumed, and that this consumption is allowed, achieved by checking the validity of the passenger’s travel rights and comparing them to the parameters collected by the previous inspections and/or inspection context"
  .

tm:waypoint a owl:Class ;
  rdfs:label "waypoint"
  ; rdfs:comment "an intermediate point along a route that a user making a trip may tap in at in order to prove that they followed a particular routing"
  .

tm:ABT a owl:Class ;
  rdfs:label "ABT"
  ; rdfs:comment "Account Based Ticketing"
  .

tm:AFC a owl:Class ;
  rdfs:label "AFC"
  ; rdfs:comment "Automated Fare Collection"
  .

tm:AR a owl:Class ;
  rdfs:label "AR"
  ; rdfs:comment "Access Right"
  .

tm:EMV a owl:Class ;
  rdfs:label "EMV"
  ; rdfs:comment "Europay MasterCard Visa standards for payment cards"
  .

tm:FM a owl:Class ;
  rdfs:label "FM"
  ; rdfs:comment "Fare Model"
  .

tm:FP a owl:Class ;
  rdfs:label "FP"
  ; rdfs:comment "Fare Pricing"
  .

tm:FS a owl:Class ;
  rdfs:label "FS"
  ; rdfs:comment "Fare Structure"
  .

tm:FSM a owl:Class ;
  rdfs:label "FSM"
  ; rdfs:comment "Full Service Model"
  .

tm:IFM a owl:Class ;
  rdfs:label "IFM"
  ; rdfs:comment "Full Service Model"
  .

tm:NFC a owl:Class ;
  rdfs:label "NFC"
  ; rdfs:comment "Near Field Communication"
  .

tm:OCR a owl:Class ;
  rdfs:label "OCR"
  ; rdfs:comment "Optical Character Recognition"
  .

tm:OJP a owl:Class ;
  rdfs:label "OJP"
  ; rdfs:comment "Open Journey Planner"
  .

tm:OSDM a owl:Class ;
  rdfs:label "OSDM"
  ; rdfs:comment "Open Sales and Distribution Model"
  .

tm:SD a owl:Class ;
  rdfs:label "SD"
  ; rdfs:comment "Sales Description"
  .

tm:ST a owl:Class ;
  rdfs:label "ST"
  ; rdfs:comment "Sales Transaction"
  .

tm:SMS a owl:Class ;
  rdfs:label "SMS"
  ; rdfs:comment "Sales Transaction"
  .

tm:VC a owl:Class ;
  rdfs:label "VC"
  ; rdfs:comment "Validation &amp; Control"
  .

tm:METHOD_OF_QUEUE_MANAGEMENT a owl:Class ;
  rdfs:label "METHOD OF QUEUE MANAGEMENT"
  ; rdfs:comment "A classification of method used to manage a queue, e.g., rails, parallel rails, ticket, appointment, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_RENTAL_POLICY a owl:Class ;
  rdfs:label "TYPE OF RENTAL POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Type of rental policy applying to hire, (e.g. specified drop-off place)</font>."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_VIA a owl:Class ;
  rdfs:label "TYPE OF VIA"
  ; rdfs:comment "A classification for VIAs, e.g. as a specific stop point, as a place name, as a general phrase."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_ASSISTANCE_NEEDED a owl:Class ;
  rdfs:label "TYPE OF ASSISTANCE NEEDED"
  ; rdfs:comment "Classification of type of assistance needed with VEHICLE ACCESS EQUIPMENT, e.g. hoist required, ramp required, level access."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_ASSISTED_BOARDING_LOCATION a owl:Class ;
  rdfs:label "TYPE OF ASSISTED BOARDING LOCATION"
  ; rdfs:comment "Classification of assistance boarding location, e.g., anywhere on platform, at specific point, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_SUBSCRIPTION_RENEWAL a owl:Class ;
  rdfs:label "TYPE OF SUBSCRIPTION RENEWAL"
  ; rdfs:comment "Nature of subscription renewal at end of subscription period, e.g. automatic, by request, none, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SuitableENUM a owl:Class ;
  rdfs:label "SuitableENUM"
  ; rdfs:comment "Allowed values for Suitable Need."
  .

tm:LimitationStatusENUM a owl:Class ;
  rdfs:label "LimitationStatusENUM"
  ; rdfs:comment "Allowed values for Limitation Status."
  .

tm:TYPE_OF_TRANSFER_RESTRICTION a owl:Class ;
  rdfs:label "TYPE OF TRANSFER RESTRICTION"
  ; rdfs:comment "Classification of TRANSFER RESTRICTION, for example, allowed, allowed at certain times, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:USUAL_DRIVING_STYLE a owl:Class ;
  rdfs:label "USUAL DRIVING STYLE"
  ; rdfs:comment "Classification o driving style, e.g., relaxed, fast."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ALLOWED_ZONE_USE a owl:Class ;
  rdfs:label "ALLOWED ZONE USE"
  ; rdfs:comment "Classification of allowed behaviour in zone, for example; cannot board in zone, must board in zone, cannot board and alight in same zone, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ModificationENUM a owl:Class ;
  rdfs:label "ModificationENUM"
  ; rdfs:comment "Allowed values for the modification status of an ENTITY IN VERSION,; has the entity been added in this version, modified in this version or deleted in this version"
  .

tm:TYPE_OF_ACCOUNTABLE_ACTIVITY a owl:Class ;
  rdfs:label "TYPE OF ACCOUNTABLE ACTIVITY"
  ; rdfs:comment "A classification of an ACCOUNTABLE ACTIViTY to allow further categorisation for accounting purposes."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:CONTROL_AND_VALIDATION_FRAME a owl:Class ;
  rdfs:label "CONTROL AND VALIDATION FRAME"
  ; rdfs:comment "A set of Validation and Control data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:navigation_path a owl:Class ;
  rdfs:label "navigation path"
  ; rdfs:comment "a route that can be used by pedestrians, wheelchairs, cyclists, etc, (i.e. passengers who are not in a transport vehicle) to access or transfer between two places / or transport access points.  NOTE: In Transmodel, a NAVIGATION PATH made up of discrete PATH LINKs."
  .

tm:stop a owl:Class ;
  rdfs:label "stop"
  ; rdfs:comment "a place where vehicles stop in order to allow passengers to get on and off.  NOTE: Transmodel separates the  concerns of the notional stop in a timetable (SCHEDULED STOP POINT) and the physical stop (STOP PLACE / QUAY)."
  .

tm:roster a owl:Class ;
  rdfs:label "roster"
  ; rdfs:comment "A list assigning specific duties to specific employees on specific occasions.  NOTE: Transmodel uses ROSTER MATRIX, ROSTER CYCLE and ROSTER DESIGN to variously specify the duty types, individuals, days of week  and other concepts making up a roster."
  .

tm:run_time a owl:Class ;
  rdfs:label "run time"
  ; rdfs:comment "the time taken for a vehicle to go between two points.  NOTE: In Transmodel a run time may be specified for the individual SERVICE LINK between two stops and for the whole journey pattern."
  .

tm:wait_time a owl:Class ;
  rdfs:label "wait time"
  ; rdfs:comment "the time interval a vehicle spends waiting at a timing point such as a stop in the course of a journey, as distinct from the run times spent moving between the points."
  .

tm:headway a owl:Class ;
  rdfs:label "headway"
  ; rdfs:comment "the interval between vehicles servicing a route and hence between the arrival of services at a stop."
  .

tm:accessibility a owl:Class ;
  rdfs:label "accessibility"
  ; rdfs:comment "the physical accessibility aspects of public transport (e.g., if there are stairs in a station) in particular with respect to passengers with various types of mobility impairment."
  .

tm:TYPE_OF_SITUATION_RELATION a owl:Class ;
  rdfs:label "TYPE OF SITUATION RELATION"
  ; rdfs:comment "Association with another SITUATION, e that has a relationship of cause or effect&#160;&#160;(or otherwise) with the SITUATION.  NOTE: the nature of the relationship can be indicated by&#160;&#160;the TYPE OF SITUATION&#160;&#160;on the RELATED SITUATION."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:SITUATION_STATUS a owl:Class ;
  rdfs:label "SITUATION STATUS"
  ; rdfs:comment "A classification of the current overall state of processing of the SITUATION, e.g. 'Draft' for not yet published; 'Published' for live SITUATIONs; 'Closed' for completed SITUATIONs."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_IMPACT a owl:Class ;
  rdfs:label "TYPE OF IMPACT"
  ; rdfs:comment "A classification of the nature of the impact on the PT SCOPE, i.e., TPEG Pti13 Service Condition values.  ."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_REMEDY a owl:Class ;
  rdfs:label "TYPE OF REMEDY"
  ; rdfs:comment "A classification of the change of availability of a facility, such as being removed, unavailable or only partially available."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_BERTH a owl:Class ;
  rdfs:label "TYPE OF BERTH"
  ; rdfs:comment "A classification of berth, e.g. lower middle top, double, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_BOOKING_ACCESS a owl:Class ;
  rdfs:label "TYPE OF BOOKING ACCESS"
  ; rdfs:comment "A classification of who can make a booking, e.g. public, staff, authorised public, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DRIVER_FEE_BASIS a owl:Class ;
  rdfs:label "DRIVER FEE BASIS"
  ; rdfs:comment "A classification of the charging basis for additional drivers, for example; free, per driver, unlimited drivers, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_HEADWAY_DISPLAY a owl:Class ;
  rdfs:label "TYPE OF HEADWAY DISPLAY"
  ; rdfs:comment "A classification of HEADWAY DISPLAY as to whether passing times, intervals, etc, are to be displayed."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:REASON_FOR_JOURNEY_MEETING a owl:Class ;
  rdfs:label "REASON FOR JOURNEY MEETING"
  ; rdfs:comment "A characterisation Log the reason for the journey meeting, e.g. joining, splitting, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_JOURNEY_DIRECTION a owl:Class ;
  rdfs:label "TYPE OF JOURNEY DIRECTION"
  ; rdfs:comment "A classification of the journey direction as inbound, outbound, clockwise, anticlockwise, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_DYNAMIC_ADVERTISEMENT a owl:Class ;
  rdfs:label "TYPE OF DYNAMIC ADVERTISEMENT"
  ; rdfs:comment "A classification of the advertisement rule to be used for journey, e.g. always show, only show journeys once started, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_PARKING_PAYMENT_PROCESS a owl:Class ;
  rdfs:label "TYPE OF PARKING PAYMENT PROCESS"
  ; rdfs:comment "A classification of a type of parking payment process, pay at display, pay by mobile, pay at exit,&#160;&#160;"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_PARKING_RESERVATION a owl:Class ;
  rdfs:label "TYPE OF PARKING RESERVATION"
  ; rdfs:comment "A classification of a type of parking reservation process for the PARKING, e.g. no reservations, reservations required, reservations possible, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PARKING_PRIORITY_CATEGORY a owl:Class ;
  rdfs:label "PARKING PRIORITY CATEGORY"
  ; rdfs:comment "Characterisation of the priority to park according to some policy rules, e.g. handicapped users during shopping hours, staff, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_ACCESS_SPACE a owl:Class ;
  rdfs:label "TYPE OF ACCESS SPACE"
  ; rdfs:comment "A classification for ACCESS SPACE, e.g. forecourt ticket hall, shop, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_ENTRANCE a owl:Class ;
  rdfs:label "TYPE OF ENTRANCE"
  ; rdfs:comment "A classification for ENTRANCE for example as an opening, door, barrier etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_HOLIDAY a owl:Class ;
  rdfs:label "TYPE OF HOLIDAY"
  ; rdfs:comment "Categorisation of holiday types, e.g. National, Regional, Local,  School, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RECHARGING_BAY a owl:Class ;
  rdfs:label "RECHARGING BAY"
  ; rdfs:comment "A PARKING BAY specifically equipped for recharging VEHICLEs."
  ; rdfs:subClassOf tm:PARKING_BAY
  .

tm:RECHARGING_STATION a owl:Class ;
  rdfs:label "RECHARGING STATION"
  ; rdfs:comment "A PARKING with bays specifically equipped for recharging VEHICLEs."
  ; rdfs:subClassOf tm:PARKING
  .

tm:VEHICLE_EQUIPMENT_PROFILE_12709 a owl:Class ;
  rdfs:label "VEHICLE EQUIPMENT PROFILE"
  ; rdfs:comment "Each instantiation of this entity gives the number of items of one TYPE OF EQUIPMENT a VEHICLE MODEL should contain for a given PURPOSE OF EQUIPMENT PROFILE.  NOTE: The set of instantiations for one VEHICLE MODEL and one purpose gives one complete 'profile'."
  .

tm:SINGLE_JOURNEY_REQUEST_FILTER a owl:Class ;
  rdfs:label "SINGLE JOURNEY REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the SINGLE JOURNEY REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:TYPE_OF_LUGGAGE_SPOT a owl:Class ;
  rdfs:label "TYPE OF LUGGAGE SPOT"
  ; rdfs:comment "A classification of a LUGGAGE SPOT EQUIPMENT, e.g., as rack, locker, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_SEAT a owl:Class ;
  rdfs:label "TYPE OF SEAT"
  ; rdfs:comment "A classification of a SEAT EQUIPMENT, e.g., as folding, reclining, etc"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:JOURNEY_PART_IN_COUPLE a owl:Class ;
  rdfs:label "JOURNEY PART  IN COUPLE"
  ; rdfs:comment "An ordered  JOURNEY PART in a JOURNEY PATTERN COUPLE."
  .

tm:FACILITY_SET_ASSIGNMENT a owl:Class ;
  rdfs:label "FACILITY SET ASSIGNMENT"
  ; rdfs:comment "The assignment of a FACILITY SET showing an exception in a LINK SEQUENCE (such as a JOURNEY PATTERN, a COMMON SECTION, or a VEHICLE JOURNEY), possibly specifying at which POINT IN JOURNEY PATTERN the validity of the FACILITY starts and ends respectively  Note: Provides a lightweight alternative to specifying FACILITY SETs on a JOURNEY PART. v2.0"
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:CALENDAR_AWARE_PT_SCOPE a owl:Class ;
  rdfs:label "CALENDAR AWARE PT SCOPE"
  ; rdfs:comment "A data scope consisting of public transport entities or combinations of entities such as OPERATORs, NETWORKs, LINEs, SCHEDULED STOP POINTs, STOP PLACEs, PLACEs, etc.  that is also related to temporal scope."
  ; rdfs:subClassOf tm:PT_SCOPE
  .

tm:OCCURRENCE a owl:Class ;
  rdfs:label "OCCURRENCE"
  ; rdfs:comment "Representation of occurrence-related statistics."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:DURATION_INTERVAL a owl:Class ;
  rdfs:label "DURATION INTERVAL"
  ; rdfs:comment "Representation of duration interval - related statistics."
  .

tm:CANCELLED_DATED_VEHICLE_JOURNEY_ENTRY a owl:Class ;
  rdfs:label "CANCELLED DATED VEHICLE JOURNEY ENTRY"
  ; rdfs:comment "The class CANCELLED DATED VEHICLE JOURNEY ENTRY represents an individual record of a specific DATED VEHICLE JOURNEY that was cancelled. It provides detailed information about the cancellation, including the reference to the OPERATING DAY, the associated SERVICE JOURNEY, and the planned VEHICLE JOURNEY. This class ensures traceability by linking the cancellation event to the original scheduled journey and may include attributes such as cancellation reason, timestamp, and responsible authority. Its purpose is to capture granular cancellation data for operational analysis and reporting."
  ; rdfs:subClassOf tm:INDICATOR_LOG_ENTRY
  .

tm:CANCELLED_JOURNEY_OCCURRENCE a owl:Class ;
  rdfs:label "CANCELLED JOURNEY OCCURRENCE"
  ; rdfs:comment "The class CANCELLED JOURNEY OCCURRENCE represents an aggregated indicator of how often cancellations occur within a defined public transport context. It is derived from CANCELLED DATED VEHICLE JOURNEY COUNT and expresses the number of cancellations or their percentage relative to the total scheduled journeys. This class is linked to the OCCURRENCE concept from the generic aggregation model, which provides attributes such as NumberOfOccurrences and PercentageOfOccurrences. Its purpose is to enable high-level reporting and KPI calculations for service reliability, allowing operators to monitor cancellation trends across different scopes such as LINE, NETWORK, or OPERATING DAY."
  ; rdfs:subClassOf tm:OCCURRENCE
  .

tm:CANCELLED_DATED_VEHICLE_JOURNEY_COUNT a owl:Class ;
  rdfs:label "CANCELLED DATED VEHICLE JOURNEY COUNT"
  ; rdfs:comment "The class CANCELLED DATED VEHICLE JOURNEY COUNT aggregates the number of cancelled DATED VEHICLE JOURNEY instances within a defined context, such as an OPERATING DAY, a LINE, or a NETWORK. Instead of storing individual entries, it provides a summarized count, enabling performance monitoring and statistical analysis of service reliability. This class is essential for high-level reporting and trend evaluation, supporting KPIs related to cancellations."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:LATE_JOURNEY_INTERVAL a owl:Class ;
  rdfs:label "LATE JOURNEY INTERVAL"
  ; rdfs:comment "The class LATE JOURNEY INTERVAL defines a time-based category used to classify delays of DATED VEHICLE JOURNEY instances into predefined duration ranges. It is associated with the DURATION INTERVAL concept, which includes attributes such as start and end duration, inclusiveness, and interval type. This class enables grouping of late journeys by severity (e.g., 0–5 minutes, 6–10 minutes) for reporting and KPI calculations. It is essential for aggregating punctuality data into meaningful intervals for trend analysis and performance evaluation."
  ; rdfs:subClassOf tm:DURATION_INTERVAL
  .

tm:LATE_DATED_VEHICLE_JOURNEY_ENTRY a owl:Class ;
  rdfs:label "LATE DATED VEHICLE JOURNEY ENTRY"
  ; rdfs:comment "The class LATE DATED VEHICLE JOURNEY ENTRY represents a detailed record of a specific DATED VEHICLE JOURNEY that experienced a delay beyond its scheduled time. It captures the operational context by referencing OPERATING DAY, SERVICE JOURNEY, and VEHICLE JOURNEY, and includes attributes such as the actual delay duration, the point of delay detection, and possibly the reason for lateness. This class provides granular data for analyzing punctuality and identifying patterns of delay at the journey level."
  ; rdfs:subClassOf tm:INDICATOR_LOG_ENTRY
  .

tm:LATE_JOURNEY_OCCURRENCES a owl:Class ;
  rdfs:label "LATE JOURNEY OCCURRENCES"
  ; rdfs:comment "The class LATE JOURNEY OCCURRENCE represents the aggregated number of late journeys within a specific LATE JOURNEY INTERVAL category. It includes attributes such as the number of occurrences and percentage of occurrences, providing statistical insight into how often delays fall into each interval. This class supports high-level reporting and helps identify patterns of lateness across different operational contexts, such as LINE, NETWORK, or OPERATING DAY."
  ; rdfs:subClassOf tm:OCCURRENCE
  .

tm:LATE_DATED_VEHICLE_JOURNEY_COUNT a owl:Class ;
  rdfs:label "LATE DATED VEHICLE JOURNEY COUNT"
  ; rdfs:comment "The class LATE DATED VEHICLE JOURNEY COUNT aggregates the number of late DATED VEHICLE JOURNEY instances within a defined scope, such as an OPERATING DAY, a LINE, or a NETWORK. Instead of storing individual delay records, it summarizes occurrences to support high-level reporting and performance monitoring. This class is essential for generating KPIs related to service punctuality and for trend analysis across multiple operating periods."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:TICKETING_BASED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "TICKETING BASED PASSENGER COUNT"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for passenger counting based on validated ticket."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:AGGREGATED_TICKETING_BASED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "AGGREGATED TICKETING BASED PASSENGER COUNT"
  ; rdfs:comment "Dynamic log entry for TICKETING BASED PASSENGER COUNT information."
  ; rdfs:subClassOf tm:INDICATOR_LOG_ENTRY
  .

tm:AGGREGATED_ONBOARD_DEVICE_BASED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "AGGREGATED ONBOARD DEVICE BASED PASSENGER COUNT"
  ; rdfs:comment "The class AGGREGATED VEHICLE PASSENGER DETECTION ENTRY represents a consolidated record of passenger detection data collected from a vehicle over a defined period or operational segment. Instead of storing individual detection events, this class aggregates multiple VEHICLE PASSENGER DETECTION ENTRY instances into a single summary, providing total passenger counts or occupancy levels for the entire MONITORED VEHICLE JOURNEY, OPERATING DAY, or a specific LEG."
  ; rdfs:subClassOf tm:INDICATOR_LOG_ENTRY
  .

tm:BOARDING_AND_ALIGHTING_BASED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "BOARDING AND ALIGHTING BASED PASSENGER COUNT"
  ; rdfs:comment "Possible implementation of LOGGABLE OBJECT designed for passenger counting based on BOARDING AND ALIGHTING (independent from the counting method)."
  ; rdfs:subClassOf tm:ACTUAL_SERVICE_DIMENSIONS
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:ONBOARD_DEVICE_BASED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "ONBOARD DEVICE BASED PASSENGER COUNT"
  ; rdfs:comment "Possible implementation of LOGGABLE OBJECT designed for passenger counting based on an onboard counting device (counting the number of passengers in the VEHICLE)."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:AGGREGATED_BOARDING_AND_ALIGHTING_ENTRY a owl:Class ;
  rdfs:label "AGGREGATED BOARDING AND ALIGHTING ENTRY"
  ; rdfs:comment "The class AGGREGATED BOARDING AND ALIGHTING ENTRY represents a summarized record of passenger movements at a higher level of aggregation, typically for a group of stops, a leg, or an entire journey. It consolidates multiple BOARDING AND ALIGHTING ENTRY instances into a single entry, providing total counts of passengers boarding and alighting rather than individual observations."
  ; rdfs:subClassOf tm:INDICATOR_LOG_ENTRY
  .

tm:EXPECTED_PASSENGER_COUNT a owl:Class ;
  rdfs:label "EXPECTED PASSENGER COUNT"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording planned number of passengers for a PT SCOPE (i.e. LINE) based on PASSENGER CARRYING REQUIREMENT of a VEHICLE TYPE."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:EXTERNAL_PASSENGER_COUNT a owl:Class ;
  rdfs:label "EXTERNAL PASSENGER COUNT"
  ; rdfs:comment "The class EXTERNAL EXPECTED PASSENGER COUNT stores expected passenger numbers provided by an external source, such as a third-party system, operator, or demand forecasting tool. Unlike internally calculated estimates, this class ensures integration of externally supplied data into the operational model. It maintains associations with SERVICE JOURNEY, STOP POINT, and OPERATING DAY, and may include metadata about the source and reliability of the data. Its purpose is to enable comparison between internal and external expectations for improved planning and reporting."
  ; rdfs:subClassOf tm:AGGREGATED_BOARDING_AND_ALIGHTING_ENTRY
  .

tm:OPRA_FUNCTIONAL_DELIVERY a owl:Class ;
  rdfs:label "OPRA FUNCTIONAL DELIVERY"
  ; rdfs:comment "Abstract delivery responding to an OpRa functional request."
  .

tm:GROUPING_INSTRUCTION a owl:Class ;
  rdfs:label "GROUPING INSTRUCTION"
  ; rdfs:comment "Grouping instruction used for dataset generation (GroupBy)."
  .

tm:AGGREGATION_INSTRUCTIONS a owl:Class ;
  rdfs:label "AGGREGATION INSTRUCTIONS"
  ; rdfs:comment "Dataset generation instructions: GroupBy and AggregateFunction."
  .

tm:PARTICIPANT_SYSTEM_13944 a owl:Class ;
  rdfs:label "PARTICIPANT SYSTEM"
  ; rdfs:comment "System endpoint that fulfils OpRa functional requests and may use one or more data sources."
  .

tm:OPRA_FUNCTIONAL_REQUEST a owl:Class ;
  rdfs:label "OPRA FUNCTIONAL REQUEST"
  ; rdfs:comment "Abstract request for OpRa functional data; specialised by topic-specific requests."
  .

tm:AGGREGATE_FUNCTION a owl:Class ;
  rdfs:label "AGGREGATE FUNCTION"
  ; rdfs:comment "Aggregation function for grouped results: sum, dailyAverage, annualAverage."
  .

tm:INDICATOR_FRAME a owl:Class ;
  rdfs:label "INDICATOR FRAME"
  ; rdfs:comment "A coherent set of OpRa data to which the same frame VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:PLANNED_FRAME a owl:Class ;
  rdfs:label "PLANNED FRAME"
  ; rdfs:comment "The planned service within the frame VALIDITY CONDITIONs."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:ACTUAL_FRAME a owl:Class ;
  rdfs:label "ACTUAL FRAME"
  ; rdfs:comment "The container element for the actual service within the VALIDITY CONDITIONs."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:CONTEXTUAL_INDICATOR_FRAME a owl:Class ;
  rdfs:label "CONTEXTUAL INDICATOR FRAME"
  ; rdfs:comment "A coherent set of KPIs to which the same frame VALIDITY CONDITIONs have been assigned. Designed for future custom indicator additions."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:SERVICE_DIMENSIONS a owl:Class ;
  rdfs:label "SERVICE DIMENSIONS"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording dimensions of planned service (lines, journeys, seats, etc.)  for a PT SCOPE (i.e. LINE).  Following calculations can be derived per PT Scope:  - numberOfSeats = capacityPerJourney x totalJourneys  - meanNumberOfSeats = Σ(capacityPerJourney) / Σ(plannedJourneyDistance),     where:  capacityPerJourney = capacityPerVehicle &#215; vehiclesAssignedToJourney,  capacityPerVehicle = seatingCapacity + standingCapacity + wheelchairPlaceCapacity  Seat capacities are obtained from the PASSENGER CARRYING REQUIREMENT of the associated VEHICLE TYPE."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:INDICATOR a owl:Class ;
  rdfs:label "INDICATOR"
  ; rdfs:comment "Base type qualifier for every OpRa derived indicator that serves the individual use case."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:INDICATOR_LOG_ENTRY a owl:Class ;
  rdfs:label "INDICATOR LOG ENTRY"
  ; rdfs:comment "Base type for OpRa indicator log entries. It extends netex:LogEntry_VersionStructure and is used through AbstractIndicatorLogEntry as the common parent for concrete indicator-specific log entries in INDICATOR FRAME data sets."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:MEAN_DELAY a owl:Class ;
  rdfs:label "MEAN DELAY"
  ; rdfs:comment "Mean delay value for delayed DATED VEHICLE JOURNEY instances within the defined scope. This corresponds to aggregated delay statistics (duration mean) derived from DELAY durations."
  .

tm:DURATION_DISTRIBUTION a owl:Class ;
  rdfs:label "DURATION DISTRIBUTION"
  ; rdfs:comment "Representation of a domain split into DURATION INTERVALs for aggregated statistics, with optional mean duration value."
  .

tm:PLANNED_SERVICE_DIMENSIONS a owl:Class ;
  rdfs:label "PLANNED SERVICE DIMENSIONS"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording dimensions of planned service (lines, journeys, seats, etc.)  for a PT SCOPE."
  ; rdfs:subClassOf tm:SERVICE_DIMENSIONS
  .

tm:ACTUAL_SERVICE_DIMENSIONS a owl:Class ;
  rdfs:label "ACTUAL SERVICE DIMENSIONS"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for Implementation of LOGGABLE OBJECT designed for recording ACTUAL SERVICE DIMENSIONS information (number of stop points, number of lines, number of journeys, number of routes, total service journey distance) for a CALENDAR BASED PT SCOPE ."
  ; rdfs:subClassOf tm:SERVICE_DIMENSIONS
  .

tm:SERVICE_INTENSITY a owl:Class ;
  rdfs:label "SERVICE INTENSITY"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording dimensions of planned service (lines, journeys, seats, etc.)  for a PT SCOPE (i.e. LINE)."
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:PLANNED_SERVICE_INTENSITY a owl:Class ;
  rdfs:label "PLANNED SERVICE INTENSITY"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording PLANNED SERVICE INTENSITY information."
  ; rdfs:subClassOf tm:SERVICE_INTENSITY
  .

tm:ACTUAL_SERVICE_INTENSITY a owl:Class ;
  rdfs:label "ACTUAL SERVICE INTENSITY"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording ACTUAL SERVICE INTENSITY information."
  ; rdfs:subClassOf tm:SERVICE_INTENSITY
  .

tm:VEHICLE_SEAT_COUNT a owl:Class ;
  rdfs:label "VEHICLE SEAT COUNT"
  ; rdfs:comment "Seat-capacity indicator for vehicles in scope. It represents the seating part of offered capacity, aligned with PassengerCapacityGroup/SeatingCapacity and applicable capacity specification methods for VEHICLE TYPEs."
  .

tm:TRANSPORT_PERFORMANCE a owl:Class ;
  rdfs:label "TRANSPORT PERFORMANCE"
  ; rdfs:comment "Total loaded transport performance [passenger-meter] within the scope."
  .

tm:FLEET_SCOPE a owl:Class ;
  rdfs:label "FLEET SCOPE"
  ; rdfs:comment "Fleet-filtering scope component used by OpRa indicators. It constrains data by GarageRef, VehicleTypeRef, VehicleRef and optional RollingStockType."
  .

tm:EXPECTED_SERVICE_INTENSITY a owl:Class ;
  rdfs:label "EXPECTED SERVICE INTENSITY"
  ; rdfs:comment "Implementation of LOGGABLE OBJECT designed for recording EXPECTED SERVICE INTENSITY information"
  ; rdfs:subClassOf tm:SERVICE_INTENSITY
  .

tm:TRANSPORT_PERFORMANCE_PER_VEHICLE a owl:Class ;
  rdfs:label "TRANSPORT PERFORMANCE PER VEHICLE"
  ; rdfs:comment "Average loaded transport performance [passenger-meter/vehicle] within the scope."
  ; rdfs:subClassOf tm:TRANSPORT_PERFORMANCE
  .

tm:LOAD_OVER_JOURNEY_DISTANCE a owl:Class ;
  rdfs:label "LOAD OVER JOURNEY DISTANCE"
  ; rdfs:comment "Mean passenger (and other transported unit) count per total journey distance [capita/m]"
  .

tm:AVERAGE_COMMERCIAL_SPEED a owl:Class ;
  rdfs:label "AVERAGE COMMERCIAL SPEED"
  ; rdfs:comment "Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."
  .

tm:MEAN_CAPACITY_OVER_JOURNEY_DISTANCE a owl:Class ;
  rdfs:label "MEAN CAPACITY OVER JOURNEY DISTANCE"
  ; rdfs:comment "Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."
  .

tm:MEAN_CAPACITY_OVER_ROUTE_DISTANCE a owl:Class ;
  rdfs:label "MEAN CAPACITY OVER ROUTE DISTANCE"
  ; rdfs:comment "Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."
  .

tm:MEAN_CAPACITY_OVER_NETWORK_DISTANCE a owl:Class ;
  rdfs:label "MEAN CAPACITY OVER NETWORK DISTANCE"
  ; rdfs:comment "Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."
  .

tm:CAPACITY_OVER_DISTANCE a owl:Class ;
  rdfs:label "CAPACITY OVER DISTANCE"
  ; rdfs:comment "Total loaded transport performance [passenger-meter] within the scope."
  .

tm:CONTEXT_KEYLIST a owl:Class ;
  rdfs:label "CONTEXT KEYLIST"
  ; rdfs:comment "Metadata in form of key/value pairs for additional description of indicator context."
  .

tm:GENERIC_CONTEXTUAL_INDICATOR a owl:Class ;
  rdfs:label "GENERIC CONTEXTUAL INDICATOR"
  ; rdfs:comment "Metadata in form of key/value pairs for additional description of contextual indicators."
  ; rdfs:subClassOf tm:CONTEXTUAL_INDICATOR
  .

tm:CONTEXTUAL_INDICATOR a owl:Class ;
  rdfs:label "CONTEXTUAL INDICATOR"
  ; rdfs:comment "Metadata in form of key/value pairs for additional description of contextual indicators."
  .

tm:DATA_MANAGED_OBJECT a owl:Class ;
  rdfs:label "DATA MANAGED OBJECT"
  ; rdfs:comment "Class for providing common properties for all objects."
  ; rdfs:subClassOf tm:ENTITY_IN_VERSION
  .

tm:KEY_LIST a owl:Class ;
  rdfs:label "KEY LIST"
  ; rdfs:comment "An arbitrary key value pair that can be associated with any DATA MANAGED OBJECT; provides an extension mechanism to include non-standard attributes."
  .

tm:KEY_VALUE a owl:Class ;
  rdfs:label "KEY VALUE"
  ; rdfs:comment "An arbitrary key value pair which may be associated with a DATA MANAGED OBJECT."
  .

tm:ACTUAL_FLEET_DIMENSIONS a owl:Class ;
  rdfs:label "ACTUAL FLEET DIMENSIONS"
  ; rdfs:comment "Actual fleet dimensions"
  ; rdfs:subClassOf tm:FLEET_DIMENSIONS
  .

tm:FLEET_DIMENSIONS a owl:Class ;
  rdfs:label "FLEET DIMENSIONS"
  ; rdfs:comment "Numeric fleet dimensions indicators"
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:PLANNED_FLEET_DIMENSIONS a owl:Class ;
  rdfs:label "PLANNED FLEET DIMENSIONS"
  ; rdfs:comment "Planned fleet dimensions"
  ; rdfs:subClassOf tm:FLEET_DIMENSIONS
  .

tm:PLANNED_CAPACITY a owl:Class ;
  rdfs:label "PLANNED CAPACITY"
  ; rdfs:comment "Planned capacity indicator"
  ; rdfs:subClassOf tm:OFFERED_CAPACITY
  .

tm:OFFERED_CAPACITY a owl:Class ;
  rdfs:label "OFFERED CAPACITY"
  ; rdfs:comment "Shared offered-capacity content group"
  ; rdfs:subClassOf tm:INDICATOR
  .

tm:ACTUAL_CAPACITY a owl:Class ;
  rdfs:label "ACTUAL CAPACITY"
  ; rdfs:comment "Actual capacity indicator"
  ; rdfs:subClassOf tm:OFFERED_CAPACITY
  .




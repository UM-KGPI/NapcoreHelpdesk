@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tm: <https://transmodel-cen.eu/6.2/> .

tm:TransmodelOntology a owl:Ontology ;
  rdfs:label "Transmodel Core Ontology v6.2" ;
  rdfs:comment "Transmodel v6.2 (2024) generated from EA UML model with class hierarchy, association roles, and multiplicity restrictions." ;
  owl:versionInfo "6.2" .



tm:PERSONAL_MODE a owl:Class ;
  rdfs:label "PERSONAL MODE"
  ; rdfs:comment "A MODE used outside of public transport services (e.g., by private car, by private cycle, by private scooter, by private boat) under a PERSONAL MODE OF OPERATION."
  ; rdfs:subClassOf tm:MODE
  .

tm:TYPE_OF_LIGHTING a owl:Class ;
  rdfs:label "TYPE OF LIGHTING"
  ; rdfs:comment "A classification of a PLACE LIGHTING as well-lit, poorly lit, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:LIGHTING_ON_METHOD a owl:Class ;
  rdfs:label "LIGHTING ON METHOD"
  ; rdfs:comment "A classification of methods for turning lights on and off."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_CROSSING a owl:Class ;
  rdfs:label "TYPE OF CROSSING"
  ; rdfs:comment "A classification for road CROSSING EQUIPMENT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ENTRANCE_ATTENTION_METHOD a owl:Class ;
  rdfs:label "ENTRANCE ATTENTION METHOD"
  ; rdfs:comment "A classification of method used to invoke opening of ENTRANCE EQUIPMENT."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:AVAILABILITY_OF_ASSISTANCE a owl:Class ;
  rdfs:label "AVAILABILITY OF ASSISTANCE"
  ; rdfs:comment "Summary indication of when assistance is available, e.g., always, never, staff hours only, peak times, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:HELP_POINT_EQUIPMENT a owl:Class ;
  rdfs:label "HELP POINT EQUIPMENT"
  ; rdfs:comment "Specialisation of PASSENGER EQUIPMENT describing a HELP POINT."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:Gamma a owl:Class ;
  rdfs:label "Gamma"
  ; rdfs:subClassOf tm:Delta
  .

tm:TYPE_OF_USER a owl:Class ;
  rdfs:label "TYPE OF USER"
  ; rdfs:comment "A classification of USER PROFILE by category of person eligible to use it, e.g., adult, student, senior, etc."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:PROJECTION a owl:Class ;
  rdfs:label "PROJECTION"
  ; rdfs:comment "An oriented correspondence from an element in one layer, onto an entity in a target layer:"
  .

tm:DISTRIBUTION_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "DISTRIBUTION VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER linked to fare product distribution."
  .

tm:Beta a owl:Class ;
  rdfs:label "Beta"
  ; rdfs:subClassOf tm:Delta
  .

tm:GENERAL_ZONE a owl:Class ;
  rdfs:label "GENERAL ZONE"
  ; rdfs:comment "A general purpose ZONE."
  ; rdfs:subClassOf tm:ZONE
  .

tm:GROUP_OF_TARIFF_ZONES a owl:Class ;
  rdfs:label "GROUP OF TARIFF ZONES"
  ; rdfs:comment "A grouping of TARIFF ZONEs dedicated to a FUNCTIONAL PURPOSE."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:POINT_ON_SECTION a owl:Class ;
  rdfs:label "POINT ON SECTION"
  ; rdfs:comment "Use of a POINT on a SECTION, may include a forward link."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:POINT_ON_LINE_SECTION a owl:Class ;
  rdfs:label "POINT ON LINE SECTION"
  ; rdfs:comment "Association of a POINT with a COMMON SECTION."
  ; rdfs:subClassOf tm:POINT_ON_SECTION
  .

tm:TYPE_OF_LINE_SECTION_POINT a owl:Class ;
  rdfs:label "TYPE OF LINE SECTION POINT"
  ; rdfs:comment "A classification of a POINT ON LINE SECTION to indicate how it should be presented, for example as a main station, optional stop, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_PARKING_USER a owl:Class ;
  rdfs:label "TYPE OF PARKING USER"
  ; rdfs:comment "A classification of a type of parking user, e.g., disabled, season ticket holder, anonymous, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:COMPOSITE_FRAME a owl:Class ;
  rdfs:label "COMPOSITE FRAME"
  ; rdfs:comment "A set of VERSION FRAMEs to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:GENERAL_FRAME a owl:Class ;
  rdfs:label "GENERAL FRAME"
  ; rdfs:comment "Set of data containing information, to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:RESOURCE_FRAME a owl:Class ;
  rdfs:label "RESOURCE FRAME"
  ; rdfs:comment "A set of resource data to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:SERVICE_CALENDAR_FRAME a owl:Class ;
  rdfs:label "SERVICE CALENDAR FRAME"
  ; rdfs:comment "A coherent set of assignments of OPERATING DAYS to DAY TYPES."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:LOCATION a owl:Class ;
  rdfs:label "LOCATION"
  ; rdfs:comment "The position of a POINT with reference to a given LOCATING SYSTEM (e.g., coordinates)."
  .

tm:LOCATING_SYSTEM a owl:Class ;
  rdfs:label "LOCATING SYSTEM"
  ; rdfs:comment "The system used as reference for location and graphical representation of the network and other spatial objects."
  .

tm:WIRE_JUNCTION a owl:Class ;
  rdfs:label "WIRE JUNCTION"
  ; rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a wire network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_POINT
  .

tm:WIRE_ELEMENT a owl:Class ;
  rdfs:label "WIRE ELEMENT"
  ; rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a wire network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_LINK
  .

tm:INFRASTRUCTURE_POINT a owl:Class ;
  rdfs:label "INFRASTRUCTURE POINT"
  ; rdfs:comment "A specialisation of POINT representing a junction point in the physical network (e.g., RAILWAY JUNCTION, ROAD JUNCTION, etc.)."
  ; rdfs:subClassOf tm:POINT
  .

tm:INFRASTRUCTURE_LINK a owl:Class ;
  rdfs:label "INFRASTRUCTURE LINK"
  ; rdfs:comment "A specialisation of LINK representing a link between two points in the physical network (e.g., RAILWAY ELEMENT, ROAD ELEMENT, etc.)."
  ; rdfs:subClassOf tm:LINK
  .

tm:ROAD_JUNCTION a owl:Class ;
  rdfs:label "ROAD JUNCTION"
  ; rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a road network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_POINT
  .

tm:IMPOSSIBLE_MANOEUVRE a owl:Class ;
  rdfs:label "IMPOSSIBLE MANOEUVRE"
  ; rdfs:comment "A specification of an impossible move for a certain type of vehicle; it specifies from which INFRASTRUCTURE LINK to which other (adjacent) INFRASTRUCTURE LINK a certain VEHICLE TYPE cannot proceed, due to physical restrictions."
  .

tm:PLANNED_REMEDY a owl:Class ;
  rdfs:label "PLANNED REMEDY"
  ; rdfs:comment "A pre-prepared REMEDY that could include utilizing an alternative FACILITY as a replacement."
  ; rdfs:subClassOf tm:REMEDY
  .

tm:FACILITY_STATUS a owl:Class ;
  rdfs:label "FACILITY STATUS"
  ; rdfs:comment "A classification of the change of availability of a facility, such as being removed, unavailable or only partially available."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:REMEDY a owl:Class ;
  rdfs:label "REMEDY"
  ; rdfs:comment "A general or planned countermeasure to compensate a deviating FACILITY CONDITION."
  .

tm:FACILITY_MONITORING_METHOD a owl:Class ;
  rdfs:label "FACILITY MONITORING METHOD"
  ; rdfs:comment "A description of the method and circumstances used to monitor a facility such as if it is manual or automatic, the frequency of monitoring or if it is done at certain times."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PASSENGER_BEACON_EQUIPMENT a owl:Class ;
  rdfs:label "PASSENGER BEACON EQUIPMENT"
  ; rdfs:comment "Specialisation of PASSENGER EQUIPMENT describing a beacon to assist disabled passengers."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:TYPE_OF_PASSENGER_BEACON a owl:Class ;
  rdfs:label "TYPE OF PASSENGER BEACON"
  ; rdfs:comment "A classification for a PASSENGER BEACON."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PASSENGER_BEACON_PROTOCOL a owl:Class ;
  rdfs:label "PASSENGER BEACON PROTOCOL"
  ; rdfs:comment "A classification of the device communication protocol used for a PASSENGER BEACON EQUIPMENT (iBEAcon, VDV431, EDDYSTONE, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:POWERED_TRAIN a owl:Class ;
  rdfs:label "POWERED TRAIN"
  ; rdfs:comment "A TRAIN that is able to move under its own power,"
  ; rdfs:subClassOf tm:TRAIN
  .

tm:SECURITY_LIST_CHECK_FAIL_ENTRY a owl:Class ;
  rdfs:label "SECURITY LIST CHECK FAIL ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the failure to pass a security check, either through being on a BLACKLIST or not being on a required WHITE LIST."
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:PASSENGER_SECURITY_LIST_CHECK_EVENT a owl:Class ;
  rdfs:label "PASSENGER SECURITY LIST CHECK EVENT"
  ; rdfs:comment "A check of some aspect of the passengers travel credentials against a SECURITY LIST, usually triggered by another PASSENGER TRAVEL CONTROL EVENT such as check in at the start of a trip."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:UNPOWERED_TRAIN a owl:Class ;
  rdfs:label "UNPOWERED TRAIN"
  ; rdfs:comment "A TRAIN that cannot move under its own power."
  ; rdfs:subClassOf tm:TRAIN
  .

tm:CLASS_IN_REPOSITORY a owl:Class ;
  rdfs:label "CLASS IN REPOSITORY"
  ; rdfs:comment "Any ENTITY name belonging to the repository; e.g., DAY TYPE, PROPERTY OF DAY, TIME BAND, VEHICLE TYPE, etc., are relevant instances of CLASS IN REPOSITORY in the context of version management."
  .

tm:ENTITY a owl:Class ;
  rdfs:label "ENTITY"
  ; rdfs:comment "Any data instance to be managed in an operational Version Management System.  NOTE: When several data sources coexist (multimodality and/or interoperability), an ENTITY has to be related to a given DATA SOURCE in which it is defined."
  .

tm:TYPE_OF_ENTITY a owl:Class ;
  rdfs:label "TYPE OF ENTITY"
  ; rdfs:comment "Classification of ENTITies, for instance according to the domain in which they are defined or used."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ENTITY_IN_VERSION a owl:Class ;
  rdfs:label "ENTITY IN VERSION"
  ; rdfs:comment "The ENTITY associated with a given VERSION."
  .

tm:VERSION a owl:Class ;
  rdfs:label "VERSION"
  ; rdfs:comment "A group of operational data instances which share the same VALIDITY CONDITIONs.  NOTE: A version belongs to a unique VERSION FRAME and is characterised by a unique TYPE OF VERSION."
  .

tm:TYPE_OF_VERSION a owl:Class ;
  rdfs:label "TYPE OF VERSION"
  ; rdfs:comment "A classification of VERSIONs; e.g., whether there is shareability of ENTITies between several versions."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_FRAME a owl:Class ;
  rdfs:label "TYPE OF FRAME"
  ; rdfs:comment "A classification of VERSION FRAMEs according to a common purpose, e.g., line descriptions for line versions, vehicle schedules, operating costs.  NOTE: A TYPE OF FRAME is ruled by a unique TYPE OF VALIDITY."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:VERSION_FRAME a owl:Class ;
  rdfs:label "VERSION FRAME"
  ; rdfs:comment "A set of VERSIONS referring to the same DATA SOURCE and belonging to the same TYPE OF FRAME.  NOTE: A FRAME may be restricted by VALIDITY CONDITIONs."
  .

tm:TYPE_OF_VALIDITY a owl:Class ;
  rdfs:label "TYPE OF VALIDITY"
  ; rdfs:comment "A classification of the validity of TYPEs OF FRAME; e.g., as a frame for schedules designed for DAY TYPEs, or for specific OPERATING DAYs."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CLASS_IN_FRAME a owl:Class ;
  rdfs:label "CLASS IN FRAME"
  ; rdfs:comment "The different CLASSes IN REPOSITORY which are relevant for the corresponding VERSION FRAMEs."
  .

tm:VALIDITY_CONDITION a owl:Class ;
  rdfs:label "VALIDITY CONDITION"
  ; rdfs:comment "Condition used in order to characterise a given VERSION of a VERSION FRAME.  NOTE: A VALIDITY CONDITION consists of a parameter (e.g., date, triggering event, etc.) and its type of application (e.g., for, from, until, etc.)."
  .

tm:VALIDITY_TRIGGER a owl:Class ;
  rdfs:label "VALIDITY TRIGGER"
  ; rdfs:comment "External event defining a VALIDITY CONDITION E.g., exceptional flow of a river, bad weather, road closure for works."
  .

tm:VALIDITY_RULE_PARAMETER a owl:Class ;
  rdfs:label "VALIDITY RULE PARAMETER"
  ; rdfs:comment "A user defined VALIDITY CONDITION used by a rule for selecting versions; e.g., river level above 1.5 metres and bad weather."
  .

tm:TRACE a owl:Class ;
  rdfs:label "TRACE"
  ; rdfs:comment "A way to record the context of the changes occurred in a given ENTITY instance, as regards the authors, the causes of the changes, etc., possibly accompanied by a descriptive text."
  .

tm:DELTA a owl:Class ;
  rdfs:label "DELTA"
  ; rdfs:comment "A record of the detailed changes of a given ENTITY IN VERSION from one VERSION to the next one.  NOTE: A DELTA contains pairs of attributes' old values - new values."
  .

tm:DATA_SOURCE a owl:Class ;
  rdfs:label "DATA SOURCE"
  ; rdfs:comment "The DATA SOURCE identifies the system which has produced the data.  NOTE: References to a data source are useful in an interoperable computer system."
  .

tm:TYPE_OF_RESPONSIBILITY_ROLE a owl:Class ;
  rdfs:label "TYPE OF RESPONSIBILITY ROLE"
  ; rdfs:comment "A classification of RESPONSIBILITY ROLEs, e.g., data ownership."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:RESPONSIBILITY_ROLE_ASSIGNMENT a owl:Class ;
  rdfs:label "RESPONSIBILITY ROLE ASSIGNMENT"
  ; rdfs:comment "The assignment of one or more roles to an ORGANISATION or an ORGANISATION PART as regards the responsibility it will have as regards specific data (e.g., ownership, planning, etc.) and the management of this data (e.g., distribution, updates, etc.)."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:RESPONSIBILITY_SET a owl:Class ;
  rdfs:label "RESPONSIBILITY SET"
  ; rdfs:comment "A list of possible responsibilities over one or more ENTITies IN VERSION, resulting from the process of the assignment of RESPONSIBILITY ROLEs (such as data origination, ownership, etc.) on specific data (instances) to ORGANISATIONs or ORGANISATION PARTs."
  .

tm:RESPONSIBILITY_ROLE a owl:Class ;
  rdfs:label "RESPONSIBILITY ROLE"
  ; rdfs:comment "A particular role an ORGANISATION or an ORGANISATION PART is playing as regards certain data, for example, data origination, data augmentation, data aggregation, data distribution, planning, operation, control, ownership, etc."
  .

tm:TYPE_OF_OPERATION a owl:Class ;
  rdfs:label "TYPE OF OPERATION"
  ; rdfs:comment "A classification of operations to express the different functional roles of a DEPARTMENT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ORGANISATION a owl:Class ;
  rdfs:label "ORGANISATION"
  ; rdfs:comment "A legally incorporated body associated with any aspect of public transportation."
  .

tm:ORGANISATIONAL_UNIT a owl:Class ;
  rdfs:label "ORGANISATIONAL UNIT"
  ; rdfs:comment "An ORGANISATION PART within an OPERATING DEPARTMENT to which a subset of responsibilities is assigned."
  ; rdfs:subClassOf tm:ORGANISATION_PART
  .

tm:TYPE_OF_ORGANISATION a owl:Class ;
  rdfs:label "TYPE OF ORGANISATION"
  ; rdfs:comment "A classification of an ORGANISATION according to its activity, e.g., a public transport company, an IT company, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ADMINISTRATIVE_ZONE a owl:Class ;
  rdfs:label "ADMINISTRATIVE ZONE"
  ; rdfs:comment "A district, region, city, municipality or other area for which an ORGANISATION has a RESPONSIBILITY ROLE."
  ; rdfs:subClassOf tm:ZONE
  .

tm:ORGANISATION_PART a owl:Class ;
  rdfs:label "ORGANISATION PART"
  ; rdfs:comment "A part of an ORGANISATION to which specific responsibilities may be assigned."
  .

tm:DEPARTMENT a owl:Class ;
  rdfs:label "DEPARTMENT"
  ; rdfs:comment "An ORGANISATION PART specific to a purpose and/or organisational structure."
  ; rdfs:subClassOf tm:ORGANISATION_PART
  .

tm:CONTACT_DETAILS a owl:Class ;
  rdfs:label "CONTACT DETAILS"
  ; rdfs:comment "Contact details for an ORGANISATION, person or VEHICLE."
  .

tm:GROUP_OF_ENTITIES a owl:Class ;
  rdfs:label "GROUP OF ENTITIES"
  ; rdfs:comment "A set of ENTITies grouped together according to a PURPOSE OF GROUPING, e.g., a grouping of stops known to the public by a common name."
  .

tm:PURPOSE_OF_GROUPING a owl:Class ;
  rdfs:label "PURPOSE OF GROUPING"
  ; rdfs:comment "Functional purpose for which GROUPs of elements are defined.  NOTE: The PURPOSE OF GROUPING may be restricted to one or more types of the given object."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:POINT_ON_LINK a owl:Class ;
  rdfs:label "POINT ON LINK"
  ; rdfs:comment "A POINT on a LINK which is not needed for LINK definition, but may be used for other purposes, e.g., for automatic vehicle monitoring, passenger information or for driver information."
  .

tm:TYPE_OF_POINT a owl:Class ;
  rdfs:label "TYPE OF POINT"
  ; rdfs:comment "A classification of POINTs according to their functional purpose."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:GROUP_OF_LINKS a owl:Class ;
  rdfs:label "GROUP OF LINKS"
  ; rdfs:comment "A grouping of LINKs for a particular purpose, e.g., a GROUP OF LINKs managed by the same AUTHORITY."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:POINT a owl:Class ;
  rdfs:label "POINT"
  ; rdfs:comment "A 0-dimensional node of the network used for the spatial description of the network.  NOTE: POINTs may be located by a LOCATION in a given LOCATING SYSTEM."
  .

tm:GROUP_OF_POINTS a owl:Class ;
  rdfs:label "GROUP OF POINTS"
  ; rdfs:comment "A grouping of POINTs of a certain TYPE OF POINT and dedicated to a PURPOSE OF GROUPING."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:TYPE_OF_LINK a owl:Class ;
  rdfs:label "TYPE OF LINK"
  ; rdfs:comment "A classification of LINKs to express the different functional roles of a LINK."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:LINK a owl:Class ;
  rdfs:label "LINK"
  ; rdfs:comment "An oriented spatial object of dimension 1 with a view to the overall description of a network, describing a connection between two POINTs."
  .

tm:LINK_IN_LINK_SEQUENCE a owl:Class ;
  rdfs:label "LINK IN LINK SEQUENCE"
  ; rdfs:comment "The order of a LINK in a LINK SEQUENCE to which it belongs."
  .

tm:LINK_SEQUENCE a owl:Class ;
  rdfs:label "LINK SEQUENCE"
  ; rdfs:comment "An ordered sequence of POINTs, LINKs, or ZONEs defining a path through the network."
  .

tm:GROUP_OF_LINK_SEQUENCES a owl:Class ;
  rdfs:label "GROUP OF LINK SEQUENCES"
  ; rdfs:comment "A grouping of LINK SEQUENCEs."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:POINT_IN_LINK_SEQUENCE a owl:Class ;
  rdfs:label "POINT IN LINK SEQUENCE"
  ; rdfs:comment "A POINT in a LINK SEQUENCE indicating its order in that particular LINK SEQUENCE."
  .

tm:TYPE_OF_LINK_SEQUENCE a owl:Class ;
  rdfs:label "TYPE OF LINK SEQUENCE"
  ; rdfs:comment "A classification of LINK SEQUENCEs used to define the different functions for which a LINK SEQUENCE may be used; e.g., route, journey pattern, trip pattern, border line etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TARIFF_ZONE a owl:Class ;
  rdfs:label "TARIFF ZONE"
  ; rdfs:comment "A ZONE used to define a zonal fare structure in a zone-counting or zone-matrix system."
  ; rdfs:subClassOf tm:ZONE
  .

tm:TYPE_OF_ZONE a owl:Class ;
  rdfs:label "TYPE OF ZONE"
  ; rdfs:comment "A classification of ZONEs, e.g., TARIFF ZONE, ADMINISTRATIVE ZONE, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ZONE a owl:Class ;
  rdfs:label "ZONE"
  ; rdfs:comment "A two-dimensional location.  NOTE: May have absolute (e.g., WGS84, Lambert, etc.) or coordinates relative to those of an encompassing space, (e.g., DECK PLAN)."
  .

tm:SIMPLE_FEATURE a owl:Class ;
  rdfs:label "SIMPLE FEATURE"
  ; rdfs:comment "An abstract representation of elementary objects related to the spatial representation of the network; POINTs (0-dimensional objects), LINKs (1-dimensional objects) and ZONEs (2-dimensional objects) may be viewed as SIMPLE FEATUREs."
  .

tm:COMPLEX_FEATURE a owl:Class ;
  rdfs:label "COMPLEX FEATURE"
  ; rdfs:comment "An aggregate of SIMPLE FEATUREs and/or other COMPLEX FEATUREs."
  .

tm:LAYER a owl:Class ;
  rdfs:label "LAYER"
  ; rdfs:comment "A user-defined GROUP OF ENTITies, specified for a particular functional purpose, associating data referring to a particular LOCATING SYSTEM."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:LINE_SHAPE a owl:Class ;
  rdfs:label "LINE SHAPE"
  ; rdfs:comment "The graphical shape of a LINK obtained from a formula or other means, using the LOCATION of its limiting POINTs and depending on the LOCATING SYSTEM used for the graphical representation."
  .

tm:POINT_PROJECTION a owl:Class ;
  rdfs:label "POINT PROJECTION"
  ; rdfs:comment "An oriented correspondence from one POINT of a source layer, onto an entity in a target layer: e.g., a POINT, LINK, LINK SEQUENCE, or COMPLEX FEATURE, within a defined TYPE OF PROJECTION."
  ; rdfs:subClassOf tm:PROJECTION
  .

tm:LINK_PROJECTION a owl:Class ;
  rdfs:label "LINK PROJECTION"
  ; rdfs:comment "An oriented correspondence from one LINK of a source layer, onto an entity in a target layer: e.g., LINK SEQUENCE, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."
  ; rdfs:subClassOf tm:PROJECTION
  .

tm:COMPLEX_FEATURE_PROJECTION a owl:Class ;
  rdfs:label "COMPLEX FEATURE PROJECTION"
  ; rdfs:comment "An oriented correspondence: from one COMPLEX FEATURE in the source layer, onto an entity in a target layer: e.g., POINT, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."
  ; rdfs:subClassOf tm:PROJECTION
  .

tm:TYPE_OF_PROJECTION a owl:Class ;
  rdfs:label "TYPE OF PROJECTION"
  ; rdfs:comment "A classification of the projections according to their functional purpose, the source and target layers."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ZONE_PROJECTION a owl:Class ;
  rdfs:label "ZONE PROJECTION"
  ; rdfs:comment "An oriented correspondence: from one ZONE in a source layer, onto a target entity: e.g., POINT, COMPLEX FEATURE, within a defined TYPE OF PROJECTION."
  ; rdfs:subClassOf tm:PROJECTION
  .

tm:MEDICAL_NEED a owl:Class ;
  rdfs:label "MEDICAL NEED"
  ; rdfs:comment "A specific USER NEED, i.e., a requirement of a passenger as regards medical constraint (e.g., allergy) to access public transport."
  ; rdfs:subClassOf tm:TYPE_OF_USER_NEED
  .

tm:USER_NEED a owl:Class ;
  rdfs:label "USER NEED"
  ; rdfs:comment "A user's need for a particular SUITABILITY."
  .

tm:ACCESSIBILITY_ASSESSMENT a owl:Class ;
  rdfs:label "ACCESSIBILITY ASSESSMENT"
  ; rdfs:comment "The accessibility characteristics of an entity used by passengers such as a LINE, STOP PLACE, STOP PLACE COMPONENT or DECK COMPONENT.  NOTE: Described by ACCESSIBILITY LIMITATIONs, and/or a set of SUITABILITies."
  .

tm:MOBILITY_NEED a owl:Class ;
  rdfs:label "MOBILITY NEED"
  ; rdfs:comment "A specific USER NEED, i.e., a constraint of a passenger as regards his mobility, e.g., wheelchair, assisted wheelchair, etc."
  ; rdfs:subClassOf tm:TYPE_OF_USER_NEED
  .

tm:PASSENGER_ACCESSIBILITY_NEED a owl:Class ;
  rdfs:label "PASSENGER ACCESSIBILITY NEED"
  ; rdfs:comment "A passenger's requirement for accessibility, comprising one or more USER NEEDs, e.g., that he is unable to navigate stairs, or lifts, or has visual or auditory impairments.  NOTE: PASSENGER ACCESSIBILITY NEEDS can be used to derive an accessibility constraint for the passenger, allowing the computation of paths for passengers with specifically constrained mobility such as in Wheelchair, No Lifts, No Stairs, etc."
  .

tm:TYPE_OF_USER_NEED a owl:Class ;
  rdfs:label "TYPE OF USER NEED"
  ; rdfs:comment "A classification of USER NEEDS."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ACCESSIBILITY_LIMITATION a owl:Class ;
  rdfs:label "ACCESSIBILITY LIMITATION"
  ; rdfs:comment "A categorisation of the accessibility characteristics of a SITE, e.g., a STOP PLACE or a STOP PLACE COMPONENT, EQUIPMENT or DECK COMPONENT to indicate its usability by passengers with specific needs, for example, those needing wheelchair access, step-free access or wanting to avoid confined spaces such as lifts.  NOTE: A small number of well-defined categories are used that are chosen to allow the consistent capture of data and the efficient computation of routes for different classes of user."
  .

tm:SUITABILITY a owl:Class ;
  rdfs:label "SUITABILITY"
  ; rdfs:comment "A statement of whether a particular USER NEED can be met; It can be used to state whether a SITE can be accessed by a passenger with a particular USER NEED."
  .

tm:ENCUMBRANCE_NEED a owl:Class ;
  rdfs:label "ENCUMBRANCE NEED"
  ; rdfs:comment "A specific USER NEED, i.e., a requirement of a passenger travelling with luggage, animal or any other object requiring special arrangements to access public transport."
  ; rdfs:subClassOf tm:TYPE_OF_USER_NEED
  .

tm:TYPE_OF_ACCESSIBILITY_LIMITATION a owl:Class ;
  rdfs:label "TYPE OF ACCESSIBILITY LIMITATION"
  ; rdfs:comment "A classification for an ACCESSIBILITY LIMITATION, e.g., as audio, visual, step free, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_SUITABILITY a owl:Class ;
  rdfs:label "TYPE OF SUITABILITY"
  ; rdfs:comment "A classification for SUITABILITY, i.e., assessments as regards a possible SUITABILITY of access according to USER NEEDS."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:PSYCHOSENSORY_NEED a owl:Class ;
  rdfs:label "PSYCHOSENSORY NEED"
  ; rdfs:comment "A specific USER NEED, i.e., a constraint of a passenger as regards his psycho-sensory impairments, such as visual impairment, auditory impairment, averse to confined spaces, etc."
  ; rdfs:subClassOf tm:TYPE_OF_USER_NEED
  .

tm:TRANSFER a owl:Class ;
  rdfs:label "TRANSFER"
  ; rdfs:comment "A pair of POINTs located sufficiently close that they offer a passenger the possibility to reach one of the POINTs when starting at the other one in a timescale which is realistic when carrying out a trip, e.g., as a CONNECTION or ACCESS."
  .

tm:TYPE_OF_TRANSFER a owl:Class ;
  rdfs:label "TYPE OF TRANSFER"
  ; rdfs:comment "A classification for TRANSFER."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ACCESS a owl:Class ;
  rdfs:label "ACCESS"
  ; rdfs:comment "The physical (spatial) possibility for a passenger to access or leave the public transport system.  NOTE: This link may be used during a trip for the walking movement of a passenger from a PLACE (origin of the trip) to a SCHEDULED STOP POINT (origin of the PT TRIP), or for the walking movement from a SCHEDULED STOP POINT (destination of the PT TRIP) to a PLACE (destination of the trip)."
  ; rdfs:subClassOf tm:TRANSFER
  .

tm:ACCESS_END a owl:Class ;
  rdfs:label "ACCESS END"
  ; rdfs:comment "Origin or destination end of an ACCESS link; may indicate a POINT and/or PLACE."
  .

tm:PLACE a owl:Class ;
  rdfs:label "PLACE"
  ; rdfs:comment "A geographic place of any type which may be specified as the origin or destination of a trip.  NOTE: A PLACE may be represented as a POINT (dimension 0), a road section (dimension 1), or a ZONE (dimension 2)."
  ; rdfs:subClassOf tm:ZONE
  .

tm:TRANSFER_END a owl:Class ;
  rdfs:label "TRANSFER END"
  ; rdfs:comment "End point of a TRANSFER."
  .

tm:TYPE_OF_PLACE a owl:Class ;
  rdfs:label "TYPE OF PLACE"
  ; rdfs:comment "A classification for PLACEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ACCESS_MODE a owl:Class ;
  rdfs:label "ACCESS MODE"
  ; rdfs:comment "A PERSONAL MODE used to access or leave the public transport system (e.g., by foot, by private bicycle, by private car)."
  ; rdfs:subClassOf tm:PERSONAL_MODE
  .

tm:MODE a owl:Class ;
  rdfs:label "MODE"
  ; rdfs:comment "A broad characterisation of the means of movement and / or operational aspect in consideration (e.g., by bus, by train, by metro, by ferry, by foot, by private car, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PUBLIC_TRANSPORT_MODE a owl:Class ;
  rdfs:label "PUBLIC TRANSPORT MODE"
  ; rdfs:comment "A MODE used for public transport services (e.g., by bus, by tram, by metro, by train, by ferry, by ship, by shared taxi car, by shared car) under either a CONVENTIONAL MODE OF OPERATION or an ALTERNATIVE MODE OF OPERATION (i.e., excluding a PERSONAL MODE OF OPERATION).  Note: Prior to TM 6.2 this was named VEHICLE MODE"
  ; rdfs:subClassOf tm:MODE
  .

tm:SUBMODE a owl:Class ;
  rdfs:label "SUBMODE"
  ; rdfs:comment "A variant of a MODE, as for instance international or domestic rail (rail being the MODE)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:OPERATING_DAY a owl:Class ;
  rdfs:label "OPERATING DAY"
  ; rdfs:comment "A day of public transport operation of which the characteristics are defined within in a specific SERVICE CALENDAR.  NOTE: An OPERATING DAY may last more than 24 hours."
  .

tm:SERVICE_CALENDAR a owl:Class ;
  rdfs:label "SERVICE CALENDAR"
  ; rdfs:comment "A collection of DAY TYPE ASSIGNMENTs."
  .

tm:DAY_TYPE a owl:Class ;
  rdfs:label "DAY TYPE"
  ; rdfs:comment "A type of day characterised by one or more properties which affect public transport operation (for example: working day, sunday, weekday in school holidays, etc.)."
  .

tm:PROPERTY_OF_DAY a owl:Class ;
  rdfs:label "PROPERTY OF DAY"
  ; rdfs:comment "A property which a day may possess, such as school holiday, weekday, summer, winter, etc."
  .

tm:DAY_TYPE_ASSIGNMENT a owl:Class ;
  rdfs:label "DAY TYPE ASSIGNMENT"
  ; rdfs:comment "The assignment of operational characteristics, expressed by DAY TYPEs, to particular OPERATING DAYs within a SERVICE CALENDAR."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TIME_BAND a owl:Class ;
  rdfs:label "TIME BAND"
  ; rdfs:comment "A period in a day, significant for some aspect of public transport, e.g., similar traffic conditions or fare category."
  .

tm:OPERATING_PERIOD a owl:Class ;
  rdfs:label "OPERATING PERIOD"
  ; rdfs:comment "A continuous interval of time between two OPERATING DAYs which will be used to define validities."
  .

tm:DAY_OF_WEEK a owl:Class ;
  rdfs:label "DAY OF WEEK"
  ; rdfs:comment "A particular weekday (from Monday to Sunday)."
  .

tm:GROUP_OF_TIMEBANDS a owl:Class ;
  rdfs:label "GROUP OF TIMEBANDS"
  ; rdfs:comment "A grouping of TIME BANDs."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:AVAILABILITY_CONDITION a owl:Class ;
  rdfs:label "AVAILABILITY CONDITION"
  ; rdfs:comment "A VALIDITY CONDITION expressed in terms of temporal parameters and referring to DAY TYPEs."
  ; rdfs:subClassOf tm:VALIDITY_CONDITION
  .

tm:ADDRESSABLE_PLACE a owl:Class ;
  rdfs:label "ADDRESSABLE PLACE"
  ; rdfs:comment "A type of PLACE to which passengers may refer to indicate the origin or a destination of a trip and that is so specific that it has an ADDRESS."
  ; rdfs:subClassOf tm:PLACE
  .

tm:POSTAL_ADDRESS a owl:Class ;
  rdfs:label "POSTAL ADDRESS"
  ; rdfs:comment "A specification of ADDRESS refining it by using the attributes used for conventional identification for mail.  NOTE: Comprises variously a building Identifier, Street name, Post code and other descriptors."
  ; rdfs:subClassOf tm:ADDRESS
  .

tm:TOPOGRAPHIC_PLACE a owl:Class ;
  rdfs:label "TOPOGRAPHIC PLACE"
  ; rdfs:comment "A type of PLACE providing the topographical context when searching for or presenting travel information, for example as the origin or destination of a trip.  NOTE: It may be of any size (e.g., County, City, Town, Village) and of different specificity (e.g., Greater London, London, West End, Westminster, St James's parish)."
  ; rdfs:subClassOf tm:PLACE
  .

tm:ADDRESS a owl:Class ;
  rdfs:label "ADDRESS"
  ; rdfs:comment "The descriptive data associated with a PLACE that can be used to describe the unique geographical context of a PLACE for the purposes of identifying it.  NOTE: May be refined as either a ROAD ADDRESS, a POSTAL ADDRESS or both."
  .

tm:COUNTRY a owl:Class ;
  rdfs:label "COUNTRY"
  ; rdfs:comment "A jurisdictional geographic boundary.  NOTE: A COUNTRY normally has a two-character IANA identifier."
  .

tm:ROAD_ADDRESS a owl:Class ;
  rdfs:label "ROAD ADDRESS"
  ; rdfs:comment "Specialization of ADDRESS using conventional characteristics such as road number and name for identification of a location along a road."
  ; rdfs:subClassOf tm:ADDRESS
  .

tm:CONTROL_CENTRE a owl:Class ;
  rdfs:label "CONTROL CENTRE"
  ; rdfs:comment "An ORGANISATION PART for an operational team who are responsible for issuing commands to control the services."
  ; rdfs:subClassOf tm:ORGANISATION_PART
  .

tm:OPERATING_DEPARTMENT a owl:Class ;
  rdfs:label "OPERATING DEPARTMENT"
  ; rdfs:comment "A specific DEPARTMENT which administers certain LINEs or certain public transport services."
  ; rdfs:subClassOf tm:DEPARTMENT
  .

tm:AUTHORITY a owl:Class ;
  rdfs:label "AUTHORITY"
  ; rdfs:comment "The ORGANISATION on which the responsibility of organising the transport service in a certain area is placed."
  ; rdfs:subClassOf tm:ORGANISATION
  ; rdfs:subClassOf tm:TRANSPORT_ORGANISATION
  .

tm:OPERATIONAL_CONTEXT a owl:Class ;
  rdfs:label "OPERATIONAL CONTEXT"
  ; rdfs:comment "Characterisation of a set of operational objects, such as timing or links determined either by a DEPARTMENT or by an ORGANISATIONAL UNIT."
  .

tm:GROUP_OF_OPERATORS a owl:Class ;
  rdfs:label "GROUP OF OPERATORS"
  ; rdfs:comment "A group of OPERATORs having for instance common schemes for fare collection or passenger information."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:OPERATOR a owl:Class ;
  rdfs:label "OPERATOR"
  ; rdfs:comment "A company providing public transport services."
  ; rdfs:subClassOf tm:ORGANISATION
  ; rdfs:subClassOf tm:TRANSPORT_ORGANISATION
  .

tm:OTHER_ORGANISATION a owl:Class ;
  rdfs:label "OTHER ORGANISATION"
  ; rdfs:comment "Generic ORGANISATION being neither an AUTHORITY, nor a public transport OPERATOR (TRAVEL AGENT, MANAGEMENT AGENT, etc.)."
  ; rdfs:subClassOf tm:ORGANISATION
  .

tm:MANAGEMENT_AGENT a owl:Class ;
  rdfs:label "MANAGEMENT AGENT"
  ; rdfs:comment "Specialisation of ORGANISATION for MANAGEMENT AGENTs."
  ; rdfs:subClassOf tm:OTHER_ORGANISATION
  .

tm:ORGANISATION_DAY_TYPE a owl:Class ;
  rdfs:label "ORGANISATION DAY TYPE"
  ; rdfs:comment "DAY TYPE that is defined in terms of operation or not operation of a referenced SERVICED ORGANISATION."
  ; rdfs:subClassOf tm:DAY_TYPE
  .

tm:SERVICED_ORGANISATION a owl:Class ;
  rdfs:label "SERVICED ORGANISATION"
  ; rdfs:comment "A public or private organisation for which public transport services are provided on specific days, e.g., a school, university or works."
  ; rdfs:subClassOf tm:OTHER_ORGANISATION
  .

tm:TRAVEL_AGENT a owl:Class ;
  rdfs:label "TRAVEL AGENT"
  ; rdfs:comment "Specialisation of ORGANISATION for TRAVEL AGENT"
  ; rdfs:subClassOf tm:OTHER_ORGANISATION
  .

tm:INSTALLED_EQUIPMENT a owl:Class ;
  rdfs:label "INSTALLED EQUIPMENT"
  ; rdfs:comment "An item of equipment either fixed (PLACE EQUIPMENT) or on board i.e., associated with vehicles.  NOTE: This equipment is material, as opposed to a service (LOCAL SERVICE) considered as an immaterial equipment."
  ; rdfs:subClassOf tm:EQUIPMENT
  .

tm:PASSENGER_EQUIPMENT a owl:Class ;
  rdfs:label "PASSENGER EQUIPMENT"
  ; rdfs:comment "An item of EQUIPMENT of a particular type actually available at a location within a PLACE or a VEHICLE"
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:TYPE_OF_EQUIPMENT a owl:Class ;
  rdfs:label "TYPE OF EQUIPMENT"
  ; rdfs:comment "A classification of equipment items to be installed at stop points or onboard vehicles, for instance."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:LOCAL_SERVICE a owl:Class ;
  rdfs:label "LOCAL SERVICE"
  ; rdfs:comment "A named service relating to the use of the SITE or transport services at a particular location, for example porterage, assistance for disabled users, booking offices, etc.  NOTE1: The service may have a VALIDITY CONDITION associated with it.  NOTE2: A LOCAL SERVICE is treated as a form of non-material EQUIPMENT."
  ; rdfs:subClassOf tm:EQUIPMENT
  .

tm:EQUIPMENT a owl:Class ;
  rdfs:label "EQUIPMENT"
  ; rdfs:comment "An item of equipment installed either in a fixed location (PLACE EQUIPMENT) or on-board vehicles (VEHICLE EQUIPMENT).  NOTE: A service (for example a LOCAL SERVICE such as LEFT LUGGAGE, or TICKETING SERVICE) available at such locations is considered as immaterial equipment as well."
  .

tm:PLACE_EQUIPMENT a owl:Class ;
  rdfs:label "PLACE EQUIPMENT"
  ; rdfs:comment "An item of EQUIPMENT of a particular type actually available at a location within a PLACE."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:FACILITY_REQUIREMENT a owl:Class ;
  rdfs:label "FACILITY REQUIREMENT"
  ; rdfs:comment "A classification of public transport vehicles according to the facilities available on the vehicle."
  .

tm:MANOEUVRING_REQUIREMENT a owl:Class ;
  rdfs:label "MANOEUVRING REQUIREMENT"
  ; rdfs:comment "A classification of requirements for a public transport VEHICLE according to the manoeuvring capabilities of the vehicle."
  .

tm:VEHICLE_MODEL a owl:Class ;
  rdfs:label "VEHICLE MODEL"
  ; rdfs:comment "A classification of public transport vehicles of the same VEHICLE TYPE, e.g., according to equipment specifications or model generation."
  .

tm:TRANSPORT_TYPE a owl:Class ;
  rdfs:label "TRANSPORT TYPE"
  ; rdfs:comment "Common properties of VEHICLE TYPEs."
  .

tm:PASSENGER_CARRYING_REQUIREMENT a owl:Class ;
  rdfs:label "PASSENGER CARRYING REQUIREMENT"
  ; rdfs:comment "A classification of requirements for a public transport vehicle according to the passenger carrying capabilities of the vehicle."
  .

tm:VEHICLE_EQUIPMENT_PROFILE a owl:Class ;
  rdfs:label "VEHICLE EQUIPMENT PROFILE"
  ; rdfs:comment "Each instantiation of this entity gives the number of items of one TYPE OF EQUIPMENT a VEHICLE MODEL should contain for a given PURPOSE OF EQUIPMENT PROFILE.  NOTE: The set of instantiations for one VEHICLE MODEL and one purpose gives one complete 'profile'."
  .

tm:PURPOSE_OF_EQUIPMENT_PROFILE a owl:Class ;
  rdfs:label "PURPOSE OF EQUIPMENT PROFILE"
  ; rdfs:comment "A functional purpose which requires a certain set of equipment of different types put together in a VEHICLE EQUIPMENT PROFILE."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:VEHICLE a owl:Class ;
  rdfs:label "VEHICLE"
  ; rdfs:comment "A public transport vehicle used for carrying passengers."
  .

tm:ACTUAL_VEHICLE_EQUIPMENT a owl:Class ;
  rdfs:label "ACTUAL VEHICLE EQUIPMENT"
  ; rdfs:comment "An item of equipment of a particular type in an individual VEHICLE."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:WHEELCHAIR_VEHICLE_EQUIPMENT a owl:Class ;
  rdfs:label "WHEELCHAIR VEHICLE EQUIPMENT"
  ; rdfs:comment "Specialisation of VEHICLE EQUIPMENT for wheelchair accessibility on board a VEHICLE providing information such as the number of wheelchair areas and the access dimensions."
  ; rdfs:subClassOf tm:ACTUAL_VEHICLE_EQUIPMENT
  .

tm:VEHICLE_ACCESS_EQUIPMENT a owl:Class ;
  rdfs:label "VEHICLE ACCESS EQUIPMENT"
  ; rdfs:comment "Specialisation of VEHICLE EQUIPMENT dedicated to access vehicles providing information such as low floor, ramp, access area dimensions, etc."
  ; rdfs:subClassOf tm:ACTUAL_VEHICLE_EQUIPMENT
  .

tm:SERVICE_FACILITY_SET a owl:Class ;
  rdfs:label "SERVICE FACILITY SET"
  ; rdfs:comment "Set of FACILITies available for a specific VEHICLE TYPE (e.g., carriage equipped with low floor) possibly only for a service (or for a SERVICE JOURNEY or a JOURNEY)."
  ; rdfs:subClassOf tm:FACILITY_SET
  .

tm:SITE_FACILITY_SET a owl:Class ;
  rdfs:label "SITE FACILITY SET"
  ; rdfs:comment "Set of FACILITies available for a SITE ELEMENT."
  ; rdfs:subClassOf tm:FACILITY_SET
  .

tm:ONBOARD_STAY a owl:Class ;
  rdfs:label "ONBOARD STAY"
  ; rdfs:comment "Permission to board early before the journey or stay on board after the journey."
  ; rdfs:subClassOf tm:SERVICE_FACILITY_SET
  .

tm:FACILITY_SET a owl:Class ;
  rdfs:label "FACILITY SET"
  ; rdfs:comment "Set of FACILITies available for a SERVICE JOURNEY or a JOURNEY PART.  NOTE: The set may be available only for a specific VEHICLE TYPE within the SERVICE (e.g., carriage equipped with low floor)."
  .

tm:TYPE_OF_FACILITY a owl:Class ;
  rdfs:label "TYPE OF FACILITY"
  ; rdfs:comment "A classification of a FACILITY or a FACILITY SET."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FACILITY a owl:Class ;
  rdfs:label "FACILITY"
  ; rdfs:comment "A named amenity available to the public at a SITE or on a SERVICE.  NOTE: A facility has no further properties other than a name; an EQUIPMENT or LOCAL SERVICE is used to describe the further properties provided as part of particular facility."
  .

tm:ACCOMMODATION a owl:Class ;
  rdfs:label "ACCOMMODATION"
  ; rdfs:comment "A combination of accommodation characteristics available on a service, e.g. \"First Class Couchette with shower and 2 bunks\"."
  ; rdfs:subClassOf tm:SERVICE_FACILITY_SET
  .

tm:TRAIN a owl:Class ;
  rdfs:label "TRAIN"
  ; rdfs:comment "A VEHICLE TYPE composed of TRAIN COMPONENTs in a certain order that cannot be split during operational use."
  ; rdfs:subClassOf tm:TRANSPORT_TYPE
  ; rdfs:subClassOf tm:VEHICLE_TYPE
  .

tm:TRAIN_COMPONENT a owl:Class ;
  rdfs:label "TRAIN COMPONENT"
  ; rdfs:comment "An instance of a TRAIN ELEMENT TYPE at a certain position and with a certain orientation in the train."
  .

tm:TRAIN_ELEMENT_TYPE a owl:Class ;
  rdfs:label "TRAIN ELEMENT TYPE"
  ; rdfs:comment "A type of carriage or engine (e.g., coach, carriage, wagon, locomotive) that can be an elementary component of a TRAIN."
  .

tm:TYPE_OF_TRAIN_ELEMENT_TYPE a owl:Class ;
  rdfs:label "TYPE OF TRAIN ELEMENT TYPE"
  ; rdfs:comment "A classification of TRAIN ELEMENT TYPEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:COMPOUND_TRAIN a owl:Class ;
  rdfs:label "COMPOUND TRAIN"
  ; rdfs:comment "A VEHICLE TYPE composed of a sequence of TRAINs and that is able to move under its own power."
  ; rdfs:subClassOf tm:VEHICLE_TYPE
  .

tm:TRAIN_IN_COMPOUND_TRAIN a owl:Class ;
  rdfs:label "TRAIN IN COMPOUND TRAIN"
  ; rdfs:comment "An instance of a certain TRAIN at a certain position and with a certain orientation in the COMPOUND TRAIN."
  .

tm:SCHEMATIC_MAP a owl:Class ;
  rdfs:label "SCHEMATIC MAP"
  ; rdfs:comment "A map representing schematically the layout of the topographic structure of PLACEs (e.g., a set of SITEs) or the public transport network (a set of LINEs), or other entity with a geometric projection (E.g., DECK PLAN for a train, vessel or aircraft).  NOTE: It can include a pixel projection of a set of ENTITies onto a bitmap image to support hyperlinked interactions."
  .

tm:NOTICE a owl:Class ;
  rdfs:label "NOTICE"
  ; rdfs:comment "A text for informational purposes on exceptions in a LINE, a JOURNEY PATTERN, etc.  NOTE: The information may be usable for passenger or driver information."
  .

tm:DELIVERY_VARIANT a owl:Class ;
  rdfs:label "DELIVERY VARIANT"
  ; rdfs:comment "A variant text of a NOTICE for use in a specific media or delivery channel (voice, printed material, etc.)."
  .

tm:TYPE_OF_DELIVERY_VARIANT a owl:Class ;
  rdfs:label "TYPE OF DELIVERY VARIANT"
  ; rdfs:comment "A classification of a DELIVERY VARIANT by way of delivering a NOTICE, e.g., by vocal announcement, by visual display, issuing printed material."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_NOTICE a owl:Class ;
  rdfs:label "TYPE OF NOTICE"
  ; rdfs:comment "A classification for a NOTICE."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SERVICE_RESTRICTION a owl:Class ;
  rdfs:label "SERVICE RESTRICTION"
  ; rdfs:comment "Parameters describing the limitations as regards the use of equipment or service."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_TICKETING a owl:Class ;
  rdfs:label "TYPE OF TICKETING"
  ; rdfs:comment "A classification for ticketing services available at a TICKETING EQUIPMENT (e.g., as purchase, collection, card top up, reservations)."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:CLASS_OF_USE a owl:Class ;
  rdfs:label "CLASS OF USE"
  ; rdfs:comment "A classification of fare and other service classes by category of user entitled to use them."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:TYPE_OF_FARE_CLASS a owl:Class ;
  rdfs:label "TYPE OF FARE CLASS"
  ; rdfs:comment "A classification for fare classes (e.g., first class, second class, business class, etc.)."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:TYPE_OF_TICKET a owl:Class ;
  rdfs:label "TYPE OF TICKET"
  ; rdfs:comment "A classification for tickets available at a TICKETING EQUIPMENT (e.g., standard, concession, promotion, group, season, travel card, etc.),"
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:TYPE_OF_PAYMENT_METHOD a owl:Class ;
  rdfs:label "TYPE OF PAYMENT METHOD"
  ; rdfs:comment "A classification for payment method (e.g., cash, credit card, debit card, travel card, contactless travel card, mobile phone, token, etc.)."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:TICKET_SCOPE a owl:Class ;
  rdfs:label "TICKET SCOPE"
  ; rdfs:comment "Scope of ticket."
  ; rdfs:subClassOf tm:SERVICE_RESTRICTION
  .

tm:ALTERNATIVE_NAME a owl:Class ;
  rdfs:label "ALTERNATIVE NAME"
  ; rdfs:comment "Alternative name for an ENTITY."
  .

tm:RAILWAY_ELEMENT a owl:Class ;
  rdfs:label "RAILWAY ELEMENT"
  ; rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a railway network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_LINK
  .

tm:ROAD_ELEMENT a owl:Class ;
  rdfs:label "ROAD ELEMENT"
  ; rdfs:comment "A type of INFRASTRUCTURE LINK used to describe a road network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_LINK
  .

tm:RAILWAY_JUNCTION a owl:Class ;
  rdfs:label "RAILWAY JUNCTION"
  ; rdfs:comment "A type of INFRASTRUCTURE POINT used to describe a railway network."
  ; rdfs:subClassOf tm:INFRASTRUCTURE_POINT
  .

tm:VEHICLE_TYPE_AT_POINT a owl:Class ;
  rdfs:label "VEHICLE TYPE AT POINT"
  ; rdfs:comment "The number of vehicles of a specified VEHICLE TYPE which may wait at a specified POINT at any one time.  NOTE: If the capacity is 0, then that type of vehicle may not stop there."
  .

tm:MEETING_RESTRICTION a owl:Class ;
  rdfs:label "MEETING RESTRICTION"
  ; rdfs:comment "A pair of INFRASTRUCTURE LINKs where vehicles of specified VEHICLE TYPEs are not allowed to meet."
  .

tm:OVERTAKING_POSSIBILITY a owl:Class ;
  rdfs:label "OVERTAKING POSSIBILITY"
  ; rdfs:comment "NETWORK RESTRICTION specifying a POINT or a LINK where vehicles of specified VEHICLE TYPEs are or are not allowed to overtake each other."
  .

tm:LINE_NETWORK a owl:Class ;
  rdfs:label "LINE NETWORK"
  ; rdfs:comment "The topological structure of a NETWORK as a graph of LINE SECTIONs.  NOTE: This allows the branches and loops of a LINE or LINEs to be described as a whole."
  .

tm:LINE_SECTION a owl:Class ;
  rdfs:label "LINE SECTION"
  ; rdfs:comment "A section of a LINE NETWORK comprising one or more POINTS or LINKS connecting two end points."
  ; rdfs:subClassOf tm:SECTION
  .

tm:ROUTE_POINT a owl:Class ;
  rdfs:label "ROUTE POINT"
  ; rdfs:comment "A POINT used to define the shape of a ROUTE through the network."
  ; rdfs:subClassOf tm:POINT
  .

tm:ALLOWED_LINE_DIRECTION a owl:Class ;
  rdfs:label "ALLOWED LINE DIRECTION"
  ; rdfs:comment "An allowed DIRECTION that can be used on a given ROUTE.  NOTE: This can be used to validate the selection of allowed values."
  .

tm:LINE a owl:Class ;
  rdfs:label "LINE"
  ; rdfs:comment "A group of ROUTEs which is generally known to the public by a similar name or number."
  .

tm:GROUP_OF_LINES a owl:Class ;
  rdfs:label "GROUP OF LINES"
  ; rdfs:comment "A grouping of lines which will be commonly referenced for a specific purpose."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:ROUTE a owl:Class ;
  rdfs:label "ROUTE"
  ; rdfs:comment "An ordered list of located POINTs defining one single path through the road (or rail) network.  NOTE: A ROUTE may pass through the same POINT more than once."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:ROUTE_LINK a owl:Class ;
  rdfs:label "ROUTE LINK"
  ; rdfs:comment "An oriented link between two ROUTE POINTs allowing the definition of a unique path through the network."
  ; rdfs:subClassOf tm:LINK
  .

tm:DESTINATION_DISPLAY_VARIANT a owl:Class ;
  rdfs:label "DESTINATION DISPLAY VARIANT"
  ; rdfs:comment "An advertised destination of a specific JOURNEY PATTERN, usually displayed on a headsign or at other on-board locations."
  .

tm:POINT_ON_ROUTE a owl:Class ;
  rdfs:label "POINT ON ROUTE"
  ; rdfs:comment "A ROUTE POINT used to define a ROUTE with its order on that ROUTE."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:NETWORK a owl:Class ;
  rdfs:label "NETWORK"
  ; rdfs:comment "A named grouping of LINEs under which a transport network is known."
  ; rdfs:subClassOf tm:GROUP_OF_LINES
  .

tm:TYPE_OF_LINE a owl:Class ;
  rdfs:label "TYPE OF LINE"
  ; rdfs:comment "A classification for LINEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TURN_STATION a owl:Class ;
  rdfs:label "TURN STATION"
  ; rdfs:comment "A place (often a terminus) where a vehicle can reverse its direction (from a ROUTE to another of opposite DIRECTION)."
  .

tm:DESTINATION_DISPLAY a owl:Class ;
  rdfs:label "DESTINATION DISPLAY"
  ; rdfs:comment "An advertised destination of a specific JOURNEY PATTERN, usually displayed on a headsign or at other on-board locations."
  .

tm:VIA a owl:Class ;
  rdfs:label "VIA"
  ; rdfs:comment "A secondary heading relevant for a certain part of the JOURNEY PATTERN advertising an onward intermediate destination to supplement the advertised (final) destination of DESTINATION DISPLAY."
  .

tm:DIRECTION a owl:Class ;
  rdfs:label "DIRECTION"
  ; rdfs:comment "A classification for the general orientation of ROUTEs."
  .

tm:BOOKING_ARRANGEMENT a owl:Class ;
  rdfs:label "BOOKING ARRANGEMENT"
  ; rdfs:comment "Booking arrangements for a FLEXIBLE LINE or other entity."
  .

tm:FLEXIBLE_POINT_PROPERTIES a owl:Class ;
  rdfs:label "FLEXIBLE POINT PROPERTIES"
  ; rdfs:comment "Set of characteristics describing the possible flexibility of POINTs."
  .

tm:FLEXIBLE_LINK_PROPERTIES a owl:Class ;
  rdfs:label "FLEXIBLE LINK PROPERTIES"
  ; rdfs:comment "Set of properties describing the flexible characteristics of a LINK."
  .

tm:FLEXIBLE_LINE a owl:Class ;
  rdfs:label "FLEXIBLE LINE"
  ; rdfs:comment "Specialisation of LINE for flexible service.  NOTE1: As the service on a LINE may not all be flexible, flexibility itself is described at JOURNEY PATTERN level (meaning that a separate JOURNEY PATTERN is needed for each type of flexibility available for the line).  NOTE2: Types of flexible services include: Virtual line services; Flexible service with a main route; Corridor services; Fixed stop area-wide flexible services; Free area-wide flexible services; Mixed combinations of flexible services of different types; Mixed combinations of flexible and regular services."
  ; rdfs:subClassOf tm:LINE
  .

tm:FLEXIBLE_ROUTE a owl:Class ;
  rdfs:label "FLEXIBLE ROUTE"
  ; rdfs:comment "Specialisation of ROUTE for flexible service.  NOTE: May include both point and zonal areas and ordered and unordered sections."
  ; rdfs:subClassOf tm:ROUTE
  .

tm:ACTIVATED_EQUIPMENT a owl:Class ;
  rdfs:label "ACTIVATED EQUIPMENT"
  ; rdfs:comment "An equipment activated by the passage of a vehicle at an ACTIVATION POINT or on an ACTIVATION LINK."
  .

tm:ACTIVATION_POINT a owl:Class ;
  rdfs:label "ACTIVATION POINT"
  ; rdfs:comment "A POINT where a control process is activated when a vehicle passes it.  NOTE: EQUIPMENT may be needed for the activation."
  ; rdfs:subClassOf tm:POINT
  .

tm:TYPE_OF_ACTIVATION a owl:Class ;
  rdfs:label "TYPE OF ACTIVATION"
  ; rdfs:comment "A classification of real-time processes that are activated when vehicles pass an ACTIVATION POINT or an ACTIVATION LINK."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TRAFFIC_CONTROL_POINT a owl:Class ;
  rdfs:label "TRAFFIC CONTROL POINT"
  ; rdfs:comment "A POINT where the traffic flow can be influenced, e.g., traffic lights (lanterns), barriers."
  ; rdfs:subClassOf tm:POINT
  .

tm:ACTIVATION_LINK a owl:Class ;
  rdfs:label "ACTIVATION LINK"
  ; rdfs:comment "A LINK where a control process is activated when a vehicle passes it."
  ; rdfs:subClassOf tm:LINK
  .

tm:TYPE_OF_TRAFFIC_CONTROL_POINT a owl:Class ;
  rdfs:label "TYPE OF TRAFFIC CONTROL POINT"
  ; rdfs:comment "A classification of TRAFFIC CONTROL POINTs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ACTIVATION_ASSIGNMENT a owl:Class ;
  rdfs:label "ACTIVATION ASSIGNMENT"
  ; rdfs:comment "An assignment of an ACTIVATION POINT or LINK to an ACTIVATED EQUIPMENT, related in its turn to a TRAFFIC CONTROL POINT.  NOTE: The considered ACTIVATION POINT or LINK will be used to influence the control process for that TRAFFIC CONTROL POINT (e.g., to fix priorities as regards the processing of competing requests from different ACTIVATION POINTs/LINKs)."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:BEACON_POINT a owl:Class ;
  rdfs:label "BEACON POINT"
  ; rdfs:comment "A POINT where a beacon or similar device to support the automatic detection of vehicles passing by is located."
  ; rdfs:subClassOf tm:ACTIVATION_POINT
  .

tm:RELIEF_POINT a owl:Class ;
  rdfs:label "RELIEF POINT"
  ; rdfs:comment "A TIMING POINT where a relief is possible, i.e., a driver may take on or hand over a vehicle.  NOTE: The vehicle may sometimes be left unattended even though it has passengers on board."
  ; rdfs:subClassOf tm:TIMING_POINT
  .

tm:GARAGE a owl:Class ;
  rdfs:label "GARAGE"
  ; rdfs:comment "A facility used for parking and maintaining vehicles.  NOTE1: PARKING POINTs in a GARAGE are called GARAGE POINTs.  NOTE2: Such a facility is often called a depot."
  .

tm:CREW_BASE a owl:Class ;
  rdfs:label "CREW BASE"
  ; rdfs:comment "A place where operating employees (e.g., drivers) report on and register their work."
  .

tm:PARKING_POINT a owl:Class ;
  rdfs:label "PARKING POINT"
  ; rdfs:comment "A TIMING POINT where vehicles may stay unattended for a long time.  NOTE1: A vehicle's return to park at a PARKING POINT marks the end of a BLOCK.  NOTE2: Normally there are no passengers on board at a PARKING POINT."
  ; rdfs:subClassOf tm:RELIEF_POINT
  .

tm:GARAGE_POINT a owl:Class ;
  rdfs:label "GARAGE POINT"
  ; rdfs:comment "A subtype of PARKING POINT located in a GARAGE."
  ; rdfs:subClassOf tm:PARKING_POINT
  .

tm:SITE_COMPONENT a owl:Class ;
  rdfs:label "SITE COMPONENT"
  ; rdfs:comment "An element of a SITE describing a part of its structure.  NOTE: SITE COMPONENTs share common properties for data management, accessibility and other features."
  ; rdfs:subClassOf tm:SITE_ELEMENT
  .

tm:ENTRANCE a owl:Class ;
  rdfs:label "ENTRANCE"
  ; rdfs:comment "A physical entrance or exit to/from a SITE; may be a door, barrier, gate or other recognizable point of access."
  ; rdfs:subClassOf tm:SITE_COMPONENT
  .

tm:ACCESS_ZONE a owl:Class ;
  rdfs:label "ACCESS ZONE"
  ; rdfs:comment "A ZONE for which the duration needed to reach a particular STOP POINT is considered to be the same."
  ; rdfs:subClassOf tm:ZONE
  .

tm:VEHICLE_ENTRANCE a owl:Class ;
  rdfs:label "VEHICLE ENTRANCE"
  ; rdfs:comment "A physical entrance or exit to/from a SITE for a VEHICLE.  NOTE: May be a door, barrier, gate or other recognizable point of vehicle access."
  ; rdfs:subClassOf tm:ENTRANCE
  .

tm:SITE a owl:Class ;
  rdfs:label "SITE"
  ; rdfs:comment "A well known PLACE to which passengers may refer to indicate the origin or a destination of a trip."
  ; rdfs:subClassOf tm:SITE_ELEMENT
  .

tm:LEVEL a owl:Class ;
  rdfs:label "LEVEL"
  ; rdfs:comment "An identified storey (ground, first, basement, mezzanine, etc.) within an interchange building or SITE on which SITE COMPONENTs reside.  NOTE: A PATH LINK may connect components on different levels."
  .

tm:SERVICE_SITE a owl:Class ;
  rdfs:label "SERVICE SITE"
  ; rdfs:comment "A sub-type of SITE which is of specific interest for the operator (e.g., where a joint service or a joint fee is proposed), other than a STOP PLACE."
  ; rdfs:subClassOf tm:SITE
  .

tm:SITE_ELEMENT a owl:Class ;
  rdfs:label "SITE ELEMENT"
  ; rdfs:comment "A specialisation of ADDRESSABLE PLACE describing common properties of a SITE or a SITE COMPONENT, including accessibility."
  ; rdfs:subClassOf tm:ADDRESSABLE_PLACE
  ; rdfs:subClassOf tm:ENVIRONMENT_PROPERTIES
  .

tm:STOP_PLACE a owl:Class ;
  rdfs:label "STOP PLACE"
  ; rdfs:comment "A place comprising one or more locations where vehicles may stop and where passengers may board or leave vehicles or prepare their trip.  NOTE: A STOP PLACE will usually have one or more well-known names."
  ; rdfs:subClassOf tm:SITE
  .

tm:QUAY a owl:Class ;
  rdfs:label "QUAY"
  ; rdfs:comment "A place such as platform, stance, or quay side where passengers have access to PT vehicles, Taxis, cars or other means of transportation.  NOTE1: A QUAY may serve one or more VEHICLE STOPPING PLACEs and be associated with one or more SCHEDULED STOP POINTS.  NOTE2: A QUAY may contain other sub QUAYs.  NOTE3: A child QUAY must be physically contained within its parent QUAY."
  ; rdfs:subClassOf tm:STOP_PLACE_SPACE
  .

tm:TYPE_OF_STOP_PLACE a owl:Class ;
  rdfs:label "TYPE OF STOP PLACE"
  ; rdfs:comment "A classification for STOP PLACEs (e.g., complex, simple, multimodal, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:STOP_PLACE_SPACE a owl:Class ;
  rdfs:label "STOP PLACE SPACE"
  ; rdfs:comment "A physical area within a STOP PLACE, for example, a QUAY, BOARDING POSITION, ACCESS SPACE or EQUIPMENT PLACE."
  ; rdfs:subClassOf tm:STOP_PLACE_COMPONENT
  .

tm:STOP_PLACE_ENTRANCE a owl:Class ;
  rdfs:label "STOP PLACE ENTRANCE"
  ; rdfs:comment "A physical entrance or exit to/from a STOP PLACE for a Passenger; may be a door, barrier, gate or other recognizable point of access."
  ; rdfs:subClassOf tm:ENTRANCE
  .

tm:BOARDING_POSITION a owl:Class ;
  rdfs:label "BOARDING POSITION"
  ; rdfs:comment "A location within a QUAY from which passengers may directly board, or onto which passengers may directly alight from a VEHICLE."
  ; rdfs:subClassOf tm:STOP_PLACE_SPACE
  .

tm:STOP_PLACE_VEHICLE_ENTRANCE a owl:Class ;
  rdfs:label "STOP PLACE VEHICLE ENTRANCE`"
  ; rdfs:comment "A physical entrance or exit to/from a STOP PLACE for a vehicle."
  ; rdfs:subClassOf tm:VEHICLE_ENTRANCE
  .

tm:STOP_PLACE_COMPONENT a owl:Class ;
  rdfs:label "STOP PLACE COMPONENT"
  ; rdfs:comment "An element of a STOP PLACE describing part of its structure.  NOTE: STOP PLACE COMPONENTs share common properties for data management, accessibility and other features."
  ; rdfs:subClassOf tm:SITE_COMPONENT
  .

tm:TYPE_OF_QUAY a owl:Class ;
  rdfs:label "TYPE OF QUAY"
  ; rdfs:comment "A classification for QUAYs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_BOARDING_POSITION a owl:Class ;
  rdfs:label "TYPE OF BOARDING POSITION"
  ; rdfs:comment "A classification for BOARDING POSITIONs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ACCESS_SPACE a owl:Class ;
  rdfs:label "ACCESS SPACE"
  ; rdfs:comment "A passenger area within a STOP PLACE such as a concourse or booking hall, immigration hall or security area that is accessible by passengers, but without a direct access to vehicles.  NOTE: Direct access to a VEHICLE is always from a QUAY and/or BOARDING POSITION."
  ; rdfs:subClassOf tm:STOP_PLACE_SPACE
  .

tm:TYPE_OF_PASSAGE a owl:Class ;
  rdfs:label "TYPE OF PASSAGE"
  ; rdfs:comment "A classification for spaces to express how the space can be used as a passage (e.g., as pathway, corridor, overpass, underpass, tunnel, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FLEXIBLE_QUAY a owl:Class ;
  rdfs:label "FLEXIBLE QUAY"
  ; rdfs:comment "A physical ZONE such as a section of a road where a flexible service is available on demand."
  .

tm:HAIL_AND_RIDE_AREA a owl:Class ;
  rdfs:label "HAIL AND RIDE AREA"
  ; rdfs:comment "Specialisation of a FLEXIBLE QUAY defining a physical section of road between a start and end point within which a Hail and Ride service is available."
  ; rdfs:subClassOf tm:FLEXIBLE_QUAY
  .

tm:FLEXIBLE_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "FLEXIBLE STOP ASSIGNMENT"
  ; rdfs:comment "The allocation of a SCHEDULED STOP POINT (i.e., a STOP POINT of a SERVICE PATTERN or JOURNEY PATTERN) to a specific FLEXIBLE STOP PLACE, and also possibly a FLEXIBLE AREA or HAIL AND RIDE AREA.  NOTE: May be subject to a VALIDITY CONDITION."
  ; rdfs:subClassOf tm:STOP_ASSIGNMENT
  .

tm:FLEXIBLE_STOP_PLACE a owl:Class ;
  rdfs:label "FLEXIBLE STOP PLACE"
  ; rdfs:comment "A specialisation of the STOP PLACE describing a stop of a FLEXIBLE SERVICE.  NOTE1: It may be composed of FLEXIBLE AREAs or HAIL AND RIDE AREAs identifying the catchment areas for flexible services (when they use areas or flexible quays).  NOTE2: Some FLEXIBLE SERVICEs also use regular STOP PLACEs for their stops."
  ; rdfs:subClassOf tm:STOP_PLACE
  .

tm:FLEXIBLE_AREA a owl:Class ;
  rdfs:label "FLEXIBLE AREA"
  ; rdfs:comment "Specialisation of a FLEXIBLE QUAY (which is abstract) to identify what is the catchment area for a flexible service (so that a stop finder can find the nearest available types of transport)."
  ; rdfs:subClassOf tm:FLEXIBLE_QUAY
  .

tm:POINT_OF_INTEREST_CLASSIFICATION_HIERARCHY a owl:Class ;
  rdfs:label "POINT OF INTEREST CLASSIFICATION HIERARCHY"
  ; rdfs:comment "A logical hierarchy for organizing POINT OF INTEREST CLASSIFICATIONs.  NOTE: A POINT OF INTEREST CLASSIFICATION can belong to more than one hierarchy."
  .

tm:POINT_OF_INTEREST_ENTRANCE a owl:Class ;
  rdfs:label "POINT OF INTEREST ENTRANCE"
  ; rdfs:comment "Specialisation of ENTRANCE to enter/exit a POINT OF INTEREST."
  ; rdfs:subClassOf tm:ENTRANCE
  .

tm:TYPE_OF_POINT_OF_INTEREST_SPACE a owl:Class ;
  rdfs:label "TYPE OF POINT OF INTEREST SPACE"
  ; rdfs:comment "A classification for POINT OF INTEREST SPACEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:POINT_OF_INTEREST_COMPONENT a owl:Class ;
  rdfs:label "POINT OF INTEREST COMPONENT"
  ; rdfs:comment "Specialisation of SITE COMPONENT for COMPONENT of POINT OF INTEREST."
  ; rdfs:subClassOf tm:SITE_COMPONENT
  .

tm:POINT_OF_INTEREST_CLASSIFICATION a owl:Class ;
  rdfs:label "POINT OF INTEREST CLASSIFICATION"
  ; rdfs:comment "A classification of a POINT OF INTEREST that may be used in a POINT OF INTEREST CLASSIFICATION HIERARCHY to categorise the point by nature of interest using a systematic taxonomy, for example Museum, Football, Stadium, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:POINT_OF_INTEREST_VEHICLE_ENTRANCE a owl:Class ;
  rdfs:label "POINT OF INTEREST VEHICLE ENTRANCE"
  ; rdfs:comment "A physical entrance for VEHICLEs to enter or exit a POINT OF INTEREST."
  ; rdfs:subClassOf tm:VEHICLE_ENTRANCE
  .

tm:POINT_OF_INTEREST_SPACE a owl:Class ;
  rdfs:label "POINT OF INTEREST SPACE"
  ; rdfs:comment "A specialisation of POINT OF INTEREST COMPONENT representing a physical area within the POINT OF INTEREST, such as a concourse."
  ; rdfs:subClassOf tm:POINT_OF_INTEREST_COMPONENT
  .

tm:POINT_OF_INTEREST a owl:Class ;
  rdfs:label "POINT OF INTEREST"
  ; rdfs:comment "A type of PLACE to or through which passengers may wish to navigate as part of their journey and which is modelled in detail by journey planners."
  ; rdfs:subClassOf tm:SITE
  .

tm:POINT_OF_INTEREST_CLASSIFICATION_MEMBER a owl:Class ;
  rdfs:label "POINT OF INTEREST CLASSIFICATION MEMBER"
  ; rdfs:comment "The POINT OF INTEREST CLASSIFICATION and POINT OF INTEREST CLASSIFICATION MEMBER are used to encode a hierarchy of classifications to index and find different types of POINT OF INTEREST; for example, <i>Educational Building -&gt; School -&gt; Primary School</i>, or <i>Cultural</i>  <i>Attraction -&gt; Museum -&gt; Art Museum</i>.  NOTE: POINT OF INTEREST CLASSIFICATION MEMBERSHIP does not have to be disjoint, i.e., the same category may appear in more than one classification."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:EQUIPMENT_PLACE a owl:Class ;
  rdfs:label "EQUIPMENT PLACE"
  ; rdfs:comment "A SITE COMPONENT containing EQUIPMENT."
  ; rdfs:subClassOf tm:SITE_COMPONENT
  .

tm:EQUIPMENT_POSITION a owl:Class ;
  rdfs:label "EQUIPMENT POSITION"
  ; rdfs:comment "The precise position within an EQUIPMENT PLACE where particular equipment is placed."
  .

tm:TROLLEY_STAND_EQUIPMENT a owl:Class ;
  rdfs:label "TROLLEY STAND EQUIPMENT"
  ; rdfs:comment "Specialisation of STOP PLACE EQUIPMENT describing trolley stands."
  ; rdfs:subClassOf tm:SITE_EQUIPMENT
  .

tm:SITE_EQUIPMENT a owl:Class ;
  rdfs:label "SITE EQUIPMENT"
  ; rdfs:comment "Specialisation of PLACE EQUIPMENT describing common properties of EQUIPMENT for SITEs (e.g., for LUGGAGE LOCKER, WAITING EQUIPMENT, TROLLEY STAND, etc.),"
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:SEATING_EQUIPMENT a owl:Class ;
  rdfs:label "SEATING EQUIPMENT"
  ; rdfs:comment "Specialisation of WAITING EQUIPMENT describing the properties of seating"
  ; rdfs:subClassOf tm:WAITING_EQUIPMENT
  .

tm:WAITING_ROOM_EQUIPMENT a owl:Class ;
  rdfs:label "WAITING ROOM EQUIPMENT"
  ; rdfs:comment "Specialisation of WAITING EQUIPMENT describing waiting rooms (number of seats, type, FACILITIEs, etc.)."
  ; rdfs:subClassOf tm:WAITING_EQUIPMENT
  .

tm:WAITING_EQUIPMENT a owl:Class ;
  rdfs:label "WAITING EQUIPMENT"
  ; rdfs:comment "Specialisation of SITE EQUIPMENT describing common features of waiting areas (shelter, waiting room, etc.)."
  ; rdfs:subClassOf tm:SITE_EQUIPMENT
  .

tm:TYPE_OF_WAITING_ROOM a owl:Class ;
  rdfs:label "TYPE OF WAITING ROOM"
  ; rdfs:comment "A classification for WAITING ROOM EQUIPMENT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_SHELTER a owl:Class ;
  rdfs:label "TYPE OF SHELTER"
  ; rdfs:comment "A classification for SHELTER EQUIPMENT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:LUGGAGE_LOCKER_EQUIPMENT a owl:Class ;
  rdfs:label "LUGGAGE LOCKER EQUIPMENT"
  ; rdfs:comment "Specialisation of SITE EQUIPMENT describing luggage lockers."
  ; rdfs:subClassOf tm:SITE_EQUIPMENT
  .

tm:SHELTER_EQUIPMENT a owl:Class ;
  rdfs:label "SHELTER EQUIPMENT"
  ; rdfs:comment "Specialisation of WAITING EQUIPMENT describing a shelter."
  ; rdfs:subClassOf tm:WAITING_EQUIPMENT
  .

tm:TYPE_OF_SEATING_EQUIPMENT a owl:Class ;
  rdfs:label "TYPE OF SEATING EQUIPMENT"
  ; rdfs:comment "A classification for SEATING EQUIPMENT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_LUGGAGE_LOCKER a owl:Class ;
  rdfs:label "TYPE OF LUGGAGE LOCKER"
  ; rdfs:comment "A classification for LUGGAGE LOCKER EQUIPMENT (e.g., left luggage, lockers, bike carriage, porterage, free trolleys, paid trolleys)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:RUBBISH_DISPOSAL a owl:Class ;
  rdfs:label "RUBBISH DISPOSAL"
  ; rdfs:comment "Specialisation of EQUIPMENT describing rubbish disposal features, (permitted rubbish types, etc.)"
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:PASSENGER_SAFETY_EQUIPMENT a owl:Class ;
  rdfs:label "PASSENGER SAFETY EQUIPMENT"
  ; rdfs:comment "Specialisation of PASSENGER EQUIPMENT describing passenger safety features of a SITE."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:SANITARY_EQUIPMENT a owl:Class ;
  rdfs:label "SANITARY EQUIPMENT"
  ; rdfs:comment "Specialisation of PASSENGER EQUIPMENT describing sanitary facilities (WC, shower, etc.)."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:TYPE_OF_GENDER_LIMITATION a owl:Class ;
  rdfs:label "TYPE OF GENDER LIMITATION"
  ; rdfs:comment "A classification for GENDER LIMITATIONs (e.g., for SANITARY EQUIPMENT; male only, female only, both)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_SANITARY_FACILITY a owl:Class ;
  rdfs:label "TYPE OF SANITARY FACILITY"
  ; rdfs:comment "A classification for SANITARY EQUIPMENT (e.g., toilet, wheelchair access toilet, shower, baby change, wheelchair baby change)"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TICKET_VALIDATOR_EQUIPMENT a owl:Class ;
  rdfs:label "TICKET VALIDATOR EQUIPMENT"
  ; rdfs:comment "Specialisation of PASSENGER EQUIPMENT (PLACE EQUIPMENT) describing ticket validators."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:TICKETING_EQUIPMENT a owl:Class ;
  rdfs:label "TICKETING EQUIPMENT"
  ; rdfs:comment "Specialization of PASSENGER EQUIPMENT for ticketing."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:ENTRANCE_EQUIPMENT a owl:Class ;
  rdfs:label "ENTRANCE EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing an equipment for an ENTRANCE (door, barrier, revolving door, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:CROSSING_EQUIPMENT a owl:Class ;
  rdfs:label "CROSSING EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing a road crossing for pedestrians (zebra, pedestrian lights, acoustic device sensors, tactile guide strips, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:ROUGH_SURFACE a owl:Class ;
  rdfs:label "ROUGH SURFACE"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT for rough surfaces, giving properties of surface texture, mainly for impaired person information."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:LIFT_EQUIPMENT a owl:Class ;
  rdfs:label "LIFT EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing a lift (depth, maximum load, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:TYPE_OF_DIRECTION_OF_USE a owl:Class ;
  rdfs:label "TYPE OF DIRECTION OF USE"
  ; rdfs:comment "Direction in which EQUIPMENT can be used, (e.g., up, down, level, one way, both ways, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ACCESS_EQUIPMENT a owl:Class ;
  rdfs:label "ACCESS EQUIPMENT"
  ; rdfs:comment "Specialisation of PLACE EQUIPMENT describing common properties of equipment with which to access a SITE (e.g., lifts, entrances, stairs, ramps, etc.)."
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:QUEUING_EQUIPMENT a owl:Class ;
  rdfs:label "QUEUING EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing queuing equipment or features."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:PLACE_LIGHTING a owl:Class ;
  rdfs:label "PLACE LIGHTING"
  ; rdfs:comment "Specialisation of PLACE EQUIPMENT describing the lighting (e.g., always on, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:RAMP_EQUIPMENT a owl:Class ;
  rdfs:label "RAMP EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing a ramp (provides ramp characteristics like length, gradient, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:TYPE_OF_SURFACE a owl:Class ;
  rdfs:label "TYPE OF SURFACE"
  ; rdfs:comment "A classification for ROUGH SURFACE types."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TRAVELATOR_EQUIPMENT a owl:Class ;
  rdfs:label "TRAVELATOR EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing a travelator (provides attributes such as speed, energy saving, etc.)."
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:TYPE_OF_HANDRAIL a owl:Class ;
  rdfs:label "TYPE OF HANDRAIL"
  ; rdfs:comment "A classification of a handrail (one side, both sides, continuous, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ESCALATOR_EQUIPMENT a owl:Class ;
  rdfs:label "ESCALATOR EQUIPMENT"
  ; rdfs:comment "Specialisation of STAIR EQUIPMENT describing an ESCALATOR."
  ; rdfs:subClassOf tm:STAIR_EQUIPMENT
  .

tm:STAIRCASE_EQUIPMENT a owl:Class ;
  rdfs:label "STAIRCASE EQUIPMENT"
  ; rdfs:comment "Specialisation of STAIR EQUIPMENT describing a staircase."
  ; rdfs:subClassOf tm:STAIR_EQUIPMENT
  .

tm:STAIR_EQUIPMENT a owl:Class ;
  rdfs:label "STAIR EQUIPMENT"
  ; rdfs:comment "Specialisation of ACCESS EQUIPMENT describing a stepped feature (stair, escalator, staircase, etc.)"
  ; rdfs:subClassOf tm:ACCESS_EQUIPMENT
  .

tm:SIGN_EQUIPMENT a owl:Class ;
  rdfs:label "SIGN EQUIPMENT"
  ; rdfs:comment "Specialisation of PLACE EQUIPMENT describing common properties of a sign (heading signs, etc.)."
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:GENERAL_SIGN a owl:Class ;
  rdfs:label "GENERAL SIGN"
  ; rdfs:comment "Specialisation of SIGN EQUIPMENT describing a sign which is neither a HEADING SIGN nor a PLACE SIGN."
  ; rdfs:subClassOf tm:SIGN_EQUIPMENT
  .

tm:HEADING_SIGN a owl:Class ;
  rdfs:label "HEADING SIGN"
  ; rdfs:comment "Specialisation of SIGN EQUIPMENT describing a sign showing a heading; provides information such as DIRECTION name, LINE name, line number etc."
  ; rdfs:subClassOf tm:SIGN_EQUIPMENT
  .

tm:PLACE_SIGN a owl:Class ;
  rdfs:label "PLACE SIGN"
  ; rdfs:comment "Specialisation of SIGN EQUIPMENT describing a sign that shows the name of a STOP PLACE."
  ; rdfs:subClassOf tm:SIGN_EQUIPMENT
  .

tm:ASSISTANCE_SERVICE a owl:Class ;
  rdfs:label "ASSISTANCE SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing assistance services, providing information such as language, accessibility trained staff, etc."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:TYPE_OF_EMERGENCY_SERVICE a owl:Class ;
  rdfs:label "TYPE OF EMERGENCY SERVICE"
  ; rdfs:comment "A classification of emergency services (e.g., police, first aid, SOS point, CCTV, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CUSTOMER_SERVICE a owl:Class ;
  rdfs:label "CUSTOMER SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing common properties of customer services, (e.g., lost property service, meeting point, complaints service, etc.)."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:LOST_PROPERTY_SERVICE a owl:Class ;
  rdfs:label "LOST PROPERTY SERVICE"
  ; rdfs:comment "Specialisation of CUSTOMER SERVICE of describing lost property services"
  ; rdfs:subClassOf tm:CUSTOMER_SERVICE
  .

tm:TYPE_OF_LOCAL_SERVICE a owl:Class ;
  rdfs:label "TYPE OF LOCAL SERVICE"
  ; rdfs:comment "A generic (abstract) classification of LOCAL SERVICEs."
  ; rdfs:subClassOf tm:TYPE_OF_EQUIPMENT
  .

tm:LEFT_LUGGAGE_SERVICE a owl:Class ;
  rdfs:label "LEFT LUGGAGE SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing left luggage amenities; provides information such as self-service locker, left luggage office,, etc."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:LUGGAGE_SERVICE a owl:Class ;
  rdfs:label "LUGGAGE SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing luggage carrying services (e.g., luggage trolley, free to use, etc.)."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:TICKETING_SERVICE a owl:Class ;
  rdfs:label "TICKETING SERVICE"
  ; rdfs:comment "Specialization of LOCAL SERVICE describing ticketing services, such as a ticket counter, online purchase, etc.; also associated with payment method and TYPE OF TICKET."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:TYPE_OF_ACCESSIBILITY_TOOLS a owl:Class ;
  rdfs:label "TYPE OF ACCESSIBILITY TOOLS"
  ; rdfs:comment "A classification of ACCESSIBILITY TOOLS used by or available from ASSISTANCE SERVICE (e.g., wheelchair, walking stick, audio navigator, visual navigator, etc.)"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MEETING_POINT_SERVICE a owl:Class ;
  rdfs:label "MEETING POINT SERVICE"
  ; rdfs:comment "Specialisation of CUSTOMER SERVICE describing a meeting point (provides characteristics such as description, label, etc.)."
  ; rdfs:subClassOf tm:CUSTOMER_SERVICE
  .

tm:COMPLAINTS_SERVICE a owl:Class ;
  rdfs:label "COMPLAINTS SERVICE"
  ; rdfs:comment "Specialisation of CUSTOMER SERVICE describing complaint services."
  ; rdfs:subClassOf tm:CUSTOMER_SERVICE
  .

tm:TYPE_OF_ASSISTANCE_SERVICE a owl:Class ;
  rdfs:label "TYPE OF ASSISTANCE SERVICE"
  ; rdfs:comment "A classification of an ASSISTANCE SERVICE (e.g., boarding assistance, onboard assistance, porterage, foreign language, sign language translation, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_STAFFING a owl:Class ;
  rdfs:label "TYPE OF STAFFING"
  ; rdfs:comment "A classification for the availability of the STAFF associated with an ASSISTANCE SERVICE (e.g., full time, part time)"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MONEY_SERVICE a owl:Class ;
  rdfs:label "MONEY SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing available money services (e.g., bureau de change, ATM, etc.)."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:TYPE_OF_CATERING_SERVICE a owl:Class ;
  rdfs:label "TYPE OF CATERING SERVICE"
  ; rdfs:comment "A classification of CATERING SERVICE (e.g., beverage vending machine, buffet, food vending machine, restaurant, snacks, trolley service, no beverages available, no food available)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_RETAIL_SERVICE a owl:Class ;
  rdfs:label "TYPE OF RETAIL SERVICE"
  ; rdfs:comment "A classification of RETAIL SERVICE (e.g., food, newspaper tobacco, health hygiene beauty, fashion accessories, bank finance insurance, tourism, photo booth)"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_COMMUNICATION_SERVICE a owl:Class ;
  rdfs:label "TYPE OF COMMUNICATION SERVICE"
  ; rdfs:comment "A classification of COMMUNICATION SERVICE (e.g., free wifi, public wifi, phone, mobile coverage, internet, video entertainment, audio entertainment, post box, post office, business services)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:CATERING_SERVICE a owl:Class ;
  rdfs:label "CATERING SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing available catering services."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:COMMUNICATION_SERVICE a owl:Class ;
  rdfs:label "COMMUNICATION SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing available communication services."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:TYPE_OF_MONEY_SERVICE a owl:Class ;
  rdfs:label "TYPE OF MONEY SERVICE"
  ; rdfs:comment "A classification of MONEY SERVICE (e.g., as cash machine, bank, insurance, bureau de change),"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_HIRE_SERVICE a owl:Class ;
  rdfs:label "TYPE OF HIRE SERVICE"
  ; rdfs:comment "A classification of HIRE SERVICEs (e.g., as car hire, motorcycle hire, cycle hire, recreational device hire)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:RETAIL_SERVICE a owl:Class ;
  rdfs:label "RETAIL SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing available retail services."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:HIRE_SERVICE a owl:Class ;
  rdfs:label "HIRE SERVICE"
  ; rdfs:comment "Specialisation of LOCAL SERVICE describing the types of available hire services (e.g., cycle hire, car hire)."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:CYCLE_STORAGE_EQUIPMENT a owl:Class ;
  rdfs:label "CYCLE STORAGE EQUIPMENT"
  ; rdfs:comment "A specialisation of PLACE EQUIPMENT describing cycle parking equipment."
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:VEHICLE_CHARGING_EQUIPMENT a owl:Class ;
  rdfs:label "VEHICLE CHARGING EQUIPMENT"
  ; rdfs:comment "Specialisation of PLACE EQUIPMENT for vehicle charging."
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:TYPE_OF_CYCLE_STORAGE_EQUIPMENT a owl:Class ;
  rdfs:label "TYPE OF CYCLE STORAGE EQUIPMENT"
  ; rdfs:comment "A classification of CYCLE STORAGE EQUIPMENT (e.g., racks, bars, railings, etc.)"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:PLACE_IN_SEQUENCE a owl:Class ;
  rdfs:label "PLACE IN SEQUENCE"
  ; rdfs:comment "Point traversed by a NAVIGATION PATH in sequence, connected by a PATH LINK to the next point; may be a PLACE, PATH JUNCTION or POINT."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:PATH_LINK_IN_SEQUENCE a owl:Class ;
  rdfs:label "PATH LINK IN SEQUENCE"
  ; rdfs:comment "A step of a NAVIGATION PATH indicating traversal of a particular PATH LINK as part of a recommended route.  The same PATH LINK may occur in different sequences in different NAVIGATION PATHs."
  ; rdfs:subClassOf tm:LINK_IN_LINK_SEQUENCE
  .

tm:GENERIC_PATH_LINK a owl:Class ;
  rdfs:label "GENERIC PATH LINK"
  ; rdfs:comment "A link between any two places that represents a step in a possible route for pedestrians, cyclists or other out of vehicle passengers.  NOTE: A place may be a fixed PLACE, such as a STOP PLACE, ACCESS SPACE or QUAY, BOARDING POSITION, POINTs OF INTEREST etc or PATH JUNCTIONs, or a place within a DECK, e.g., DECK, SPACE, DECK ENTRANCE, DECK PATH JUNCTION, etc."
  ; rdfs:subClassOf tm:LINK
  .

tm:PATH_LINK_END a owl:Class ;
  rdfs:label "PATH LINK END"
  ; rdfs:comment "Beginning or end for a GENERIC PATH LINK."
  .

tm:GENERIC_NAVIGATION_PATH a owl:Class ;
  rdfs:label "GENERIC NAVIGATION PATH"
  ; rdfs:comment "A designated path between two places; may include an ordered sequence of PATH LINKs."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:GENERIC_PATH_JUNCTION a owl:Class ;
  rdfs:label "GENERIC PATH JUNCTION"
  ; rdfs:comment "A designated point at which two or more GENERIC PATH LINKs may connect or branch."
  ; rdfs:subClassOf tm:POINT
  .

tm:CHECK_CONSTRAINT a owl:Class ;
  rdfs:label "CHECK CONSTRAINT"
  ; rdfs:comment "Characteristics of a process that takes place at a SITE COMPONENT, or an ONBOARD SPACE, such as check-in, security screening, ticket control or immigration, that may potentially incur a time penalty that should be allowed for when journey planning."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TYPE_OF_ACCESS_FEATURE a owl:Class ;
  rdfs:label "TYPE OF ACCESS FEATURE"
  ; rdfs:comment "A Classification of ACCESS FEATURE for CHECK CONSTRAINT (e.g., barrier, narrow entrance, confined space, queue management, etc.)"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_CONGESTION a owl:Class ;
  rdfs:label "TYPE OF CONGESTION"
  ; rdfs:comment "A typology of congestions resulting from CHECK CONSTRAINT (e.g., no waiting, queue, crowding, full)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_SERVICE_NATURE a owl:Class ;
  rdfs:label "TYPE OF SERVICE NATURE"
  ; rdfs:comment "A classification for service available for a CHECK CONSTRAINT (e.g., self-service machine, counter service)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CHECK_CONSTRAINT_THROUGHPUT a owl:Class ;
  rdfs:label "CHECK CONSTRAINT THROUGHPUT"
  ; rdfs:comment "Throughput of a CHECK CONSTRAINT: the number of passengers who can pass through it in a specified interval."
  .

tm:TYPE_OF_CHECK_CONSTRAINT a owl:Class ;
  rdfs:label "TYPE OF CHECK CONSTRAINT"
  ; rdfs:comment "A classification of CHECK CONSTRAINT (e.g., ticket collection, ticket purchase, baggage check-in, incoming customs, outgoing customs, tax refunds, etc.)"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:CHECK_CONSTRAINT_DELAY a owl:Class ;
  rdfs:label "CHECK CONSTRAINT DELAY"
  ; rdfs:comment "Time penalty associated with a CHECK CONSTRAINT."
  .

tm:PARKING_COMPONENT a owl:Class ;
  rdfs:label "PARKING COMPONENT"
  ; rdfs:comment "Generic COMPONENT of a PARKING (e.g., PARKING AREA or PARKING BAY)"
  ; rdfs:subClassOf tm:SITE_COMPONENT
  .

tm:PARKING a owl:Class ;
  rdfs:label "PARKING"
  ; rdfs:comment "Designated locations for leaving vehicles such as cars, motorcycles and bicycles."
  ; rdfs:subClassOf tm:SITE
  .

tm:PARKING_ENTRANCE_FOR_VEHICLES a owl:Class ;
  rdfs:label "PARKING ENTRANCE FOR VEHICLES"
  ; rdfs:comment "An entrance for vehicles to the PARKING from the road."
  ; rdfs:subClassOf tm:VEHICLE_ENTRANCE
  .

tm:PARKING_PASSENGER_ENTRANCE a owl:Class ;
  rdfs:label "PARKING PASSENGER ENTRANCE"
  ; rdfs:comment "A pedestrian, wheelchair or other out-of-vehicle-mode entrance to the PARKING."
  ; rdfs:subClassOf tm:ENTRANCE
  .

tm:PARKING_BAY a owl:Class ;
  rdfs:label "PARKING BAY"
  ; rdfs:comment "A place to park an individual vehicle."
  ; rdfs:subClassOf tm:PARKING_COMPONENT
  .

tm:PARKING_CAPACITY a owl:Class ;
  rdfs:label "PARKING CAPACITY"
  ; rdfs:comment "PARKING properties providing information about its CAPACITY."
  .

tm:PARKING_PROPERTIES a owl:Class ;
  rdfs:label "PARKING PROPERTIES"
  ; rdfs:comment "PARKING specific properties other than its capacity."
  .

tm:PARKING_AREA a owl:Class ;
  rdfs:label "PARKING AREA"
  ; rdfs:comment "A marked zone within a PARKING containing PARKING BAYs."
  ; rdfs:subClassOf tm:PARKING_COMPONENT
  .

tm:VEHICLE_QUAY_ALIGNMENT a owl:Class ;
  rdfs:label "VEHICLE QUAY ALIGNMENT"
  ; rdfs:comment "The alignment of a particular QUAY with a vehicle as the result of positioning a VEHICLE at a particular VEHICLE STOPPING PLACE."
  .

tm:VEHICLE_STOPPING_PLACE a owl:Class ;
  rdfs:label "VEHICLE STOPPING PLACE"
  ; rdfs:comment "A place on the vehicle track where vehicles stop in order for passengers to board or alight from a vehicle.  NOTE1: A vehicle track is located on the respective INFRASTRUCTURE LINK for the MODE (RAILWAY ELEMENT of rail network, ROAD ELEMENT of road network, etc.).  NOTE2: A VEHICLE STOPPING PLACE may be served by one or more QUAYs."
  ; rdfs:subClassOf tm:STOP_PLACE_COMPONENT
  .

tm:VEHICLE_POSITION_ALIGNMENT a owl:Class ;
  rdfs:label "VEHICLE POSITION ALIGNMENT"
  ; rdfs:comment "The alignment of a particular BOARDING POSITION with the entrance of a VEHICLE as the result of positioning the VEHICLE at a particular VEHICLE STOPPING PLACE."
  .

tm:VEHICLE_STOPPING_POSITION a owl:Class ;
  rdfs:label "VEHICLE STOPPING POSITION"
  ; rdfs:comment "The stopping position of a vehicle or one of its components as a Location.  NOTE1: May be specified as a ZONE corresponding to the bounding polygon of the vehicle, or one or more POINTs corresponding to parts of the vehicle such as a door.  NOTE2: If given as a single point, indicates the position for the door relative to an indicated side of the vehicle."
  ; rdfs:subClassOf tm:STOP_PLACE_COMPONENT
  .

tm:TYPE_OF_RELATION_TO_VEHICLE a owl:Class ;
  rdfs:label "TYPE OF RELATION TO VEHICLE"
  ; rdfs:comment "A classification of the way a VEHICLE STOPPING POSITION is used (e.g., front left, front right, back left, back right, driver left, driver right)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "TYPE OF JOURNEY PATTERN"
  ; rdfs:comment "A classification of JOURNEY PATTERNs used to distinguish categories of JOURNEY PATTERN other than SERVICE JOURNEY PATTERN and DEAD RUN PATTERN."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:POINT_IN_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "POINT IN JOURNEY PATTERN"
  ; rdfs:comment "A SCHEDULED STOP POINT or TIMING POINT in a JOURNEY PATTERN with its order in that JOURNEY PATTERN."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:JOURNEY_PATTERN a owl:Class ;
  rdfs:label "JOURNEY PATTERN"
  ; rdfs:comment "An ordered list of SCHEDULED STOP POINTs and TIMING POINTs on a single ROUTE, describing the pattern of working for public transport vehicles.  NOTE1: A JOURNEY PATTERN may pass through the same POINT more than once.  NOTE2: The first point of a JOURNEY PATTERN is the origin; the last point is the destination."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:DEAD_RUN_PATTERN a owl:Class ;
  rdfs:label "DEAD RUN PATTERN"
  ; rdfs:comment "A JOURNEY PATTERN to be used for DEAD RUNs."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN
  .

tm:TIMING_POINT_IN_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "TIMING POINT IN JOURNEY PATTERN"
  ; rdfs:comment "A POINT in a JOURNEY PATTERN which is a TIMING POINT."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:TIMING_LINK_IN_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "TIMING LINK IN JOURNEY PATTERN"
  ; rdfs:comment "The position of a TIMING LINK in a JOURNEY PATTERN.  NOTE: This entity is needed if a TIMING LINK is repeated in the same JOURNEY PATTERN, and separate information is to be stored about each iteration of the TIMING LINK."
  ; rdfs:subClassOf tm:LINK_IN_LINK_SEQUENCE
  .

tm:TIMING_POINT a owl:Class ;
  rdfs:label "TIMING POINT"
  ; rdfs:comment "A POINT against which the timing information necessary to build schedules may be recorded."
  ; rdfs:subClassOf tm:POINT
  .

tm:GROUP_OF_TIMING_LINKS a owl:Class ;
  rdfs:label "GROUP OF TIMING LINKS"
  ; rdfs:comment "A set of TIMING LINKs grouped together according to the similarity of TIME BANDs which are relevant to them.  NOTE: There may be a GROUP OF TIMING LINKS which covers all TIMING LINKs, for use when different GROUPs OF TIMING LINKS are not needed."
  ; rdfs:subClassOf tm:GROUP_OF_LINKS
  .

tm:TIMING_LINK a owl:Class ;
  rdfs:label "TIMING LINK"
  ; rdfs:comment "An ordered pair of TIMING POINTs for which run times may be recorded."
  ; rdfs:subClassOf tm:LINK
  .

tm:TIMING_PATTERN a owl:Class ;
  rdfs:label "TIMING PATTERN"
  ; rdfs:comment "The subset of a JOURNEY PATTERN made up only of TIMING POINTs IN JOURNEY PATTERN."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:DEFAULT_CONNECTION a owl:Class ;
  rdfs:label "DEFAULT CONNECTION"
  ; rdfs:comment "The physical (spatial) possibility for a passenger to change from one public transport vehicle to another to continue the trip.   NOTE1: It specifies default times to be used to change from one mode of transport to another at an area or national level as specified by a TOPOGRAPHIC PLACE, STOP AREA or SITE ELEMENT.   NOTE2: It may be further restricted to a specific MODE or OPERATOR or only apply in a particular direction of transfer, e.g., bus to rail may have a different time for rail to bus."
  ; rdfs:subClassOf tm:TRANSFER
  .

tm:DEFAULT_CONNECTION_END a owl:Class ;
  rdfs:label "DEFAULT CONNECTION END"
  ; rdfs:comment "One end of a DEFAULT CONNECTION."
  .

tm:SITE_CONNECTION_END a owl:Class ;
  rdfs:label "SITE CONNECTION END"
  ; rdfs:comment "One end of a SITE CONNECTION."
  ; rdfs:subClassOf tm:CONNECTION_END
  .

tm:SITE_CONNECTION a owl:Class ;
  rdfs:label "SITE CONNECTION"
  ; rdfs:comment "The physical (spatial) possibility for a passenger to change from one public transport vehicle to another to continue the trip, determined by physical locations, such as SITEs and/or its components and/or ENTRANCEs, in particular STOP PLACEs and/or its components.  NOTE: Different times may be necessary to cover the resulting distance, depending on the kind of passenger."
  ; rdfs:subClassOf tm:TRANSFER
  .

tm:CONNECTION_END a owl:Class ;
  rdfs:label "CONNECTION END"
  ; rdfs:comment "One end of a CONNECTION."
  .

tm:SERVICE_LINK a owl:Class ;
  rdfs:label "SERVICE LINK"
  ; rdfs:comment "A LINK between an ordered pair of SCHEDULED STOP POINTs."
  ; rdfs:subClassOf tm:LINK
  .

tm:SERVICE_PATTERN a owl:Class ;
  rdfs:label "SERVICE PATTERN"
  ; rdfs:comment "The subset of a JOURNEY PATTERN made up only of STOP POINTs IN JOURNEY PATTERN."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:SERVICE_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "SERVICE JOURNEY PATTERN"
  ; rdfs:comment "The JOURNEY PATTERN for a (passenger carrying) SERVICE JOURNEY."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN
  .

tm:SCHEDULED_STOP_POINT a owl:Class ;
  rdfs:label "SCHEDULED STOP POINT"
  ; rdfs:comment "A POINT where passengers can board or alight from vehicles."
  ; rdfs:subClassOf tm:POINT
  .

tm:CONNECTION a owl:Class ;
  rdfs:label "CONNECTION"
  ; rdfs:comment "The physical (spatial) possibility for a passenger to change from one public transport vehicle to another to continue the trip, determined by a pair of points which may be either SCHEDULED STOP POINTs or VEHICLE MEETING POINTs.  NOTE: Different times may be necessary to cover the link between these points, depending on the kind of passenger."
  ; rdfs:subClassOf tm:TRANSFER
  .

tm:STOP_AREA a owl:Class ;
  rdfs:label "STOP AREA"
  ; rdfs:comment "A group of SCHEDULED STOP POINTs close to each other."
  .

tm:TYPE_OF_STOP_POINT a owl:Class ;
  rdfs:label "TYPE OF STOP POINT"
  ; rdfs:comment "A classification of SCHEDULED STOP POINTs, used for instance to characterise the equipment to be installed at stops (post, shelter, seats, etc.)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:STOP_POINT_IN_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "STOP POINT IN JOURNEY PATTERN"
  ; rdfs:comment "A POINT in a JOURNEY PATTERN which is a SCHEDULED STOP POINT."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:COMMON_SECTION a owl:Class ;
  rdfs:label "COMMON SECTION"
  ; rdfs:comment "A part of a public transport network where the ROUTEs of several JOURNEY PATTERNs are going in parallel and where the synchronisation of SERVICE JOURNEYs may be planned and controlled with respect to commonly used LINKs and SCHEDULED STOP POINTs.  NOTE: COMMON SECTIONs are defined arbitrarily and need not cover the total lengths of topologically bundled sections."
  ; rdfs:subClassOf tm:SECTION
  .

tm:ROUTING_CONSTRAINT_ZONE a owl:Class ;
  rdfs:label "ROUTING CONSTRAINT ZONE"
  ; rdfs:comment "A ZONE specifying constraints on activity when a journey is routed through it.  NOTE: Examples of routing constraints are \"If you board in this ZONE, you can't alight in the same ZONE\"; \"If you board in this ZONE, you can alight only if the journey has passed through at least one STOP outside of the ZONE\"; \"Journey will go on only if there are passenger on board\", etc."
  ; rdfs:subClassOf tm:ZONE
  .

tm:TRANSFER_RESTRICTION a owl:Class ;
  rdfs:label "TRANSFER RESTRICTION"
  ; rdfs:comment "A constraint that can be applied on a CONNECTION or INTERCHANGE between two SCHEDULED STOP POINT, preventing or forbidding the passenger to use it."
  .

tm:SERVICE_EXCLUSION a owl:Class ;
  rdfs:label "SERVICE EXCLUSION"
  ; rdfs:comment "A constraint on the use of a service; the service, on this specific JOURNEY PATTERN (usually a FTS JOURNEY PATTERN) cannot operate when another (regular) service operates.  NOTE: This may occur only on subpart of the JOURNEY PATTERN, or only on one or some specific SCHEDULED STOP POINTS within the pattern."
  .

tm:TIME_DEMAND_TYPE a owl:Class ;
  rdfs:label "TIME DEMAND TYPE"
  ; rdfs:comment "An indicator of traffic conditions or other factors which may affect vehicle run or wait times.  NOTE: It may be entered directly by the scheduler or defined by the use of TIME BANDs."
  .

tm:TIME_DEMAND_TYPE_ASSIGNMENT a owl:Class ;
  rdfs:label "TIME DEMAND TYPE ASSIGNMENT"
  ; rdfs:comment "The assignment of a TIME DEMAND TYPE to a TIME BAND depending on the DAY TYPE and GROUP OF TIMING LINKS."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "STOP ASSIGNMENT"
  ; rdfs:comment "The allocation of a SCHEDULED STOP POINT to a specific STOP PLACE, and also possibly a QUAY."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:DYNAMIC_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "DYNAMIC STOP ASSIGNMENT"
  ; rdfs:comment "The association of a SCHEDULED STOP POINT with a specific STOP PLACE and also possibly a QUAY for a specific DATED VEHICLE JOURNEY.  NOTE: Overrides any PASSENGER STOP ASSIGNMENT and VEHICLE JOURNEY STOP ASSIGNMENT for the SCHEDULED STOP POINT."
  ; rdfs:subClassOf tm:VEHICLE_JOURNEY_STOP_ASSIGNMENT
  .

tm:PASSENGER_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "PASSENGER STOP ASSIGNMENT"
  ; rdfs:comment "The default allocation of a SCHEDULED STOP POINT to a specific STOP PLACE, and also possibly a QUAY."
  ; rdfs:subClassOf tm:STOP_ASSIGNMENT
  .

tm:PASSENGER_BOARDING_POSITION_ASSIGNMENT a owl:Class ;
  rdfs:label "PASSENGER BOARDING POSITION ASSIGNMENT"
  ; rdfs:comment "The association of a SCHEDULED STOP POINT with a specific STOP PLACE and also possibly a QUAY and BOARDING POSITION; may be general for all types of vehicle at that stop, or specific to a VEHICLE TYPE such as a TRAIN, in which case a TRAIN COMPONENT may also be specified to indicate a specific carriage."
  ; rdfs:subClassOf tm:STOP_ASSIGNMENT
  .

tm:NAVIGATION_PATH_ASSIGNMENT a owl:Class ;
  rdfs:label "NAVIGATION PATH ASSIGNMENT"
  ; rdfs:comment "The allocation of a NAVIGATION PATH to a specific STOP POINT ASSIGNMENT, for example to indicate the path to be taken to make a CONNECTION."
  ; rdfs:subClassOf tm:STOP_ASSIGNMENT
  .

tm:NOTICE_ASSIGNMENT a owl:Class ;
  rdfs:label "NOTICE ASSIGNMENT"
  ; rdfs:comment "The assignment of a NOTICE showing an exception in a JOURNEY PATTERN, a COMMON SECTION, or a VEHICLE JOURNEY, possibly specifying at which POINT IN JOURNEY PATTERN the validity of the NOTICE starts and ends respectively."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:PASSENGER_INFORMATION_EQUIPMENT a owl:Class ;
  rdfs:label "PASSENGER INFORMATION EQUIPMENT"
  ; rdfs:comment "A public transport information piece of equipment, as for instance terminals (on street, at information desks, telematic, etc.) or printed material (leaflets displayed at stops, booklets, etc.)."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:LOGICAL_DISPLAY a owl:Class ;
  rdfs:label "LOGICAL DISPLAY"
  ; rdfs:comment "A set of data that can be assembled for assignment to a physical PASSENGER INFORMATION EQUIPMENT or to a logical channel such as web or media; it is independent of any physical embodiment.   NOTE: A LOGICAL DISPLAY may have a set of DISPLAY ASSIGNMENTS each of which associates a JOURNEY PATTERN whose journeys are to be shown at the LOGICAL DISPLAY, usually in the context of a specific SCHEDULED STOP POINT."
  .

tm:TYPE_OF_PASSENGER_INFORMATION_EQUIPMENT a owl:Class ;
  rdfs:label "TYPE OF PASSENGER INFORMATION EQUIPMENT"
  ; rdfs:comment "A classification for PASSENGER INFORMATION EQUIPMENT (e.g., next stop indicator, stop announcements, passenger information facility)."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:DISPLAY_ASSIGNMENT a owl:Class ;
  rdfs:label "DISPLAY ASSIGNMENT"
  ; rdfs:comment "The assignment of one SCHEDULED STOP POINT and one JOURNEY PATTERN to a PASSENGER INFORMATION EQUIPMENT specifying that information on the SCHEDULED STOP POINT and the JOURNEY PATTERN will be provided (e.g., displayed, printed)."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:INFRASTRUCTURE_FRAME a owl:Class ;
  rdfs:label "INFRASTRUCTURE FRAME"
  ; rdfs:comment "A set of infrastructure network data (and other data logically related to these) to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:SERVICE_FRAME a owl:Class ;
  rdfs:label "SERVICE FRAME"
  ; rdfs:comment "A set of network service data (and other data logically related to these) to which the same VALIDITY CONDITIONs has been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:SITE_FRAME a owl:Class ;
  rdfs:label "SITE FRAME"
  ; rdfs:comment "A set of SITE data to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:TEMPLATE_VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "TEMPLATE VEHICLE JOURNEY"
  ; rdfs:comment "A repeating VEHICLE JOURNEY for which a frequency has been specified, either as a HEADWAY JOURNEY GROUP (e.g., every 20 minutes) or a RHYTHMICAL JOURNEY GROUP (e.g., at 15, 27 and 40 minutes past the hour).  NOTE: It may thus represent multiple journeys."
  ; rdfs:subClassOf tm:VEHICLE_JOURNEY
  .

tm:TRAIN_NUMBER a owl:Class ;
  rdfs:label "TRAIN NUMBER"
  ; rdfs:comment "A specification of codes assigned to particular VEHICLE JOURNEYs or JOURNEY PARTs when operated by TRAINs or COMPOUND TRAINs according to a functional purpose (passenger information, operation follow-up, etc.)."
  .

tm:DEAD_RUN a owl:Class ;
  rdfs:label "DEAD RUN"
  ; rdfs:comment "A non-service VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:VEHICLE_JOURNEY
  .

tm:TYPE_OF_PRODUCT_CATEGORY a owl:Class ;
  rdfs:label "TYPE OF PRODUCT CATEGORY"
  ; rdfs:comment "A classification for VEHICLE JOURNEYs to express some common properties of journeys for marketing and fare products."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "VEHICLE JOURNEY"
  ; rdfs:comment "The planned movement of a type of public transport vehicle (indicated by a VEHICLE TYPE, TRAIN or COMPOUND TRAIN) on a DAY TYPE from the start point to the end point of a JOURNEY PATTERN on a specified ROUTE.  NOTE: A DATED VEHICLE Journey uses a SERVICE CALENDAR to resolve the DAY TYPE for the VEHICLE JOURNEY into specific dates of operation."
  ; rdfs:subClassOf tm:JOURNEY
  .

tm:TYPE_OF_SERVICE a owl:Class ;
  rdfs:label "TYPE OF SERVICE"
  ; rdfs:comment "A classification for VEHICLE JOURNEYs, SPECIAL SERVICEs and DEAD RUNs to express some common properties of journeys to be taken into account in the scheduling and/or operations control process."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:JOURNEY a owl:Class ;
  rdfs:label "JOURNEY"
  ; rdfs:comment "Common properties of VEHICLE JOURNEYs and SPECIAL SERVICEs, e.g., their link to accounting characteristics."
  .

tm:GROUP_OF_SERVICES a owl:Class ;
  rdfs:label "GROUP OF SERVICES"
  ; rdfs:comment "A group of JOURNEYs, often known to its users by a name or a number."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:SERVICE_JOURNEY a owl:Class ;
  rdfs:label "SERVICE JOURNEY"
  ; rdfs:comment "A passenger carrying VEHICLE JOURNEY for one specified DAY TYPE.  NOTE: The pattern of working is in principle defined by a SERVICE JOURNEY PATTERN."
  ; rdfs:subClassOf tm:VEHICLE_JOURNEY
  .

tm:SPECIAL_SERVICE a owl:Class ;
  rdfs:label "SPECIAL SERVICE"
  ; rdfs:comment "A work of a vehicle that is not planned in a classical way, i.e., that is generally not based on VEHICLE JOURNEYs using JOURNEY PATTERNs, and that involves specific characteristics (such as specific access rights) and/or may be operated under specific circumstances."
  ; rdfs:subClassOf tm:JOURNEY
  .

tm:TEMPLATE_SERVICE_JOURNEY a owl:Class ;
  rdfs:label "TEMPLATE SERVICE JOURNEY"
  ; rdfs:comment "A passenger carrying TEMPLATE VEHICLE JOURNEY.  NOTE: It may represent multiple journeys."
  ; rdfs:subClassOf tm:SERVICE_JOURNEY
  ; rdfs:subClassOf tm:TEMPLATE_VEHICLE_JOURNEY
  .

tm:DEFAULT_SERVICE_JOURNEY_RUN_TIME a owl:Class ;
  rdfs:label "DEFAULT SERVICE JOURNEY RUN TIME"
  ; rdfs:comment "The default time taken to traverse a TIMING LINK during a SERVICE JOURNEY, for a specified TIME DEMAND TYPE.  NOTE: Can be superseded by a JOURNEY PATTERN RUN TIME or a VEHICLE JOURNEY RUN TIME."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:DEFAULT_DEAD_RUN_RUN_TIME a owl:Class ;
  rdfs:label "DEFAULT DEAD RUN RUN TIME"
  ; rdfs:comment "The default time taken to traverse a TIMING LINK during a DEAD RUN, for a specified TIME DEMAND TYPE.  NOTE: Can be superseded by a JOURNEY PATTERN RUN TIME or a VEHICLE JOURNEY RUN TIME."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:TURNAROUND_TIME_LIMIT a owl:Class ;
  rdfs:label "TURNAROUND TIME LIMIT"
  ; rdfs:comment "The maximum time for which a vehicle may be scheduled to wait at a particular TIMING POINT (often included in a TURN STATION) without being returned to a PARKING POINT.  NOTE1: Can be superseded by a DEAD RUN.  NOTE2: Optionally, a minimum time for a vehicle to turn its direction may also be recorded."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:VEHICLE_TYPE_PREFERENCE a owl:Class ;
  rdfs:label "VEHICLE TYPE PREFERENCE"
  ; rdfs:comment "The preference for the use of a particular VEHICLE TYPE for a SERVICE JOURNEY PATTERN, depending on the DAY TYPE and TIME DEMAND TYPE.  NOTE1: The rank of preferences must be recorded.   NOTE2: Different VEHICLE TYPEs may be given the same rank."
  .

tm:JOURNEY_PATTERN_LAYOVER a owl:Class ;
  rdfs:label "JOURNEY PATTERN LAYOVER"
  ; rdfs:comment "Time allowance at the end of each journey on a specified JOURNEY PATTERN, to allow for delays and for other purposes.   NOTE: This layover supersedes any global layover and can be superseded by a VEHICLE JOURNEY LAYOVER on a specific journey."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN_TIMING
  .

tm:JOURNEY_PATTERN_HEADWAY a owl:Class ;
  rdfs:label "JOURNEY PATTERN HEADWAY"
  ; rdfs:comment "Time interval between vehicles at a certain TIMING POINT for VEHICLE JOURNEYs running on a certain JOURNEY PATTERN.  NOTE1: Can be superseded by the VEHICLE JOURNEY HEADWAY on a specific journey.  NOTE2: This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN_TIMING
  .

tm:JOURNEY_PATTERN_RUN_TIME a owl:Class ;
  rdfs:label "JOURNEY PATTERN RUN TIME"
  ; rdfs:comment "The time taken to traverse a TIMING LINK in a particular JOURNEY PATTERN, for a specified TIME DEMAND TYPE.  NOTE: Supersedes the DEFAULT SERVICE JOURNEY RUN TIME and DEFAULT DEAD RUN RUN TIME but can be superseded by a VEHICLE JOURNEY RUN TIME on a specific journey."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN_TIMING
  .

tm:JOURNEY_PATTERN_WAIT_TIME a owl:Class ;
  rdfs:label "JOURNEY PATTERN WAIT TIME"
  ; rdfs:comment "The time a vehicle has to wait at a specific TIMING POINT IN JOURNEY PATTERN, for a specified TIME DEMAND TYPE.  NOTE: Can be superseded by a VEHICLE JOURNEY WAIT TIME on a specific journey."
  ; rdfs:subClassOf tm:JOURNEY_PATTERN_TIMING
  .

tm:VEHICLE_JOURNEY_LAYOVER a owl:Class ;
  rdfs:label "VEHICLE JOURNEY LAYOVER"
  ; rdfs:comment "A time allowance at the end of a specified VEHICLE JOURNEY.  NOTE: This time supersedes any global layover or JOURNEY PATTERN LAYOVER."
  ; rdfs:subClassOf tm:JOURNEY_LAYOVER
  .

tm:VEHICLE_JOURNEY_HEADWAY a owl:Class ;
  rdfs:label "VEHICLE JOURNEY HEADWAY"
  ; rdfs:comment "Time interval between vehicles at a certain TIMING POINT for a certain VEHICLE JOURNEY (to be understood as the duration between this and the previous VEHICLE JOURNEY).  NOTE1: Supersedes JOURNEY PATTERN HEADWAY.  NOTE2: This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."
  ; rdfs:subClassOf tm:JOURNEY_HEADWAY
  .

tm:VEHICLE_JOURNEY_WAIT_TIME a owl:Class ;
  rdfs:label "VEHICLE JOURNEY WAIT TIME"
  ; rdfs:comment "The time for a vehicle to wait at a particular TIMING POINT IN JOURNEY PATTERN on a specified VEHICLE JOURNEY.  NOTE: This wait time will override any applicable JOURNEY PATTERN WAIT TIME."
  ; rdfs:subClassOf tm:JOURNEY_WAIT_TIME
  .

tm:RHYTHMICAL_JOURNEY_GROUP a owl:Class ;
  rdfs:label "RHYTHMICAL JOURNEY GROUP"
  ; rdfs:comment "A group of VEHICLE JOURNEYS following the same JOURNEY PATTERN having the same \"rhythm\" every hour (for example, runs at xxh10, xxh25 and xxh45, etc.) between a specified start and end time."
  ; rdfs:subClassOf tm:JOURNEY_FREQUENCY_GROUP
  .

tm:HEADWAY_JOURNEY_GROUP a owl:Class ;
  rdfs:label "HEADWAY JOURNEY GROUP"
  ; rdfs:comment "A group of VEHICLE JOURNEYs following the same JOURNEY PATTERN having the same HEADWAY INTERVAL between a specified start and end time (for example, every 10 min).  NOTE: May be used to simplify the presentation of timetables."
  ; rdfs:subClassOf tm:JOURNEY_FREQUENCY_GROUP
  .

tm:HEADWAY_INTERVAL a owl:Class ;
  rdfs:label "HEADWAY INTERVAL"
  ; rdfs:comment "A time interval or a duration defining a headway period and characterising a HEADWAY JOURNEY GROUP (e.g., every 10 min, every 4-6 min)."
  .

tm:VEHICLE_JOURNEY_RUN_TIME a owl:Class ;
  rdfs:label "VEHICLE JOURNEY RUN TIME"
  ; rdfs:comment "The time taken to traverse a specified TIMING LINK IN JOURNEY PATTERN on a specified VEHICLE JOURNEY.  NOTE: This gives the most detailed control over times and supersedes the JOURNEY PATTERN RUN TIME, the DEFAULT SERVICE JOURNEY RUN TIME and the DEFAULT DEAD RUN RUN TIME."
  ; rdfs:subClassOf tm:JOURNEY_RUN_TIME
  .

tm:JOURNEY_FREQUENCY_GROUP a owl:Class ;
  rdfs:label "JOURNEY FREQUENCY GROUP"
  ; rdfs:comment "A group of JOURNEYs defined in order to describe special behaviour like frequency-based services or rhythmical services (for example, runs at xxh10, xxh25 and xxh45); this is especially useful for passenger information)."
  .

tm:DEFAULT_INTERCHANGE a owl:Class ;
  rdfs:label "DEFAULT INTERCHANGE"
  ; rdfs:comment "A quality parameter fixing the acceptable duration (standard and maximum) for an INTERCHANGE to be planned between two SCHEDULED STOP POINTs.  NOTE: This parameter will be used to control whether any two VEHICLE JOURNEYs serving those points may be in connection."
  .

tm:SERVICE_JOURNEY_INTERCHANGE a owl:Class ;
  rdfs:label "SERVICE JOURNEY INTERCHANGE"
  ; rdfs:comment "The scheduled possibility for transfer of passengers between two SERVICE JOURNEYs at the same or different SCHEDULED STOP POINTs."
  ; rdfs:subClassOf tm:INTERCHANGE
  .

tm:SERVICE_JOURNEY_PATTERN_INTERCHANGE a owl:Class ;
  rdfs:label "SERVICE JOURNEY PATTERN INTERCHANGE"
  ; rdfs:comment "A recognised/organised possibility for passengers to change public transport vehicles using two SCHEDULED STOP POINTs (which may be identical) on two particular SERVICE JOURNEY PATTERNs, including the maximum wait duration allowed and the standard duration to be aimed at.  NOTE1: Any specified durations override the DEFAULT INTERCHANGE durations.  NOTE2: Schedulers may use this entity for synchronisation of journeys."
  ; rdfs:subClassOf tm:INTERCHANGE
  .

tm:JOURNEY_MEETING a owl:Class ;
  rdfs:label "JOURNEY MEETING"
  ; rdfs:comment "A time constraint for one or several SERVICE JOURNEYs fixing interchanges between them and/or an external event (e.g., arrival or departure of a feeder line, opening time of the theatre, etc.)."
  .

tm:INTERCHANGE a owl:Class ;
  rdfs:label "INTERCHANGE"
  ; rdfs:comment "The scheduled possibility for transfer of passengers at the same or different SCHEDULED STOP POINTs."
  .

tm:INTERCHANGE_RULE a owl:Class ;
  rdfs:label "INTERCHANGE RULE"
  ; rdfs:comment "Conditions governing the possibility of interchanging between two SERVICE JOURNEYs, stopping at the same or different SCHEDULED STOP POINTs, where at least one of the two SERVICE JOURNEYs is indicated indirectly by a DIRECTION, LINE or VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:INTERCHANGE
  .

tm:INTERCHANGE_RULE_TIMING a owl:Class ;
  rdfs:label "INTERCHANGE RULE TIMING"
  ; rdfs:comment "Timings for an INTERCHANGE RULE for a given TIME DEMAND TYPE or TIME BAND."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:INTERCHANGE_RULE_PARAMETER a owl:Class ;
  rdfs:label "INTERCHANGE RULE PARAMETER"
  ; rdfs:comment "Assignment of parameters characterising an INTERCHANGE RULE."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:PURPOSE_OF_JOURNEY_PARTITION a owl:Class ;
  rdfs:label "PURPOSE OF JOURNEY PARTITION"
  ; rdfs:comment "An operational purpose changing within a JOURNEY PATTERN and with this subdividing the SERVICE JOURNEY into JOURNEY PARTs."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:COUPLED_JOURNEY a owl:Class ;
  rdfs:label "COUPLED JOURNEY"
  ; rdfs:comment "A journey where two or more VEHICLE JOURNEYs originally planned as separately timed journeys, are combined throughout their complete VEHICLE JOURNEYs, running instead as a single timed VEHICLE JOURNEY."
  .

tm:TYPE_OF_COUPLING a owl:Class ;
  rdfs:label "TYPE OF COUPLING"
  ; rdfs:comment "A classification for the functional reason for coupling of JOURNEY PARTs and BLOCK PARTs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:JOURNEY_PART a owl:Class ;
  rdfs:label "JOURNEY PART"
  ; rdfs:comment "A part of a VEHICLE JOURNEY created according to a specific functional purpose, for instance in situations when vehicle coupling or separating occurs."
  .

tm:JOURNEY_PART_COUPLE a owl:Class ;
  rdfs:label "JOURNEY PART COUPLE"
  ; rdfs:comment "Two or more JOURNEY PARTs of different VEHICLE JOURNEYs served simultaneously by a COMPOUND TRAIN.  NOTE: For trains, planned to run using a single train path (i.e., the infrastructure capacity needed to run a train between two places over a given time-period)"
  .

tm:TYPE_OF_FLEXIBLE_SERVICE a owl:Class ;
  rdfs:label "TYPE OF FLEXIBLE SERVICE"
  ; rdfs:comment "A characterisation denoting the type of flexibility, e.g., if it is a virtual line service, flexible service with main route, corridor service, fixed stop area-wide flexible service, free area-wide flexible service or a mixed types of flexible service types."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FLEXIBLE_SERVICE_PROPERTIES a owl:Class ;
  rdfs:label "FLEXIBLE SERVICE PROPERTIES"
  ; rdfs:comment "Flexibility characteristics of a SERVICE JOURNEY, e.g., cancelled unless ordered and/or timing may be adjusted at time of booking or even later for service optimisation purposes."
  .

tm:JOURNEY_TIMING a owl:Class ;
  rdfs:label "JOURNEY TIMING"
  ; rdfs:comment "Time-related information referring to journey timing whose value depends on the time of use and so can be associated with a TIME DEMAND TYPE, TIME BAND or OPERATIONAL CONTEXT."
  .

tm:JOURNEY_RUN_TIME a owl:Class ;
  rdfs:label "JOURNEY RUN TIME"
  ; rdfs:comment "The time taken to traverse a TIMING LINK on a specific VEHICLE JOURNEY or on VEHICLE JOURNEYs made using a specific JOURNEY PATTERN for a specified TIME DEMAND TYPE."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:JOURNEY_WAIT_TIME a owl:Class ;
  rdfs:label "JOURNEY WAIT TIME"
  ; rdfs:comment "The time a vehicle has to wait at a specific TIMING POINT IN JOURNEY PATTERN, for a specified TIME DEMAND TYPE.  NOTE: This wait time can be superseded by a VEHICLE JOURNEY WAIT TIME."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:JOURNEY_LAYOVER a owl:Class ;
  rdfs:label "JOURNEY LAYOVER"
  ; rdfs:comment "Time allowance at the end of each journey to allow for delays and for other purposes."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:JOURNEY_HEADWAY a owl:Class ;
  rdfs:label "JOURNEY HEADWAY"
  ; rdfs:comment "Time interval between vehicles at a certain TIMING POINT.  NOTE: This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."
  ; rdfs:subClassOf tm:JOURNEY_TIMING
  .

tm:JOURNEY_ACCOUNTING a owl:Class ;
  rdfs:label "JOURNEY ACCOUNTING"
  ; rdfs:comment "Parameters characterising VEHICLE JOURNEYs or SPECIAL SERVICEs used for accounting purposes in particular in contracts between ORGANISATIONs."
  .

tm:NORMAL_DATED_VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "NORMAL DATED VEHICLE JOURNEY"
  ; rdfs:comment "A DATED VEHICLE JOURNEY identical to a long-term planned VEHICLE JOURNEY, possibly updated according to short-term modifications of the PRODUCTION PLAN decided by the control staff."
  ; rdfs:subClassOf tm:DATED_VEHICLE_JOURNEY
  .

tm:DATED_VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "DATED VEHICLE JOURNEY"
  ; rdfs:comment "A particular journey of a vehicle on a particular OPERATING DAY including all modifications possibly decided by the control staff."
  .

tm:PASSING_TIME a owl:Class ;
  rdfs:label "PASSING TIME"
  ; rdfs:comment "Time data concerning public transport vehicles passing a particular POINT; e.g., arrival time, departure time, waiting time."
  .

tm:TARGET_PASSING_TIME a owl:Class ;
  rdfs:label "TARGET PASSING TIME"
  ; rdfs:comment "Time data about when a public transport vehicle should pass a particular POINT IN JOURNEY PATTERN on a particular DATED VEHICLE JOURNEY, in order to match the latest valid plan."
  ; rdfs:subClassOf tm:DATED_PASSING_TIME
  .

tm:DATED_PASSING_TIME a owl:Class ;
  rdfs:label "DATED PASSING TIME"
  ; rdfs:comment "A PASSING TIME on a particular OPERATING DAY."
  ; rdfs:subClassOf tm:PASSING_TIME
  .

tm:TIMETABLED_PASSING_TIME a owl:Class ;
  rdfs:label "TIMETABLED PASSING TIME"
  ; rdfs:comment "Long-term planned time data concerning public transport vehicles passing a particular POINT IN JOURNEY PATTERN on a specified VEHICLE JOURNEY for a certain DAY TYPE."
  ; rdfs:subClassOf tm:PASSING_TIME
  .

tm:BLOCK_PART a owl:Class ;
  rdfs:label "BLOCK PART"
  ; rdfs:comment "Part of a BLOCK corresponding to a specific JOURNEY PART of one of the VEHICLE JOURNEYs in a BLOCK."
  .

tm:VEHICLE_SERVICE_PART a owl:Class ;
  rdfs:label "VEHICLE SERVICE PART"
  ; rdfs:comment "A part of a VEHICLE SERVICE composed of one or more BLOCKs and limited by periods spent at the GARAGE managing the vehicle in question."
  .

tm:RELIEF_OPPORTUNITY a owl:Class ;
  rdfs:label "RELIEF OPPORTUNITY"
  ; rdfs:comment "A time in a BLOCK where a vehicle passes a RELIEF POINT.  NOTE: This opportunity may or may not be actually used for a relief."
  .

tm:BLOCK a owl:Class ;
  rdfs:label "BLOCK"
  ; rdfs:comment "The work required to be done by a vehicle from the time it leaves a PARKING POINT after parking until its next return to park at a PARKING POINT.   NOTE1: A TRAIN COMPOSITION is a VEHICLE.  NOTE2: Any subsequent departure from a PARKING POINT after parking marks the start of a new BLOCK."
  .

tm:NORMAL_DATED_BLOCK a owl:Class ;
  rdfs:label "NORMAL DATED BLOCK"
  ; rdfs:comment "A DATED BLOCK identical to a long-term planned BLOCK, possibly updated according to short-term modifications decided by the control staff."
  ; rdfs:subClassOf tm:DATED_BLOCK
  .

tm:COMPOUND_BLOCK a owl:Class ;
  rdfs:label "COMPOUND BLOCK"
  ; rdfs:comment "The work of a VEHICLE during the time it is coupled to another VEHICLE.   NOTE: A VEHICLE can be, for instance, a TRAIN COMPOSITION or a COMPOUND TRAIN COMPOSITION."
  .

tm:DATED_BLOCK a owl:Class ;
  rdfs:label "DATED BLOCK"
  ; rdfs:comment "The work of a vehicle on a particular OPERATING DAY from the time it leaves a PARKING POINT after parking until its next return to park at a PARKING POINT.  NOTE: A TRAIN COMPOSITION is a VEHICLE, so this may also be used for trains."
  .

tm:COURSE_OF_JOURNEYS a owl:Class ;
  rdfs:label "COURSE OF JOURNEYS"
  ; rdfs:comment "A part of a BLOCK composed of consecutive VEHICLE JOURNEYs defined for the same DAY TYPE, all operated on the same LINE."
  .

tm:VEHICLE_SERVICE a owl:Class ;
  rdfs:label "VEHICLE SERVICE"
  ; rdfs:comment "A work plan for a VEHICLE for a whole day, planned for a specific DAY TYPE."
  .

tm:TRAIN_COMPONENT_LABEL_ASSIGNMENT a owl:Class ;
  rdfs:label "TRAIN COMPONENT LABEL ASSIGNMENT"
  ; rdfs:comment "The allocation of an advertised designation (e.g., a coach number) to a TRAIN COMPONENT for all or part of a journey."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:VEHICLE_TYPE_STOP_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE TYPE STOP ASSIGNMENT"
  ; rdfs:comment "The allocation of a VEHICLE STOPPING POSITION of a VEHICLE TYPE for a particular VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:STOP_ASSIGNMENT
  .

tm:TIMETABLE_FRAME a owl:Class ;
  rdfs:label "TIMETABLE FRAME"
  ; rdfs:comment "A set of timetable data to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:VEHICLE_SCHEDULE_FRAME a owl:Class ;
  rdfs:label "VEHICLE SCHEDULE FRAME"
  ; rdfs:comment "A coherent set of BLOCKS, COMPOUND BLOCKs, COURSEs of JOURNEY and VEHICLE SCHEDULEs to which the same set of VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:TYPE_OF_VALUE a owl:Class ;
  rdfs:label "TYPE OF VALUE"
  ; rdfs:comment "An ENTITY that serves to classify another entry, using as a list of simple code values, each with a name."
  .

tm:ASSIGNMENT a owl:Class ;
  rdfs:label "ASSIGNMENT"
  ; rdfs:comment "The association of one or more other assigned ENTITies with a primary ENTITY in order to describe some characteristic of the 'assigned to' ENTITY; the assignment may itself also have attributes.  NOTE: There may be multiple assignments applying to the same entity in which case an order and / or VALIDITY CONDITIONs may apply in order to determine the current assignment to use."
  .

tm:GENERAL_SECTION a owl:Class ;
  rdfs:label "GENERAL SECTION"
  ; rdfs:comment "A specific ordered sequence of POINTs or LINKs."
  ; rdfs:subClassOf tm:SECTION
  .

tm:SECTION a owl:Class ;
  rdfs:label "SECTION"
  ; rdfs:comment "An ordered sequence of POINTs or LINKs."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:SECTION_IN_LINK_SEQUENCE a owl:Class ;
  rdfs:label "SECTION IN LINK SEQUENCE"
  ; rdfs:comment "A SECTION embedded in a LINK SEQUENCE.  NOTE: A LINK SEQUENCE can contain several SECTIONS (ordered)."
  .

tm:VIEW a owl:Class ;
  rdfs:label "VIEW"
  ; rdfs:comment "A VIEW assembles selected properties of one or more ENTITIEs into a separate named structure for read only use, usually to simplify an implementation, for example a CALL assembles POINT in JOURNEY PATTERN with PASSING TIMEs and other data describing a visit to an individual a STOP POINT by a SERVICE JOURNEY.  NOTE: A view may have a persistent identity and version, but all its attributes are derived through existing relationship to other ENTITIES and its data values can be considered as copies of the normalised data from which is derived."
  .

tm:ALTERNATIVE_TEXT a owl:Class ;
  rdfs:label "ALTERNATIVE TEXT"
  ; rdfs:comment "Alternative text for any textual attribute of an ENTITY."
  .

tm:CLASS_ATTRIBUTE a owl:Class ;
  rdfs:label "CLASS ATTRIBUTE"
  ; rdfs:comment "Any attribute of a class. (metalevel component)"
  .

tm:LOG_ENTRY a owl:Class ;
  rdfs:label "LOG ENTRY"
  ; rdfs:comment "A time-stamped record of an event or change of state."
  .

tm:LOG a owl:Class ;
  rdfs:label "LOG"
  ; rdfs:comment "An ordered collection of LOG ENTRies."
  .

tm:LOGGABLE_OBJECT a owl:Class ;
  rdfs:label "LOGGABLE OBJECT"
  ; rdfs:comment "An entity for which LOG ENTRies may be made."
  .

tm:EVENT a owl:Class ;
  rdfs:label "EVENT"
  ; rdfs:comment "Any time-stamped event recorded in the system, having some consequences on entities."
  .

tm:TYPE_OF_EVENT a owl:Class ;
  rdfs:label "TYPE OF EVENT"
  ; rdfs:comment "A classification of EVENTs (e.g., ALARMs, INCIDENTs) according to their cause or effect."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:GENERAL_EVENT a owl:Class ;
  rdfs:label "GENERAL EVENT"
  ; rdfs:comment "Concrete class for generic events."
  ; rdfs:subClassOf tm:EVENT
  .

tm:EMPLOYEE a owl:Class ;
  rdfs:label "EMPLOYEE"
  ; rdfs:comment "An employee of a public transport company."
  .

tm:TYPE_OF_QUALIFICATION a owl:Class ;
  rdfs:label "TYPE OF QUALIFICATION"
  ; rdfs:comment "A classification of a QUALIFICATION possessed by an EMPLOYEE."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:QUALIFICATION a owl:Class ;
  rdfs:label "QUALIFICATION"
  ; rdfs:comment "A specific knowledge or ability or experience, or a certified skill or education, which may be possessed by an EMPLOYEE and which may be necessary to work a DUTY."
  .

tm:MESSAGE_PART a owl:Class ;
  rdfs:label "MESSAGE PART"
  ; rdfs:comment "A partial or complete information adapted for a specific type of usage and type of media."
  ; rdfs:subClassOf tm:NOTICE
  .

tm:PUBLICATION_SCOPE a owl:Class ;
  rdfs:label "PUBLICATION SCOPE"
  ; rdfs:comment "An extent in which it is relevant to publish a MESSAGE expressed using entities such as LINEs, SCHEDULED STOP POINTs and VEHICLE JOURNEYs etc."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:PUBLICATION_DECISION a owl:Class ;
  rdfs:label "PUBLICATION DECISION"
  ; rdfs:comment "An approval or disapproval regulating if a MESSAGE can be published in a certain PUBLICATION SCOPE."
  .

tm:PUBLICATION_WINDOW a owl:Class ;
  rdfs:label "PUBLICATION WINDOW"
  ; rdfs:comment "A period during which the MESSAGE should be published."
  .

tm:MESSAGE a owl:Class ;
  rdfs:label "MESSAGE"
  ; rdfs:comment "A communicated information<font color=\"#3b3e41\">.</font>"
  .

tm:TYPE_OF_MESSAGE_PART_CONTENT a owl:Class ;
  rdfs:label "TYPE OF MESSAGE PART CONTENT"
  ; rdfs:comment "A classification of the content type, e.g., as header, summary, detail, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MESSAGE_PRIORITY a owl:Class ;
  rdfs:label "MESSAGE PRIORITY"
  ; rdfs:comment "An arbitrary rating of how a MESSAGE ranks in relation to other potentially conflicting MESSAGEs when presentation bandwidth is limited."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PUBLISHING_CHANNEL a owl:Class ;
  rdfs:label "PUBLISHING CHANNEL"
  ; rdfs:comment "Specifies through which channels a MESSAGE should be disseminated."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:PT_SCOPE a owl:Class ;
  rdfs:label "PT SCOPE"
  ; rdfs:comment "An extent consisting of public transport entities or combinations of entities such as OPERATORs, NETWORKs, LINEs, SCHEDULED STOP POINTs, STOP PLACEs, PLACEs, etc."
  ; rdfs:subClassOf tm:PUBLICATION_SCOPE
  .

tm:PUBLISHING_ACTION a owl:Class ;
  rdfs:label "PUBLISHING ACTION"
  ; rdfs:comment "A guidance to processing options such as through which channels a MESSAGE should be disseminated."
  .

tm:TYPE_OF_AUDIENCE a owl:Class ;
  rdfs:label "TYPE OF AUDIENCE"
  ; rdfs:comment "A classification of the categories a MESSAGE is intended for, e.g., staff or passengers."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_MESSAGE a owl:Class ;
  rdfs:label "TYPE OF MESSAGE"
  ; rdfs:comment "A classification of MESSAGEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ORGANISATION_ROLE a owl:Class ;
  rdfs:label "ORGANISATION ROLE"
  ; rdfs:comment "Generic corporate role to provide or manage transport services."
  ; rdfs:subClassOf tm:RESPONSIBILITY_ROLE
  .

tm:TRANSPORT_USER_ROLE a owl:Class ;
  rdfs:label "TRANSPORT USER ROLE"
  ; rdfs:comment "General user ROLE for consuming travel services, including information services."
  ; rdfs:subClassOf tm:RESPONSIBILITY_ROLE
  .

tm:EMPLOYEE_ROLE a owl:Class ;
  rdfs:label "EMPLOYEE ROLE"
  ; rdfs:comment "The EMPLOYEE ROLE is to work for an organisation providing any aspect of the travel services."
  ; rdfs:subClassOf tm:RESPONSIBILITY_ROLE
  .

tm:TRAVEL_ORGANISATION_ROLE a owl:Class ;
  rdfs:label "TRAVEL ORGANISATION ROLE"
  ; rdfs:comment "The role of an ORGANISATION in providing any kind of travel related service."
  ; rdfs:subClassOf tm:ORGANISATION_ROLE
  .

tm:TRAVEL_DOCUMENT_CONTROLLING_ORGANISATION_ROLE a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT CONTROLLING ORGANISATION ROLE"
  ; rdfs:comment "The role of an ORGANISATION to provide the service of checking the validity of passenger's travel documents to ensure they have sufficient access rights for the journey that they are making."
  ; rdfs:subClassOf tm:TRAVEL_ORGANISATION_ROLE
  .

tm:SERVICE_OPERATOR_ROLE a owl:Class ;
  rdfs:label "SERVICE OPERATOR ROLE"
  ; rdfs:comment "The role of an organisation that provides a service to the customer who uses a product - in particular the carrier role for public transport, but also possibly ancillary services such as catering, baggage handling, parking, etc."
  ; rdfs:subClassOf tm:TRAVEL_ORGANISATION_ROLE
  .

tm:CUSTOMER_SERVICE_PROVIDER_ROLE a owl:Class ;
  rdfs:label "CUSTOMER SERVICE PROVIDER ROLE"
  ; rdfs:comment "The role of an ORGANISATION to provide \"help line\" and similar retail and fulfilment support facilities for CUSTOMERs, including replacement of stolen or damaged tickets and assistance with the installation of applications."
  ; rdfs:subClassOf tm:TRAVEL_ORGANISATION_ROLE
  .

tm:TRAVEL_DOCUMENT_CONTROLLER_ROLE a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT CONTROLLER ROLE"
  ; rdfs:comment "The EMPLOYEE ROLE to check travel documents; often, but not necessarily, the same as a CONDUCTOR ROLE."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:DRIVER_ROLE a owl:Class ;
  rdfs:label "DRIVER ROLE"
  ; rdfs:comment "The EMPLOYEE ROLE of driving a VEHICLE."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:CUSTOMER_SERVICE_ROLE a owl:Class ;
  rdfs:label "CUSTOMER SERVICE ROLE"
  ; rdfs:comment "The EMPLOYEE ROLE of providing retail and assistance services through multiple channels, working for a CUSTOMER SERVICE PROVIDER."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:STATION_EMPLOYEE_ROLE a owl:Class ;
  rdfs:label "STATION EMPLOYEE ROLE"
  ; rdfs:comment "The role of providing services at a station or other interchange."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:CONDUCTOR_ROLE a owl:Class ;
  rdfs:label "CONDUCTOR ROLE"
  ; rdfs:comment "The EMPLOYEE ROLE of managing the on-board delivery of services and undertaking control and validation of TRAVEL DOCUMENTS."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:ADMINISTRATIVE_ORGANISATION_ROLE a owl:Class ;
  rdfs:label "ADMINISTRATIVE ORGANISATION ROLE"
  ; rdfs:comment "Any organisational role involving some aspect of the management of data or the use of data."
  ; rdfs:subClassOf tm:ORGANISATION_ROLE
  .

tm:REGISTRAR_ROLE a owl:Class ;
  rdfs:label "REGISTRAR ROLE"
  ; rdfs:comment "The ADMINISTRATIVE ORGANISATION ROLE of coordinating the issue of registration codes for entities such as stops, organisations, products, etc., so that they are unique.  NOTE: The Registrar may issue unique identifiers directly or devise rules for others to generate unique identifiers."
  ; rdfs:subClassOf tm:ADMINISTRATIVE_ORGANISATION_ROLE
  .

tm:SECURITY_MANAGER_ROLE a owl:Class ;
  rdfs:label "SECURITY MANAGER ROLE"
  ; rdfs:comment "The ORGANISATION ROLE of establishing and coordinating a security policy across the provider organisations, and of certifying and auditing of organisations, applications, etc., for their conformance to the security policy."
  ; rdfs:subClassOf tm:ADMINISTRATIVE_ORGANISATION_ROLE
  .

tm:DATA_COLLECTOR_ROLE a owl:Class ;
  rdfs:label "DATA COLLECTOR ROLE"
  ; rdfs:comment "The ORGANISATION ROLE of collecting and forwarding data between the various parties."
  ; rdfs:subClassOf tm:ADMINISTRATIVE_ORGANISATION_ROLE
  .

tm:TECHNOLOGY_ORGANISATION_ROLE a owl:Class ;
  rdfs:label "TECHNOLOGY ORGANISATION ROLE"
  ; rdfs:comment "The role of an ORGANISATION that provides some aspect of electronic fare or information services and products."
  ; rdfs:subClassOf tm:ORGANISATION_ROLE
  .

tm:TRAFFIC_INFORMATION_OFFICER_ROLE a owl:Class ;
  rdfs:label "TRAFFIC INFORMATION OFFICER ROLE"
  ; rdfs:comment "An employee role of providing PASSENGERs and CUSTOMERs with traffic information."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:SITUATION_AUTHOR_ROLE a owl:Class ;
  rdfs:label "SITUATION AUTHOR ROLE"
  ; rdfs:comment "A ROLE dedicated to entering or editing SITUATIONs into the system."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:PUBLICATION_APPROVER_ROLE a owl:Class ;
  rdfs:label "PUBLICATION APPROVER ROLE"
  ; rdfs:comment "A ROLE dedicated to decide if a MESSAGE fulfils relevant criteria to be published in a certain PUBLICATION SCOPE."
  ; rdfs:subClassOf tm:EMPLOYEE_ROLE
  .

tm:GENERAL_OBSERVER_ROLE a owl:Class ;
  rdfs:label "GENERAL OBSERVER ROLE"
  ; rdfs:comment "The general role of observing the passenger information"
  ; rdfs:subClassOf tm:TRANSPORT_USER_ROLE
  .

tm:SPECIFIC_OBSERVER_ROLE a owl:Class ;
  rdfs:label "SPECIFIC OBSERVER ROLE"
  ; rdfs:comment "The role of observing passenger information for the trip of a specific PASSENGER or GROUP OF PASSENGERs."
  ; rdfs:subClassOf tm:TRANSPORT_USER_ROLE
  .

tm:SECURITY_LISTING a owl:Class ;
  rdfs:label "SECURITY LISTING"
  ; rdfs:comment "The presence of an identified Entity on a SECURITY LIST."
  .

tm:TYPE_OF_SECURITY_LIST a owl:Class ;
  rdfs:label "TYPE OF SECURITY LIST"
  ; rdfs:comment "A classification of a SECURITY LIST."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SECURITY_LISTABLE a owl:Class ;
  rdfs:label "SECURITY LISTABLE"
  ; rdfs:comment "An entity capable of being placed on a SECURITY LIST."
  .

tm:WHITELIST a owl:Class ;
  rdfs:label "WHITELIST"
  ; rdfs:comment "A list of items (TRAVEL DOCUMENTs, CONTRACTs, etc.) explicitly approved for processing."
  ; rdfs:subClassOf tm:SECURITY_LIST
  .

tm:BLACKLIST a owl:Class ;
  rdfs:label "BLACKLIST"
  ; rdfs:comment "A list of items (TRAVEL DOCUMENTs, CONTRACTs, etc.) the validity of which has been cancelled temporarily or permanently, for a specific reason like loss of the document, technical malfunction, no credit on bank account, offences committed by the customer, etc."
  ; rdfs:subClassOf tm:SECURITY_LIST
  .

tm:SECURITY_LIST a owl:Class ;
  rdfs:label "SECURITY LIST"
  ; rdfs:comment "A list of items whose status is to be accepted or denied for a process such as purchase or validation."
  .

tm:TRANSFER_TIME a owl:Class ;
  rdfs:label "TRANSFER TIME"
  ; rdfs:comment "The time needed to make a TRANSFER given a specific ACCESSIBILITY ASSESSMENT."
  .

tm:DATED_JOURNEY_PART a owl:Class ;
  rdfs:label "DATED JOURNEY PART"
  ; rdfs:comment "A JOURNEY PART taking place on a particular OPERATING DAY."
  .

tm:DATED_SPECIAL_SERVICE a owl:Class ;
  rdfs:label "DATED SPECIAL SERVICE"
  ; rdfs:comment "A SPECIAL SERVICE taking place on a particular OPERATING DAY.  NOTE: It may derive from a planned SPECIAL SERVICE, or be only occasional."
  .

tm:EXTRA_DATED_VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "EXTRA DATED VEHICLE JOURNEY"
  ; rdfs:comment "A DATED VEHICLE JOURNEY added to the PRODUCTION PLAN in addition to the long term planned NORMAL DATED VEHICLE JOURNEYs."
  ; rdfs:subClassOf tm:DATED_VEHICLE_JOURNEY
  .

tm:DATED_VEHICLE_JOURNEY_INTERCHANGE a owl:Class ;
  rdfs:label "DATED VEHICLE JOURNEY INTERCHANGE"
  ; rdfs:comment "A VEHICLE JOURNEY INTERCHANGE between two DATED VEHICLE JOURNEYs.  NOTE: It could be created ad-hoc or be based on a planned interchange such as a SERVICE JOURNEY INTERCHANGE, a SERVICE JOURNEY PATTERN INTERCHANGE, or an INTERCHANGE RULE."
  .

tm:DATED_VEHICLE_SERVICE a owl:Class ;
  rdfs:label "DATED VEHICLE SERVICE"
  ; rdfs:comment "A VEHICLE SERVICE taking place on a particular OPERATING DAY."
  .

tm:DATED_VEHICLE_SERVICE_PART a owl:Class ;
  rdfs:label "DATED VEHICLE SERVICE PART"
  ; rdfs:comment "A VEHICLE SERVICE PART taking place on a particular OPERATING DAY."
  .

tm:ARRIVAL a owl:Class ;
  rdfs:label "ARRIVAL"
  ; rdfs:comment "A view that brings together data relating to the arrival to a POINT IN JOURNEY PATTERN in a VEHICLE JOURNEY or DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:CALL_PART
  .

tm:CALL_PART a owl:Class ;
  rdfs:label "CALL PART"
  ; rdfs:comment "A view that brings together data relating to the arrival to or the departure from a POINT IN JOURNEY PATTERN in a VEHICLE JOURNEY or DATED VEHICLE JOURNEY."
  .

tm:DEPARTURE a owl:Class ;
  rdfs:label "DEPARTURE"
  ; rdfs:comment "A view that brings together data relating to the departure from a POINT IN JOURNEY PATTERN in a VEHICLE JOURNEY or DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:CALL_PART
  .

tm:CALL a owl:Class ;
  rdfs:label "CALL"
  ; rdfs:comment "A view that brings together data relating to the individual visit to a POINT IN JOURNEY PATTERN in a VEHICLE JOURNEY or DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:VIEW
  .

tm:DATED_CALL a owl:Class ;
  rdfs:label "DATED CALL"
  ; rdfs:comment "A view that brings together data relating to the individual visit to a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:VIEW
  .

tm:DATED_ARRIVAL a owl:Class ;
  rdfs:label "DATED ARRIVAL"
  ; rdfs:comment "A view that brings together data relating to the arrival to a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:DATED_CALL_PART
  .

tm:DATED_CALL_PART a owl:Class ;
  rdfs:label "DATED CALL PART"
  ; rdfs:comment "A view that brings together data relating to the arrival to or the departure from a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  .

tm:DATED_DEPARTURE a owl:Class ;
  rdfs:label "DATED DEPARTURE"
  ; rdfs:comment "A view that brings together data relating to the departure from a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:DATED_CALL_PART
  .

tm:PRODUCTION_PLAN a owl:Class ;
  rdfs:label "PRODUCTION PLAN"
  ; rdfs:comment "A reference version of production activities (service journeys, dead runs, duties, etc.).  NOTE: CONTROL ACTIONs are described with reference to the PRODUCTION PLAN they amend."
  .

tm:LOGICAL_VEHICLE a owl:Class ;
  rdfs:label "LOGICAL VEHICLE"
  ; rdfs:comment "A theoretically available vehicle resource for an OPERATING DAY, foreseen to be monitored."
  .

tm:LOGICAL_DRIVER a owl:Class ;
  rdfs:label "LOGICAL DRIVER"
  ; rdfs:comment "A theoretically available driver resource for an OPERATING DAY, foreseen to be monitored."
  .

tm:VEHICLE_DETECTING_LOG_ENTRY a owl:Class ;
  rdfs:label "VEHICLE DETECTING LOG ENTRY"
  ; rdfs:comment "A record of detected raw real-time data that is recognized to be related with a certain VEHICLE."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:VEHICLE_DETECTING a owl:Class ;
  rdfs:label "VEHICLE DETECTING"
  ; rdfs:comment "An activity consisting in the identification of a vehicle at a certain time by a detection device and of collecting raw data, such as an absolute location of the vehicle."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:TYPE_OF_VEHICLE_DETECTING a owl:Class ;
  rdfs:label "TYPE OF VEHICLE DETECTING"
  ; rdfs:comment "A characterisation of the detection activity."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:DETECTED_OPERATION a owl:Class ;
  rdfs:label "DETECTED OPERATION"
  ; rdfs:comment "An actual data detected in a VEHICLE DETECTING event, e.g., detection of an actual vehicle coupling, detection of an INCIDENT or detection of an actual relief."
  .

tm:VEHICLE_MONITORING_LOG_ENTRY a owl:Class ;
  rdfs:label "VEHICLE MONITORING LOG ENTRY"
  ; rdfs:comment "A record of computed information describing some aspect of how a certain LOGICAL VEHICLE performs in relation to the latest operation plan based on comparing information from detection devices with operational data."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:MONITORED_SPECIAL_SERVICE a owl:Class ;
  rdfs:label "MONITORED SPECIAL SERVICE"
  ; rdfs:comment "A special service that is monitored as being operated by a LOGICAL VEHICLE."
  .

tm:IMPEDED_TIME a owl:Class ;
  rdfs:label "IMPEDED TIME"
  ; rdfs:comment "The difference between the impeded and non-impeded passage of a LINK.  NOTE: It consists of slow down time, waiting time, and accelerating time."
  .

tm:TYPE_OF_VEHICLE_MONITORING a owl:Class ;
  rdfs:label "TYPE OF VEHICLE MONITORING"
  ; rdfs:comment "The aspect (type of situation) addressed by the monitoring activity."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:MONITORED_VEHICLE_JOURNEY a owl:Class ;
  rdfs:label "MONITORED VEHICLE JOURNEY"
  ; rdfs:comment "A journey that is monitored as being operated by a LOGICAL VEHICLE.  NOTE: According to the monitoring system capabilities, a MONITORED VEHICLE JOURNEY may be related to a DATED VEHICLE JOURNEY, or only to a JOURNEY PATTERN."
  .

tm:VEHICLE_MONITORING a owl:Class ;
  rdfs:label "VEHICLE MONITORING"
  ; rdfs:comment "An activity consisting in the assignment, at a certain time, of operational data to a monitored LOGICAL VEHICLE (e.g., that the vehicle is operating a certain MONITORED VEHICLE JOURNEY or has passed at a certain OBSERVED PASSING TIME at a POINT)."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:MONITORED_OPERATION a owl:Class ;
  rdfs:label "MONITORED OPERATION"
  ; rdfs:comment "Operational data monitored in a VEHICLE MONITORING event (e.g., monitoring a LOGICAL VEHICLE, coupling to others, as operating a planned TRAIN BLOCK)."
  .

tm:OBSERVED_PASSING_TIME a owl:Class ;
  rdfs:label "OBSERVED PASSING TIME"
  ; rdfs:comment "The actual passing of a public transport vehicle at a pre-defined POINT during a MONITORED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:DATED_PASSING_TIME
  .

tm:ESTIMATED_PASSING_TIME a owl:Class ;
  rdfs:label "ESTIMATED PASSING TIME"
  ; rdfs:comment "A time data, calculated from the latest available input, about when a public transport vehicle will pass a particular POINT IN JOURNEY PATTERN on a specified DATED VEHICLE JOURNEY.  NOTE: Mainly used to inform passengers about expected times of arrival and/or departure, but may also be used for monitoring and re-planning."
  ; rdfs:subClassOf tm:DATED_PASSING_TIME
  .

tm:CONTROL_ACTION a owl:Class ;
  rdfs:label "CONTROL ACTION"
  ; rdfs:comment "An action resulting from a decision taken by the controller causing an amendment of the operation planned in the PRODUCTION PLAN."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:LOGICAL_VEHICLE_CANCELLATION a owl:Class ;
  rdfs:label "LOGICAL VEHICLE CANCELLATION"
  ; rdfs:comment "A CONTROL ACTION consisting in removing a LOGICAL VEHICLE from the production plan."
  ; rdfs:subClassOf tm:VEHICLE_CONTROL_ACTION
  .

tm:VEHICLE_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE ASSIGNMENT"
  ; rdfs:comment "The assignment, or the cancellation of an assignment, of a physical VEHICLE to a LOGICAL VEHICLE.  NOTE: This assignment may be overridden by a further assignment."
  ; rdfs:subClassOf tm:ASSIGNMENT
  ; rdfs:subClassOf tm:VEHICLE_CONTROL_ACTION
  .

tm:CHANGE_OF_VEHICLE a owl:Class ;
  rdfs:label "CHANGE OF VEHICLE"
  ; rdfs:comment "A CONTROL ACTION consisting in removing, at a certain point in time and space, all work assigned to a LOGICAL VEHICLE and of assigning it to another LOGICAL VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_CONTROL_ACTION
  .

tm:VEHICLE_CONTROL_ACTION a owl:Class ;
  rdfs:label "VEHICLE CONTROL ACTION"
  ; rdfs:comment "A CONTROL ACTION affecting the LOGICAL VEHICLE."
  ; rdfs:subClassOf tm:CONTROL_ACTION
  .

tm:VEHICLE_WORK_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE WORK ASSIGNMENT"
  ; rdfs:comment "The assignment, or the cancellation of an assignment, of a physical VEHICLE to a LOGICAL VEHICLE to some planned work, represented as DATED BLOCKs or as DATED VEHICLE JOURNEYs.  NOTE: This assignment may be overridden by a further assignment."
  ; rdfs:subClassOf tm:ASSIGNMENT
  ; rdfs:subClassOf tm:VEHICLE_CONTROL_ACTION
  .

tm:LOGICAL_VEHICLE_CREATION a owl:Class ;
  rdfs:label "LOGICAL VEHICLE CREATION"
  ; rdfs:comment "A CONTROL ACTION consisting in creating a completely new LOGICAL VEHICLE and assigning DATED VEHICLE JOURNEYs to the new LOGICAL VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_CONTROL_ACTION
  .

tm:CHANGE_OF_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "CHANGE OF JOURNEY PATTERN"
  ; rdfs:comment "A CONTROL ACTION consisting in assigning a new JOURNEY PATTERN (and the ROUTE supporting it) to a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:CHANGE_OF_JOURNEY_TIMING a owl:Class ;
  rdfs:label "CHANGE OF JOURNEY TIMING"
  ; rdfs:comment "A CONTROL ACTION consisting in changing one or several characteristics of a DATED VEHICLE JOURNEY, in particular the departure time of the journey."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:PARTIAL_JOURNEY_CANCELLATION a owl:Class ;
  rdfs:label "PARTIAL JOURNEY CANCELLATION"
  ; rdfs:comment "A CONTROL ACTION consisting in assigning a JOURNEY PATTERN that is a subset of the original JOURNEY PATTERN to a DATED VEHICLE JOURNEY; thus specifically expressing that a part of a DATED VEHICLE JOURNEY has been cancelled."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:JOURNEY_CANCELLATION a owl:Class ;
  rdfs:label "JOURNEY CANCELLATION"
  ; rdfs:comment "A CONTROL ACTION consisting in deleting a DATED VEHICLE JOURNEY from the latest valid plan."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:JOURNEY_CREATION a owl:Class ;
  rdfs:label "JOURNEY CREATION"
  ; rdfs:comment "A CONTROL ACTION consisting in adding a completely new DATED VEHICLE JOURNEY to the latest valid plan."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:ELEMENTARY_JOURNEY_CONTROL_ACTION a owl:Class ;
  rdfs:label "ELEMENTARY JOURNEY CONTROL ACTION"
  ; rdfs:comment "A non-composite CONTROL ACTION affecting DATED VEHICLE JOURNEYs."
  ; rdfs:subClassOf tm:CONTROL_ACTION
  .

tm:FLEXIBLE_JOURNEY_ACTIVATION a owl:Class ;
  rdfs:label "FLEXIBLE JOURNEY ACTIVATION"
  ; rdfs:comment "A CONTROL ACTION consisting in activating a DATED VEHICLE JOURNEY that has a booking pre-condition."
  ; rdfs:subClassOf tm:ELEMENTARY_JOURNEY_CONTROL_ACTION
  .

tm:DEPARTURE_LAG a owl:Class ;
  rdfs:label "DEPARTURE LAG"
  ; rdfs:comment "A CONTROL ACTION consisting of gradually shifting a set of departures at one POINT.  NOTE: It allows a change of the timetable without abrupt variations in the intervals."
  ; rdfs:subClassOf tm:COMPOSITE_JOURNEY_CONTROL_ACTION
  .

tm:RESPACING a owl:Class ;
  rdfs:label "RESPACING"
  ; rdfs:comment "A CONTROL ACTION to respace departure times at one POINT after a journey or a vehicle has been added or cancelled, in order to preserve the regularity of intervals."
  ; rdfs:subClassOf tm:COMPOSITE_JOURNEY_CONTROL_ACTION
  .

tm:COMPOSITE_JOURNEY_CONTROL_ACTION a owl:Class ;
  rdfs:label "COMPOSITE JOURNEY CONTROL ACTION"
  ; rdfs:comment "A CONTROL ACTION affecting a set of DATED VEHICLE JOURNEYs with a correlated set of adjustments."
  ; rdfs:subClassOf tm:CONTROL_ACTION
  .

tm:DEPARTURE_EXCHANGE a owl:Class ;
  rdfs:label "DEPARTURE EXCHANGE"
  ; rdfs:comment "A CONTROL ACTION consisting in permuting at one POINT the departure times of two or several DATED VEHICLE JOURNEYs."
  ; rdfs:subClassOf tm:COMPOSITE_JOURNEY_CONTROL_ACTION
  .

tm:RESORPTION a owl:Class ;
  rdfs:label "RESORPTION"
  ; rdfs:comment "A CONTROL ACTION consisting of progressively resorbing a delay on one DATED VEHICLE JOURNEY by rescheduling the departure times at one POINT of the following journeys.  NOTE: It is a way of maintaining regular intervals after a disturbance on a particular journey."
  ; rdfs:subClassOf tm:COMPOSITE_JOURNEY_CONTROL_ACTION
  .

tm:INTERCHANGE_CANCELLATION a owl:Class ;
  rdfs:label "INTERCHANGE CANCELLATION"
  ; rdfs:comment "A CONTROL ACTION consisting in deleting a DATED VEHICLE JOURNEY INTERCHANGE from the latest valid plan so that a distributor DATED VEHICLE JOURNEY no longer needs to wait for a feeder DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:INTERCHANGE_CONTROL_ACTION
  .

tm:INTERCHANGE_MODIFICATION a owl:Class ;
  rdfs:label "INTERCHANGE MODIFICATION"
  ; rdfs:comment "A CONTROL ACTION expressing that the duration a distributor DATED VEHICLE JOURNEY needs to wait for a feeder DATED VEHICLE JOURNEY in a DATED VEHICLE JOURNEY INTERCHANGE is changed or that a different DATED VEHICLE JOURNEY is to wait for the feeder."
  ; rdfs:subClassOf tm:INTERCHANGE_CONTROL_ACTION
  .

tm:INTERCHANGE_CREATION a owl:Class ;
  rdfs:label "INTERCHANGE CREATION"
  ; rdfs:comment "A CONTROL ACTION consisting in adding a completely new DATED VEHICLE JOURNEY INTERCHANGE between a feeder DATED VEHICLE JOURNEY and a distributor DATED VEHICLE JOURNEY to the latest valid plan."
  ; rdfs:subClassOf tm:INTERCHANGE_CONTROL_ACTION
  .

tm:INTERCHANGE_CONTROL_ACTION a owl:Class ;
  rdfs:label "INTERCHANGE CONTROL ACTION"
  ; rdfs:comment "A CONTROL ACTION affecting a DATED VEHICLE JOURNEY INTERCHANGE."
  ; rdfs:subClassOf tm:CONTROL_ACTION
  .

tm:OPERATIONAL_EVENT a owl:Class ;
  rdfs:label "OPERATIONAL EVENT"
  ; rdfs:comment "Any event affecting the public transport operation (production follow-up, management of information or the technical functioning), occurring at a certain time and that is recorded in the system.  NOTE: An OPERATIONAL EVENT is generally causing a CONTROL ACTION."
  ; rdfs:subClassOf tm:EVENT
  .

tm:ALARM a owl:Class ;
  rdfs:label "ALARM"
  ; rdfs:comment "An EVENT alerting the staff in charge of operations control on a probable dysfunction: operational threshold exceeded (e.g., delay), emergency call, failure, etc."
  ; rdfs:subClassOf tm:OPERATIONAL_EVENT
  .

tm:VEHICLE_INCIDENT a owl:Class ;
  rdfs:label "VEHICLE INCIDENT"
  ; rdfs:comment "An INCIDENT concerning LOGICAL VEHICLEs."
  ; rdfs:subClassOf tm:INCIDENT
  .

tm:FACILITY_OPERATIONAL_EVENT a owl:Class ;
  rdfs:label "FACILITY OPERATIONAL EVENT"
  ; rdfs:comment "An OPERATIONAL EVENT concerning a FACILITY."
  ; rdfs:subClassOf tm:OPERATIONAL_EVENT
  .

tm:SITE_OPERATIONAL_EVENT a owl:Class ;
  rdfs:label "SITE OPERATIONAL EVENT"
  ; rdfs:comment "An OPERATIONAL EVENT applying to a SITE."
  ; rdfs:subClassOf tm:OPERATIONAL_EVENT
  .

tm:DRIVER_INCIDENT a owl:Class ;
  rdfs:label "DRIVER INCIDENT"
  ; rdfs:comment "An INCIDENT concerning LOGICAL DRIVERs."
  ; rdfs:subClassOf tm:INCIDENT
  .

tm:INCIDENT a owl:Class ;
  rdfs:label "INCIDENT"
  ; rdfs:comment "An unforeseen EVENT influencing the operation of the network."
  ; rdfs:subClassOf tm:OPERATIONAL_EVENT
  .

tm:OPERATIONAL_MESSAGE a owl:Class ;
  rdfs:label "OPERATIONAL MESSAGE"
  ; rdfs:comment "An information exchange between an EMPLOYEE (e.g., a controller), a LOGICAL DRIVER or a LOGICAL VEHICLE, used to inform about a CONTROL ACTION or an EVENT."
  ; rdfs:subClassOf tm:MESSAGE
  .

tm:CALL_FOR_REPAIRS a owl:Class ;
  rdfs:label "CALL FOR REPAIRS"
  ; rdfs:comment "A MESSAGE of a controller sent to a GARAGE to ask for repair of a VEHICLE."
  ; rdfs:subClassOf tm:OPERATIONAL_MESSAGE
  .

tm:CALL_FOR_MEANS a owl:Class ;
  rdfs:label "CALL FOR MEANS"
  ; rdfs:comment "A MESSAGE of a controller sent to a PARKING POINT to ask for the activation of resources in stand-by."
  ; rdfs:subClassOf tm:OPERATIONAL_MESSAGE
  .

tm:SITUATION_SOURCE a owl:Class ;
  rdfs:label "SITUATION SOURCE"
  ; rdfs:comment "A description of the origin of the incident or deviation information."
  .

tm:SITUATION_REASON a owl:Class ;
  rdfs:label "SITUATION REASON"
  ; rdfs:comment "A classification of what caused the SITUATION."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_SITUATION_SOURCE a owl:Class ;
  rdfs:label "TYPE OF SITUATION SOURCE"
  ; rdfs:comment "A classification of the SITUATION SOURCE."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:SITUATION a owl:Class ;
  rdfs:label "SITUATION"
  ; rdfs:comment "An incident or deviation affecting traffic or travel circumstances."
  .

tm:RELATED_SITUATION a owl:Class ;
  rdfs:label "RELATED SITUATION"
  ; rdfs:comment "Association with another SITUATION, typically one&#160;&#160;that has a relationship of cause or effect or otherwise with the SITUATION.  NOTE: the nature of the relationship can be indicated by&#160;&#160;the TYPE OF SITUATION&#160;&#160;on the RELATED SITUATION."
  .

tm:SITUATION_CAUSE a owl:Class ;
  rdfs:label "SITUATION CAUSE"
  ; rdfs:comment "An event or set of events inducing a change in public transport or traffic operation."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:METHOD_OF_CAPTURE a owl:Class ;
  rdfs:label "METHOD OF CAPTURE"
  ; rdfs:comment "A classification of the method used to acquire knowledge of the deviation or incident."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DELAY a owl:Class ;
  rdfs:label "DELAY"
  ; rdfs:comment "A description of deviations from the public transport timetable."
  ; rdfs:subClassOf tm:PT_SITUATION_CONSEQUENCE
  .

tm:PT_SITUATION_MESSAGE a owl:Class ;
  rdfs:label "PT SITUATION MESSAGE"
  ; rdfs:comment "An information communicated concerning a certain PT SITUATION."
  ; rdfs:subClassOf tm:MESSAGE
  .

tm:CASUALTIES a owl:Class ;
  rdfs:label "CASUALTIES"
  ; rdfs:comment "A description of the number of persons that have been injured or died."
  ; rdfs:subClassOf tm:PT_SITUATION_CONSEQUENCE
  .

tm:PT_SITUATION_GENERAL_CONSEQUENCE a owl:Class ;
  rdfs:label "PT SITUATION GENERAL CONSEQUENCE"
  ; rdfs:comment "A parameter describing a general consequence of a PT SITUATION."
  ; rdfs:subClassOf tm:PT_SITUATION_CONSEQUENCE
  .

tm:EASEMENT a owl:Class ;
  rdfs:label "EASEMENT"
  ; rdfs:comment "A description of temporary (fare) exceptions allowed because of disruptions."
  ; rdfs:subClassOf tm:PT_SITUATION_CONSEQUENCE
  .

tm:PT_SITUATION_AFFECTED_SCOPE a owl:Class ;
  rdfs:label "PT SITUATION AFFECTED SCOPE"
  ; rdfs:comment "An extent directly involved in the PT SITUATION expressed using entities such as OPERATORs, NETWORKs, LINEs, SCHEDULED STOP POINTs, STOP PLACEs, PLACEs etc."
  ; rdfs:subClassOf tm:PT_SCOPE
  .

tm:PT_SITUATION_CONSEQUENCE_SCOPE a owl:Class ;
  rdfs:label "PT SITUATION CONSEQUENCE SCOPE"
  ; rdfs:comment "An extent impacted by the PT SITUATION CONSEQUENCE expressed using entities such as LINEs, SERVICE JOURNEYs etc."
  ; rdfs:subClassOf tm:PT_SCOPE
  .

tm:TYPE_OF_DELAY a owl:Class ;
  rdfs:label "TYPE OF DELAY"
  ; rdfs:comment "A classification of the delay."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PT_SITUATION_CONSEQUENCE a owl:Class ;
  rdfs:label "PT SITUATION CONSEQUENCE"
  ; rdfs:comment "A description of the consequences of the PT SITUATION, generally or in relation to involved or indirectly impacted public transport elements."
  .

tm:PT_SITUATION a owl:Class ;
  rdfs:label "PT SITUATION"
  ; rdfs:comment "An incident or deviation affecting the planned PT operation."
  ; rdfs:subClassOf tm:SITUATION
  .

tm:FACILITY_CONDITION a owl:Class ;
  rdfs:label "FACILITY CONDITION"
  ; rdfs:comment "A changed state of availability affecting a MONITORED FACILITY."
  .

tm:MONITORED_VEHICLE_JOURNEY_FACILITY a owl:Class ;
  rdfs:label "MONITORED VEHICLE JOURNEY FACILITY"
  ; rdfs:comment "A monitored named amenity or capability enhancing a VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:MONITORED_FACILITY
  .

tm:MONITORED_VEHICLE_EQUIPMENT_FACILITY a owl:Class ;
  rdfs:label "MONITORED VEHICLE EQUIPMENT FACILITY"
  ; rdfs:comment "A monitored named amenity or capability enabled by ACTUAL VEHICLE EQUIPMENT."
  ; rdfs:subClassOf tm:MONITORED_FACILITY
  .

tm:MONITORED_PLACE_EQUIPMENT_FACILITY a owl:Class ;
  rdfs:label "MONITORED PLACE EQUIPMENT FACILITY"
  ; rdfs:comment "A monitored named amenity or capability related to a PLACE EQUIPMENT."
  ; rdfs:subClassOf tm:MONITORED_FACILITY
  .

tm:MONITORED_JOURNEY_PART_FACILITY a owl:Class ;
  rdfs:label "MONITORED JOURNEY PART FACILITY"
  ; rdfs:comment "A monitored named amenity or capability enhancing a JOURNEY PART."
  ; rdfs:subClassOf tm:MONITORED_FACILITY
  .

tm:TYPE_OF_ACCESS_RIGHT_ASSIGNMENT a owl:Class ;
  rdfs:label "TYPE OF ACCESS RIGHT ASSIGNMENT"
  ; rdfs:comment "A classification of ACCESS RIGHT ASSIGNMENT to indicate the purpose of the assignment."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TRAVEL_DOCUMENT a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT"
  ; rdfs:comment "Group of elements concerned with temporal scope."
  .

tm:SALES_TRANSACTION a owl:Class ;
  rdfs:label "SALES TRANSACTION"
  ; rdfs:comment "A sale of a SALES OFFER PACKAGE"
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:CUSTOMER_PURCHASE_STATUS a owl:Class ;
  rdfs:label "CUSTOMER PURCHASE STATUS"
  ; rdfs:comment "A classification of possible statuses of CUSTOMER PURCHASE PACKAGE, e.g., booked, paid for, consumed."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:OFFERED_TRAVEL_SPECIFICATION a owl:Class ;
  rdfs:label "OFFERED TRAVEL SPECIFICATION"
  ; rdfs:comment "A set of parameters giving details of the offered consumption of access rights associated with a SALES PACKAGE OFFER or a CUSTOMER PURCHASE PACKAGE, (e.g., origin and destination of a travel, class of travel, etc.)."
  ; rdfs:subClassOf tm:TRAVEL_SPECIFICATION
  .

tm:TRAVEL_DOCUMENT_SECURITY_LISTING a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT SECURITY LISTING"
  ; rdfs:comment "The presence of a specific TRAVEL DOCUMENT on a SECURITY LIST."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:TRAVEL_SPECIFICATION a owl:Class ;
  rdfs:label "TRAVEL SPECIFICATION"
  ; rdfs:comment "A set of parameters giving details of an intended consumption of access rights by a TRANSPORT CUSTOMER (e.g., origin and destination of a travel, class of travel, etc.)."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:CUSTOMER_PURCHASE_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "CUSTOMER PURCHASE PARAMETER ASSIGNMENT"
  ; rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying detailed parameters corresponding to a particular CUSTOMER PURCHASE PACKAGE, chosen from those available for a given fare structure (e.g. the origin or destination zone in a zone-counting system)."
  ; rdfs:subClassOf tm:VALIDITY_PARAMETER_ASSIGNMENT
  .

tm:CUSTOMER_PURCHASE_PACKAGE a owl:Class ;
  rdfs:label "CUSTOMER PURCHASE PACKAGE"
  ; rdfs:comment "A purchase of a SALES OFFER PACKAGE by a TRANSPORT CUSTOMER, giving access rights corresponding to those of one or several FARE PRODUCTs materialised as one or several TRAVEL DOCUMENTs."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:CUSTOMER_PURCHASE_PACKAGE_PRICE a owl:Class ;
  rdfs:label "CUSTOMER PURCHASE PACKAGE PRICE"
  ; rdfs:comment "A specialisation of FARE PRICE that defines the price of a CUSTOMER PURCHASE PACKAGE."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:CUSTOMER_PURCHASE_PACKAGE_ELEMENT a owl:Class ;
  rdfs:label "CUSTOMER PURCHASE PACKAGE ELEMENT"
  ; rdfs:comment "A purchase of a SALES OFFER PACKAGE ELEMENT by a TRANSPORT CUSTOMER, with an indication of all selected parameters."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:CONTROL_RECORD a owl:Class ;
  rdfs:label "CONTROL RECORD"
  ; rdfs:comment "A LOG ENTRY recording general audit properties of a validation or control action."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:VALIDATED_ACCESS a owl:Class ;
  rdfs:label "VALIDATED ACCESS"
  ; rdfs:comment "A validated use of a VALIDABLE ELEMENT, composed of ACCESSED FARE STRUCTURE ELEMENTs."
  ; rdfs:subClassOf tm:CONTROL_RECORD
  .

tm:VALIDATION_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "VALIDATION PARAMETER ASSIGNMENT"
  ; rdfs:comment "An ACCESS RIGHT PARAMETER ASSIGNMENT relating a fare collection parameter to a VALIDATED ACCESS or one of its components."
  ; rdfs:subClassOf tm:ACCESS_RIGHT_PARAMETER_ASSIGNMENT
  .

tm:OFFENCE a owl:Class ;
  rdfs:label "OFFENCE"
  ; rdfs:comment "A log entry providing data on a violation of fare rules."
  ; rdfs:subClassOf tm:CONTROL_RECORD
  .

tm:VALIDATION_ENTRY a owl:Class ;
  rdfs:label "VALIDATION ENTRY"
  ; rdfs:comment "The result of the comparison between one or several CONTROL ENTRies and the theoretical access rights attached to the TRAVEL DOCUMENT controlled, validating the right to consume and possibly providing a DEBIT or one or more OFFENCEs."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:ACCESSED_FARE_STRUCTURE_ELEMENT a owl:Class ;
  rdfs:label "ACCESSED FARE STRUCTURE ELEMENT"
  ; rdfs:comment "A validated use of a FARE STRUCTURE ELEMENT, composed of CONTROLLED ACCESSes."
  .

tm:CONTROL_PASSENGER_TRIP_EVENT a owl:Class ;
  rdfs:label "CONTROL PASSENGER TRIP EVENT"
  ; rdfs:comment "The control of the consumption of access rights by the inspection of a TRAVEL DOCUMENT by a <font color=\"#0f0f0f\">travel document inspector</font>."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:PASSENGER_CHECK_IN_EVENT a owl:Class ;
  rdfs:label "PASSENGER CHECK IN EVENT"
  ; rdfs:comment "A passenger action to check in at the start of a trip."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:PASSENGER_WAY_POINT_EVENT a owl:Class ;
  rdfs:label "PASSENGER WAY POINT EVENT"
  ; rdfs:comment "A passenger action to check in at a way point along a trip."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:PASSENGER_TRAVEL_CONTROL_EVENT a owl:Class ;
  rdfs:label "PASSENGER TRAVEL CONTROL EVENT"
  ; rdfs:comment "An event concerned with validating or controlling a passengers use of the transport network."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:PASSENGER_ACTIVATE_TRIP_EVENT a owl:Class ;
  rdfs:label "PASSENGER ACTIVATE TRIP EVENT"
  ; rdfs:comment "A passenger action to initiate the consumption of access rights, usually at the start of a trip, for example by stamping a ticket at a validator device, or by an online interaction."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:PASSENGER_CHECK_OUT_EVENT a owl:Class ;
  rdfs:label "PASSENGER CHECK OUT EVENT"
  ; rdfs:comment "A passenger action to check out at the end of a trip."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_CONTROL_EVENT
  .

tm:PASSENGER_WAY_POINT_ENTRY a owl:Class ;
  rdfs:label "PASSENGER WAY POINT ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording a passenger checking in at a way point while in a trip so as to indicate travel by a specific itinerary."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:MONITORED_FACILITY a owl:Class ;
  rdfs:label "MONITORED FACILITY"
  ; rdfs:comment "A monitored FACILITY that may have different states of availability."
  .

tm:MONITORED_LOCAL_SERVICE_FACILITY a owl:Class ;
  rdfs:label "MONITORED LOCAL SERVICE FACILITY"
  ; rdfs:comment "A monitored named amenity or capability related to a LOCAL SERVICE."
  ; rdfs:subClassOf tm:MONITORED_FACILITY
  .

tm:ROUNDING_METHOD a owl:Class ;
  rdfs:label "ROUNDING METHOD"
  ; rdfs:comment "A classification of PRICING RULES."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:FARE_DAY_TYPE a owl:Class ;
  rdfs:label "FARE DAY TYPE"
  ; rdfs:comment "A type of day used in the fare collection domain, characterised by one or more properties which affect the definition of access rights and prices in the fare system."
  ; rdfs:subClassOf tm:DAY_TYPE
  .

tm:TYPE_OF_PRICING_RULE a owl:Class ;
  rdfs:label "TYPE OF PRICING RULE"
  ; rdfs:comment "A classification of a PRICING RULE."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:LIMITING_RULE a owl:Class ;
  rdfs:label "LIMITING RULE"
  ; rdfs:comment "A rule for limiting the results of a price calculation."
  ; rdfs:subClassOf tm:DISCOUNTING_RULE
  .

tm:ROUNDING_STEP a owl:Class ;
  rdfs:label "ROUNDING STEP"
  ; rdfs:comment "Parameters to determine the rounding value to be used for a given calculation result.  NOTE: If a rounding step table is used, any value equal to or larger than the step key and smaller that the next step key should be rounded to the value indicated for the step value."
  .

tm:PRICING_SERVICE a owl:Class ;
  rdfs:label "PRICING SERVICE"
  ; rdfs:comment "A web service used to provide prices dynamically at time of booking or purchase."
  .

tm:ROUNDING a owl:Class ;
  rdfs:label "ROUNDING"
  ; rdfs:comment "Parameters directing the rounding of values that are the result of calculations."
  .

tm:DISCOUNTING_RULE a owl:Class ;
  rdfs:label "DISCOUNTING RULE"
  ; rdfs:comment "A price calculation rule determined by a discount."
  ; rdfs:subClassOf tm:PRICING_RULE
  .

tm:PRICING_RULE a owl:Class ;
  rdfs:label "PRICING RULE"
  ; rdfs:comment "A rule used for the calculation of FARE PRICE, determined either by a set of parameters to be applied to a reference price or by a more complex algorithm.  NOTE: PRICING RULEs may be chained together."
  .

tm:PRICE_UNIT a owl:Class ;
  rdfs:label "PRICE UNIT"
  ; rdfs:comment "A unit to express prices: amount of currency, abstract fare unit, ticket unit or token etc."
  .

tm:PRICING_PARAMETER_SET a owl:Class ;
  rdfs:label "PRICING PARAMETER SET"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of parameters controlling pricing calculations.</font>"
  .

tm:MONTH_VALIDITY_OFFSET a owl:Class ;
  rdfs:label "MONTH VALIDITY OFFSET"
  ; rdfs:comment "Days before (negative) or after (positive) the start of the month that a product with a calendar period driven activation becomes valid."
  .

tm:PRICE_GROUP a owl:Class ;
  rdfs:label "PRICE GROUP"
  ; rdfs:comment "A grouping of prices, allowing the grouping of numerous possible consumption elements into a limited number of price references, or to apply grouped increase, in value or percentage."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:FARE_PRICE a owl:Class ;
  rdfs:label "FARE PRICE"
  ; rdfs:comment "Price features for a PRICEABLE OBJECT."
  .

tm:PRICEABLE_OBJECT a owl:Class ;
  rdfs:label "PRICEABLE OBJECT"
  ; rdfs:comment "An element which may have a FARE PRICE."
  .

tm:PARKING_CHARGE_BAND a owl:Class ;
  rdfs:label "PARKING CHARGE BAND"
  ; rdfs:comment "Parking charges that describe the cost of using a PARKING or PARKING AREA for a given period."
  ; rdfs:subClassOf tm:TIME_STRUCTURE_FACTOR
  .

tm:PARKING_PRICE a owl:Class ;
  rdfs:label "PARKING PRICE"
  ; rdfs:comment "A specialisation of FARE PRICE that defines the price of a PARKING CHARGE BAND."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:PARKING_TARIFF a owl:Class ;
  rdfs:label "PARKING TARIFF"
  ; rdfs:comment "A set of PARKING CHARGE BANDS that describe the cost of using a PARKING or PARKING AREA."
  .

tm:CELL a owl:Class ;
  rdfs:label "CELL"
  ; rdfs:comment "A unique individual combination of features within a FARE TABLE, used to associate a FARE PRICE with a fare element."
  .

tm:FARE_TABLE a owl:Class ;
  rdfs:label "FARE TABLE"
  ; rdfs:comment "A grouping of prices that may be associated with various fare elements such as the DISTANCE MATRIX ELEMENT, FARE STRUCTURE ELEMENT, GEOGRAPHICAL INTERVAL or GROUP OF ACCESS RIGHT PARAMETERs.  NOTE: Tables may be nested."
  .

tm:BORDER_POINT a owl:Class ;
  rdfs:label "BORDER POINT"
  ; rdfs:comment "A POINT on the network marking a boundary for the fare calculation.  NOTE: May or may not be a SCHEDULED STOP POINT."
  ; rdfs:subClassOf tm:TIMING_POINT
  .

tm:SERIES_CONSTRAINT a owl:Class ;
  rdfs:label "SERIES CONSTRAINT"
  ; rdfs:comment "An extension of a DISTANCE MATRIX ELEMENT (a cell of an origin-destination matrix for TARIFF ZONEs or SCHEDULED STOP POINTs) expressing a fare distance for the corresponding trip (value in km, number of fare units, etc.), constrained to specific routes.  NOTE: SERIES CONSTRAINTs are mainly used for rail fares."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:FARE_SCHEDULED_STOP_POINT a owl:Class ;
  rdfs:label "FARE SCHEDULED STOP POINT"
  ; rdfs:comment "A specialisation of SCHEDULED STOP POINT describing a stop with fare accounting and routing characteristics."
  ; rdfs:subClassOf tm:SCHEDULED_STOP_POINT
  .

tm:SERIES_CONSTRAINT_PRICE a owl:Class ;
  rdfs:label "SERIES CONSTRAINT PRICE"
  ; rdfs:comment "A set of all possible price features of a SERIES CONSTRAINT: default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TYPE_OF_SERIES_CONSTRAINT a owl:Class ;
  rdfs:label "TYPE OF SERIES CONSTRAINT"
  ; rdfs:comment "A classification of a SERIES CONSTRAINT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FARE_ZONE a owl:Class ;
  rdfs:label "FARE ZONE"
  ; rdfs:comment "A specialization of TARIFF ZONE to include FARE SECTIONs."
  ; rdfs:subClassOf tm:TARIFF_ZONE
  .

tm:TYPE_OF_ROUTING a owl:Class ;
  rdfs:label "TYPE OF ROUTING"
  ; rdfs:comment "A classification of the ROUTING, e.g., direct, indirect; may be used to choose pricing criteria."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:FARE_SECTION a owl:Class ;
  rdfs:label "FARE SECTION"
  ; rdfs:comment "A subdivision of a JOURNEY PATTERN consisting of consecutive POINTs IN JOURNEY PATTERN, used to define an element of the fare structure."
  ; rdfs:subClassOf tm:SECTION
  .

tm:FARE_POINT_IN_JOURNEY_PATTERN a owl:Class ;
  rdfs:label "FARE POINT IN JOURNEY PATTERN"
  ; rdfs:comment "A POINT IN JOURNEY PATTERN which represents the start or end of a FARE SECTION, or a point used to define a SERIES CONSTRAINT."
  ; rdfs:subClassOf tm:POINT_IN_JOURNEY_PATTERN
  .

tm:FARE_UNIT a owl:Class ;
  rdfs:label "FARE UNIT"
  ; rdfs:comment "A unit associated with a FARE STRUCTURE FACTOR."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:FARE_INTERVAL a owl:Class ;
  rdfs:label "FARE INTERVAL"
  ; rdfs:comment "An interval-based aspect of the fare structure."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:FARE_ELEMENT_IN_SEQUENCE a owl:Class ;
  rdfs:label "FARE ELEMENT IN SEQUENCE"
  ; rdfs:comment "A part of an access right, including its possible order in the sequence of elementary access rights."
  .

tm:FARE_STRUCTURE_FACTOR a owl:Class ;
  rdfs:label "FARE STRUCTURE FACTOR"
  ; rdfs:comment "A factor influencing access rights definition or calculation of prices."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:GEOGRAPHICAL_INTERVAL_PRICE a owl:Class ;
  rdfs:label "GEOGRAPHICAL INTERVAL PRICE"
  ; rdfs:comment "A set of all possible price features of a GEOGRAPHICAL INTERVAL: default total price, etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:GEOGRAPHICAL_INTERVAL a owl:Class ;
  rdfs:label "GEOGRAPHICAL INTERVAL"
  ; rdfs:comment "A geographical interval specifying access rights for the FARE STRUCTURE ELEMENTs within the range of this interval: 0-5 km, 4-6 zones etc."
  ; rdfs:subClassOf tm:FARE_INTERVAL
  .

tm:GEOGRAPHICAL_UNIT_PRICE a owl:Class ;
  rdfs:label "GEOGRAPHICAL UNIT PRICE"
  ; rdfs:comment "A set of all possible price features of a GEOGRAPHICAL UNIT: default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:GEOGRAPHICAL_STRUCTURE_FACTOR a owl:Class ;
  rdfs:label "GEOGRAPHICAL STRUCTURE FACTOR"
  ; rdfs:comment "The value of a GEOGRAPHICAL INTERVAL or a DISTANCE MATRIX ELEMENT expressed by a GEOGRAPHICAL UNIT."
  ; rdfs:subClassOf tm:FARE_STRUCTURE_FACTOR
  .

tm:GEOGRAPHICAL_UNIT a owl:Class ;
  rdfs:label "GEOGRAPHICAL UNIT"
  ; rdfs:comment "A unit for calculating geographical graduated fares."
  ; rdfs:subClassOf tm:FARE_UNIT
  .

tm:GROUP_OF_DISTANCE_MATRIX_ELEMENTS a owl:Class ;
  rdfs:label "GROUP OF DISTANCE MATRIX ELEMENTS"
  ; rdfs:comment "A grouping of DISTANCE MATRIX ELEMENTS.  NOTE: May be used to provide reusable sets of Origin / Destination pairs."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:DISTANCE_MATRIX_ELEMENT a owl:Class ;
  rdfs:label "DISTANCE MATRIX ELEMENT"
  ; rdfs:comment "A cell of an origin-destination matrix for TARIFF ZONEs or SCHEDULED STOP POINTs, expressing a fare distance for the corresponding trip: value in km, number of fare units etc."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:DISTANCE_MATRIX_ELEMENT_PRICE a owl:Class ;
  rdfs:label "DISTANCE MATRIX ELEMENT PRICE"
  ; rdfs:comment "A set of all possible price features of a DISTANCE MATRIX ELEMENT: default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TIME_UNIT_PRICE a owl:Class ;
  rdfs:label "TIME UNIT PRICE"
  ; rdfs:comment "A set of all possible price features of a TIME UNIT: default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TIME_STRUCTURE_FACTOR a owl:Class ;
  rdfs:label "TIME STRUCTURE FACTOR"
  ; rdfs:comment "The value of a TIME INTERVAL expressed by a TIME UNIT."
  ; rdfs:subClassOf tm:FARE_STRUCTURE_FACTOR
  .

tm:TIME_INTERVAL_PRICE a owl:Class ;
  rdfs:label "TIME INTERVAL PRICE"
  ; rdfs:comment "A set of all possible price features of a TIME INTERVAL, e.g., default total price, etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TIME_INTERVAL a owl:Class ;
  rdfs:label "TIME INTERVAL"
  ; rdfs:comment "A time-based interval specifying access rights for the FARE STRUCTURE ELEMENTs within the range of this interval: 0-1 hour, 1-3 days etc."
  ; rdfs:subClassOf tm:FARE_INTERVAL
  .

tm:TIME_UNIT a owl:Class ;
  rdfs:label "TIME UNIT"
  ; rdfs:comment "A unit for calculating time-based graduated fares."
  ; rdfs:subClassOf tm:FARE_UNIT
  .

tm:QUALITY_STRUCTURE_FACTOR a owl:Class ;
  rdfs:label "QUALITY STRUCTURE FACTOR"
  ; rdfs:comment "A factor influencing access rights definition or calculation of prices, based on the quality: traffic congestion threshold, early/late reservation etc."
  ; rdfs:subClassOf tm:FARE_STRUCTURE_FACTOR
  .

tm:FARE_DEMAND_FACTOR a owl:Class ;
  rdfs:label "FARE DEMAND FACTOR"
  ; rdfs:comment "A named set of parameters defining a period of travel with a given price, for example off peak, peak, super off peak, etc."
  ; rdfs:subClassOf tm:QUALITY_STRUCTURE_FACTOR
  .

tm:FARE_QUOTA_FACTOR a owl:Class ;
  rdfs:label "FARE QUOTA FACTOR"
  ; rdfs:comment "A named set of parameters defining a number of quota fares available of a given denomination."
  ; rdfs:subClassOf tm:QUALITY_STRUCTURE_FACTOR
  .

tm:QUALITY_STRUCTURE_FACTOR_PRICE a owl:Class ;
  rdfs:label "QUALITY STRUCTURE FACTOR PRICE"
  ; rdfs:comment "A set of all possible price features of a QUALITY STRUCTURE FACTOR, e.g., default total price, etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:START_TIME_AT_STOP_POINT a owl:Class ;
  rdfs:label "START TIME AT STOP POINT"
  ; rdfs:comment "A time at which a fare time band (peak, off peak, etc.) is deemed to begin for trips starting at a particular station."
  .

tm:FARE_STRUCTURE_ELEMENT a owl:Class ;
  rdfs:label "FARE STRUCTURE ELEMENT"
  ; rdfs:comment "A sequence or set of CONTROLLABLE ELEMENTs to which rules for limitation of access rights and calculation of prices (fare structure) are applied."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:TYPE_OF_TARIFF a owl:Class ;
  rdfs:label "TYPE OF TARIFF"
  ; rdfs:comment "A classification of TARIFFs to express the different classes of fares."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FARE_STRUCTURE_ELEMENT_PRICE a owl:Class ;
  rdfs:label "FARE STRUCTURE ELEMENT PRICE"
  ; rdfs:comment "A set of all possible price features of a FARE STRUCTURE ELEMENT: default total price, discount in value or percentage etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:FARE_STRUCTURE_ELEMENT_IN_SEQUENCE a owl:Class ;
  rdfs:label "FARE STRUCTURE ELEMENT IN SEQUENCE"
  ; rdfs:comment "A FARE STRUCTURE ELEMENT as a part of a VALIDABLE ELEMENT, including its possible order in the sequence of FARE STRUCTURE ELEMENTs forming that VALIDABLE ELEMENT, and its possible quantitative limitation."
  ; rdfs:subClassOf tm:FARE_ELEMENT_IN_SEQUENCE
  .

tm:TARIFF a owl:Class ;
  rdfs:label "TARIFF"
  ; rdfs:comment "A particular tariff, described by a combination of parameters."
  .

tm:CONTROLLABLE_ELEMENT_PRICE a owl:Class ;
  rdfs:label "CONTROLLABLE ELEMENT PRICE"
  ; rdfs:comment "A set of all possible price features of a CONTROLLABLE ELEMENT: default total price, discount in value or percentage etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:CONTROLLABLE_ELEMENT_IN_SEQUENCE a owl:Class ;
  rdfs:label "CONTROLLABLE ELEMENT IN SEQUENCE"
  ; rdfs:comment "A CONTROLLABLE ELEMENT as a part of a FARE STRUCTURE ELEMENT, including its possible order in the sequence of CONTROLLABLE ELEMENTs grouped together to form that FARE STRUCTURE ELEMENT, and its possible quantitative limitation."
  ; rdfs:subClassOf tm:FARE_ELEMENT_IN_SEQUENCE
  .

tm:VALIDABLE_ELEMENT_PRICE a owl:Class ;
  rdfs:label "VALIDABLE ELEMENT PRICE"
  ; rdfs:comment "A set of all possible price features of a VALIDABLE ELEMENT: default total price, discount in value or percentage etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:VALIDABLE_ELEMENT a owl:Class ;
  rdfs:label "VALIDABLE ELEMENT"
  ; rdfs:comment "A sequence or set of FARE STRUCTURE ELEMENTs, grouped together to be validated in one go."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:CONTROLLABLE_ELEMENT a owl:Class ;
  rdfs:label "CONTROLLABLE ELEMENT"
  ; rdfs:comment "The smallest controllable element of public transport consumption, all along which any VALIDITY PARAMETER ASSIGNMENT remains valid."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:CHARGING_MOMENT a owl:Class ;
  rdfs:label "CHARGING MOMENT"
  ; rdfs:comment "A classification of FARE PRODUCTs according to the payment method and the account location: pre-payment with cancellation (throw-away), pre-payment with debit on a value card, pre-payment without consumption registration (pass), post-payment etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:FARE_PRODUCT_PRICE a owl:Class ;
  rdfs:label "FARE PRODUCT PRICE"
  ; rdfs:comment "A set of all possible price features of a FARE PRODUCT: default total price, discount in value or percentage etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:SERVICE_ACCESS_RIGHT a owl:Class ;
  rdfs:label "SERVICE ACCESS RIGHT"
  ; rdfs:comment "An immaterial marketable element dedicated to accessing some services."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:TYPE_OF_FARE_PRODUCT a owl:Class ;
  rdfs:label "TYPE OF FARE PRODUCT"
  ; rdfs:comment "A classification of FARE PRODUCTs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FARE_PRODUCT a owl:Class ;
  rdfs:label "FARE PRODUCT"
  ; rdfs:comment "An immaterial marketable element (access rights, discount rights, etc.), specific to a CHARGING MOMENT."
  ; rdfs:subClassOf tm:SERVICE_ACCESS_RIGHT
  .

tm:THIRD_PARTY_PRODUCT a owl:Class ;
  rdfs:label "THIRD PARTY PRODUCT"
  ; rdfs:comment "A FARE PRODUCT that is marketed together with a Public Transport FARE PRODUCT."
  ; rdfs:subClassOf tm:FARE_PRODUCT
  .

tm:CAPPING_RULE a owl:Class ;
  rdfs:label "CAPPING RULE"
  ; rdfs:comment "A capping limit for a given time interval, where the capping is expressed by another product (for example, the London Oyster card fare, which charges for each journey at a reduced price until travel equivalent to a day pass for the mode of travel has been consumed)."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:USAGE_DISCOUNT_RIGHT a owl:Class ;
  rdfs:label "USAGE DISCOUNT RIGHT"
  ; rdfs:comment "A FARE PRODUCT allowing a customer to benefit from discounts when consuming VALIDABLE ELEMENTs."
  ; rdfs:subClassOf tm:FARE_PRODUCT
  .

tm:CAPPING_RULE_PRICE a owl:Class ;
  rdfs:label "CAPPING RULE PRICE"
  ; rdfs:comment "A set of all possible price features of a CAPPING RULE: default total price, discount in value or percentage etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:AMOUNT_OF_PRICE_UNIT a owl:Class ;
  rdfs:label "AMOUNT OF PRICE UNIT"
  ; rdfs:comment "A FARE PRODUCT consisting in a stored value of PRICE UNITs: an amount of money on an electronic purse, amount of units on a value card etc."
  ; rdfs:subClassOf tm:FARE_PRODUCT
  .

tm:ACCESS_RIGHT_IN_PRODUCT a owl:Class ;
  rdfs:label "ACCESS RIGHT IN PRODUCT"
  ; rdfs:comment "A VALIDABLE ELEMENT as a part of a PRE-ASSIGNED FARE PRODUCT, including its possible order in the set of all VALIDABLE ELEMENTs grouped together to define the access right assigned to that PRE-ASSIGNED FARE PRODUCT."
  ; rdfs:subClassOf tm:FARE_ELEMENT_IN_SEQUENCE
  .

tm:PRE_ASSIGNED_FARE_PRODUCT a owl:Class ;
  rdfs:label "PRE-ASSIGNED FARE PRODUCT"
  ; rdfs:comment "A FARE PRODUCT consisting of one or several VALIDABLE ELEMENTs, specific to a CHARGING <font color=\"#0f0f0f\">MOMENT</font>."
  ; rdfs:subClassOf tm:FARE_PRODUCT
  .

tm:ENTITLEMENT_PRODUCT a owl:Class ;
  rdfs:label "ENTITLEMENT PRODUCT"
  ; rdfs:comment "A precondition to access a service or to purchase a FARE PRODUCT issued by an organisation that may not be a PT operator (e.g., military card)."
  ; rdfs:subClassOf tm:SERVICE_ACCESS_RIGHT
  .

tm:SUPPLEMENT_PRODUCT a owl:Class ;
  rdfs:label "SUPPLEMENT PRODUCT"
  ; rdfs:comment "<font color=\"#0f0f0f\">A PRE-ASSIGNED FARE PRODUCT that will provide additional rights when used with (as a complement of) another (reserved seat, second to first class upgrade, etc.).</font>  <font color=\"#0f0f0f\">NOTE: SUPPLEMENT PRODUCT also usually has an additional price.</font>"
  ; rdfs:subClassOf tm:PRE_ASSIGNED_FARE_PRODUCT
  .

tm:SALE_DISCOUNT_RIGHT a owl:Class ;
  rdfs:label "SALE DISCOUNT RIGHT"
  ; rdfs:comment "A FARE PRODUCT allowing a customer to benefit from discounts when purchasing SALES OFFER PACKAGEs."
  ; rdfs:subClassOf tm:FARE_PRODUCT
  .

tm:CAPPED_DISCOUNT_RIGHT a owl:Class ;
  rdfs:label "CAPPED DISCOUNT RIGHT"
  ; rdfs:comment "A specialisation of SALE DISCOUNT RIGHT where the discount is expressed as a rule specifying a ceiling on the price for a given time interval (for example, the London Oyster card fare, which charges for each journey until travel equivalent to a day pass has been consumed after which further travel is free on that day)."
  ; rdfs:subClassOf tm:SALE_DISCOUNT_RIGHT
  .

tm:VALIDITY_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "VALIDITY PARAMETER ASSIGNMENT"
  ; rdfs:comment "An ACCESS RIGHT PARAMETER ASSIGNMENT relating a fare collection parameter to a theoretical FARE PRODUCT (or one of its components) or a SALES OFFER PACKAGE."
  ; rdfs:subClassOf tm:ACCESS_RIGHT_PARAMETER_ASSIGNMENT
  .

tm:GENERIC_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "GENERIC PARAMETER ASSIGNMENT"
  ; rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying generic access rights for a class of products (e.g., a time band limit - 7 to 10 a.m. - for trips made with a student pass)."
  ; rdfs:subClassOf tm:VALIDITY_PARAMETER_ASSIGNMENT
  .

tm:ACCESS_RIGHT_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "ACCESS RIGHT PARAMETER ASSIGNMENT"
  ; rdfs:comment "The assignment of a fare collection parameter (referring to geography, time, quality or usage) to an element of a fare system (access right, validated access, control mean, etc.)."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:SPECIFIC_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "SPECIFIC PARAMETER ASSIGNMENT"
  ; rdfs:comment "A VALIDITY PARAMETER ASSIGNMENT specifying practical parameters during a TRAVEL SPECIFICATION, within a given fare structure (e.g., the origin or destination zone in a zone-counting system)."
  ; rdfs:subClassOf tm:VALIDITY_PARAMETER_ASSIGNMENT
  .

tm:ORGANISATIONAL_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "ORGANISATIONAL VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to organisational issues<i>.</i>"
  .

tm:ROUTING_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "ROUTING VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER linked to a specific routing."
  .

tm:SERVICE_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "SERVICE VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to service characteristics (e.g., class)."
  .

tm:FARE_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "FARE VALIDITY PARAMETERS"
  ; rdfs:comment "A type of SCOPING VALIDITY PARAMETER linked to FARE PRODUCTS and/or their distribution."
  .

tm:SCOPING_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "SCOPING VALIDITY PARAMETERS"
  ; rdfs:comment "<font color=\"#0f0f0f\">A grouping of parameters travel guarantees and remedies offered </font>"
  .

tm:TEMPORAL_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "TEMPORAL VALIDITY PARAMETERS"
  ; rdfs:comment "<font color=\"#0f0f0f\">Grouping of time-related parameters defining the validity of access rights.</font>"
  .

tm:NETWORK_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "NETWORK VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to the network structure."
  .

tm:TYPE_OF_ACCESS_RIGHT_RESTRICTION a owl:Class ;
  rdfs:label "TYPE OF ACCESS RIGHT RESTRICTION"
  ; rdfs:comment "Classification of access right restrictions for specifying EASEMENTs."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:FARE_EASEMENT_PARAMETER_CHANGE a owl:Class ;
  rdfs:label "FARE EASEMENT PARAMETER CHANGE"
  ; rdfs:comment "A change to an access right because of a disruption to the network, expressed in terms of ACCESS RIGHT PARAMETERs."
  .

tm:FARE_EASEMENT a owl:Class ;
  rdfs:label "FARE EASEMENT"
  ; rdfs:comment "A change to the normal access rights given to PASSENGERS because of a disruption to the network, for example permission for metro ticket holders to use local rail and bus services if the metro is suspended."
  .

tm:USAGE_PARAMETER_PRICE a owl:Class ;
  rdfs:label "USAGE PARAMETER PRICE"
  ; rdfs:comment "A set of all possible price features of a USAGE PARAMETER: discount in value or percentage, etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TYPE_OF_USAGE_PARAMETER a owl:Class ;
  rdfs:label "TYPE OF USAGE PARAMETER"
  ; rdfs:comment "A classification of USAGE PARAMETERs to express the nature of parameters."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:USAGE_PARAMETER a owl:Class ;
  rdfs:label "USAGE PARAMETER"
  ; rdfs:comment "A parameter used to specify the use of a SALES OFFER PACKAGE or a FARE PRODUCT."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:ROUND_TRIP a owl:Class ;
  rdfs:label "ROUND TRIP"
  ; rdfs:comment "Parameters relating to single or return trip use of an access right."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:MINIMUM_STAY a owl:Class ;
  rdfs:label "MINIMUM STAY"
  ; rdfs:comment "Parameters expressing details of any minimum stay at the destination required to use an access right."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:USAGE_VALIDITY_PERIOD a owl:Class ;
  rdfs:label "USAGE VALIDITY PERIOD"
  ; rdfs:comment "A time limitation for validity of a FARE PRODUCT or a SALES OFFER PACKAGE.  NOTE: It may be composed of a standard duration (e.g. 3 days, 1 month) and/or fixed start/end dates and times."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_MINIMUM_STAY a owl:Class ;
  rdfs:label "TYPE OF MINIMUM STAY"
  ; rdfs:comment "A classification of MINIMUM STAY requirements."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FREQUENCY_OF_USE a owl:Class ;
  rdfs:label "FREQUENCY OF USE"
  ; rdfs:comment "The limits of usage frequency for a FARE PRODUCT (or one of its components) or a SALES OFFER PACKAGE during a specific VALIDITY PERIOD.  NOTE: There may be different prices depending on how often the right is consumed during the period."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_USAGE_VALIDITY_PERIOD a owl:Class ;
  rdfs:label "TYPE OF USAGE VALIDITY PERIOD"
  ; rdfs:comment "A classification of TYPE OF USAGE VALIDITY PERIOD."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_USAGE_TRIGGER a owl:Class ;
  rdfs:label "TYPE OF USAGE TRIGGER"
  ; rdfs:comment "A classification of the events that may start or end a USAGE VALIDITY PERIOD, for example, 'purchase' 'start of ride', 'end of ride', 'end of day', 'end of period', etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:STEP_LIMIT a owl:Class ;
  rdfs:label "STEP LIMIT"
  ; rdfs:comment "Geographical parameter limiting the access rights by counts of stops, sections or zones."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_FREQUENCY_OF_USE a owl:Class ;
  rdfs:label "TYPE OF FREQUENCY OF USE"
  ; rdfs:comment "A classification of FREQUENCY OF USE."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:INTERCHANGING a owl:Class ;
  rdfs:label "INTERCHANGING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters expressing limitations on making changes within a trip.</font>"
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:ROUTING a owl:Class ;
  rdfs:label "ROUTING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters expressing limitations on routing of an access right.</font>"
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:COMPANION_PROFILE a owl:Class ;
  rdfs:label "COMPANION PROFILE"
  ; rdfs:comment "The number and characteristics of the persons entitled to travel in a group or as companions to another USER PROFILE.   <b>  </b>"
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_CONCESSION a owl:Class ;
  rdfs:label "TYPE OF CONCESSION"
  ; rdfs:comment "A classification of USER PROFILE by type of person eligible to use it."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:GROUP_TICKET a owl:Class ;
  rdfs:label "GROUP TICKET"
  ; rdfs:comment "The number and characteristics of persons entitled to travel in addition to the holder of an access right."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:USER_PROFILE a owl:Class ;
  rdfs:label "USER PROFILE"
  ; rdfs:comment "Eligibility requirements to be met by the social profile of a passenger, based on age group, residence, employment status, sex, mobility requirements etc., used for allowing discounts: 18-40 years old, graduates, preferences, unemployed, women, etc."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:RESIDENTIAL_QUALIFICATION a owl:Class ;
  rdfs:label "RESIDENTIAL QUALIFICATION"
  ; rdfs:comment "A parameter providing an authorisation to consider a user as being characterised by a USER PROFILE."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:COMMERCIAL_PROFILE a owl:Class ;
  rdfs:label "COMMERCIAL PROFILE"
  ; rdfs:comment "A category of users depending on their commercial relations with the operator (frequency of use, amount of purchase etc.), often used for allowing discounts."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_PROOF_ACCEPTED a owl:Class ;
  rdfs:label "TYPE OF PROOF ACCEPTED"
  ; rdfs:comment "A classification of TYPEs of PROOF ACCEPTED to prove eligibility for a USER PROFILE."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ENTITLEMENT_REQUIRED a owl:Class ;
  rdfs:label "ENTITLEMENT REQUIRED"
  ; rdfs:comment "A parameter indicating whether a particular FARE PRODUCT requires an entitlement (e.g., ownership) to another product in order to buy or use an access right."
  ; rdfs:subClassOf tm:ENTITLEMENT
  .

tm:TYPE_OF_ENTITLEMENT a owl:Class ;
  rdfs:label "TYPE OF ENTITLEMENT"
  ; rdfs:comment "A classification of ENTITLEMENT by type of person eligible to use it."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ENTITLEMENT_GIVEN a owl:Class ;
  rdfs:label "ENTITLEMENT GIVEN"
  ; rdfs:comment "A parameter indicating whether a particular FARE PRODUCT provides an entitlement to buy or use an access right."
  ; rdfs:subClassOf tm:ENTITLEMENT
  .

tm:TYPE_OF_BAGGAGE_USE a owl:Class ;
  rdfs:label "TYPE OF BAGGAGE USE"
  ; rdfs:comment "A classification of how baggage may be used, for example, carry on, check in, luggage van, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:LUGGAGE_ALLOWANCE a owl:Class ;
  rdfs:label "LUGGAGE ALLOWANCE"
  ; rdfs:comment "The number and characteristics (weight, volume) of luggage that a holder of an access right is entitled to carry."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_BAGGAGE a owl:Class ;
  rdfs:label "TYPE OF BAGGAGE"
  ; rdfs:comment "A classification of TYPE OF BAGGAGE, e.g., suitcase, push-chair, bicycle, sports gear."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_RESERVATION_FEE a owl:Class ;
  rdfs:label "TYPE OF RESERVATION FEE"
  ; rdfs:comment "Classification of Fee basis for making a reservation, e.g., as per group, per leg, per change, per person, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CANCELLING a owl:Class ;
  rdfs:label "CANCELLING"
  ; rdfs:comment "A parameter giving conditions for cancelling of a booked access right."
  ; rdfs:subClassOf tm:BOOKING_POLICY
  .

tm:METHOD_OF_BOOKING a owl:Class ;
  rdfs:label "METHOD OF BOOKING"
  ; rdfs:comment "A method by which a booking or reservation may be made, e.g., on line, telephone, in person, etc.,"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PURCHASE_WINDOW a owl:Class ;
  rdfs:label "PURCHASE WINDOW"
  ; rdfs:comment "Period in which the FARE PRODUCT must be purchased."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:RESERVING a owl:Class ;
  rdfs:label "RESERVING"
  ; rdfs:comment "Parameters indicating whether the access right requires reservation."
  ; rdfs:subClassOf tm:BOOKING_POLICY
  .

tm:TYPE_OF_RESERVATION_NEEDED a owl:Class ;
  rdfs:label "TYPE OF RESERVATION NEEDED"
  ; rdfs:comment "Classification of type of reservation needed."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RESERVATION_MOMENT a owl:Class ;
  rdfs:label "RESERVATION MOMENT"
  ; rdfs:comment "A classification of the moment at which a booking or reservation may be made, e.g., in advance, at stop, on boarding, on board, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:BOOKING_POLICY a owl:Class ;
  rdfs:label "BOOKING POLICY"
  ; rdfs:comment "A parameter giving common conditions for booking or cancelling an access right."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_RESERVATION_RULE a owl:Class ;
  rdfs:label "TYPE OF RESERVATION RULE"
  ; rdfs:comment "Classification of requirement for making a reservation, e.g., required, required for groups."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RESELLING_MOMENT a owl:Class ;
  rdfs:label "RESELLING MOMENT"
  ; rdfs:comment "A classification of the moment at which a booking or reservation may be made, e.g., in advance, at stop, on boarding, on board, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:REPLACING a owl:Class ;
  rdfs:label "REPLACING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters indicating whether </font>and how the access right may be replaced."
  ; rdfs:subClassOf tm:RESELLING
  .

tm:REFUNDING a owl:Class ;
  rdfs:label "REFUNDING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters indicating whether </font>and how the FARE PRODUCT may be refunded."
  ; rdfs:subClassOf tm:RESELLING
  .

tm:TRANSFERABILITY a owl:Class ;
  rdfs:label "TRANSFERABILITY"
  ; rdfs:comment "The number and characteristics of persons entitled to use the public transport service instead of the original TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:RESELLING a owl:Class ;
  rdfs:label "RESELLING"
  ; rdfs:comment "Parameters indicating the common resale conditions (i.e., for exchange or refund) attached to a fare product."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_RESALE a owl:Class ;
  rdfs:label "TYPE OF RESALE"
  ; rdfs:comment "Classification of after sale condition."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:REBATING a owl:Class ;
  rdfs:label "REBATING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters indicating whether </font>and how a rebate may be offered for the product, for example if performance targets are not met or an inferior replacement service is run."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:EXCHANGING a owl:Class ;
  rdfs:label "EXCHANGING"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters indicating whether </font>and how an access right may be exchanged for another access right (for example, changing the date of a ticket)."
  ; rdfs:subClassOf tm:RESELLING
  .

tm:CHARGING_POLICY a owl:Class ;
  rdfs:label "CHARGING POLICY"
  ; rdfs:comment "A parameter governing minimum amount and credit allowed when consuming a FARE PRODUCT."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_RE_ENTRY_POLICY a owl:Class ;
  rdfs:label "TYPE OF RE-ENTRY POLICY"
  ; rdfs:comment "A classification of same station RE-ENTRY POLICY; how to treat a user reentering a station within a specified time limit (e.g., example, no charge, maximum fare, block, etc)."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:PENALTY_POLICY a owl:Class ;
  rdfs:label "PENALTY POLICY"
  ; rdfs:comment "Parameters determining a policy regarding different aspects of penalty charges, for example repeated entry at the same station, not having a ticket etc."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_PENALTY_POLICY a owl:Class ;
  rdfs:label "TYPE OF PENALTY POLICY"
  ; rdfs:comment "A classification of PENALTY POLICY, for example no fare, excess fare, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_CREDIT_POLICY a owl:Class ;
  rdfs:label "TYPE OF CREDIT POLICY"
  ; rdfs:comment "A classification of credit methods to apply when applying a CHARGING POLICY, for example to allow credit if a user runs out of funds on their account or stored value card."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:SALES_OFFER_PACKAGE_PRICE a owl:Class ;
  rdfs:label "SALES OFFER PACKAGE PRICE"
  ; rdfs:comment "A set of all possible price features of a SALES OFFER PACKAGE: default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:SALES_NOTICE_ASSIGNMENT a owl:Class ;
  rdfs:label "SALES NOTICE ASSIGNMENT"
  ; rdfs:comment "The assignment of a NOTICE to a SALES OFFER PACKAGE or a GROUP OF SALES OFFER PACKAGEs."
  ; rdfs:subClassOf tm:NOTICE_ASSIGNMENT
  .

tm:DISTRIBUTION_ASSIGNMENT a owl:Class ;
  rdfs:label "DISTRIBUTION ASSIGNMENT"
  ; rdfs:comment "An assignment of the COUNTRY and/or DISTRIBUTION CHANNEL through which a FARE PRODUCT may or may not be distributed."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TYPE_OF_SALES_OFFER_PACKAGE a owl:Class ;
  rdfs:label "TYPE OF SALES OFFER PACKAGE"
  ; rdfs:comment "A classification of SALES OFFER PACKAGEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SALES_OFFER_PACKAGE_SUBSTITUTION a owl:Class ;
  rdfs:label "SALES OFFER PACKAGE SUBSTITUTION"
  ; rdfs:comment "Information on the preferred substitution of a SALES OFFER PACKAGE by another (or a set of others) if a quota restricted FARE PRODUCT is no longer available."
  ; rdfs:subClassOf tm:SALES_OFFER_PACKAGE
  .

tm:SALES_OFFER_PACKAGE a owl:Class ;
  rdfs:label "SALES OFFER PACKAGE"
  ; rdfs:comment "A package to be sold as a whole, consisting of one or several FARE PRODUCTs materialised thanks to one or several TRAVEL DOCUMENTs."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:SALES_OFFER_PACKAGE_ELEMENT a owl:Class ;
  rdfs:label "SALES OFFER PACKAGE ELEMENT"
  ; rdfs:comment "The assignment of a FARE PRODUCT to a TYPE OF TRAVEL DOCUMENT in order to define a SALES OFFER PACKAGE, realised as a fixed assignment (printing, magnetic storage etc.) or by the possibility for the FARE PRODUCT to be reloaded on the TYPE OF TRAVEL DOCUMENT."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:TYPE_OF_DISTRIBUTION_ASSIGNMENT a owl:Class ;
  rdfs:label "TYPE OF DISTRIBUTION ASSIGNMENT"
  ; rdfs:comment "A classification of DISTRIBUTION ASSIGNMENTs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:GROUP_OF_SALES_OFFER_PACKAGES a owl:Class ;
  rdfs:label "GROUP OF SALES OFFER PACKAGES"
  ; rdfs:comment "A grouping of SALES OFFER PACKAGEs."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:GROUP_OF_DISTRIBUTION_CHANNELS a owl:Class ;
  rdfs:label "GROUP OF DISTRIBUTION CHANNELS"
  ; rdfs:comment "A grouping of DISTRIBUTION CHANNELs."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  .

tm:TYPE_OF_FULFILMENT_METHOD a owl:Class ;
  rdfs:label "TYPE OF FULFILMENT METHOD"
  ; rdfs:comment "A classification of FULFILMENT METHOD, e.g., as email, print from online, collect, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FULFILMENT_METHOD a owl:Class ;
  rdfs:label "FULFILMENT METHOD"
  ; rdfs:comment "The means by which the TRAVEL DOCUMENT is delivered to the TRANSPORT CUSTOMER, e.g., online, collection, etc."
  ; rdfs:subClassOf tm:PRICEABLE_OBJECT
  .

tm:TYPE_OF_DISTRIBUTION_CHANNEL a owl:Class ;
  rdfs:label "TYPE OF DISTRIBUTION CHANNEL"
  ; rdfs:comment "A classification of DISTRIBUTION CHANNEL, e.g., as operator ticket office, onboard, self-service, third-party agent, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_DISTRIBUTION_RIGHT a owl:Class ;
  rdfs:label "TYPE OF DISTRIBUTION RIGHT"
  ; rdfs:comment "A classification of distribution rights, e.g., to sell, to exchange, to accept, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DISTRIBUTION_CHANNEL a owl:Class ;
  rdfs:label "DISTRIBUTION CHANNEL"
  ; rdfs:comment "A type of outlet for selling of a FARE PRODUCT."
  .

tm:FULFILMENT_METHOD_PRICE a owl:Class ;
  rdfs:label "FULFILMENT METHOD PRICE"
  ; rdfs:comment "A set of all possible price features of a FULFILMENT METHOD default total price etc."
  ; rdfs:subClassOf tm:FARE_PRICE
  .

tm:TYPE_OF_MACHINE_READABILITY a owl:Class ;
  rdfs:label "TYPE OF MACHINE READABILITY"
  ; rdfs:comment "A classification of methods of machine reading travel documents, for example ocr, magnetic strip, NFC, etc"
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_TRAVEL_DOCUMENT a owl:Class ;
  rdfs:label "TYPE OF TRAVEL DOCUMENT"
  ; rdfs:comment "A classification of TRAVEL DOCUMENTs expressing their general functionalities and local functional characteristics specific to the operator."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SMARTCARD a owl:Class ;
  rdfs:label "SMARTCARD"
  ; rdfs:comment "A smart card with the necessary facilities (hardware and software) are) to host a MEDIUM APPLICATION INSTANCE and communicate with a control device."
  ; rdfs:subClassOf tm:MEDIUM_ACCESS_DEVICE
  .

tm:EMV_CARD a owl:Class ;
  rdfs:label "EMV CARD"
  ; rdfs:comment "A standardised payment card (Europay MasterCard, Visa etc.), capable of being used as token for an Account Based Ticketing system."
  ; rdfs:subClassOf tm:MEDIUM_ACCESS_DEVICE
  .

tm:MEDIUM_APPLICATION_INSTANCE a owl:Class ;
  rdfs:label "MEDIUM APPLICATION INSTANCE"
  ; rdfs:comment "Initialised instance of a software application that runs on a MEDIUM ACCESS DEVICE."
  .

tm:MEDIUM_ACCESS_DEVICE a owl:Class ;
  rdfs:label "MEDIUM ACCESS DEVICE"
  ; rdfs:comment "A component (mobile phone, smart card, etc.) with the necessary facilities (hardware and software) to host a MEDIUM APPLICATION INSTANCE and communicate with a control device."
  ; rdfs:subClassOf tm:PASSENGER_EQUIPMENT
  .

tm:MEDIUM_ACCESS_DEVICE_SECURITY_LISTING a owl:Class ;
  rdfs:label "MEDIUM ACCESS DEVICE SECURITY LISTING"
  ; rdfs:comment "The presence of a specific MEDIUM ACCESS DEVICE on a SECURITY LIST."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:TYPE_OF_MEDIUM_ACCESS_DEVICE a owl:Class ;
  rdfs:label "TYPE OF MEDIUM ACCESS DEVICE"
  ; rdfs:comment "A classification of MEDIUM ACCESS DEVICEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:MOBILE_DEVICE a owl:Class ;
  rdfs:label "MOBILE DEVICE"
  ; rdfs:comment "A mobile device (mobile phone, tablet, etc.) with the necessary facilities (hardware and software) to host a MEDIUM APPLICATION INSTANCE and communicate with a control device."
  ; rdfs:subClassOf tm:MEDIUM_ACCESS_DEVICE
  .

tm:CUSTOMER_SECURITY_LISTING a owl:Class ;
  rdfs:label "CUSTOMER SECURITY LISTING"
  ; rdfs:comment "The presence of a specific TRANSPORT CUSTOMER on a SECURITY LIST."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:FARE_CONTRACT_SECURITY_LISTING a owl:Class ;
  rdfs:label "FARE CONTRACT SECURITY LISTING"
  ; rdfs:comment "The presence of a specific FARE CONTRACT on a SECURITY LIST.  ."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:TYPE_OF_CUSTOMER_ACCOUNT a owl:Class ;
  rdfs:label "TYPE OF CUSTOMER ACCOUNT"
  ; rdfs:comment "A classification of CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FARE_CONTRACT_STATUS a owl:Class ;
  rdfs:label "FARE CONTRACT STATUS"
  ; rdfs:comment "A classification of possible status of a CUSTOMER ACCOUNT, e.g., active, suspended, archived, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:CUSTOMER_ACCOUNT_SECURITY_LISTING a owl:Class ;
  rdfs:label "CUSTOMER ACCOUNT SECURITY LISTING"
  ; rdfs:comment "The presence of a specific CUSTOMER ACCOUNT on a SECURITY LIST."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:FARE_CONTRACT_ENTRY a owl:Class ;
  rdfs:label "FARE CONTRACT ENTRY"
  ; rdfs:comment "A LOG ENTRY associated with a FARE CONTRACT."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:TYPE_OF_FARE_CONTRACT_ENTRY a owl:Class ;
  rdfs:label "TYPE OF FARE CONTRACT ENTRY"
  ; rdfs:comment "A classification of FARE CONTRACT ENTRY."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:CUSTOMER_ACCOUNT a owl:Class ;
  rdfs:label "CUSTOMER ACCOUNT"
  ; rdfs:comment "A registration of the TRANSPORT CUSTOMER with an ACCOUNT PROVIDER to obtain travel services."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:FARE_CONTRACT a owl:Class ;
  rdfs:label "FARE CONTRACT"
  ; rdfs:comment "A contract with a particular (but possibly anonymous) customer, ruling the consumption of transport services (and joint services).  NOTE: A FARE CONTRACT may be designed for a fixed SALES OFFER PACKAGE (e.g., ticket) or to allow successive purchases of SALES OFFER PACKAGEs."
  ; rdfs:subClassOf tm:LOGGABLE_OBJECT
  .

tm:TRANSPORT_CUSTOMER a owl:Class ;
  rdfs:label "TRANSPORT CUSTOMER"
  ; rdfs:comment "A specific person or organisation involved in a fare process.  NOTE: There may be a FARE CONTRACT between the TRANSPORT CUSTOMER and the OPERATOR or the AUTHORITY ruling the consumption of services."
  .

tm:TYPE_OF_FARE_CONTRACT a owl:Class ;
  rdfs:label "TYPE OF FARE CONTRACT"
  ; rdfs:comment "A classification of FARE CONTRACT."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:CUSTOMER_ELIGIBILITY a owl:Class ;
  rdfs:label "CUSTOMER ELIGIBILITY"
  ; rdfs:comment "A parameter indicating whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific validity parameter. This may be subject to a particular VALIDITY CONDITION."
  .

tm:USER_PROFILE_ELIGIBILITY a owl:Class ;
  rdfs:label "USER PROFILE ELIGIBILITY"
  ; rdfs:comment "Whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT with a specific USER PROFILE as a validity parameter."
  ; rdfs:subClassOf tm:CUSTOMER_ELIGIBILITY
  .

tm:COMMERCIAL_PROFILE_ELIGIBILITY a owl:Class ;
  rdfs:label "COMMERCIAL PROFILE ELIGIBILITY"
  ; rdfs:comment "A parameter indicating whether a specific TRANSPORT CUSTOMER is eligible for a FARE PRODUCT linked to a specific COMMERCIAL PROFILE."
  ; rdfs:subClassOf tm:CUSTOMER_ELIGIBILITY
  .

tm:RESIDENTIAL_ELIGIBILITY a owl:Class ;
  rdfs:label "RESIDENTIAL ELIGIBILITY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Parameters indicating whether a specific TRANSPORT CUSTOMER is eligible for an access right with a specific RESIDENTIAL PROFILE as a validity parameter.</font>"
  ; rdfs:subClassOf tm:CUSTOMER_ELIGIBILITY
  .

tm:CUSTOMER_PAYMENT_MEANS a owl:Class ;
  rdfs:label "CUSTOMER PAYMENT MEANS"
  ; rdfs:comment "A registered means with which a TRANSPORT CUSTOMER wishes to make payments for a CUSTOMER ACCOUNT, e.g., by nominated EMV CARD."
  .

tm:RETAIL_DEVICE a owl:Class ;
  rdfs:label "RETAIL DEVICE"
  ; rdfs:comment "<font color=\"#0f0f0f\">An equipment used to sell FARE PRODUCTs.</font>  <font color=\"#0f0f0f\">NOTE: Its identity can be used to record fulfilment and to support security processes.</font>"
  ; rdfs:subClassOf tm:SECURITY_LISTABLE
  ; rdfs:subClassOf tm:TICKETING_EQUIPMENT
  .

tm:RETAIL_CONSORTIUM a owl:Class ;
  rdfs:label "RETAIL CONSORTIUM"
  ; rdfs:comment "A group of ORGANISATIONs formally incorporated as a retailer of FARE PRODUCTS."
  ; rdfs:subClassOf tm:GROUP_OF_ENTITIES
  ; rdfs:subClassOf tm:ORGANISATION
  .

tm:RETAIL_DEVICE_SECURITY_LISTING a owl:Class ;
  rdfs:label "RETAIL DEVICE SECURITY LISTING"
  ; rdfs:comment "The presence of a specific RETAIL DEVICE on a SECURITY LIST."
  ; rdfs:subClassOf tm:SECURITY_LISTING
  .

tm:TYPE_OF_RETAIL_DEVICE a owl:Class ;
  rdfs:label "TYPE OF RETAIL DEVICE"
  ; rdfs:comment "A classification of RETAIL DEVICEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:REQUESTED_TRAVEL_SPECIFICATION a owl:Class ;
  rdfs:label "REQUESTED TRAVEL SPECIFICATION"
  ; rdfs:comment "A set of parameters giving details of an intended consumption of access rights requested by a TRANSPORT CUSTOMER (e.g., origin and destination of a travel, class of travel, etc.)."
  ; rdfs:subClassOf tm:TRAVEL_SPECIFICATION
  .

tm:FARE_PRODUCT_SALE_DEBIT a owl:Class ;
  rdfs:label "FARE PRODUCT SALE DEBIT"
  ; rdfs:comment "A LOG ENTRY recording data about a debiting action made to purchase a FARE PRODUCT."
  ; rdfs:subClassOf tm:FARE_DEBIT
  .

tm:OFFENCE_DEBIT a owl:Class ;
  rdfs:label "OFFENCE DEBIT"
  ; rdfs:comment "A LOG ENTRY recording data about a debiting action for a fine for an OFFENCE or penalty fare."
  ; rdfs:subClassOf tm:FARE_DEBIT
  .

tm:FARE_DEBIT a owl:Class ;
  rdfs:label "FARE DEBIT"
  ; rdfs:comment "A LOG ENTRY recording data about a debiting action relating to a fare or use of a fare."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:BOOKING_DEBIT a owl:Class ;
  rdfs:label "BOOKING DEBIT"
  ; rdfs:comment "A LOG ENTRY recording data about a debiting action for a booking fee."
  ; rdfs:subClassOf tm:FARE_DEBIT
  .

tm:OTHER_DEBIT a owl:Class ;
  rdfs:label "OTHER DEBIT"
  ; rdfs:comment "<font color=\"#0f0f0f\">A LOG ENTRY recording data about a debiting action for a payment type other than a FARE PRODUCT SALE DEBIT, TRIP DEBIT, OFFENCE DEBIT or BOOKING DEBIT.</font>"
  ; rdfs:subClassOf tm:FARE_DEBIT
  .

tm:TRIP_DEBIT a owl:Class ;
  rdfs:label "TRIP DEBIT"
  ; rdfs:comment "A LOG ENTRY recording data about a debiting action for post-payment for a specific trip."
  ; rdfs:subClassOf tm:FARE_DEBIT
  .

tm:TRAVEL_SPECIFICATION_EVENT a owl:Class ;
  rdfs:label "TRAVEL SPECIFICATION EVENT"
  ; rdfs:comment "The selection of a set of travel options by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:EVENT
  .

tm:FARE_CONTRACT_EVENT a owl:Class ;
  rdfs:label "FARE CONTRACT EVENT"
  ; rdfs:comment "An event associated with a FARE CONTRACT."
  ; rdfs:subClassOf tm:EVENT
  .

tm:SALES_EVENT a owl:Class ;
  rdfs:label "SALES EVENT"
  ; rdfs:comment "The purchase of a product by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:CUSTOMER_DEREGISTER_EVENT a owl:Class ;
  rdfs:label "CUSTOMER DEREGISTER EVENT"
  ; rdfs:comment "The closing of a CUSTOMER ACCOUNT and the removal of all personal details."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_EVENT
  .

tm:CUSTOMER_ACCOUNT_EVENT a owl:Class ;
  rdfs:label "CUSTOMER ACCOUNT EVENT"
  ; rdfs:comment "An action performed by a TRANSPORT CUSTOMER relating to a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:RESTORE_CUSTOMER_ACCOUNT_EVENT a owl:Class ;
  rdfs:label "RESTORE CUSTOMER ACCOUNT EVENT"
  ; rdfs:comment "The reinstallation to replacement media of an electronic travel document by a TRANSPORT CUSTOMER on a MEDIA DEVICE, usually as a MEDIA APPLICATION, possibly with recovered stored value."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_EVENT
  .

tm:CUSTOMER_MODIFY_PROFILE_EVENT a owl:Class ;
  rdfs:label "CUSTOMER MODIFY PROFILE EVENT"
  ; rdfs:comment "The modification by a TRANSPORT CUSTOMER of his CUSTOMER ACCOUNT details."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_EVENT
  .

tm:CUSTOMER_REGISTER_MEDIA_EVENT a owl:Class ;
  rdfs:label "CUSTOMER REGISTER MEDIA EVENT"
  ; rdfs:comment "The registration of a specific MEDIA instance such as an EMV CARD against a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_EVENT
  .

tm:CUSTOMER_REGISTER_EVENT a owl:Class ;
  rdfs:label "CUSTOMER REGISTER EVENT"
  ; rdfs:comment "The registration by the TRANSPORT CUSTOMER for a new account."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_EVENT
  .

tm:RESTORE_CUSTOMER_ACCOUNT_ENTRY a owl:Class ;
  rdfs:label "RESTORE CUSTOMER ACCOUNT ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the restoration of a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_PROFILE_MODIFICATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER PROFILE MODIFICATION ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the updating of a TRANSPORT CUSTOMER's account information."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_REGISTRATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER REGISTRATION ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the registration of a CUSTOMER and the creating of a new account."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_MEDIA_REGISTRATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER MEDIA REGISTRATION ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the registration of a media item against a CUSTOMER ACCOUNT, such as an EMV CARD as a payment method for the account."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_DEREGISTRATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER DEREGISTRATION ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the closing of an account and the clearing from record of all personal details of a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_ACCOUNT_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER ACCOUNT ENTRY"
  ; rdfs:comment "An abstract FARE CONTRACT ENTRY relating to a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:ACCOUNT_DETECT_ELIGIBILITY_CHANGE_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT ELIGIBILITY CHANGE EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system of a change in the eligibility of a user for a product they currently own, requiring an adjustment of some sort."
  ; rdfs:subClassOf tm:ACCOUNT_SECURITY_EVENT
  .

tm:ACCOUNT_SECURITY_EVENT a owl:Class ;
  rdfs:label "ACCOUNT SECURITY EVENT"
  ; rdfs:comment "A security event initiated by the processing of a CUSTOMER ACCOUNT by an Account Based Ticketing system."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:DENY_ACCOUNT_ON_SECURITY_LIST_EVENT a owl:Class ;
  rdfs:label "DENY ACCOUNT ON SECURITY LIST EVENT"
  ; rdfs:comment "The denial of rights by placing an ENTITY on a BLACKLIST and/or removing it from a WHITELIST."
  ; rdfs:subClassOf tm:ACCOUNT_SECURITY_EVENT
  .

tm:ACCOUNT_SUSPEND_EVENT a owl:Class ;
  rdfs:label "ACCOUNT SUSPEND EVENT"
  ; rdfs:comment "The suspension of a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:ACCOUNT_SECURITY_EVENT
  .

tm:ACCOUNT_REVIVE_EVENT a owl:Class ;
  rdfs:label "ACCOUNT REVIVE EVENT"
  ; rdfs:comment "The reinstatement of a suspended CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:ACCOUNT_SECURITY_EVENT
  .

tm:ALLOW_ACCOUNT_ON_SECURITY_LIST_EVENT a owl:Class ;
  rdfs:label "ALLOW ACCOUNT ON SECURITY LIST EVENT"
  ; rdfs:comment "The granting of rights by placing an ENTITY on a WHITELIST and/or removing it from a BLACKLIST."
  ; rdfs:subClassOf tm:ACCOUNT_SECURITY_EVENT
  .

tm:CEASES_TO_BE_ELIGIBLE_ENTRY a owl:Class ;
  rdfs:label "CEASES TO BE ELIGIBLE ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the detection that a user has ceased to be eligible for a product for which they were previously eligible, e.g., by virtue of growing older, changing employment status, or residence."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:BECOMES_ELIGIBLE_ENTRY a owl:Class ;
  rdfs:label "BECOMES ELIGIBLE ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the detection that a user has become eligible for a product for which they were previously ineligible, e.g., by virtue of growing older, changing employment status, or residence."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:SECURITY_LIST_DENY_ENTRY a owl:Class ;
  rdfs:label "SECURITY LIST DENY ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the denying of access to the transport network by the addition to a BLACKLIST or removal from a WHITELIST of a token that identifies a TRANSPORT CUSTOMER, CUSTOMER ACCOUNT, FARE CONTRACT, TRAVEL DOCUMENT, etc"
  ; rdfs:subClassOf tm:SECURITY_LIST_ENTRY
  .

tm:SECURITY_LIST_ALLOW_ENTRY a owl:Class ;
  rdfs:label "SECURITY LIST ALLOW ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the granting of access to the network by the addition to a WHITELIST or removal from a BLACKLIST of a token that identifies of an ENTITY such as a TRANSPORT CUSTOMER, CUSTOMER ACCOUNT, FARE CONTRACT, TRAVEL DOCUMENT, etc."
  ; rdfs:subClassOf tm:SECURITY_LIST_ENTRY
  .

tm:ACCOUNT_REVIVE_ENTRY a owl:Class ;
  rdfs:label "ACCOUNT REVIVE ENTRY"
  ; rdfs:comment "A CUSTOMER ACCOUNT ENTRY recording the reinstatement of a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:SECURITY_LIST_ENTRY a owl:Class ;
  rdfs:label "SECURITY LIST ENTRY"
  ; rdfs:comment "An abstract FARE CONTRACT ENTRY relating to measures to enforce Revenue Protection."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:ACCOUNT_SUSPEND_ENTRY a owl:Class ;
  rdfs:label "ACCOUNT SUSPEND ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the denying of access to the transport network by the addition to a BLACKLIST or removal from a WHITELIST of a token that identifies a CUSTOMER, CUSTOMER ACCOUNT, FARE CONTRACT, TRAVEL DOCUMENT, etc."
  ; rdfs:subClassOf tm:CUSTOMER_ACCOUNT_ENTRY
  .

tm:CUSTOMER_REFUND_EVENT a owl:Class ;
  rdfs:label "CUSTOMER REFUND EVENT"
  ; rdfs:comment "The giving of a refund to a TRANSPORT CUSTOMER for a product previously purchased."
  ; rdfs:subClassOf tm:CUSTOMER_SALES_EVENT
  .

tm:CUSTOMER_RESERVATION_CREATION_EVENT a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION CREATION EVENT"
  ; rdfs:comment "The creation or modification of a reservation by a TRANSPORT CUSTOMER, possibly without purchase."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_EVENT
  .

tm:CUSTOMER_SALES_EVENT a owl:Class ;
  rdfs:label "CUSTOMER SALES EVENT"
  ; rdfs:comment "<font color=\"#0f0f0f\">The purchase or subsequent alteration of a<i> </i>FARE PRODUCT by a TRANSPORT CUSTOMER.</font>"
  ; rdfs:subClassOf tm:SALES_EVENT
  .

tm:CUSTOMER_EXCHANGE_EVENT a owl:Class ;
  rdfs:label "CUSTOMER EXCHANGE EVENT"
  ; rdfs:comment "The exchange by a TRANSPORT CUSTOMER of a product for another product."
  ; rdfs:subClassOf tm:CUSTOMER_SALES_EVENT
  .

tm:CUSTOMER_PRODUCT_PURCHASE_EVENT a owl:Class ;
  rdfs:label "CUSTOMER PRODUCT PURCHASE EVENT"
  ; rdfs:comment "The purchase of a FARE PRODUCT by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:CUSTOMER_SALES_EVENT
  .

tm:ACCOUNT_AUTO_RENEWAL_EVENT a owl:Class ;
  rdfs:label "ACCOUNT AUTO RENEWAL EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system that a renewable product such as a pass needs to be renewed.  NOTE: Depending on the configuration, may trigger either an automatic renewal or a notice to the customer."
  ; rdfs:subClassOf tm:ACCOUNT_SALES_EVENT
  .

tm:ACCOUNT_AUTO_TOP_UP_EVENT a owl:Class ;
  rdfs:label "ACCOUNT AUTO TOP UP EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system that the account balance has fallen below a threshold which needs to be topped up using a preset payment method and increment."
  ; rdfs:subClassOf tm:ACCOUNT_SALES_EVENT
  .

tm:ACCOUNT_SALES_EVENT a owl:Class ;
  rdfs:label "ACCOUNT SALES EVENT"
  ; rdfs:comment "A sales event affecting a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:SALES_EVENT
  .

tm:ACCOUNT_AWARD_REFUND_EVENT a owl:Class ;
  rdfs:label "ACCOUNT AWARD REFUND EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system that a refund needs to be awarded, for example because guaranteed performance targets have not been met."
  ; rdfs:subClassOf tm:ACCOUNT_SALES_EVENT
  .

tm:MEDIA_RECHARGE_PURCHASE_ENTRY a owl:Class ;
  rdfs:label "MEDIA RECHARGE PURCHASE ENTRY"
  ; rdfs:comment "A SALES TRANSACTION recording the purchase of a recharge of stored value by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:CUSTOMER_PRODUCT_PURCHASE_ENTRY
  .

tm:CUSTOMER_RESERVATION_CREATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION CREATION ENTRY"
  ; rdfs:comment "A CUSTOMER RESERVATION CREATION ENTRY recording the reservation of an access right."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_ENTRY
  .

tm:TRAVEL_COMPENSATION_ENTRY a owl:Class ;
  rdfs:label "TRAVEL COMPENSATION ENTRY"
  ; rdfs:comment "A SALES TRANSACTION recording the payment to the TRANSPORT CUSTOMER of compensation for some service shortcoming."
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:FARE_PRODUCT_EXCHANGE_ENTRY a owl:Class ;
  rdfs:label "FARE PRODUCT EXCHANGE ENTRY"
  ; rdfs:comment "A SALES TRANSACTION recording the alteration or exchange of a FARE PRODUCT for another by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:FARE_PRODUCT_PURCHASE_ENTRY a owl:Class ;
  rdfs:label "FARE PRODUCT PURCHASE ENTRY"
  ; rdfs:comment "A CUSTOMER PURCHASE ENTRY recording the purchase of a FARE PRODUCT by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:CUSTOMER_PRODUCT_PURCHASE_ENTRY
  .

tm:TRIP_PURCHASE_ENTRY a owl:Class ;
  rdfs:label "TRIP PURCHASE ENTRY"
  ; rdfs:comment "A CUSTOMER PURCHASE ENTRY recording the purchase of a single trip FARE PRODUCT by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:FARE_PRODUCT_PURCHASE_ENTRY
  .

tm:CUSTOMER_RESERVATION_CANCELLATION_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER RESERVATION CANCELLATION ENTRY"
  ; rdfs:comment "A CUSTOMER RESERVATION ENTRY recording the cancellation of a reservation."
  ; rdfs:subClassOf tm:CUSTOMER_RESERVATION_ENTRY
  .

tm:FARE_PRODUCT_REFUND_ENTRY a owl:Class ;
  rdfs:label "FARE PRODUCT REFUND ENTRY"
  ; rdfs:comment "A SALES TRANSACTION recording a refund given to a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:CUSTOMER_PRODUCT_PURCHASE_ENTRY a owl:Class ;
  rdfs:label "CUSTOMER PRODUCT PURCHASE ENTRY"
  ; rdfs:comment "An abstract SALES TRANSACTION recording a purchase of any sort by a TRANSPORT CUSTOMER."
  ; rdfs:subClassOf tm:SALES_TRANSACTION
  .

tm:FARE_PRODUCT_RENEWAL_ENTRY a owl:Class ;
  rdfs:label "FARE PRODUCT RENEWAL ENTRY"
  ; rdfs:comment "<font color=\"#0f0f0f\">A CUSTOMER PRODUCT PURCHASE ENTRY recording the renewal of a FARE PRODUCT such as a pass by a TRANSPORT CUSTOMER.</font>"
  ; rdfs:subClassOf tm:CUSTOMER_PRODUCT_PURCHASE_ENTRY
  .

tm:CUSTOMER_MEDIA_INSTALL_EVENT a owl:Class ;
  rdfs:label "CUSTOMER MEDIA INSTALL EVENT"
  ; rdfs:comment "The installation of an electronic travel document on a MEDIA DEVICE, usually as a MEDIA APPLICATION."
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:CUSTOMER_MEDIA_RESTORE_EVENT a owl:Class ;
  rdfs:label "CUSTOMER MEDIA RESTORE EVENT"
  ; rdfs:comment "The replacement of an electronic MEDIA DEVICE."
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:CUSTOMER_PRODUCT_ACTIVATION_EVENT a owl:Class ;
  rdfs:label "CUSTOMER PRODUCT ACTIVATION EVENT"
  ; rdfs:comment "The activation of a FARE PRODUCT, for example, on an installed MEDIA, or for use with a CUSTOMER ACCOUNT."
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:CUSTOMER_MEDIA_APPLICATION_RESTORE_EVENT a owl:Class ;
  rdfs:label "CUSTOMER MEDIA APPLICATION RESTORE EVENT"
  ; rdfs:comment "The reinstallation to replacement media of an electronic travel document on a MEDIA DEVICE, usually as a MEDIA APPLICATION, possibly with recovered stored value."
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:CUSTOMER_FULFILMENT_EVENT a owl:Class ;
  rdfs:label "CUSTOMER FULFILMENT EVENT"
  ; rdfs:comment "The delivery to a TRANSPORT CUSTOMER of a materialisation of a FARE PRODUCT as a TRAVEL DOCUMENT."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:CUSTOMER_COLLECT_EVENT a owl:Class ;
  rdfs:label "CUSTOMER COLLECT EVENT"
  ; rdfs:comment "The collection by the TRANSPORT CUSTOMER of a TRAVEL DOCUMENT and/or MEDIUM ACCESS DEVICE from any FULFILMENT CHANNEL."
  ; rdfs:subClassOf tm:CUSTOMER_FULFILMENT_EVENT
  .

tm:MEDIA_APPLICATION_RESTORE_ENTRY a owl:Class ;
  rdfs:label "MEDIA APPLICATION RESTORE ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the reinstallation of a previously purchased application on a MEDIA ACCESS DEVICE, possibly with the recovery of stored value."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:ADJUST_BALANCE_ON_CHECK_IN_ENTRY a owl:Class ;
  rdfs:label "ADJUST BALANCE ON CHECK IN ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the adjustment of the balance from an amount deposited on account on a MEDIUM ACCESS DEVICE when a passenger checks in or interacts with a system."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:TRAVEL_DOCUMENT_COLLECTION_ENTRY a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT COLLECTION ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the physical delivery of a TRAVEL DOCUMENT to a TRANSPORT CUSTOMER, for example from a ticket on demand machine at a station, or internet self-service."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:TRAVEL_DOCUMENT_ANNULMENT_ENTRY a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT ANNULMENT ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the annulment of a TRAVEL DOCUMENT so that it may no longer be used."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:MEDIA_PRODUCT_DEACTIVATION_ENTRY a owl:Class ;
  rdfs:label "MEDIA PRODUCT DEACTIVATION ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the deactivation of a previously purchased or installed product."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:MEDIA_PRODUCT_INSTALLATION_ENTRY a owl:Class ;
  rdfs:label "MEDIA PRODUCT INSTALLATION ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the installation of a previously purchased product on a MEDIA ACCESS DEVICE."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:PURCHASE_FULFILMENT_ENTRY a owl:Class ;
  rdfs:label "PURCHASE FULFILMENT ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the delivery of a TRAVEL DOCUMENT to a TRANSPORT CUSTOMER by any means, for example by email, SMS or download"
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:MEDIA_PRODUCT_ACTIVATION_ENTRY a owl:Class ;
  rdfs:label "MEDIA PRODUCT ACTIVATION ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the activation of a previously purchased or installed product.  NOTE: Might for example also involve placing on a WHITELIST."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:FULFILMENT_ENTRY a owl:Class ;
  rdfs:label "FULFILMENT ENTRY"
  ; rdfs:comment "An abstract FARE CONTRACT ENTRY relating to delivery of a purchase."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:MEDIA_RESTORE_ENTRY a owl:Class ;
  rdfs:label "MEDIA RESTORE ENTRY"
  ; rdfs:comment "A FULFILMENT ENTRY recording the replacement of the MEDIUM ACCESS DEVICE."
  ; rdfs:subClassOf tm:FULFILMENT_ENTRY
  .

tm:FARE_SECURITY_MANAGER_ROLE a owl:Class ;
  rdfs:label "FARE SECURITY MANAGER ROLE"
  ; rdfs:comment "<font color=\"#0f0f0f\">The ADMINISTRATIVE ORGANISATION ROLE of establishing and coordinating a security policy for fare data across the provider organisations, and of the certifying and auditing of organisations, applications, etc., for their conformance to the security policy.</font>"
  ; rdfs:subClassOf tm:SECURITY_MANAGER_ROLE
  .

tm:FARE_DATA_COLLECTOR_ROLE a owl:Class ;
  rdfs:label "FARE DATA COLLECTOR ROLE"
  ; rdfs:comment "The role of collecting and forwarding fare data between the various parties concerned with product delivery, such as PRODUCT RETAILER, PRODUCT OWNER, etc.  NOTE: May be undertaken by a separate intermediary."
  ; rdfs:subClassOf tm:DATA_COLLECTOR_ROLE
  .

tm:FARE_PRODUCT_RETAILER_ROLE a owl:Class ;
  rdfs:label "FARE PRODUCT RETAILER ROLE"
  ; rdfs:comment "The role of an organisation to sell products to TRANSPORT CUSTOMERs, as authorised by the holder of a FARE PRODUCT OWNER ROLE.  NOTE: The FARE PRODUCT RETAILER ROLE may be undertaken by the same party as the FARE PRODUCT OWNER ROLE, the ACCOUNT PROVIDER ROLE, or a secondary outlet such as a TRAVEL AGENT, newsagent, or other third party, etc."
  ; rdfs:subClassOf tm:FARE_ORGANISATION_ROLE
  .

tm:FARE_REGISTRAR_ROLE a owl:Class ;
  rdfs:label "FARE REGISTRAR ROLE"
  ; rdfs:comment "The ADMINISTRATIVE ORGANISATION ROLE of coordinating the issue of unique registration codes (for example, by determining rules for generating unique codes) for data linked to fare management such as FARE CONTRACTs, TRAVEL DOCUMENTs, etc."
  ; rdfs:subClassOf tm:REGISTRAR_ROLE
  .

tm:FARE_ORGANISATION_ROLE a owl:Class ;
  rdfs:label "FARE ORGANISATION ROLE"
  ; rdfs:comment "Any corporate role in providing or managing transport services."
  ; rdfs:subClassOf tm:ORGANISATION_ROLE
  .

tm:FARE_PRODUCT_ISSUER_ROLE a owl:Class ;
  rdfs:label "FARE PRODUCT ISSUER ROLE"
  ; rdfs:comment "A role of an organisation introduced when there are a large number of fare product owners and a large number of distributors.  NOTE: The FARE PRODUCT ISSUER ROLE makes a portfolio of products available to a product distributor to be sold via product retailers to TRANSPORT CUSTOMERs."
  ; rdfs:subClassOf tm:FARE_ORGANISATION_ROLE
  .

tm:FARE_PRODUCT_ATTRIBUTOR_ROLE a owl:Class ;
  rdfs:label "FARE PRODUCT ATTRIBUTOR ROLE"
  ; rdfs:comment "The role of being an agent of a FARE PRODUCT OWNER, i.e., the role of an intermediary organisation to whom certain responsibilities have been delegated by the FARE PRODUCT OWNER, for instance to provide the technical implementation of the products defined by the FARE PRODUCT OWNER."
  ; rdfs:subClassOf tm:FARE_ORGANISATION_ROLE
  .

tm:FARE_PRODUCT_DISTRIBUTOR_ROLE a owl:Class ;
  rdfs:label "FARE PRODUCT DISTRIBUTOR ROLE"
  ; rdfs:comment "<font color=\"#0f0f0f\">The role, in large networks, of organising and accounting for the wholesale distribution of FARE PRODUCTs, as delegated by the FARE PRODUCT OWNER ROLE and to supply products to the FARE PRODUCT RETAILER ROLE.</font>"
  ; rdfs:subClassOf tm:FARE_ORGANISATION_ROLE
  .

tm:FARE_PRODUCT_OWNER_ROLE a owl:Class ;
  rdfs:label "FARE PRODUCT OWNER ROLE"
  ; rdfs:comment "The role of the organisation which has commercial ownership of a FARE PRODUCT and is responsible for specifying pricing, usage conditions and commercial rules for the product, for ensuring there are processes for marketing and retailing the product, customer payment, control and validation, back office accounting and settlement and for customer service."
  ; rdfs:subClassOf tm:FARE_ORGANISATION_ROLE
  .

tm:PAYMENT_PROVIDER_ROLE a owl:Class ;
  rdfs:label "PAYMENT PROVIDER ROLE"
  ; rdfs:comment "The role of channelling funds from the CUSTOMER to the FARE PRODUCT RETAILER for travel services, and particularly for usage-based travel products (e.g., EMV provider, ApplePay, PayPal, Android Pay, etc.)."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:IDENTITY_PROVIDER_ROLE a owl:Class ;
  rdfs:label "IDENTITY PROVIDER ROLE"
  ; rdfs:comment "The role of supplying a trusted identity token that can be associated with a CUSTOMER ACCOUNT, TRAVEL DOCUMENT, etc.  NOTE: The IDENTITY PROVIDER ROLE may be undertaken by transport AUTHORITies and OPERATORs, but also non-transport organisations, such as governments central and local, mobile network operators, or online service providers (e.g., Google, Facebook) and banks."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:MEDIUM_APPLICATION_OWNER_ROLE a owl:Class ;
  rdfs:label "MEDIUM APPLICATION OWNER ROLE"
  ; rdfs:comment "For media-centric products, the APPLICATION OWNER ROLE has commercial ownership of the software MEDIA APPLICATION hosting a product and is contracted by the PRODUCT OWNER for the use of the application with the customer."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:MEDIA_PROVIDER_ROLE a owl:Class ;
  rdfs:label "MEDIA PROVIDER ROLE"
  ; rdfs:comment "The role of supplying the media used for the TRAVEL DOCUMENT, that is a physical support containing a machine readable/writable data/processor application.  NOTE: This can include transport industry smartcards, payment industry contactless cards, public sector issued cards, mobile phones or paper (for barcodes), new formats such as watches and key fobs, and NFC enabled devices."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:MEDIUM_APPLICATION_PROVIDER_ROLE a owl:Class ;
  rdfs:label "MEDIUM APPLICATION PROVIDER ROLE"
  ; rdfs:comment "For media-centric products, the APPLICATION PROVIDER supplies the software application that hosts a TRAVEL DOCUMENT and presents it to CONTROL DEVICEs for automatic control and validation."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:ACCOUNT_PROVIDER_ROLE a owl:Class ;
  rdfs:label "ACCOUNT PROVIDER ROLE"
  ; rdfs:comment "In Account Based Ticketing, the ACCOUNT PROVIDER provides the online account by means of which the product is delivered. Normally this involves a direct relationship with the CUSTOMER, though it may also be done as a white-labelled service for another party."
  ; rdfs:subClassOf tm:TECHNOLOGY_ORGANISATION_ROLE
  .

tm:GROUP_MEMBER_ROLE a owl:Class ;
  rdfs:label "GROUP MEMBER ROLE"
  ; rdfs:comment "The role of a passenger travelling under the access rights granted by a GROUP TICKET."
  ; rdfs:subClassOf tm:PASSENGER_ROLE
  .

tm:PASSENGER_ROLE a owl:Class ;
  rdfs:label "PASSENGER ROLE"
  ; rdfs:comment "The general role of consuming a travel service."
  ; rdfs:subClassOf tm:TRANSPORT_USER_ROLE
  .

tm:OFFENDER_ROLE a owl:Class ;
  rdfs:label "OFFENDER ROLE"
  ; rdfs:comment "The role enacted by someone attempting to travel with no or insufficient access rights."
  ; rdfs:subClassOf tm:PASSENGER_ROLE
  .

tm:INDIVIDUAL_PASSENGER_ROLE a owl:Class ;
  rdfs:label "INDIVIDUAL PASSENGER ROLE"
  ; rdfs:comment "The role of a passenger consuming a travel service as a single individual."
  ; rdfs:subClassOf tm:PASSENGER_ROLE
  .

tm:INDIVIDUAL_PURCHASER_ROLE a owl:Class ;
  rdfs:label "INDIVIDUAL PURCHASER ROLE"
  ; rdfs:comment "The role of a person in purchasing a FARE PRODUCT as a private individual; often, but not necessarily, the same as the PASSENGER ROLE."
  ; rdfs:subClassOf tm:PURCHASER_ROLE
  .

tm:COMPANION_ROLE a owl:Class ;
  rdfs:label "COMPANION ROLE"
  ; rdfs:comment "The role of accompanying another passenger under the access rights granted by the other passenger's ticket."
  ; rdfs:subClassOf tm:PASSENGER_ROLE
  .

tm:CORPORATE_PURCHASER_ROLE a owl:Class ;
  rdfs:label "CORPORATE PURCHASER ROLE"
  ; rdfs:comment "The role of purchasing FARE PRODUCTs on behalf of a corporate body such as a company, school, government department, etc."
  ; rdfs:subClassOf tm:PURCHASER_ROLE
  .

tm:PURCHASER_ROLE a owl:Class ;
  rdfs:label "PURCHASER ROLE"
  ; rdfs:comment "The role of the party who pays for a travel service for one or more TRANSPORT CUSTOMERs."
  ; rdfs:subClassOf tm:TRANSPORT_USER_ROLE
  .

tm:TYPE_OF_OFFENCE a owl:Class ;
  rdfs:label "TYPE OF OFFENCE"
  ; rdfs:comment "A classification of OFFENCE, for example wrong CLASS OF SEAT, not valid for PRODUCT CATEGORY, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:OTHER_CONTROL_MEANS a owl:Class ;
  rdfs:label "OTHER CONTROL MEANS"
  ; rdfs:comment "A particular means other than a control device, for example a manual procedure, used to control apply control processes."
  ; rdfs:subClassOf tm:CONTROL_MEANS
  .

tm:CONTROL_TYPE a owl:Class ;
  rdfs:label "CONTROL TYPE"
  ; rdfs:comment "A classification of passenger controls, e.g., entry, exit, en route or occasional controls."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:DEVICE_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "DEVICE PARAMETER ASSIGNMENT"
  ; rdfs:comment "An ACCESS RIGHT PARAMETER ASSIGNMENT expressing the location (or other fixed parameters) of a CONTROL MEANS."
  ; rdfs:subClassOf tm:ACCESS_RIGHT_PARAMETER_ASSIGNMENT
  .

tm:DEVICE_RELATED_CONTROL_MEANS a owl:Class ;
  rdfs:label "DEVICE RELATED CONTROL MEANS"
  ; rdfs:comment "A specific device constituting the CONTROL MEANS to control TRAVEL DOCUMENTs."
  ; rdfs:subClassOf tm:CONTROL_MEANS
  .

tm:CONTROL_MEANS a owl:Class ;
  rdfs:label "CONTROL MEANS"
  ; rdfs:comment "A particular means (control device or manual control procedure) used to control TRAVEL DOCUMENTs."
  .

tm:CONTROLLED_ACCESS a owl:Class ;
  rdfs:label "CONTROLLED ACCESS"
  ; rdfs:comment "A validated use of a CONTROLLABLE ELEMENT."
  ; rdfs:subClassOf tm:CONTROL_RECORD
  .

tm:CONTROL_PARAMETER_ASSIGNMENT a owl:Class ;
  rdfs:label "CONTROL PARAMETER ASSIGNMENT"
  ; rdfs:comment "An ACCESS RIGHT PARAMETER ASSIGNMENT relating a fare collection parameter to a CONTROL ENTRY."
  ; rdfs:subClassOf tm:ACCESS_RIGHT_PARAMETER_ASSIGNMENT
  .

tm:CONTROL_ENTRY a owl:Class ;
  rdfs:label "CONTROL ENTRY"
  ; rdfs:comment "The description of a control action, i.e., the comparison of actual and current parameters (time, location, etc.) to the access rights to which the holder of a TRAVEL DOCUMENT is entitled."
  ; rdfs:subClassOf tm:CONTROL_RECORD
  .

tm:FARE_TRIP_ACTIVATION_ENTRY a owl:Class ;
  rdfs:label "FARE TRIP ACTIVATION ENTRY"
  ; rdfs:comment "<font color=\"#0f0f0f\">A PASSENGER TRAVEL ENTRY recording the initiation of the consumption of access rights by a TRANSPORT CUSTOMER making a trip, for example by means of marking a TRAVEL DOCUMENT using a ticket validator machine.</font>"
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:PASSENGER_CHECK_OUT_ENTRY a owl:Class ;
  rdfs:label "PASSENGER CHECK OUT ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the check-out of a passenger at a barrier or validation point at the end of a journey.  NOTE: May trigger post payment."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:CONTROL_PASSENGER_TRIP_ENTRY a owl:Class ;
  rdfs:label "CONTROL PASSENGER TRIP ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the control of the consumption of access rights by the inspection of a TRAVEL DOCUMENT by a TRAVEL DOCUMENT CONTROLLER.  NOTE: May include marking (cancellation) of the TRAVEL DOCUMENT."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:PASSENGER_TRAVEL_ENTRY a owl:Class ;
  rdfs:label "PASSENGER TRAVEL ENTRY"
  ; rdfs:comment "An abstract VALIDATION ENTRY relating to control of the PASSENGER."
  ; rdfs:subClassOf tm:VALIDATION_ENTRY
  .

tm:PASSENGER_CHECK_IN_ENTRY a owl:Class ;
  rdfs:label "PASSENGER CHECK IN ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the check-out of a passenger at a barrier or validation point at the end of a journey.  NOTE: May trigger prepayment."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:SITUATION_REQUEST_POLICY a owl:Class ;
  rdfs:label "SITUATION REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when finding SITUATIONs."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:SITUATION_REQUEST a owl:Class ;
  rdfs:label "SITUATION REQUEST"
  ; rdfs:comment "A PI REQUEST to find extant SITUATIONs."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:MESSAGE_REQUEST_FILTER a owl:Class ;
  rdfs:label "MESSAGE REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the SITUATION REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:SITUATION_DELIVERY a owl:Class ;
  rdfs:label "SITUATION DELIVERY"
  ; rdfs:comment "The result returned by a SITUATION REQUEST."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:TARIFF_ZONE_IN_AREA a owl:Class ;
  rdfs:label "TARIFF ZONE IN AREA"
  ; rdfs:comment "Association of a Stop with a tariff Zone."
  .

tm:STOP_FARE_REQUEST a owl:Class ;
  rdfs:label "STOP FARE REQUEST"
  ; rdfs:comment "A PI REQUEST to find the fares products for a stop."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:STOP_FARE_DELIVERY a owl:Class ;
  rdfs:label "STOP FARE DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY that returns the tariff zones for a stop."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:TRIP_PROFILE_REQUIREMENTS a owl:Class ;
  rdfs:label "TRIP PROFILE REQUIREMENTS"
  ; rdfs:comment "<font color=\"#0f0f0f\">The number and characteristics of the persons wishing to travel</font>."
  .

tm:TRIP_FARE_REQUEST_FILTER a owl:Class ;
  rdfs:label "TRIP FARE REQUEST FILTER"
  ; rdfs:comment "Parameters controlling the type of fares returned by a TRIP FARE REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:TRIP_FARE_REQUEST_POLICY a owl:Class ;
  rdfs:label "TRIP FARE REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used when computing and decorating TRIP FARE REQUEST results."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:TRIP_FARE_REQUEST a owl:Class ;
  rdfs:label "TRIP FARE REQUEST"
  ; rdfs:comment "A PI REQUEST about fares for a TRIP or TRIP LEG."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:TRIP_FARE_DELIVERY a owl:Class ;
  rdfs:label "TRIP FARE DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY returning the results for a TRIP FARE REQUEST."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:SINGLE_TRIP_FARE_REQUEST a owl:Class ;
  rdfs:label "SINGLE TRIP FARE REQUEST"
  ; rdfs:comment "A TRIP FARE REQUEST about fares for a single trip or return trip."
  ; rdfs:subClassOf tm:TRIP_FARE_REQUEST
  .

tm:REPEATED_TRIP_FARE_REQUIREMENTS a owl:Class ;
  rdfs:label "REPEATED TRIP FARE REQUIREMENTS"
  ; rdfs:comment "<font color=\"#0f0f0f\">The characteristics of a repeated trip, for example, number of trips per day, etc.</font>"
  .

tm:REPEATED_TRIP_FARE_REQUEST a owl:Class ;
  rdfs:label "REPEATED TRIP FARE REQUEST"
  ; rdfs:comment "A TRIP FARE REQUEST about the best fare products to use for repeated similar trips."
  ; rdfs:subClassOf tm:TRIP_FARE_REQUEST
  .

tm:FARE_PRODUCT_DELIVERY a owl:Class ;
  rdfs:label "FARE PRODUCT DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY that returns details of FARE PRODUCTS."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:FARE_PRODUCT_REQUEST_FILTER a owl:Class ;
  rdfs:label "FARE PRODUCT REQUEST FILTER"
  ; rdfs:comment "Parameters controlling the type of fares returned by a FARE PRODUCT REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:FARE_PRODUCT_REQUEST a owl:Class ;
  rdfs:label "FARE PRODUCT REQUEST"
  ; rdfs:comment "A PI REQUEST to find details about a FARE PRODUCT or SALES OFFER PACKAGE."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:FARE_PRODUCT_REQUEST_POLICY a owl:Class ;
  rdfs:label "FARE PRODUCT REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used when computing and decorating FARE PRODUCT REQUEST results."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:DRIVER a owl:Class ;
  rdfs:label "DRIVER"
  ; rdfs:comment "An EMPLOYEE whose usual work is to drive a public transport vehicle."
  ; rdfs:subClassOf tm:EMPLOYEE
  .

tm:NO_CHECK_IN_DETECTED_ENTRY a owl:Class ;
  rdfs:label "NO CHECK IN DETECTED ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the detection that a passenger has failed to check in at the end of a journey.  NOTE: This may be triggered by a subsequent check in or by back office processes looking for unmatched way point check in and check out events within a specified window."
  ; rdfs:subClassOf tm:UNMATCHED_TRAVEL_ENTRY
  .

tm:PASSENGER_USED_SAME_STOP_ENTRY a owl:Class ;
  rdfs:label "PASSENGER USED SAME STOP ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the detection of a passenger re-entering a station within a threshold period."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:NO_CHECK_OUT_DETECTED_ENTRY a owl:Class ;
  rdfs:label "NO CHECK OUT DETECTED ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the detection that a passenger has failed to check out at the end of a journey.  NOTE: This may be triggered by a subsequent check in or by back office processes looking for unmatched check in and check out events within a specified window."
  ; rdfs:subClassOf tm:UNMATCHED_TRAVEL_ENTRY
  .

tm:UNMATCHED_TRAVEL_ENTRY a owl:Class ;
  rdfs:label "UNMATCHED TRAVEL ENTRY"
  ; rdfs:comment "A PASSENGER TRAVEL ENTRY recording the detection that an incompletely recorded trip has been detected."
  ; rdfs:subClassOf tm:PASSENGER_TRAVEL_ENTRY
  .

tm:ACCOUNT_PROCESSING_EVENT a owl:Class ;
  rdfs:label "ACCOUNT PROCESSING EVENT"
  ; rdfs:comment "An event initiated by the processing of a CUSTOMER ACCOUNT by an Account Based Ticketing system."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:ACCOUNT_DETECT_SUSPICIOUS_BEHAVIOUR_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT SUSPICIOUS BEHAVIOUR EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system of suspicious or fraudulent use of a TRAVEL DOCUMENT, for example being used in two different places at the same time."
  ; rdfs:subClassOf tm:ACCOUNT_PROCESSING_EVENT
  .

tm:ACCOUNT_DETECT_REENTRY_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT REENTRY EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system of reentry at the same station within a specified threshold period."
  ; rdfs:subClassOf tm:ACCOUNT_PROCESSING_EVENT
  .

tm:ACCOUNT_DETECT_NO_CHECK_OUT_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT NO CHECK OUT EVENT"
  ; rdfs:comment "The detection that a passenger has failed to check out at the end of a trip.  NOTE: This may be triggered by a subsequent check in on a new journey or by back office processes looking for unmatched check in and check out events within a specified window."
  ; rdfs:subClassOf tm:ACCOUNT_PROCESSING_EVENT
  .

tm:ACCOUNT_DETECT_TRIP_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT TRIP EVENT"
  ; rdfs:comment "The detection by an Account Based Ticketing system of a trip made by the user that needs to be accounted for."
  ; rdfs:subClassOf tm:ACCOUNT_PROCESSING_EVENT
  .

tm:ACCOUNT_DETECT_NO_CHECK_IN_EVENT a owl:Class ;
  rdfs:label "ACCOUNT DETECT NO CHECK IN EVENT"
  ; rdfs:comment "The detection that a passenger has failed to check in at the beginning of a trip.  NOTE: This may be triggered by a subsequent check out or by back office processes looking for unmatched check in and check out events within a specified window."
  ; rdfs:subClassOf tm:ACCOUNT_PROCESSING_EVENT
  .

tm:NO_ACCESS_RIGHTS_ENTRY a owl:Class ;
  rdfs:label "NO ACCESS RIGHTS ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the detection of a TRANSPORT CUSTOMER travelling without having purchased access rights"
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:NO_PROOF_ON_PERSON_ENTRY a owl:Class ;
  rdfs:label "NO PROOF ON PERSON ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the detection of a customer who claims to have purchased access rights but has no proof, e.g., TRAVEL DOCUMENT on their person."
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:TRAVEL_DOCUMENT_CONFISCATION_ENTRY a owl:Class ;
  rdfs:label "TRAVEL DOCUMENT CONFISCATION ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the confiscation of a TRAVEL DOCUMENT from a TRANSPORT CUSTOMER because of an OFFENCE."
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:REVENUE_PROTECTION_ENTRY a owl:Class ;
  rdfs:label "REVENUE PROTECTION ENTRY"
  ; rdfs:comment "An abstract FARE CONTRACT ENTRY representing the recording of an event relating to revenue protection."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:SUSPICIOUS_BEHAVIOUR_ENTRY a owl:Class ;
  rdfs:label "SUSPICIOUS BEHAVIOUR ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION EVENT recording the detection of suspicious behaviour."
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:INSUFFICIENT_ACCESS_RIGHTS_ENTRY a owl:Class ;
  rdfs:label "INSUFFICIENT ACCESS RIGHTS ENTRY"
  ; rdfs:comment "A REVENUE PROTECTION ENTRY recording the result of the comparison between one or several CONTROL ENTRies and the theoretical access rights attached to the TRAVEL DOCUMENT controlled, detecting insufficient rights to consume and possibly giving rise to a FARE DEBIT or one or more OFFENCEs."
  ; rdfs:subClassOf tm:REVENUE_PROTECTION_ENTRY
  .

tm:FARE_FRAME a owl:Class ;
  rdfs:label "FARE FRAME"
  ; rdfs:comment "A set of FARE data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:FARE_FRAME_DEFAULTS a owl:Class ;
  rdfs:label "FARE FRAME DEFAULTS"
  ; rdfs:comment "A set of pricing parameters and values to apply to an individual element in the FARE FRAME if no explicit value is specified on the element."
  .

tm:SALES_TRANSACTION_FRAME a owl:Class ;
  rdfs:label "SALES TRANSACTION FRAME"
  ; rdfs:comment "A set of SALES TRANSACTION data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:PT_TRIP a owl:Class ;
  rdfs:label "PT TRIP"
  ; rdfs:comment "A<font color=\"#0f0f0f\"> part of a TRIP PATTERN consisting of a continuous sequence of PT RIDE LEGs and CONNECTION LEGs.</font>  <font color=\"#0f0f0f\">Note: IT must not contain any ACCESS LEGs or PERSONAL LEGs</font>"
  ; rdfs:subClassOf tm:TRIP
  .

tm:PT_RIDE_LEG a owl:Class ;
  rdfs:label "PT RIDE LEG"
  ; rdfs:comment "A part of a TRIP PATTERN corresponding to the movement of a user (passenger, driver) on one and only one public transport vehicle (such as a train bus, ferry) from one SCHEDULED STOP POINT to another, on one JOURNEY PATTERN operating in a conventional MODE OF OPERATION."
  ; rdfs:subClassOf tm:RIDE_LEG
  .

tm:LEG_TRACK a owl:Class ;
  rdfs:label "LEG TRACK"
  ; rdfs:comment "The spatial projection of the leg as a set of coordinate points for a specific purpose., such as displaying it on a map."
  .

tm:PATH_GUIDANCE a owl:Class ;
  rdfs:label "PATH GUIDANCE"
  ; rdfs:comment "An instruction to a passenger for an individual step when following a path between the start and the end of a TRANSFER LEG."
  .

tm:TRIP_REASON a owl:Class ;
  rdfs:label "TRIP REASON"
  ; rdfs:comment "A classification of a passenger's reason for undertaking a TRIP PATTERN, e.g., work commute, school pick up, shopping, etc."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:NON_PT_TRIP a owl:Class ;
  rdfs:label "NON-PT TRIP"
  ; rdfs:comment "A<font color=\"#0f0f0f\"> part of a TRIP PATTERN consisting of a continuous sequence of PERSONAL LEGs and TRANSFER LEGs.</font>  <font color=\"#0f0f0f\">Note: IT must not contain any PT RIDE LEGs.</font>"
  ; rdfs:subClassOf tm:TRIP
  .

tm:MIXED_TRIP a owl:Class ;
  rdfs:label "MIXED TRIP"
  ; rdfs:comment "A<font color=\"#0f0f0f\"> part of a TRIP PATTERN that mixes both PT RIDE LEGs and PERSONAL LEGs.</font>"
  ; rdfs:subClassOf tm:TRIP
  .

tm:TRIP_PATTERN a owl:Class ;
  rdfs:label "TRIP PATTERN"
  ; rdfs:comment "A movement of a passenger (or another person, e.g., driver) from an origin to a destination PLACE, done for a specific TRIP REASON.  A TRIP PATTERN may consist of one or more consecutive TRIPs<font color=\"#0f0f0f\">.</font>"
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:SPOT_AFFINITY a owl:Class ;
  rdfs:label "SPOT AFFINITY"
  ; rdfs:comment "A group of proximate seats suitable for selection for use by a group of travellers, for example, as being side by side, face to face, around a table, near a wheelchair spot, etc."
  .

tm:ACCESS_LEG a owl:Class ;
  rdfs:label "ACCESS LEG"
  ; rdfs:comment "A part of a TRIP PATTERN corresponding to the movement of a passenger when not on a public transport vehicle, from an origin PLACE to a SCHEDULED STOP POINT or VEHICLE MEETING POINT, or from a SCHEDULED STOP POINT or VEHICLE MEETING POINT to a destination PLACE.   NOTE: May reference an ACCESS."
  ; rdfs:subClassOf tm:TRANSFER_LEG
  .

tm:TYPE_OF_GUARANTEE a owl:Class ;
  rdfs:label "TYPE OF GUARANTEE"
  ; rdfs:comment "A classification of the type of guarantee offered for a given leg."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:LEG a owl:Class ;
  rdfs:label "LEG"
  ; rdfs:comment "<font color=\"#0f0f0f\">A part of a TRIP PATTERN corresponding to the movement of a user in a single vehicle, or a pedestrian mode such as walking.</font>"
  ; rdfs:subClassOf tm:LINK
  .

tm:CONNECTION_LEG a owl:Class ;
  rdfs:label "CONNECTION LEG"
  ; rdfs:comment "A part of a TRIP PATTERN corresponding to the movement of a passenger transferring from one SERVICE JOURNEY to another, made over a CONNECTION from one SCHEDULED STOP POINT (or VEHICLE MEETING POINT) to another, and possibly following a specific NAVIGATION PATH<font color=\"#0f0f0f\">.</font>"
  ; rdfs:subClassOf tm:TRANSFER_LEG
  .

tm:PERSONAL_LEG a owl:Class ;
  rdfs:label "PERSONAL LEG"
  ; rdfs:comment "A part of a TRIP PATTERN corresponding to the movement of a user from one PLACE to another, where the TRIP is made entirely by personal means, and neither of the endpoints is a SCHEDULED STOP POINT or VEHICLE MEETING POINT."
  ; rdfs:subClassOf tm:LEG
  .

tm:TRIP a owl:Class ;
  rdfs:label "TRIP"
  ; rdfs:comment "A part of a TRIP PATTERN describing the movement of a passenger from one PLACE of any sort to another.  NOTE: A TRIP may consist of one or more consecutive LEGs having some common characteristics."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:TRAVEL a owl:Class ;
  rdfs:label "TRAVEL"
  ; rdfs:comment "A sequence of TRIP PATTERNs made by a passenger."
  .

tm:TRAVELLING_ENTITY a owl:Class ;
  rdfs:label "TRAVELLING ENTITY"
  ; rdfs:comment "A moving person or object following a TRIP PATTERN."
  .

tm:TRAVEL_FLOW a owl:Class ;
  rdfs:label "TRAVEL FLOW"
  ; rdfs:comment "A summary of the TRAVELs made by many passengers"
  .

tm:TYPE_OF_TRAVELLING_ENTITY a owl:Class ;
  rdfs:label "TYPE OF TRAVELLING ENTITY"
  ; rdfs:comment "A classification of a TRAVELLING ENTITY, e.g., as person, family, cyclist, driver in car, tracked mobile phone, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_PASSENGER a owl:Class ;
  rdfs:label "TYPE OF PASSENGER"
  ; rdfs:comment "A classification of passenger."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MONITORED_LEG_CALL_PART a owl:Class ;
  rdfs:label "MONITORED LEG CALL PART"
  ; rdfs:comment "A view that brings together data to present to a passenger making a specific MONITORED TRIP relating to the arrival to or the departure from a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  .

tm:MONITORED_TRIP_PATTERN a owl:Class ;
  rdfs:label "MONITORED TRIP PATTERN"
  ; rdfs:comment "A monitored passenger movement from an origin to a destination PLACE, consisting of one or more MONITORED LEGs undertaken in sequence."
  .

tm:MONITORED_TRIP a owl:Class ;
  rdfs:label "MONITORED TRIP"
  ; rdfs:comment "A part of a MONITORED TRIP PATTERN corresponding to the movement of a passenger from one PLACE of any sort to another as one or more LEGS, possibly with some common characteristics"
  .

tm:MONITORED_LEG_DEPARTURE a owl:Class ;
  rdfs:label "MONITORED LEG DEPARTURE"
  ; rdfs:comment "A view that brings together data to present to the passenger making a specific MONITORED TRIP relating to the departure from a POINT IN JOURNEY PATTERN in a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:MONITORED_LEG_CALL_PART
  .

tm:TRIP_PATTERN_MONITORING a owl:Class ;
  rdfs:label "TRIP PATTERN MONITORING"
  ; rdfs:comment "Real-time monitoring of a passenger movement to provide progress information for a passenger."
  .

tm:MONITORED_LEG_CALL a owl:Class ;
  rdfs:label "MONITORED LEG CALL"
  ; rdfs:comment "Data to present to a passenger making a specific MONITORED TRIP relating to the status of an individual visit by a VEHICLE JOURNEY to a POINT IN JOURNEY PATTERN.  NOTE: May be for origin, destination, and intermediate points."
  .

tm:MONITORED_LEG_PROGRESS a owl:Class ;
  rdfs:label "MONITORED LEG PROGRESS"
  ; rdfs:comment "The relative progress of a passenger along a LEG."
  .

tm:MONITORED_LEG a owl:Class ;
  rdfs:label "MONITORED LEG"
  ; rdfs:comment "A part of a MONITORED TRIP PATTERN corresponding to the movement of a user in a single vehicle, or a pedestrian mode such as walking."
  .

tm:MONITORED_LEG_ARRIVAL a owl:Class ;
  rdfs:label "MONITORED LEG ARRIVAL"
  ; rdfs:comment "A view that brings together data to present to a passenger making a specific MONITORED TRIP relating to the arrival at a POINT IN JOURNEY PATTERN of a DATED VEHICLE JOURNEY."
  ; rdfs:subClassOf tm:MONITORED_LEG_CALL_PART
  .

tm:PASSENGER_FARE_OFFER a owl:Class ;
  rdfs:label "PASSENGER FARE OFFER"
  ; rdfs:comment "An available fare for a specific PT RIDE LEG in a PT TRIP or for the whole PT TRIP, or for the whole TRIP PATTERN.  NOTE: The fare may be restricted to particular products and conditions as described by SPECIFIC PARAMETER ASSIGNMENTs."
  .

tm:MEAN_RUN_TIME a owl:Class ;
  rdfs:label "MEAN RUN TIME"
  ; rdfs:comment "An estimated value of the mean run time on a TIMING LINK, used to inform passengers on the mean duration of trips."
  ; rdfs:subClassOf tm:JOURNEY_RUN_TIME
  .

tm:MEAN_INTERCHANGE_TIME a owl:Class ;
  rdfs:label "MEAN INTERCHANGE TIME"
  ; rdfs:comment "An estimated value of the mean time to make an INTERCHANGE, used to inform passengers on the mean duration of trips.  NOTE: May be derived from low level breakdown."
  ; rdfs:subClassOf tm:TRANSFER_TIME
  .

tm:MEAN_PASSENGER_WAIT_TIME a owl:Class ;
  rdfs:label "MEAN PASSENGER WAIT TIME"
  ; rdfs:comment "An estimated mean waiting time for a passenger at a SCHEDULED STOP POINT, used to calculate the approximate duration of a trip.  NOTE: This value is estimated from the mean interval between vehicles on a JOURNEY PATTERN or a COMMON SECTION."
  ; rdfs:subClassOf tm:JOURNEY_WAIT_TIME
  .

tm:PI_REQUEST_POLICY a owl:Class ;
  rdfs:label "PI REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Optimisation criteria to be used when computing and decorating the results for the PI REQUEST.</font>"
  .

tm:PARTICIPANT_SYSTEM a owl:Class ;
  rdfs:label "PARTICIPANT SYSTEM"
  ; rdfs:comment "A SYSTEM supporting a service to fulfil specific types of PI REQUESTs.  NOTE: May be associated with one or more DATA SOURCEs."
  .

tm:TYPE_OF_REQUEST a owl:Class ;
  rdfs:label "TYPE OF REQUEST"
  ; rdfs:comment "A classification of PI REQUESTs."
  .

tm:PI_REQUEST_FILTER a owl:Class ;
  rdfs:label "PI REQUEST FILTER"
  ; rdfs:comment "<font color=\"#0f0f0f\">Filtering criteria to be used when computing the results for a PI REQUEST.</font>"
  .

tm:PI_REQUEST a owl:Class ;
  rdfs:label "PI REQUEST"
  ; rdfs:comment "A request for specific information on public transport."
  .

tm:PI_DELIVERY a owl:Class ;
  rdfs:label "PI DELIVERY"
  ; rdfs:comment "A connection of a passenger to the operator information system, directly or via an employee, including one or several queries, and returning results."
  .

tm:EXCHANGE_POINTS_REQUEST_POLICY a owl:Class ;
  rdfs:label "EXCHANGE POINTS REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when executing an EXCHANGE POINT REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:EXCHANGE_POINTS_DELIVERY a owl:Class ;
  rdfs:label "EXCHANGE POINTS DELIVERY"
  ; rdfs:comment "The result returned by an EXCHANGE POINTS REQUEST."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:EXCHANGE_POINTS_REQUEST a owl:Class ;
  rdfs:label "EXCHANGE POINTS REQUEST"
  ; rdfs:comment "A PI REQUEST to find POINTs that can be used in distributed trip planning as common boundary SCHEDULED STOP POINTs between adjacent regions of separate data coverage."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:EXCHANGE_POINTS_REQUEST_FILTER a owl:Class ;
  rdfs:label "EXCHANGE POINTS REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the EXCHANGE POINTS REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:LOCATION_DELIVERY a owl:Class ;
  rdfs:label "LOCATION DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY to make one or more LOCATION REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:PLACE_RESULT a owl:Class ;
  rdfs:label "PLACE RESULT"
  ; rdfs:comment "Information on a place returned as part of LOCATION DELIVERY."
  .

tm:LOCATION_REQUEST a owl:Class ;
  rdfs:label "LOCATION REQUEST"
  ; rdfs:comment "A PI REQUEST to find a stop."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:LOCATION_PLACE_FILTER a owl:Class ;
  rdfs:label "LOCATION PLACE FILTER"
  ; rdfs:comment "Filter parameters used to limit the PLACE related results of the LOCATION REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:LOCATION_GEOMETRY_RESTRICTION a owl:Class ;
  rdfs:label "LOCATION GEOMETRY RESTRICTION"
  ; rdfs:comment "Filter parameters used to limit the spatial results of the LOCATION REQUEST."
  .

tm:LOCATION_REQUEST_POLICY a owl:Class ;
  rdfs:label "LOCATION REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when finding and decorating trip stops."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:STOP_EVENT_REQUEST a owl:Class ;
  rdfs:label "STOP EVENT REQUEST"
  ; rdfs:comment "A PI REQUEST about arrivals and departures from a given stop and/or LOGICAL DISPLAY at that stop."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:STOP_EVENT_DELIVERY a owl:Class ;
  rdfs:label "STOP EVENT DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY to make one or more STOP EVENT REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:STOP_EVENT_REQUEST_POLICY a owl:Class ;
  rdfs:label "STOP EVENT REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when computing and decorating STOP EVENT REQUEST results."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:STOP_EVENT_REQUEST_CONTENT_FILTER a owl:Class ;
  rdfs:label "STOP EVENT REQUEST CONTENT FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the STOP EVENT REQUESTs."
  ; rdfs:subClassOf tm:TRIP_REQUEST_FILTER
  .

tm:SCHEDULE_REQUEST_POLICY a owl:Class ;
  rdfs:label "SCHEDULE REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when computing and decorating SCHEDULE REQUEST results."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:SCHEDULE_DELIVERY a owl:Class ;
  rdfs:label "SCHEDULE DELIVERY"
  ; rdfs:comment "A specialization of PI DELIVERY to make one or more SCHEDULE REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:SCHEDULE_REQUEST a owl:Class ;
  rdfs:label "SCHEDULE REQUEST"
  ; rdfs:comment "A PI REQUEST about public timetables."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:SCHEDULE_REQUEST_CONTENT_FILTER a owl:Class ;
  rdfs:label "SCHEDULE REQUEST CONTENT FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the SCHEDULE REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:TRIP_MOBILITY_FILTER a owl:Class ;
  rdfs:label "TRIP MOBILITY FILTER"
  ; rdfs:comment "Filter parameters determined by accessibility criteria."
  .

tm:TRIP_REQUEST_FILTER a owl:Class ;
  rdfs:label "TRIP REQUEST FILTER"
  ; rdfs:comment "Filter parameters common to TRIP REQUESTs."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:TRIP_DELIVERY a owl:Class ;
  rdfs:label "TRIP DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to make one or more TRIP REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:TRIP_ACCESS_CONSTRAINT a owl:Class ;
  rdfs:label "TRIP ACCESS CONSTRAINT"
  ; rdfs:comment "Parameters limiting the time and nature of the access leg used to reach the PT stop (e.g., to be able to specify \"Walk up to 5 minutes\", \"cycle up to 20 minutes\", \"drive up to 30 minutes\", etc.)."
  .

tm:TRIP_DESTINATION_PLACE a owl:Class ;
  rdfs:label "TRIP DESTINATION PLACE"
  ; rdfs:comment "A destination location for a TRIP REQUEST."
  ; rdfs:subClassOf tm:TRIP_REQUEST_PLACE
  .

tm:TRIP_REQUEST a owl:Class ;
  rdfs:label "TRIP REQUEST"
  ; rdfs:comment "A PI REQUEST to make an optimal trip proposal, according to a specified TRIP REQUEST POLICY."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:TRIP_VIA_PLACE a owl:Class ;
  rdfs:label "TRIP VIA PLACE"
  ; rdfs:comment "A routing location used to constrain the journeys returned; only VEHICLE JOURNEYs whose JOURNEY PATTERNs do or do not pass through the specified points will be returned."
  ; rdfs:subClassOf tm:TRIP_REQUEST_PLACE
  .

tm:TRIP_ORIGIN_PLACE a owl:Class ;
  rdfs:label "TRIP ORIGIN PLACE"
  ; rdfs:comment "An origin location for a TRIP REQUEST."
  ; rdfs:subClassOf tm:TRIP_REQUEST_PLACE
  .

tm:TRIP_REQUEST_PLACE a owl:Class ;
  rdfs:label "TRIP REQUEST PLACE"
  ; rdfs:comment "Origin, destination or via locations of a trip subject of a TRIP REQUEST."
  .

tm:TRIP_REQUEST_POLICY a owl:Class ;
  rdfs:label "TRIP REQUEST POLICY"
  ; rdfs:comment "Optimisation criteria to be used to when computing and decorating trip plans."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:SERVICE_JOURNEY_REQUEST a owl:Class ;
  rdfs:label "SERVICE JOURNEY REQUEST"
  ; rdfs:comment "A PI REQUEST to find information about a specific SERVICE JOURNEY."
  ; rdfs:subClassOf tm:PI_REQUEST
  .

tm:SERVICE_JOURNEY_DELIVERY a owl:Class ;
  rdfs:label "SERVICE JOURNEY DELIVERY"
  ; rdfs:comment "A specialisation of PI DELIVERY to respond to one or more SERVICE JOURNEY REQUESTs."
  ; rdfs:subClassOf tm:PI_DELIVERY
  .

tm:SERVICE_JOURNEY_REQUEST_POLICY a owl:Class ;
  rdfs:label "SERVICE JOURNEY REQUEST POLICY"
  ; rdfs:comment "<font color=\"#0f0f0f\">Criteria to be used to when computing and decorating results for a </font>SERVICE JOURNEY REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_POLICY
  .

tm:SITUATION_REQUEST_FILTER a owl:Class ;
  rdfs:label "SITUATION REQUEST FILTER"
  ; rdfs:comment "Filter parameters used to limit the results of the SITUATION REQUEST."
  ; rdfs:subClassOf tm:PI_REQUEST_FILTER
  .

tm:SPARE_DUTY a owl:Class ;
  rdfs:label "SPARE DUTY"
  ; rdfs:comment "A DUTY to which specific timed work has not yet been assigned."
  ; rdfs:subClassOf tm:DUTY
  .

tm:REFUELLING_EQUIPMENT a owl:Class ;
  rdfs:label "REFUELLING EQUIPMENT"
  ; rdfs:comment "A fixed EQUIPMENT used for refuelling vehicles."
  ; rdfs:subClassOf tm:PLACE_EQUIPMENT
  .

tm:VEHICLE_RELEASE_EQUIPMENT a owl:Class ;
  rdfs:label "VEHICLE RELEASE EQUIPMENT"
  ; rdfs:comment "A specialisation of INSTALLED EQUIPMENT describing equipment for releasing a vehicle from a lock so it can be used."
  ; rdfs:subClassOf tm:INSTALLED_EQUIPMENT
  .

tm:ALTERNATIVE_MODE_LEG a owl:Class ;
  rdfs:label "ALTERNATIVE MODE LEG"
  ; rdfs:comment "A part of a TRIP PATTERN corresponding to the movement of a user (passenger, driver) using an ALTERNATIVE MODE OF OPERATION from one PLACE to another and that is not an ACCESS LEG nor a CONNECTION LEG."
  ; rdfs:subClassOf tm:RIDE_LEG
  .

tm:SERVICE_BOOKING_ARRANGEMENT a owl:Class ;
  rdfs:label "SERVICE BOOKING ARRANGEMENT"
  ; rdfs:comment "Information on booking rules and additional data allowing the user to take the decision to book a service and to undertake the booking of a LOCAL SERVICE."
  ; rdfs:subClassOf tm:BOOKING_ARRANGEMENT
  .

tm:PARKING_AREA_CAPACITY_ASSIGNMENT a owl:Class ;
  rdfs:label "PARKING AREA CAPACITY ASSIGNMENT"
  ; rdfs:comment "The allocation of a number of spots for a particular VEHICLE TYPE within a PARKING AREA."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:VEHICLE_ACCESS_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE ACCESS ASSIGNMENT"
  ; rdfs:comment "The allocation of a MEDIUM ACCESS DEVICE to a specific VEHICLE, to allow the user (TRANSPORT CUSTOMER) to access the vehicle (typically for VEHICLE SHARING or VEHICLE RENTAL).  NOTE: This allocation may have validity limitations."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:SERVICE_ACCESS_CODE a owl:Class ;
  rdfs:label "SERVICE ACCESS CODE"
  ; rdfs:comment "Code to access a service, can be numerical code, barcode, flashcode, etc."
  ; rdfs:subClassOf tm:TRAVEL_DOCUMENT
  .

tm:MONITORED_VEHICLE_SERVICE_PARKING_BAY a owl:Class ;
  rdfs:label "MONITORED VEHICLE SERVICE PARKING BAY"
  ; rdfs:comment "A spot in the PARKING AREA dedicated to VEHICLE SHARING or VEHICLE RENTING which is monitored for occupancy."
  ; rdfs:subClassOf tm:VEHICLE_SHARING_PARKING_BAY
  .

tm:PARKING_BAY_STATUS a owl:Class ;
  rdfs:label "PARKING BAY STATUS"
  ; rdfs:comment "A categorisation of the availability of the parking spot, such as being temporarily closed, unavailable, available."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:VEHICLE_POOLER_PROFILE a owl:Class ;
  rdfs:label "VEHICLE POOLER PROFILE"
  ; rdfs:comment "A set of USER PARAMETERS required for a specific SINGLE JOURNEY of a VEHICLE POOLING SERVICE."
  ; rdfs:subClassOf tm:USER_PROFILE
  .

tm:VEHICLE_POOLING_DRIVER_INFO a owl:Class ;
  rdfs:label "VEHICLE POOLING DRIVER INFO"
  ; rdfs:comment "Information characterising an INDIVIDUAL TRAVELLER as a driver of a VEHICLE POOLING SERVICE."
  .

tm:INDIVIDUAL_PASSENGER_INFO a owl:Class ;
  rdfs:label "INDIVIDUAL PASSENGER INFO"
  ; rdfs:comment "Information characterising an INDIVIDUAL TRAVELLER as a user of any MODE of transport, based on any MODE OF OPERATION."
  .

tm:INDIVIDUAL_TRAVELLER a owl:Class ;
  rdfs:label "INDIVIDUAL TRAVELLER"
  ; rdfs:comment "Individual travelling person."
  ; rdfs:subClassOf tm:TRAVELLING_ENTITY
  .

tm:INDIVIDUAL_DRIVER_ROLE a owl:Class ;
  rdfs:label "INDIVIDUAL DRIVER ROLE"
  ; rdfs:comment "The role of a user driving a vehicle and providing a travel service as a single individual (for example, in the context of car pooling)."
  ; rdfs:subClassOf tm:TRANSPORT_USER_ROLE
  .

tm:DUTY_PART a owl:Class ;
  rdfs:label "DUTY PART"
  ; rdfs:comment "A continuous part of a driver DUTY during which the driver is under the management of the company and which may include BREAKs."
  ; rdfs:subClassOf tm:TIME_ACCOUNTABLE_ACTIVITY
  .

tm:DUTY a owl:Class ;
  rdfs:label "DUTY"
  ; rdfs:comment "The work to be performed by a driver on a particular DAY TYPE."
  ; rdfs:subClassOf tm:TIME_ACCOUNTABLE_ACTIVITY
  .

tm:ASSIGNED_DUTY a owl:Class ;
  rdfs:label "ASSIGNED DUTY"
  ; rdfs:comment "A DUTY to which specific timed work has been assigned."
  ; rdfs:subClassOf tm:DUTY
  .

tm:TASK a owl:Class ;
  rdfs:label "TASK"
  ; rdfs:comment "Any continuous piece of non-driving work, performed by a driver."
  ; rdfs:subClassOf tm:NON_DRIVING_SPELL
  .

tm:BREAK_FACILITY a owl:Class ;
  rdfs:label "BREAK FACILITY"
  ; rdfs:comment "A canteen, cafe, kiosk or any place where drivers have toilet and refreshment facilities."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:STAND_BY a owl:Class ;
  rdfs:label "STAND-BY"
  ; rdfs:comment "A non-driving period of a driver's DUTY when the driver must wait ready to take on any specified piece of work instantly."
  ; rdfs:subClassOf tm:NON_DRIVING_SPELL
  .

tm:NON_DRIVING_SPELL a owl:Class ;
  rdfs:label "NON-DRIVING SPELL"
  ; rdfs:comment "A continuous period in a STRETCH when a driver is performing some non-driving TASK or waiting on STAND-BY."
  ; rdfs:subClassOf tm:SPELL
  .

tm:DRIVING_SPELL a owl:Class ;
  rdfs:label "DRIVING SPELL"
  ; rdfs:comment "A continuous period in a STRETCH, during which a driver is on duty in one vehicle."
  ; rdfs:subClassOf tm:SPELL
  .

tm:TYPE_OF_TASK a owl:Class ;
  rdfs:label "TYPE OF TASK"
  ; rdfs:comment "A classification of a TASK."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SPELL a owl:Class ;
  rdfs:label "SPELL"
  ; rdfs:comment "A continuous period in a STRETCH, when a driver is on duty on one vehicle or performing one other type of work."
  ; rdfs:subClassOf tm:ACCOUNTABLE_ACTIVITY
  .

tm:STRETCH a owl:Class ;
  rdfs:label "STRETCH"
  ; rdfs:comment "A STRETCH is a period of a driver's DUTY during which the driver is continuously working without a BREAK but that may include PAUSEs during which the driver remains responsible for the vehicle."
  ; rdfs:subClassOf tm:TIME_ACCOUNTABLE_ACTIVITY
  .

tm:BREAK a owl:Class ;
  rdfs:label "BREAK"
  ; rdfs:comment "A period of time within a DUTY PART during which the driver is not responsible for a vehicle and can rest, usually at a BREAK FACILITY."
  ; rdfs:subClassOf tm:ACCOUNTABLE_ACTIVITY
  .

tm:PAUSE a owl:Class ;
  rdfs:label "PAUSE"
  ; rdfs:comment "A period of paid driver time at the end of a SERVICE JOURNEY or during or after a DEAD RUN when the driver is responsible for the VEHICLE, but resting in the VEHICLE or in a designated BREAK FACILITY near the POINT where the VEHICLE has stopped."
  ; rdfs:subClassOf tm:TIME_ACCOUNTABLE_ACTIVITY
  .

tm:TYPE_OF_ALLOWANCE a owl:Class ;
  rdfs:label "TYPE OF ALLOWANCE"
  ; rdfs:comment "A classification of additional paid times, including the information whether the allowance is given before or after the main activity."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:FILL_IN_TIME a owl:Class ;
  rdfs:label "FILL IN TIME"
  ; rdfs:comment "A non-productive period of driver time that is the result of the duty cutting procedure or is introduced to prolong a DRIVING SPELL to a minimum length."
  ; rdfs:subClassOf tm:ACCOUNTABLE_ACTIVITY
  .

tm:TIME_ALLOWANCE a owl:Class ;
  rdfs:label "TIME ALLOWANCE"
  ; rdfs:comment "A fixed paid time allowed to perform certain activities to prepare for or to complete the work assigned either to a BLOCK, a DUTY, a DUTY PART, a STRETCH or a SPELL."
  .

tm:DRIVER_TRIP a owl:Class ;
  rdfs:label "DRIVER TRIP"
  ; rdfs:comment "A planned non-driving movement of a driver within a DUTY PART between two TIMING POINTs that may include using one or several VEHICLE JOURNEYs on vehicles driven by other drivers."
  ; rdfs:subClassOf tm:ACCOUNTABLE_ACTIVITY
  .

tm:DRIVER_TRIP_TIME a owl:Class ;
  rdfs:label "DRIVER TRIP TIME"
  ; rdfs:comment "The time allowed for a driver to cover a particular DRIVER TRIP during a specified TIME BAND."
  .

tm:DUTY_TYPE a owl:Class ;
  rdfs:label "DUTY TYPE"
  ; rdfs:comment "A classification of a DUTY, in terms of working hours within the day."
  .

tm:CONTINUOUS_DUTY a owl:Class ;
  rdfs:label "CONTINUOUS DUTY"
  ; rdfs:comment "A classification of a DUTY, in terms of working hours within the day comprising a single period of paid work."
  ; rdfs:subClassOf tm:DUTY_TYPE
  .

tm:SPLIT_DUTY a owl:Class ;
  rdfs:label "SPLIT DUTY"
  ; rdfs:comment "A classification of a DUTY, in terms of working hours comprising several time bands separated in different DUTY PARTs by periods of unpaid time."
  ; rdfs:subClassOf tm:DUTY_TYPE
  .

tm:DRIVER_SCHEDULE_FRAME a owl:Class ;
  rdfs:label "DRIVER SCHEDULE FRAME"
  ; rdfs:comment "A coherent set of DUTies to which the same set of VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:ROW_DRIVER a owl:Class ;
  rdfs:label "ROW/DRIVER"
  ; rdfs:comment "A row in a ROSTER MATRIX which is related to a theoretically available driver."
  .

tm:ROSTER_MATRIX a owl:Class ;
  rdfs:label "ROSTER MATRIX"
  ; rdfs:comment "A table showing the duty plan for a period of days and for a number of theoretically available drivers."
  .

tm:ROSTER_ELEMENT a owl:Class ;
  rdfs:label "ROSTER ELEMENT"
  ; rdfs:comment "A cell in a ROSTER MATRIX where the individual DUTY to be performed by a theoretically available driver on a certain OPERATING DAY is entered or it is marked that it is a day of rest."
  .

tm:REST a owl:Class ;
  rdfs:label "REST"
  ; rdfs:comment "A representation of a day off for a driver, crew member or other EMPLOYEE."
  .

tm:COLUMN_DAY a owl:Class ;
  rdfs:label "COLUMN/DAY"
  ; rdfs:comment "A column in a ROSTER MATRIX which is related to an OPERATING DAY."
  .

tm:WORK a owl:Class ;
  rdfs:label "WORK"
  ; rdfs:comment "A WORK is a representation of a day on duty for a driver."
  .

tm:ROSTER_CYCLE_ELEMENT a owl:Class ;
  rdfs:label "ROSTER CYCLE ELEMENT"
  ; rdfs:comment "A ROSTER CYCLE ELEMENT is an element of a ROSTER CYCLE which represents a day of work or rest for a theoretically available driver in the ordered sequence of days for that cycle."
  .

tm:ROSTER_CYCLE a owl:Class ;
  rdfs:label "ROSTER CYCLE"
  ; rdfs:comment "A ROSTER CYCLE is a sequence pattern of days of work and days of rest where the days of work may be further specified by a particular DUTY TYPE."
  .

tm:ROSTER_DESIGN a owl:Class ;
  rdfs:label "ROSTER DESIGN"
  ; rdfs:comment "An element for roster building made up of a particular number of DESIGN WEEKs, to each of which a different sequence pattern of DUTY TYPEs and days of rest will be assigned."
  .

tm:DESIGN_WEEK a owl:Class ;
  rdfs:label "DESIGN WEEK"
  ; rdfs:comment "A DESIGN WEEK is a week viewed as a part of a ROSTER DESIGN with a specified order in that design."
  .

tm:ROSTER_DESIGN_IN_MATRIX a owl:Class ;
  rdfs:label "ROSTER DESIGN IN MATRIX"
  ; rdfs:comment "A ROSTER DESIGN IN MATRIX describes the order in which different ROSTER DESIGNs are applied to construct a certain ROSTER MATRIX."
  .

tm:ROSTER_DESIGN_TYPE a owl:Class ;
  rdfs:label "ROSTER DESIGN TYPE"
  ; rdfs:comment "A ROSTER DESIGN TYPE is a classification of a ROSTER DESIGN which may describe the number of weeks that are covered, the proportion of work to free days or other characteristics."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:DESIGN_WEEK_ELEMENT a owl:Class ;
  rdfs:label "DESIGN WEEK ELEMENT"
  ; rdfs:comment "A DESIGN WEEK ELEMENT is an element of a DESIGN WEEK representing a particular DAY OF WEEK designating if it is a day of rest or work according to a specific DUTY TYPE for a theoretically available driver."
  .

tm:DRIVER_ASSIGNMENT a owl:Class ;
  rdfs:label "DRIVER ASSIGNMENT"
  ; rdfs:comment "An assignment of an EMPLOYEE to a ROW/DRIVER in a ROSTER MATRIX for a specified OPERATING DAY."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TYPE_OF_ABSENCE a owl:Class ;
  rdfs:label "TYPE OF ABSENCE"
  ; rdfs:comment "A classification that indicates the reason why an EMPLOYEE is absent from work and if it is a planned or un-planned absence."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ABSENCE a owl:Class ;
  rdfs:label "ABSENCE"
  ; rdfs:comment "An actual absence of an EMPLOYEE from work on a particular OPERATING DAY for a specified time."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:ACCOUNTING_PERIOD a owl:Class ;
  rdfs:label "ACCOUNTING PERIOD"
  ; rdfs:comment "An ACCOUNTING PERIOD is a continuous interval between two OPERATING DAYs which will be used for accounting purposes."
  .

tm:WAGE_INCREASE a owl:Class ;
  rdfs:label "WAGE INCREASE"
  ; rdfs:comment "a WAGE INCREASE is an indication to the accountancy software that the performed work was affected by aggravating circumstances to such a degree that additional payment should be allotted."
  .

tm:COST_CENTRE a owl:Class ;
  rdfs:label "COST CENTRE"
  ; rdfs:comment "A COST CENTRE is a business unit, or other type of classification used by an ORGANISATIONS's accountancy department, to which costs can be collected or attributed according to cost type and origin."
  .

tm:ACCOUNT_ENTRY a owl:Class ;
  rdfs:label "ACCOUNT ENTRY"
  ; rdfs:comment "An ACCOUNT ENTRY is a record of aggregated ACTIVITY LOG ENTRY data per WAGE TYPE, EMPLOYEE and COST CENTRE for one OPERATING DAY that is used to transfer information on duties actually worked by drivers to an external accounting system."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:WAGE_TYPE_ASSIGNMENT a owl:Class ;
  rdfs:label "WAGE TYPE ASSIGNMENT"
  ; rdfs:comment "A WAGE TYPE ASSIGNMENT is an assignment of a TYPE OF WAGE to a DAY TYPE and a TIME BAND."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TYPE_OF_WAGE a owl:Class ;
  rdfs:label "TYPE OF WAGE"
  ; rdfs:comment "A TYPE OF WAGE is a classification used for wage accounting, which associates sums of work time recorded in ACCOUNT ENTRies to TIME BANDs relevant for accounting."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:ACTIVITY_LOG_ENTRY a owl:Class ;
  rdfs:label "ACTIVITY LOG ENTRY"
  ; rdfs:comment "An ACTIVITY LOG ENTRY is a record, including the data needed for accounting, of the actual time worked (planned as well as unplanned), in a STRETCH, or spent for a BREAK, by an EMPLOYEE on a specified OPERATING DAY."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:LOGICAL_DRIVER_CANCELLATION a owl:Class ;
  rdfs:label "LOGICAL DRIVER CANCELLATION"
  ; rdfs:comment "A LOGICAL DRIVER CANCELLATION is a CONTROL ACTION consisting in removing a LOGICAL DRIVER from the production plan."
  ; rdfs:subClassOf tm:DRIVER_CONTROL_ACTION
  .

tm:CHANGE_OF_DRIVER a owl:Class ;
  rdfs:label "CHANGE OF DRIVER"
  ; rdfs:comment "A CHANGE OF DRIVER is a CONTROL ACTION consisting in removing, at a certain point in time and space (in principle a RELIEF POINT), all work assigned to a LOGICAL DRIVER and of assigning it to another LOGICAL DRIVER."
  ; rdfs:subClassOf tm:DRIVER_CONTROL_ACTION
  .

tm:DRIVER_CONTROL_ACTION a owl:Class ;
  rdfs:label "DRIVER CONTROL ACTION"
  ; rdfs:comment "A DRIVER CONTROL ACTION is a CONTROL ACTION affecting a LOGICAL DRIVER."
  ; rdfs:subClassOf tm:CONTROL_ACTION
  .

tm:LOGICAL_DRIVER_CREATION a owl:Class ;
  rdfs:label "LOGICAL DRIVER CREATION"
  ; rdfs:comment "A LOGICAL DRIVER CREATION is a CONTROL ACTION consisting in creating a completely new LOGICAL DRIVER and assigning dated spells to this LOGICAL DRIVER."
  ; rdfs:subClassOf tm:DRIVER_CONTROL_ACTION
  .

tm:LOCATED_EVENT a owl:Class ;
  rdfs:label "LOCATED EVENT"
  ; rdfs:comment "An EVENT with additional location and timing information"
  ; rdfs:subClassOf tm:EVENT
  .

tm:RECORDED_TRIP a owl:Class ;
  rdfs:label "RECORDED TRIP"
  ; rdfs:comment "The actual TRIP undertaken by a passenger from an origin to a destination."
  ; rdfs:subClassOf tm:TRIP_MONITORING_LOG_ENTRY
  .

tm:RECORDED_LEG a owl:Class ;
  rdfs:label "RECORDED LEG"
  ; rdfs:comment "The recording of the actual LEG followed by a passenger on an OPERATING DAY"
  ; rdfs:subClassOf tm:TRIP_MONITORING_LOG_ENTRY
  .

tm:INTERCHANGE_STATUS a owl:Class ;
  rdfs:label "INTERCHANGE STATUS"
  ; rdfs:comment "The information about the actual status of a SERVICE JOURNEY INTERCHANGE on a specified OPERATING DAY.  NOTE: Recorded information on missed interchanges may be of particular interest."
  ; rdfs:subClassOf tm:VEHICLE_MONITORING_LOG_ENTRY
  .

tm:BOARDING_AND_ALIGHTING a owl:Class ;
  rdfs:label "BOARDING AND ALIGHTING"
  ; rdfs:comment "The numbers of passengers boarding and alighting at a STOP POINT during a RECORDED STOP."
  ; rdfs:subClassOf tm:VEHICLE_MONITORING_LOG_ENTRY
  .

tm:RECORDED_STOP a owl:Class ;
  rdfs:label "RECORDED STOP"
  ; rdfs:comment "The recorded stop at a STOP POINT during actual service operation to possibly let passengers board or alight the vehicle."
  ; rdfs:subClassOf tm:VEHICLE_MONITORING_LOG_ENTRY
  .

tm:TYPE_OF_MODE_OF_OPERATION a owl:Class ;
  rdfs:label "TYPE OF MODE OF OPERATION"
  ; rdfs:comment "A classification for a MODE OF OPERATION."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:ALTERNATIVE_MODE_OF_OPERATION a owl:Class ;
  rdfs:label "ALTERNATIVE MODE OF OPERATION"
  ; rdfs:comment "Any publicly advertised mode of operation different from the CONVENTIONAL MODE OF OPERATION, for example: VEHICLE SHARING, VEHICLE RENTAL, VEHICLE POOLING."
  ; rdfs:subClassOf tm:MODE_OF_OPERATION
  .

tm:SCHEDULED_OPERATION a owl:Class ;
  rdfs:label "SCHEDULED OPERATION"
  ; rdfs:comment "The operation of a transportation using any kind of vehicle with a predefined timetable."
  ; rdfs:subClassOf tm:CONVENTIONAL_MODE_OF_OPERATION
  .

tm:MODE_OF_OPERATION a owl:Class ;
  rdfs:label "MODE OF OPERATION"
  ; rdfs:comment "Method of providing means of transport, this can be a CONVENTIONAL, ALTERNATIVE or a PERSONAL MODE OF OPERATION."
  .

tm:VEHICLE_POOLING a owl:Class ;
  rdfs:label "VEHICLE POOLING"
  ; rdfs:comment "An ALTERNATIVE MODE OF OPERATION of a privately-owned vehicle consisting in sharing the vehicle for a trip between the driver who is at the same time performing a trip and at least another traveller.  NOTE: Chauffeured Car and Taxi are special types of VEHICLE POOLING (with a dedicated TYPE OF OPERATION)."
  ; rdfs:subClassOf tm:ALTERNATIVE_MODE_OF_OPERATION
  .

tm:PERSONAL_MODE_OF_OPERATION a owl:Class ;
  rdfs:label "PERSONAL MODE OF OPERATION"
  ; rdfs:comment "<font color=\"#0f0f0f\">A non-advertised MODE OF OPERATION of vehicles by persons using their own vehicle.</font>"
  ; rdfs:subClassOf tm:MODE_OF_OPERATION
  .

tm:CONVENTIONAL_MODE_OF_OPERATION a owl:Class ;
  rdfs:label "CONVENTIONAL MODE OF OPERATION"
  ; rdfs:comment "Legacy mode of operation which is provided as a scheduled and/or flexible publicly advertised transport offer."
  ; rdfs:subClassOf tm:MODE_OF_OPERATION
  .

tm:VEHICLE_SHARING a owl:Class ;
  rdfs:label "VEHICLE SHARING"
  ; rdfs:comment "Short term VEHICLE RENTAL where the vehicle can be taken from and parked at different places in the urban area, possibly without the constraint to bring the vehicle back to a specific location."
  ; rdfs:subClassOf tm:ALTERNATIVE_MODE_OF_OPERATION
  .

tm:FLEXIBLE_OPERATION a owl:Class ;
  rdfs:label "FLEXIBLE OPERATION"
  ; rdfs:comment "Passenger transport operation linked to a fixed network/schedule but offering flexibility, in order for instance, to optimise the service or to satisfy passenger demand."
  ; rdfs:subClassOf tm:CONVENTIONAL_MODE_OF_OPERATION
  .

tm:VEHICLE_RENTAL a owl:Class ;
  rdfs:label "VEHICLE RENTAL"
  ; rdfs:comment "An ALTERNATIVE MODE OF OPERATION of a vehicle, part of a FLEET (in general, privately owned), available for use for a certain period of time and fee, with the constraint that it must be returned to specified agencies."
  ; rdfs:subClassOf tm:ALTERNATIVE_MODE_OF_OPERATION
  .

tm:FLEET a owl:Class ;
  rdfs:label "FLEET"
  ; rdfs:comment "A set of vehicles of any type."
  .

tm:TYPE_OF_FLEET a owl:Class ;
  rdfs:label "TYPE OF FLEET"
  ; rdfs:comment "A classification for a fleet of VEHICLEs."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TYPE_OF_MOBILITY_SERVICE a owl:Class ;
  rdfs:label "TYPE OF MOBILITY SERVICE"
  ; rdfs:comment "<font color=\"#0f0f0f\">Classification of MOBILITY SERVICE</font>"
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:TAXI_SERVICE a owl:Class ;
  rdfs:label "TAXI SERVICE"
  ; rdfs:comment "A type of VEHICLE POOLING SERVICE where the service may be regulated according to a particular taxi policy."
  ; rdfs:subClassOf tm:VEHICLE_POOLING_SERVICE
  .

tm:VEHICLE_RENTAL_SERVICE a owl:Class ;
  rdfs:label "VEHICLE RENTAL SERVICE"
  ; rdfs:comment "A transport service offer related to VEHICLE RENTAL."
  ; rdfs:subClassOf tm:COMMON_VEHICLE_SERVICE
  .

tm:CHAUFFEURED_VEHICLE_SERVICE a owl:Class ;
  rdfs:label "CHAUFFEURED VEHICLE SERVICE"
  ; rdfs:comment "A type of VEHICLE POOLING SERVICE which can only be used by prior arrangement and where the driver has a commercial agreement with the user."
  ; rdfs:subClassOf tm:VEHICLE_POOLING_SERVICE
  .

tm:VEHICLE_SHARING_SERVICE a owl:Class ;
  rdfs:label "VEHICLE SHARING SERVICE"
  ; rdfs:comment "A transport service offer related to VEHICLE SHARING."
  ; rdfs:subClassOf tm:COMMON_VEHICLE_SERVICE
  .

tm:VEHICLE_POOLING_SERVICE a owl:Class ;
  rdfs:label "VEHICLE POOLING SERVICE"
  ; rdfs:comment "A transport service that connects users (driver and passenger(s) to carry out SINGLE JOURNEYs."
  ; rdfs:subClassOf tm:COMMON_VEHICLE_SERVICE
  .

tm:ONLINE_SERVICE a owl:Class ;
  rdfs:label "ONLINE SERVICE"
  ; rdfs:comment "Any remotely accessible service providing access to any mode of transportation and/or information related to transportation services."
  ; rdfs:subClassOf tm:MOBILITY_SERVICE
  .

tm:ONLINE_SERVICE_OPERATOR a owl:Class ;
  rdfs:label "ONLINE SERVICE OPERATOR"
  ; rdfs:comment "An ORGANISATION that provides online access to an ONLINE SERVICE without necessarily operating transport services."
  ; rdfs:subClassOf tm:ORGANISATION
  .

tm:VEHICLE_MEETING_POINT a owl:Class ;
  rdfs:label "VEHICLE MEETING POINT"
  ; rdfs:comment "A POINT where drivers can pick up/drop off vehicles and passengers can board on (or alight from) vehicles in an ALTERNATIVE MODE OF OPERATION."
  ; rdfs:subClassOf tm:POINT
  .

tm:VEHICLE_MEETING_LINK a owl:Class ;
  rdfs:label "VEHICLE MEETING LINK"
  ; rdfs:comment "A LINK between an ordered pair of VEHICLE MEETING POINTs."
  ; rdfs:subClassOf tm:LINK
  .

tm:GROUP_OF_SINGLE_JOURNEYS a owl:Class ;
  rdfs:label "GROUP OF SINGLE JOURNEYS"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of SINGLE JOURNEYs grouped together for a functional purpose. </font>"
  ; rdfs:subClassOf tm:GROUP_OF_SERVICES
  .

tm:SINGLE_JOURNEY a owl:Class ;
  rdfs:label "SINGLE JOURNEY"
  ; rdfs:comment "The planned movement of any type of vehicle from the start point to the end point of a JOURNEY on a specified route."
  ; rdfs:subClassOf tm:JOURNEY
  .

tm:TAXI_PARKING_AREA a owl:Class ;
  rdfs:label "TAXI PARKING AREA"
  ; rdfs:comment "A specific area where any taxi is able to safely park for a long period."
  ; rdfs:subClassOf tm:PARKING_AREA
  .

tm:VEHICLE_POOLING_PARKING_AREA a owl:Class ;
  rdfs:label "VEHICLE POOLING PARKING AREA"
  ; rdfs:comment "A dedicated space of a PARKING AREA for either vehicles active in a VEHICLE POOLING SERVICE or vehicles of pooling service users, where vehicles can be left for a long time."
  ; rdfs:subClassOf tm:PARKING_AREA
  .

tm:PARKING_COMPONENT_PROPERTIES a owl:Class ;
  rdfs:label "PARKING COMPONENT PROPERTIES"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of public facing characteristics of a PARKING COMPONENT facilitating the recognition of the component by a traveller.</font>"
  .

tm:VEHICLE_MEETING_PLACE a owl:Class ;
  rdfs:label "VEHICLE MEETING PLACE"
  ; rdfs:comment "A place where vehicles and passengers meet to change mode of transportation, for boarding, alighting, pick-up, drop-off, etc."
  ; rdfs:subClassOf tm:ADDRESSABLE_PLACE
  .

tm:VEHICLE_POOLING_MEETING_PLACE a owl:Class ;
  rdfs:label "VEHICLE POOLING MEETING PLACE"
  ; rdfs:comment "A meeting place for VEHICLE POOLING, designated or agreed by the vehicle pooling driver and the traveller, i.e., where drivers and passengers meet for pick up/ drop off."
  ; rdfs:subClassOf tm:VEHICLE_MEETING_PLACE
  .

tm:TAXI_STAND a owl:Class ;
  rdfs:label "TAXI STAND"
  ; rdfs:comment "A set of spots where any taxi is able to safely stop for a short period of time to load passengers."
  ; rdfs:subClassOf tm:QUAY
  .

tm:VEHICLE_POOLING_PARKING_BAY a owl:Class ;
  rdfs:label "VEHICLE POOLING PARKING BAY"
  ; rdfs:comment "A dedicated spot to park either a vehicle active in a pooling service or a vehicle of a pooling service user."
  ; rdfs:subClassOf tm:PARKING_BAY
  .

tm:VEHICLE_SHARING_PARKING_BAY a owl:Class ;
  rdfs:label "VEHICLE SHARING PARKING BAY"
  ; rdfs:comment "A spot in the PARKING AREA dedicated to vehicle sharing or rental."
  ; rdfs:subClassOf tm:PARKING_BAY
  .

tm:VEHICLE_POOLING_PLACE_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE POOLING PLACE ASSIGNMENT"
  ; rdfs:comment "The allocation of a VEHICLE POOLING SERVICE to a VEHICLE POOLING PARKING AREA or a VEHICLE POOLING MEETING PLACE"
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_PLACE_ASSIGNMENT
  .

tm:VEHICLE_SHARING_PLACE_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE SHARING PLACE ASSIGNMENT"
  ; rdfs:comment "The allocation of a VEHICLE SHARING AREA to any vehicle sharing or rental service"
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_PLACE_ASSIGNMENT
  .

tm:VEHICLE_MEETING_POINT_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE MEETING POINT ASSIGNMENT"
  ; rdfs:comment "The allocation of a VEHICLE MEETING POINT to a SITE COMPONENT (for vehicle pooling or vehicle sharing purposes)"
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:DYNAMIC_VEHICLE_MEETING_POINT_ASSIGNMENT a owl:Class ;
  rdfs:label "DYNAMIC VEHICLE MEETING POINT ASSIGNMENT"
  ; rdfs:comment "Dynamic allocation of a VEHICLE MEETING ASSIGNMENT."
  ; rdfs:subClassOf tm:VEHICLE_MEETING_POINT_ASSIGNMENT
  .

tm:TYPE_OF_PARKING a owl:Class ;
  rdfs:label "TYPE OF PARKING"
  ; rdfs:comment "A classification for a PARKING, e.g., on street, multi-storey, parking lot, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SINGLE_JOURNEY_PATH a owl:Class ;
  rdfs:label "SINGLE JOURNEY PATH"
  ; rdfs:comment "An ordered list of POINTs IN SINGLE JOURNEY PATH on a single ROUTE, describing the pattern of working for an ALTERNATIVE MODE service.  NOTE1: A SINGLE JOURNEY PATH may pass through the same POINT more than once.  NOTE2: SINGLE JOURNEY PATH are mostly used to defined PATHs used by several SINGLE JOURNEYs."
  ; rdfs:subClassOf tm:LINK_SEQUENCE
  .

tm:MODE_RESTRICTION_ASSESSMENT a owl:Class ;
  rdfs:label "MODE RESTRICTION ASSESSMENT"
  ; rdfs:comment "Qualification of a ROUTE LINK resulting from the analysis of restrictions concerning the related INFRASTRUCTURE LINKs."
  .

tm:VEHICLE_MEETING_POINT_IN_PATH a owl:Class ;
  rdfs:label "VEHICLE MEETING POINT IN PATH"
  ; rdfs:comment "One VEHICLE MEETING POINT that can be the start or the end of a SINGLE JOURNEY PATH."
  ; rdfs:subClassOf tm:POINT_IN_LINK_SEQUENCE
  .

tm:COMMON_VEHICLE_SERVICE a owl:Class ;
  rdfs:label "COMMON VEHICLE SERVICE"
  ; rdfs:comment "A transport service offer related to VEHICLEs."
  ; rdfs:subClassOf tm:MOBILITY_SERVICE
  .

tm:TYPE_OF_SPOT_AFFINITY a owl:Class ;
  rdfs:label "TYPE OF SPOT AFFINITY"
  ; rdfs:comment "A classification of a seat affinity as being side by side, face to face, around a table, near a wheelchair spot, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:VEHICLE_SHARING_PARKING_AREA a owl:Class ;
  rdfs:label "VEHICLE SHARING PARKING AREA"
  ; rdfs:comment "A dedicated part of the PARKING AREA for vehicle sharing or rental which is composed of one or more VEHICLE SHARING PARKING BAYs."
  ; rdfs:subClassOf tm:PARKING_AREA
  .

tm:TAXI_SERVICE_PLACE_ASSIGNMENT a owl:Class ;
  rdfs:label "TAXI SERVICE PLACE ASSIGNMENT"
  ; rdfs:comment "The allocation of a TAXI SERVICE to a TAXI PARKING AREA or a TAXI STAND."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_PLACE_ASSIGNMENT
  .

tm:VEHICLE_MODEL_PROFILE a owl:Class ;
  rdfs:label "VEHICLE MODEL PROFILE"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of characteristics of equipment installed on-board and characterising a VEHICLE MODEL.</font>"
  .

tm:CAR_MODEL_PROFILE a owl:Class ;
  rdfs:label "CAR MODEL PROFILE"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of characteristics of equipment provided with a car characterising the specific VEHICLE MODEL.</font>"
  ; rdfs:subClassOf tm:VEHICLE_MODEL_PROFILE
  .

tm:CYCLE_MODEL_PROFILE a owl:Class ;
  rdfs:label "CYCLE MODEL PROFILE"
  ; rdfs:comment "<font color=\"#0f0f0f\">A set of characteristics of equipment provided with a cycle that characterise the specific VEHICLE MODEL.</font>"
  ; rdfs:subClassOf tm:VEHICLE_MODEL_PROFILE
  .

tm:ONLINE_SERVICE_OPERATOR_ROLE a owl:Class ;
  rdfs:label "ONLINE SERVICE OPERATOR ROLE"
  ; rdfs:comment "The role of an ORGANISATION that provides an online service to the customer who uses a product - in particular, the carrier role for public transport, but also possibly ancillary services such as catering, baggage handling, parking, etc."
  ; rdfs:subClassOf tm:TRAVEL_ORGANISATION_ROLE
  .

tm:TRACTIVE_ROLLING_STOCK_ITEM a owl:Class ;
  rdfs:label "TRACTIVE ROLLING STOCK ITEM"
  ; rdfs:comment "A powered item of rolling stock, such as a specific locomotive or powered railcar."
  ; rdfs:subClassOf tm:ROLLING_STOCK_ITEM
  .

tm:TRAILING_ROLLING_STOCK_ITEM a owl:Class ;
  rdfs:label "TRAILING ROLLING STOCK ITEM"
  ; rdfs:comment "An unpowered item of rolling stock such as a specific passenger carriage, luggage van, passenger vehicle carrier wagon or freight wagon."
  ; rdfs:subClassOf tm:ROLLING_STOCK_ITEM
  .

tm:TRANSPORT_ORGANISATION a owl:Class ;
  rdfs:label "TRANSPORT ORGANISATION"
  ; rdfs:comment "Specialisation of ORGANISATION providing transport services related to particular modes of operation."
  ; rdfs:subClassOf tm:ORGANISATION
  .

tm:TAXI_RANK a owl:Class ;
  rdfs:label "TAXI RANK"
  ; rdfs:comment "A STOP PLACE specifically for taxis, comprising one or more TAXI STANDs."
  ; rdfs:subClassOf tm:STOP_PLACE
  .

tm:VEHICLE_TYPE a owl:Class ;
  rdfs:label "VEHICLE TYPE"
  ; rdfs:comment "A classification of public transport vehicles according to the vehicle scheduling requirements in mode and capacity (e.g., standard bus, double-decker, etc.).  NOTE: The VEHICLE TYPE is distinct from the VEHICLE MODEL which describes features of a class of vehicles, e.g., Model T Ford, and the VEHICLE EQUIPMENT PROFILE, which lists details of the equipment with which a VEHICLE MODEL is equipped."
  ; rdfs:subClassOf tm:TRANSPORT_TYPE
  .

tm:SIMPLE_VEHICLE_TYPE a owl:Class ;
  rdfs:label "SIMPLE VEHICLE TYPE"
  ; rdfs:comment "A classification of a personal transport means (cycle, scooter, skis, etc.) according to its properties."
  ; rdfs:subClassOf tm:TRANSPORT_TYPE
  .

tm:TYPE_OF_FUEL a owl:Class ;
  rdfs:label "TYPE OF FUEL"
  ; rdfs:comment "A classification of the type of fuel used by a VEHICLE."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:MOBILITY_SERVICE a owl:Class ;
  rdfs:label "MOBILITY SERVICE"
  ; rdfs:comment "<font color=\"#445469\">An alternative mode transport service available over a widespread area<b>, </b>for example, car pooling, rental, etc. </font>NOTE: <font color=\"#445469\">The service may be accessible at designated SITEs</font>"
  ; rdfs:subClassOf tm:EQUIPMENT
  .

tm:GENERAL_POOLING_SERVICE a owl:Class ;
  rdfs:label "GENERAL POOLING SERVICE"
  ; rdfs:comment "A transport service that connects private vehicle owners and passenger(s) to carry out SINGLE JOURNEYs."
  ; rdfs:subClassOf tm:VEHICLE_POOLING_SERVICE
  .

tm:VEHICLE_SERVICE_PLACE_ASSIGNMENT a owl:Class ;
  rdfs:label "VEHICLE SERVICE PLACE ASSIGNMENT"
  ; rdfs:comment "The allocation of a VEHICLE SERVICE to a SITE ELEMENT or a VEHICLE MEETING PLACE."
  ; rdfs:subClassOf tm:ASSIGNMENT
  .

tm:TRAIN_COMPOSITION a owl:Class ;
  rdfs:label "TRAIN COMPOSITION"
  ; rdfs:comment "A specific instance of a TRAIN composed of TRAIN COMPOSITION COMPONENTs in a certain order."
  ; rdfs:subClassOf tm:VEHICLE
  .

tm:COMPOUND_TRAIN_COMPOSITION a owl:Class ;
  rdfs:label "COMPOUND TRAIN COMPOSITION"
  ; rdfs:comment "A TRAIN COMPOSITION composed of a sequence of other shorter TRAIN COMPOSITIONs."
  ; rdfs:subClassOf tm:TRAIN_COMPOSITION
  .

tm:TRAIN_COMPOSITION_COMPONENT a owl:Class ;
  rdfs:label "TRAIN COMPOSITION COMPONENT"
  ; rdfs:comment "A specification of the order and orientation of a specific ROLLING STOCK ELEMENT in a TRAIN COMPOSITION."
  .

tm:EQUIPMENT_VALIDITY_PARAMETERS a owl:Class ;
  rdfs:label "EQUIPMENT VALIDITY PARAMETERS"
  ; rdfs:comment "A type of VALIDITY PARAMETER related to service characteristics (e.g., class)."
  .

tm:ROLLING_STOCK_ITEM a owl:Class ;
  rdfs:label "ROLLING STOCK ITEM"
  ; rdfs:comment "A specific instance of an elementary unit of rolling stock (e.g., railcar, wagon, locomotive); its properties are given by a TRAIN ELEMENT TYPE."
  ; rdfs:subClassOf tm:VEHICLE
  .

tm:RENTAL_OPTION a owl:Class ;
  rdfs:label "RENTAL OPTION"
  ; rdfs:comment "A USAGE PARAMETER characterising access rights to RENTAL SERVICEs."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:ADDITIONAL_DRIVER_OPTION a owl:Class ;
  rdfs:label "ADDITIONAL DRIVER OPTION"
  ; rdfs:comment "A specialisation of USAGE PARAMETER characterising additional driver access rights to a RENTAL SERVICE."
  ; rdfs:subClassOf tm:RENTAL_OPTION
  .

tm:RENTAL_PENALTY_POLICY a owl:Class ;
  rdfs:label "RENTAL PENALTY POLICY"
  ; rdfs:comment "Policy regarding different aspects of hire charges, charges, for example refuelling, late vehicle return, loss of vehicle or equipment, traffic fines, etc."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:TYPE_OF_RENTAL_PENALTY_POLICY a owl:Class ;
  rdfs:label "TYPE OF RENTAL PENALTY POLICY"
  ; rdfs:comment "A classification of a RENTAL PENALTY POLICY; action taken if user breaks rental agreement, e.g., fails to return vehicle."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:TYPE_OF_TRAIN_COUPLING a owl:Class ;
  rdfs:label "TYPE OF TRAIN COUPLING"
  ; rdfs:comment "Classification of physical coupling used between two TRAIN COMPONENTs.  NOTE: The two TRAIN COMPONENTs must be in the same TRAIN or in the same COMPOUND TRAIN."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:RESERVE_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "RESERVE VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the booking of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:REGISTER_VEHICLE_COLLECTION_ENTRY a owl:Class ;
  rdfs:label "REGISTER VEHICLE COLLECTION ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the collecting of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:WITHDRAW_VEHICLE_EVENT a owl:Class ;
  rdfs:label "WITHDRAW VEHICLE EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT occurring when a VEHICLE is withdrawn from being available."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:REGISTER_VEHICLE_RETURN_ENTRY a owl:Class ;
  rdfs:label "REGISTER VEHICLE RETURN ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the return of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:RESERVE_VEHICLE_EVENT a owl:Class ;
  rdfs:label "RESERVE VEHICLE EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT occurring when a customer reserves a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:REGISTER_VEHICLE_COLLECTION_EVENT a owl:Class ;
  rdfs:label "REGISTER VEHICLE COLLECTION EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT occurring when a customer is registered as collecting a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:REGISTER_VEHICLE_RETURN_EVENT a owl:Class ;
  rdfs:label "REGISTER VEHICLE RETURN EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT occurring when a customer returns a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:DETECT_NO_RETURN_EVENT a owl:Class ;
  rdfs:label "DETECT NO RETURN EVENT"
  ; rdfs:comment "A VEHICLE PROVISION EVENT occurring when a customer fails to return a VEHICLE by an appointed time."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_EVENT
  .

tm:WITHDRAW_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "WITHDRAW VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the withdrawal of a VEHICLE as available."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:VEHICLE_PROVISION_EVENT a owl:Class ;
  rdfs:label "VEHICLE PROVISION EVENT"
  ; rdfs:comment "An event associated with some aspect of provision of a VEHICLE by an operator to a customer, e.g., reserving, check-out, return, etc."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_EVENT
  .

tm:VEHICLE_PROVISION_ENTRY a owl:Class ;
  rdfs:label "VEHICLE PROVISION ENTRY"
  ; rdfs:comment "A VEHICLE SERVICE ENTRY recording some aspect of provision of a VEHICLE by an operator to a customer, e.g., reserving, check-out, return, etc."
  ; rdfs:subClassOf tm:VEHICLE_SERVICE_ENTRY
  .

tm:DETECT_NO_RETURN_ENTRY a owl:Class ;
  rdfs:label "DETECT NO RETURN ENTRY"
  ; rdfs:comment "A VEHICLE PROVISION ENTRY recording the failure to return a VEHICLE by a specified time."
  ; rdfs:subClassOf tm:VEHICLE_PROVISION_ENTRY
  .

tm:SUBSCRIBING a owl:Class ;
  rdfs:label "SUBSCRIBING"
  ; rdfs:comment "Parameters governing subscription to a product that allows payment in instalments at regular intervals."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:Spare a owl:Class ;
  rdfs:label "Spare"
  .

tm:Spare2 a owl:Class ;
  rdfs:label "Spare2"
  .

tm:TRAIN_COMPOSITION_COUPLING a owl:Class ;
  rdfs:label "TRAIN COMPOSITION COUPLING"
  ; rdfs:comment "The nature of the coupling between two TRAIN COMPOSITION COMPONENTs in a TRAIN COMPOSITION."
  .

tm:TRAIN_COMPONENT_COUPLING a owl:Class ;
  rdfs:label "TRAIN COMPONENT COUPLING"
  ; rdfs:comment "The nature of the physical coupling between two TRAIN COMPONENTs in a TRAIN."
  .

tm:TYPE_OF_PARKING_STAY a owl:Class ;
  rdfs:label "TYPE OF PARKING STAY"
  ; rdfs:comment "A classification of the type of parking stay, e.g., long term, short term; may be used to choose pricing criteria."
  ; rdfs:subClassOf tm:TYPE_OF_VALUE
  .

tm:VEHICLE_TYPE_ZONE_RESTRICTION a owl:Class ;
  rdfs:label "VEHICLE TYPE ZONE RESTRICTION"
  ; rdfs:comment "Restriction on Zone use for a specific TRANSPORT TYPE"
  .

tm:MOBILITY_SERVICE_CONSTRAINT_ZONE a owl:Class ;
  rdfs:label "MOBILITY SERVICE CONSTRAINT ZONE"
  ; rdfs:comment "ZONE defining a restriction on used of a MOBILITY SERVICE, e.g. no entry, no drop off, etc."
  ; rdfs:subClassOf tm:ZONE
  .

tm:Service_Zone_Use_ALLOWED_VALUES a owl:Class ;
  rdfs:label "Service Zone Use ALLOWED VALUES"
  ; rdfs:comment "Allowed values for Zone Use."
  .

tm:MOBILITY_SERVICE_FRAME a owl:Class ;
  rdfs:label "MOBILITY SERVICE FRAME"
  ; rdfs:comment "A set of MOBILITY SERVICE data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:MOBILITY_JOURNEY_FRAME a owl:Class ;
  rdfs:label "MOBILITY JOURNEY FRAME"
  ; rdfs:comment "A set of MOBILITY JOURNEY data elements to which the same VALIDITY CONDITIONs have been assigned."
  ; rdfs:subClassOf tm:VERSION_FRAME
  .

tm:RELATED_ORGANISATION a owl:Class ;
  rdfs:label "RELATED ORGANISATION"
  ; rdfs:comment "Formal relationship to another ORGANISATION for example subcontractor, owner, etc."
  .

tm:TYPE_OF_ZONE_RESTRICTION a owl:Class ;
  rdfs:label "TYPE OF ZONE RESTRICTION"
  ; rdfs:comment "A classification of restriction on a MOBILITY SERVICE CONSTRAINT ZONE, for example cannot pick up in zone, forbidden zone, must pick up in zone, etc, etc."
  ; rdfs:subClassOf tm:TYPE_OF_ENTITY
  .

tm:SUSPENDING a owl:Class ;
  rdfs:label "SUSPENDING"
  ; rdfs:comment "Conditions governing suspension of a FARE PRODUCT, e.g., for a period pass or subscription that may allow a hiatus in use with a corresponding extension of equivalent value to the suspension period."
  ; rdfs:subClassOf tm:USAGE_PARAMETER
  .

tm:ROLLING_STOCK_INVENTORY a owl:Class ;
  rdfs:label "ROLLING STOCK INVENTORY"
  ; rdfs:comment "A collection of rolling stock of any type used to assemble trains."
  .

tm:PARKING_RENTAL_STATUS a owl:Class ;
  rdfs:label "PARKING RENTAL STATUS"
  ; rdfs:comment "A summary of the status of the parking at a given point on time."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:PARKING_BAY_CONDITION a owl:Class ;
  rdfs:label "PARKING BAY CONDITION"
  ; rdfs:comment "A record of the status of the parking bay at a given moment in time."
  ; rdfs:subClassOf tm:LOG_ENTRY
  .

tm:COMPOSITION_IN_COMPOUND_TRAIN_COMPOSITION a owl:Class ;
  rdfs:label "COMPOSITION IN COMPOUND TRAIN COMPOSITION"
  ; rdfs:comment "The specification of the order of TRAIN COMPOSITIONs in a COMPOUND TRAIN COMPOSITION."
  .

tm:TRACTIVE_ELEMENT_TYPE a owl:Class ;
  rdfs:label "TRACTIVE ELEMENT TYPE"
  ; rdfs:comment "A TRAIN ELEMENT TYPE that is self-propelled, e.g., a locomotive or powered railcar."
  ; rdfs:subClassOf tm:TRAIN_ELEMENT_TYPE
  .

tm:TRAILING_ELEMENT_TYPE a owl:Class ;
  rdfs:label "TRAILING ELEMENT TYPE"
  ; rdfs:comment "A TRAIN ELEMENT TYPE that cannot propel itself, e.g., a railway carriage, luggage van, passenger vehicle wagon, etc"
  ; rdfs:subClassOf tm:TRAIN_ELEMENT_TYPE
  .

tm:Epsilon a owl:Class ;
  rdfs:label "Epsilon"
  ; rdfs:subClassOf tm:Alpha
  .

tm:Alpha a owl:Class ;
  rdfs:label "Alpha"
  .

tm:Delta a owl:Class ;
  rdfs:label "Delta"
  .

tm:ASSISTANCE_BOOKING_SERVICE a owl:Class ;
  rdfs:label "ASSISTANCE BOOKING SERVICE"
  ; rdfs:comment "A specialisation of LOCAL SERVICE providing information about how to book assistance for wheelchair and disabled users."
  ; rdfs:subClassOf tm:LOCAL_SERVICE
  .

tm:VEHICLE_SERVICE_EVENT a owl:Class ;
  rdfs:label "VEHICLE SERVICE EVENT"
  ; rdfs:comment "An abstract event associated with a VEHICLE SERVICE."
  ; rdfs:subClassOf tm:FARE_CONTRACT_EVENT
  .

tm:VEHICLE_SERVICE_ENTRY a owl:Class ;
  rdfs:label "VEHICLE SERVICE ENTRY"
  ; rdfs:comment "A LOG ENTRY recording information about a VEHICLE SERVICE."
  ; rdfs:subClassOf tm:FARE_CONTRACT_ENTRY
  .

tm:BOOK_VEHICLE_EVENT a owl:Class ;

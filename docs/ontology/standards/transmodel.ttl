  ; rdfs:comment "A VEHICLE SHARING ENTRY recording the booking of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_USE_ENTRY
  .

tm:COLLECT_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "COLLECT VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE SHARING ENTRY recording the collecting of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_USE_ENTRY
  .

tm:RETURN_VEHICLE_ENTRY a owl:Class ;
  rdfs:label "RETURN VEHICLE ENTRY"
  ; rdfs:comment "A VEHICLE SHARING ENTRY recording the return of a VEHICLE."
  ; rdfs:subClassOf tm:VEHICLE_USE_ENTRY
  .

tm:REPORT_TRAFFIC_OFFENCE_ENTRY a owl:Class ;
  rdfs:label "REPORT TRAFFIC OFFENCE ENTRY"
  ; rdfs:comment "A VEHICLE SHARING ENTRY recording the report of a traffic offence by a VEHICLE."

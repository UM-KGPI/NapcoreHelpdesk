opra:ActualFrame
    a owl:Class ;
    rdfs:label "Actual Frame"@en ;
    skos:prefLabel "actual frame"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_framework/opra_frames/opra_actualFrame_version.xsd. The container element for the actual service within the VALIDITY CONDITIONs."@en .

opra:ActualFrameRequest
    a owl:Class ;
    rdfs:label "Actual Frame Request"@en ;
    skos:prefLabel "actual frame request"@en ;
    skos:altLabel "request element to get"@en ;

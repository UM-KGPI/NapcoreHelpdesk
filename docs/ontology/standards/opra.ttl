@prefix siri: <https://siri.org.uk/siri/1.3#> .
@prefix transmodel: <https://transmodel-cen.eu/6.2/> .
@prefix nits: <https://napcore.eu/ontology/nits#> .

<https://transmodel-cen.eu/opra/1.0>
    a owl:Ontology ;
    dct:title "OPRA Ontology with Schema Relationships"@en ;
    dct:description "OWL ontology with extracted inheritance and composition relationships from XSD."@en ;
    owl:versionInfo "0.2-xsd-rebuild-with-relationships" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Concepts with Semantic Relationships
#################################################################

opra:AbstractCtxIndicator
    a owl:Class ;
    skos:definition "Dummy Supertype for a CONTEXTUAL INDICATOR."@en ;
    skos:prefLabel "abstract ctx indicator"@en ;
    skos:altLabel "abstractctxindicator"@en ;
    rdfs:subClassOf netex:DataManagedObject ;
    rdfs:comment "Extracted from XSD schema"@en .

opra:AbstractLogEntry
    a owl:Class ;
    skos:definition "Dummy Supertype for LOG ENTRY."@en ;
    skos:prefLabel "abstract log entry"@en ;
    skos:altLabel "abstractlogentry"@en ;
    skos:altLabel "dummy supertype for log entry"@en ;

    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_serviceIntensity.xsd. A request element to get ACTUAL SERVICE INTENSITIes."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:AverageCommercialSpeed
    a owl:Class ;
    rdfs:label "Average Commercial Speed"@en ;
    skos:prefLabel "average commercial speed"@en ;
    skos:altLabel "speed value calculated from difference"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_serviceIntensity_version.xsd. Speed value calculated from difference between arrival and departure time at terminals and ROUTE length, including stop waiting times."@en .

opra:CancelledDatedVehicleJourneyCount
    a owl:Class ;
    rdfs:label "Cancelled Dated Vehicle Journey Count"@en ;
    skos:prefLabel "cancelled dated vehicle journey count"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_cancelledDatedVehicleJourney_version.xsd. Implementation of a CANCELLED DATED VEHICLE JOURNEY COUNT."@en ;
    skos:related opra:AbstractIndicator .

opra:CancelledDatedVehicleJourneyDiscoveryDelivery
    a owl:Class ;
    rdfs:label "Cancelled Dated Vehicle Journey Discovery Delivery"@en ;
    skos:prefLabel "cancelled dated vehicle journey discovery delivery"@en ;
    skos:altLabel "discovery delivery element to"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_cancelledDatedVehicleJourneys.xsd. A discovery delivery element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:CancelledDatedVehicleJourneyDiscoveryRequest
    a owl:Class ;
    rdfs:label "Cancelled Dated Vehicle Journey Discovery Request"@en ;
    skos:prefLabel "cancelled dated vehicle journey discovery request"@en ;
    skos:altLabel "discovery request element to"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_cancelledDatedVehicleJourneys.xsd. A discovery request element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:CancelledDatedVehicleJourneysRequest
    a owl:Class ;
    rdfs:label "Cancelled Dated Vehicle Journeys Request"@en ;
    skos:prefLabel "cancelled dated vehicle journeys request"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_cancelledDatedVehicleJourneys.xsd. A request element to get CANCELLED DATED VEHICLE JOURNEYs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:CapabilitiesRequest
    a owl:Class ;
    rdfs:label "Capabilities Request"@en ;
    skos:prefLabel "capabilities request"@en ;
    skos:altLabel "requests a the current capabilities"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra.xsd. Requests a the current capabilities of the server. Answered with a CapabilitiesResponse. Reserved for future use."@en .

opra:CapabilitiesResponse
    a owl:Class ;
    rdfs:label "Capabilities Response"@en ;
    skos:prefLabel "capabilities response"@en ;
    skos:altLabel "responses with the capabilities of"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra.xsd. Responses with the capabilities of an implementation.  Reserved for future use."@en .

opra:CapacitySpecification
    a owl:Class ;
    rdfs:label "Capacity Specification"@en ;
    skos:prefLabel "capacity specification"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_capacity_version.xsd. Element providing capability to specify methods and capacity values for VEHICLE TYPEs."@en .

opra:ContextualIndicatorDiscoveryDelivery

    skos:prefLabel "contextual indicator discovery request"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_contextualIndicators.xsd. A request element to get CONTEXTUAL INDICATORs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:ContextualIndicatorFrame
    a owl:Class ;
    rdfs:label "Contextual Indicator Frame"@en ;
    skos:prefLabel "contextual indicator frame"@en ;
    skos:altLabel "coherent set of contextual"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_framework/opra_frames/opra_contextualIndicatorFrame_version.xsd. A coherent set of CONTEXTUAL INDICATORs to which the same frame VALIDITY CONDITIONs have been assigned."@en .

opra:ContextualIndicatorRequest
    a owl:Class ;
    rdfs:label "Contextual Indicator Request"@en ;
    skos:prefLabel "contextual indicator request"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_contextualIndicators.xsd. A request element to get CONTEXTUAL INDICATORs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:DurationInterval
    a owl:Class ;
    rdfs:label "Duration Interval"@en ;
    skos:prefLabel "duration interval"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_framework/opra_reusableComponents/opra_durationDistribution_support.xsd. Element for basic occurrence statistics of a DURATION INTERVAL."@en .

opra:ExpectedPassengerCount
    a owl:Class ;
    rdfs:label "Expected Passenger Count"@en ;
    skos:prefLabel "expected passenger count"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_expectedPassengerCount_version.xsd. Implementation of LOGGABLE OBJECT designed for recording EXPECTED PASSENGER COUNT information."@en ;
    skos:related opra:AbstractIndicator .

opra:ExpectedPassengerCountDiscoveryDelivery
    a owl:Class ;
    rdfs:label "Expected Passenger Count Discovery Delivery"@en ;
    skos:prefLabel "expected passenger count discovery delivery"@en ;
    skos:altLabel "discovery delivery element to"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_expectedPassengerCounts.xsd. A discovery delivery element to get EXPECTED PASSENGER COUNTs."@en ;
    skos:related opra:OpraDiscoveryDelivery .

opra:ExpectedPassengerCountDiscoveryRequest
    a owl:Class ;
    rdfs:label "Expected Passenger Count Discovery Request"@en ;
    skos:prefLabel "expected passenger count discovery request"@en ;
    skos:altLabel "discovery request element to"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_expectedPassengerCounts.xsd. A discovery request element to get EXPECTED PASSENGER COUNTs."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:ExpectedPassengerCountRequest
    a owl:Class ;
    rdfs:label "Expected Passenger Count Request"@en ;
    skos:prefLabel "expected passenger count request"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_expectedPassengerCounts.xsd. A request element to get EXPECTED PASSENGER COUNTs."@en ;
    skos:related opra:OpraFunctionalRequest .

opra:ExpectedServiceIntensity
    a owl:Class ;
    rdfs:label "Expected Service Intensity"@en ;
    skos:prefLabel "expected service intensity"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_serviceIntensity_version.xsd. Implementation of LOGGABLE OBJECT designed for recording EXPECTED SERVICE INTENSITY information."@en ;

    rdfs:comment "Extracted from OpRa XSD source: opra_indicators/opra_serviceDimensions_version.xsd. Implementation of LOGGABLE OBJECT designed for recording ACTUAL SERVICE DIMENSIONS information."@en ;
    skos:related opra:AbstractIndicator .

opra:ActualServiceDimensionsDiscoveryDelivery
    a owl:Class ;
    rdfs:label "Actual Service Dimensions Discovery Delivery"@en ;

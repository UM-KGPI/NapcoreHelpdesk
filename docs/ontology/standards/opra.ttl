    skos:related opra:OpraDiscoveryDelivery .

opra:ActualCapacityDiscoveryRequest
    a owl:Class ;
    rdfs:label "Actual Capacity Discovery Request"@en ;
    skos:prefLabel "actual capacity discovery request"@en ;
    skos:altLabel "discovery request element to"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_capacity.xsd. A discovery request element to get ACTUAL CAPACITIes."@en ;
    skos:related opra:OpraDiscoveryRequest .

opra:ActualCapacityRequest
    a owl:Class ;
    rdfs:label "Actual Capacity Request"@en ;
    skos:prefLabel "actual capacity request"@en ;
    skos:altLabel "request element to get"@en ;
    rdfs:comment "Extracted from OpRa XSD source: opra_service/opra_service_capacity.xsd. A request element to get ACTUAL CAPACITIes."@en ;
    skos:related opra:OpraFunctionalRequest .


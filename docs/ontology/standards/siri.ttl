siri:DatedCall
    a owl:Class ;
    rdfs:label "Dated Call"@en ;
    skos:prefLabel "dated call"@en ;
    skos:altLabel "datedcall"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. Complete sequence of stops along the route path, in calling order."@en .

siri:DatedTimetableVersionFrame
    a owl:Class ;
    rdfs:label "Dated Timetable Version Frame"@en ;
    skos:prefLabel "dated timetable version frame"@en ;
    skos:altLabel "datedtimetableversionframe"@en ;
    skos:altLabel "timetable frame to run"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_productionTimetable_service.xsd. A TIMETABLE FRAME to run on a specified date."@en .

siri:DatedVehicleJourney
    a owl:Class ;
    rdfs:label "Dated Vehicle Journey"@en ;
    skos:prefLabel "dated vehicle journey"@en ;
    skos:altLabel "datedvehiclejourney"@en ;
    skos:altLabel "planned vehicle journey taking"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. A planned VEHICLE JOURNEY taking place on a particular date."@en .

siri:DepartureBoardingActivity
    a owl:Class ;
    rdfs:label "Departure Boarding Activity"@en ;
    skos:prefLabel "departure boarding activity"@en ;
    skos:altLabel "departureboardingactivity"@en ;
    skos:altLabel "nature of boarding allowed at"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Nature of boarding allowed at stop. Default is 'Boarding'."@en .

siri:DepartureCancellationReason
    a owl:Class ;
    rdfs:label "Departure Cancellation Reason"@en ;
    skos:prefLabel "departure cancellation reason"@en ;
    skos:altLabel "departurecancellationreason"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Text annotation to be used in cases where DepartureStatus is set to 'cancelled'. (since SIRI 2.1)"@en .

siri:DepartureFormationAssignment
    a owl:Class ;
    rdfs:label "Assignment Of A Train Formation"@en ;
    skos:prefLabel "assignment of a train formation"@en ;
    skos:altLabel "departure formation assignment"@en ;
    skos:altLabel "departureformationassignment"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Assignment of a TRAIN formation to a physical QUAY (platform or sectors thereof). (since SIRI 2.1)"@en .

siri:DepartureOrientationRelativeToQuay
    a owl:Class ;
    rdfs:label "Departure Orientation Relative To Quay"@en ;
    skos:prefLabel "departure orientation relative to quay"@en ;
    skos:altLabel "departureorientationrelativetoquay"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Indication of the direction of travel of the vehicle (e.g. TRAIN formation) with respect to the platform, or more precisely the QUAY. Unbounded to allow multiple languages. (since SIRI 2.1) Examples: - \"towards A\" or \"towards sector A\" if the QUAY is separated into sub-QUAYs or so called sectors. This would be equivalent to the vehicle departing in the direction of sector A on a QUAY with sectors A-B-C-D. If the departing vehicle is represented as an arrow, \"towards A\" would be abstracted as \"<= A-B-C-D\". - \"towards 0\" or \"towards reference point 0\" if sectors are not available or the QUAY has a reference point, e.g. for measuring the length of the QUAY, identified by \"0\". This would be equivalent to the vehicle departing in the direction of this reference point. If the departing vehicle is represented as an arrow, \"towards 0\" would be abstracted as \"<= 0...100\". \"100\" (as in percent) could denote the opposite side of the QUAY (measured at the full length of the QUAY with respect to the reference point). It is advised to specify a reference point that is meaningful for passengers on location."@en .

siri:DeparturePlatformName
    a owl:Class ;
    rdfs:label "Departure Platform Name"@en ;
    skos:prefLabel "departure platform name"@en ;
    skos:altLabel "departure quay bay or platform"@en ;
    skos:altLabel "departureplatformname"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Departure QUAY (bay or platform) name. Default taken from planned timetable."@en .

siri:DepartureProximityText
    a owl:Class ;
    rdfs:label "Arbitrary Text String To Show"@en ;
    skos:prefLabel "arbitrary text string to show"@en ;
    skos:altLabel "departure proximity text"@en ;
    skos:altLabel "departureproximitytext"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Arbitrary text string to show to indicate the status of the departure of the vehicle, for example, “Boarding”, “GatesClosed”. (since SIRI 2.0)"@en .

siri:DepartureStatus
    a owl:Class ;
    rdfs:label "Departure Status"@en ;
    skos:prefLabel "departure status"@en ;
    skos:altLabel "departurestatus"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Classification of the timeliness of the departure part of the CALL, according to a fixed list of values. This may reflect a presentation policy, for example CALLs less than one minute behind target time are still classified as on-time. Applications may use this to guide their own presentation of times."@en .

siri:Destination
    a owl:Class ;
    rdfs:label "Description Of A Destination"@en ;
    skos:prefLabel "description of a destination"@en ;
    skos:altLabel "destination"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model_discovery/siri_line.xsd. Description of a DESTINATION."@en .

siri:DestinationName
    a owl:Class ;
    rdfs:label "Destination Name"@en ;
    skos:prefLabel "destination name"@en ;
    skos:altLabel "destinationname"@en ;
    skos:altLabel "name of the destination"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. The name of the DESTINATION of the journey; used to help identify the VEHICLE to the public. Note when used in a CALL, this is the Dynamic Destination Display: since vehicles can change their destination during a journey, the destination included here should be what the VEHICLE will display when it reaches the stop."@en .

siri:Direction
    a owl:Class ;
    rdfs:label "Description Of A Direction"@en ;
    skos:prefLabel "description of a direction"@en ;
    skos:altLabel "direction"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Description of a DIRECTION."@en .

siri:DistributorStopOrder
    a owl:Class ;
    rdfs:label "Distributor Stop Order"@en ;
    skos:prefLabel "distributor stop order"@en ;
    skos:altLabel "distributorstoporder"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. For implementations in which the overall order is not defined by VISIT NUMBER, i.e. in case VisitNumberIsOrder is set to false, ORDER can be used to associate the stop order instead.  ORDER is also used together with VISIT NUMBER in scenarios where an extra CALL is inserted as a result of despatching alterations. Because such an extra CALL may have the same VisitNumber as another (cancelled) CALL, the STOP ORDER is needed. (since SIRI 2.1)"@en .

siri:DistributorVisitNumber
    a owl:Class ;
    rdfs:label "Distributor Visit Number"@en ;
    skos:prefLabel "distributor visit number"@en ;
    skos:altLabel "distributorvisitnumber"@en ;
    skos:altLabel "sequence of visit to distributor"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. Sequence of visit to Distributor stop within Distributor JOURNEY PATTERN."@en .

siri:EndpointDeniedAccessError
    a owl:Class ;
    rdfs:label "Endpoint Denied Access Error"@en ;
    skos:prefLabel "endpoint denied access error"@en ;
    skos:altLabel "endpointdeniedaccesserror"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_request_errorConditions.xsd. Error:Endpoint to which a message is to be distributed did not allow access by the client. (since SIRI 2.0)"@en .

siri:EndpointNotAvailableAccessError
    a owl:Class ;
    rdfs:label "Endpoint Not Available Access Error"@en ;

siri:ActualDepartureTime
    a owl:Class ;
    rdfs:label "Actual Departure Time"@en ;
    skos:prefLabel "actual departure time"@en ;
    skos:altLabel "actualdeparturetime"@en ;
    skos:altLabel "observed time of departure of"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Observed time of departure of VEHICLE from stop."@en .

siri:ActualHeadwayInterval
    a owl:Class ;
    rdfs:label "Actual Headway Interval"@en ;
    skos:prefLabel "actual headway interval"@en ;
    skos:altLabel "actualheadwayinterval"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. For frequency based services, observed interval between vehicles at stop."@en .

siri:AimedArrivalTime
    a owl:Class ;
    rdfs:label "Aimed Arrival Time"@en ;
    skos:prefLabel "aimed arrival time"@en ;
    skos:altLabel "aimedarrivaltime"@en ;
    skos:altLabel "target arrival time of vehicle"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Target arrival time of VEHICLE at stop according to latest working timetable."@en .

siri:AimedArrivalTimeOfFeeder
    a owl:Class ;
    rdfs:label "Aimed Arrival Time Of Feeder"@en ;
    skos:prefLabel "aimed arrival time of feeder"@en ;
    skos:altLabel "aimedarrivaltimeoffeeder"@en ;
    skos:altLabel "planned time at which feeder"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. Planned time at which feeder VEHICLE is scheduled to arrive. (since SIRI 2.1)"@en .

siri:AimedDepartureTime
    a owl:Class ;
    rdfs:label "Aimed Departure Time"@en ;
    skos:prefLabel "aimed departure time"@en ;
    skos:altLabel "aimeddeparturetime"@en ;
    skos:altLabel "target departure time of vehicle"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Target departure time of VEHICLE from stop according to latest working timetable."@en .

siri:AimedDepartureTimeOfDistributor
    a owl:Class ;
    rdfs:label "Aimed Departure Time Of Distributor"@en ;
    skos:prefLabel "aimed departure time of distributor"@en ;
    skos:altLabel "aimeddeparturetimeofdistributor"@en ;
    skos:altLabel "planned time at which distributor"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_datedVehicleJourney.xsd. Planned time at which distributor VEHICLE is scheduled to depart. (since SIRI 2.1)"@en .

siri:AimedFlexibleArea
    a owl:Class ;
    rdfs:label "Aimed Flexible Area"@en ;
    skos:prefLabel "aimed flexible area"@en ;
    skos:altLabel "aimedflexiblearea"@en ;
    skos:altLabel "area that encompasses the scheduled"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Area that encompasses the scheduled flexible stop locations according to the planned timetable. (since SIRI 2.1)"@en .

siri:AimedHeadwayInterval
    a owl:Class ;
    rdfs:label "Aimed Headway Interval"@en ;
    skos:prefLabel "aimed headway interval"@en ;
    skos:altLabel "aimedheadwayinterval"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. For frequency based services, target interval between vehicles at stop."@en .

siri:AimedLatestPassengerAccessTime
    a owl:Class ;
    rdfs:label "Aimed Latest Passenger Access Time"@en ;
    skos:prefLabel "aimed latest passenger access time"@en ;
    skos:altLabel "aimedlatestpassengeraccesstime"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Latest target time at which a PASSENGER should aim to arrive at the STOP PLACE containing the stop. This time may be earlier than the VEHICLE departure times and may include time for processes such as checkin, security, etc.(As specified by CHECK CONSTRAINT DELAYs in the underlying data). If absent assume to be the same as Earliest expected departure time. (since SIRI 2.0)"@en .

siri:AimedLocationName
    a owl:Class ;
    rdfs:label "Aimed Location Name"@en ;
    skos:prefLabel "aimed location name"@en ;
    skos:altLabel "aimedlocationname"@en ;
    skos:altLabel "name or description eg address"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Name or description (e.g. address) of the scheduled location or flexible area. (since SIRI 2.1)"@en .

siri:AirSubmode
    a owl:Class ;
    rdfs:label "Air Submode"@en ;
    skos:prefLabel "air submode"@en ;
    skos:altLabel "airsubmode"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_modes.xsd. TPEG Pti08 and Pts108 \"AirService\" submodes."@en .

siri:AllowAll
    a owl:Class ;
    rdfs:label "Allow Access To All Topics"@en ;
    skos:prefLabel "allow access to all topics"@en ;
    skos:altLabel "allow all"@en ;
    skos:altLabel "allowall"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_utility/siri_permissions.xsd. Allow access to all topics known to the service."@en .

siri:AllowedResourceUsageExceededError
    a owl:Class ;
    rdfs:label "Allowed Resource Usage Exceeded Error"@en ;
    skos:prefLabel "allowed resource usage exceeded error"@en ;
    skos:altLabel "allowedresourceusageexceedederror"@en ;
    skos:altLabel "error valid request was made"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_request_errorConditions.xsd. Error: Valid request was made but request would exceed the permitted resource usage of the client."@en .

siri:ArrivalBoardingActivity
    a owl:Class ;
    rdfs:label "Arrival Boarding Activity"@en ;
    skos:prefLabel "arrival boarding activity"@en ;
    skos:altLabel "arrivalboardingactivity"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Type of alighting allowed at stop. Default is 'Alighting'."@en .

siri:ArrivalCancellationReason
    a owl:Class ;
    rdfs:label "Arrival Cancellation Reason"@en ;
    skos:prefLabel "arrival cancellation reason"@en ;
    skos:altLabel "arrivalcancellationreason"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Text annotation to be used in cases where ArrivalStatus is set to 'cancelled'. (since SIRI 2.1)"@en .

siri:ArrivalFormationAssignment
    a owl:Class ;
    rdfs:label "Arrival Formation Assignment"@en ;
    skos:prefLabel "arrival formation assignment"@en ;
    skos:altLabel "arrivalformationassignment"@en ;
    skos:altLabel "assignment of a train formation"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Assignment of a TRAIN formation to a physical QUAY (platform or sectors thereof). If not given, assume same as for departure. (since SIRI 2.1)"@en .

siri:ArrivalOrientationRelativeToQuay
    a owl:Class ;
    rdfs:label "Arrival Orientation Relative To Quay"@en ;
    skos:prefLabel "arrival orientation relative to quay"@en ;
    skos:altLabel "arrivalorientationrelativetoquay"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Indication of the direction of travel of the vehicle (e.g. TRAIN formation) with respect to the platform, or more precisely the QUAY. Unbounded to allow multiple languages. (since SIRI 2.1) Examples: - \"towards A\" or \"towards sector A\" if the QUAY is separated into sub-QUAYs or so called sectors. This would be equivalent to the vehicle arriving at sector A first when approaching the QUAY with sectors A-B-C-D. If the arriving vehicle is represented as an arrow, \"towards A\" would be abstracted as \"=> A-B-C-D\". - \"towards 0\" or \"towards reference point 0\" if sectors are not available or the QUAY has a reference point, e.g. for measuring the length of the QUAY, identified by \"0\". This would be equivalent to the vehicle arriving at this reference point first when approaching the QUAY. If the arriving vehicle is represented as an arrow, \"towards 0\" would be abstracted as \"=> 0...100\". \"100\" (as in percent) could denote the opposite side of the QUAY (measured at the full length of the QUAY with respect to the reference point). It is advised to specify a reference point that is meaningful for passengers on location."@en .

siri:ArrivalPlatformName
    a owl:Class ;
    rdfs:label "Arrival Platform Name"@en ;
    skos:prefLabel "arrival platform name"@en ;
    skos:altLabel "arrivalplatformname"@en ;
    skos:altLabel "bay or platform quay name"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Bay or platform (QUAY) name to show passenger i.e. expected platform for vehicle to arrive at.  Inheritable property. Can be omitted if the same as the DeparturePlatformName If there no arrival platform name separate from the departure platform name, the precedence is: (i) any arrival platform on any related dated timetable element,  (ii) any departure platform name on this estimated element; (iii) any departure platform name on any related dated timetable CALL."@en .

siri:ArrivalProximityText
    a owl:Class ;
    rdfs:label "Arbitrary Text String To Show"@en ;
    skos:prefLabel "arbitrary text string to show"@en ;
    skos:altLabel "arrival proximity text"@en ;
    skos:altLabel "arrivalproximitytext"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Arbitrary text string to show to indicate the status of the departure of the VEHICLE for example, “Enroute”, “5 Km”, “Approaching”. May depend on the policy of the OPERATOR, for example show “Approaching” if less than 200metres away from stop. (since SIRI 2.0)"@en .

siri:ArrivalStatus
    a owl:Class ;
    rdfs:label "Arrival Status"@en ;
    skos:prefLabel "arrival status"@en ;
    skos:altLabel "arrivalstatus"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Classification of the timeliness of the visit according to a fixed list of values. If not specified, same as DepartureStatus."@en .

siri:AssistanceFacility
    a owl:Class ;
    rdfs:label "Assistance Facility"@en ;
    skos:prefLabel "assistance facility"@en ;
    skos:altLabel "assistancefacility"@en ;
    skos:altLabel "classification of assistance facility"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_facilities.xsd. Classification of Assistance Facility."@en .

siri:AuthenticatedRequest
    a owl:Class ;
    rdfs:label "Authenticated Request"@en ;
    skos:prefLabel "authenticated request"@en ;
    skos:altLabel "authenticatedrequest"@en ;
    skos:altLabel "subsititutable type for an authenticated"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_requests.xsd. Subsititutable type for an authenticated request Authenticated."@en .

siri:BeyondDataHorizon
    a owl:Class ;
    rdfs:label "Beyond Data Horizon"@en ;
    skos:prefLabel "beyond data horizon"@en ;
    skos:altLabel "beyonddatahorizon"@en ;
    skos:altLabel "error data period or subscription"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_request_errorConditions.xsd. Error: Data period or subscription period is outside of period covered by service."@en .

siri:BusSubmode
    a owl:Class ;
    rdfs:label "Bus Submode"@en ;
    skos:prefLabel "bus submode"@en ;
    skos:altLabel "bussubmode"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_modes.xsd. TPEG Pti05 and Pts105 \"BusService\" submodes."@en .

siri:CapabilitiesRequest
    a owl:Class ;
    rdfs:label "Capabilities Request"@en ;
    skos:prefLabel "capabilities request"@en ;
    skos:altLabel "capabilitiesrequest"@en ;
    skos:altLabel "requests a the current capabilities"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri.xsd. Requests a the current capabilities of the server. Answred with a CpabailitiesResponse."@en .

siri:CapabilitiesResponse
    a owl:Class ;
    rdfs:label "Capabilities Response"@en ;
    skos:prefLabel "capabilities response"@en ;
    skos:altLabel "capabilitiesresponse"@en ;
    skos:altLabel "responses with the capabilities of"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri.xsd. Responses with the capabilities of an implementation."@en .

siri:CapabilityNotSupportedError
    a owl:Class ;
    rdfs:label "Capability Not Supported Error"@en ;
    skos:prefLabel "capability not supported error"@en ;
    skos:altLabel "capabilitynotsupportederror"@en ;
    skos:altLabel "error service does not support"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_request_errorConditions.xsd. Error: Service does not support the requested capability."@en .

siri:CheckStatusRequest
    a owl:Class ;
    rdfs:label "Check Status Request"@en ;
    skos:prefLabel "check status request"@en ;
    skos:altLabel "checkstatusrequest"@en ;
    skos:altLabel "request from consumer to producer"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_common_services.xsd. Request from Consumer to Producer to check whether services is working. Answers a CheckStatusRequest."@en ;
    skos:related siri:AbstractTrackedRequest .

siri:CheckStatusResponse
    a owl:Class ;
    rdfs:label "Check Status Response"@en ;
    skos:prefLabel "check status response"@en ;
    skos:altLabel "checkstatusresponse"@en ;
    skos:altLabel "response from producer to consumer"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_common_services.xsd. Response from Producer to Consumer to inform whether services is working. Answers a CheckStatusRequest."@en ;
    skos:related siri:AbstractResponse .

siri:CoachSubmode
    a owl:Class ;
    rdfs:label "Coach Submode"@en ;
    skos:prefLabel "coach submode"@en ;
    skos:altLabel "coachsubmode"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_modes.xsd. TPEG Pti03 and Pts103 \"CoachService\" submodes."@en .

siri:CompoundTrain
    a owl:Class ;
    rdfs:label "Compound Train"@en ;
    skos:prefLabel "compound train"@en ;
    skos:altLabel "compoundtrain"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_journey.xsd. Groups of carriages may be managed as sections by composing TRAINs into a COMPOUND TRAIN, for example if a TRAIN joins (or splits from) another TRAIN. (since SIRI 2.1) TRAINs within a COMPOUND TRAIN may have different origins and destinations due to joining/splitting. A COMPOUND TRAIN may be stable for one or multiple JOURNEY PARTs and change at a certain STOP POINT due to planned joining/splitting, despatching alterations or a situation."@en .

siri:Condition
    a owl:Class ;
    rdfs:label "Condition"@en ;
    skos:prefLabel "condition"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_situationClassifiers.xsd. Classification of effect on service. TPEG PTS043 ServiceStatus"@en .

siri:ConnectionLinkPermissions
    a owl:Class ;

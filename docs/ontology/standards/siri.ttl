    skos:altLabel "endpointnotavailableaccesserror"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_request_errorConditions.xsd. Error:Recipient of a message to be distributed is not available. (since SIRI 2.0)"@en .

siri:EnvironmentReason
    a owl:Class ;
    rdfs:label "Environment Reason"@en ;

siri:EstimatedCall
    a owl:Class ;
    rdfs:label "Estimated Call"@en ;
    skos:prefLabel "estimated call"@en ;
    skos:altLabel "estimatedcall"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_estimatedVehicleJourney.xsd. Ordered sequence of SCHEDULED STOP POINTs called at by the VEHICLE JOURNEY. If IsCompleteStopSequence is false, may be just those stops that are altered."@en .

siri:EstimatedServiceJourneyInterchange
    a owl:Class ;
    rdfs:label "Estimated Service Journey Interchange"@en ;
    skos:prefLabel "estimated service journey interchange"@en ;
    skos:altLabel "estimatedservicejourneyinterchange"@en ;
    skos:altLabel "realtime service journey interchange"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri_model/siri_estimatedVehicleJourney.xsd. A real-time SERVICE JOURNEY INTERCHANGE that may be made between the stops of two monitored journeys. It includes the current real-time predicted transfer and wait times. (since SIRI 2.0)"@en .


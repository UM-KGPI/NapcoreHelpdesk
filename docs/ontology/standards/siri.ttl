@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix siri: <http://www.siri.org.uk/siri/2.1#> .

#################################################################
# Ontology Header
#################################################################

<http://www.siri.org.uk/siri/2.1>
    a owl:Ontology ;
    dct:title "SIRI Ontology"@en ;
    dct:description "SIRI OWL ontology regenerated from the full recursive SIRI XSD tree. It contains concept classes extracted from all local schema files."@en ;
    dct:creator "SIRI / NAPCORE Community" ;
    dct:created "2026-05-10"^^xsd:date ;
    owl:versionIRI <http://www.siri.org.uk/siri/2.1> ;
    owl:versionInfo "0.2-xsd-rebuild" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# SIRI Core Relationships
#################################################################

siri:hasCall
    a owl:ObjectProperty ;
    rdfs:label "has call"@en ;
    rdfs:comment "Links an EstimatedVehicleJourney to its call nodes (DatedCall, EstimatedCall, RecordedCall)."@en ;
    rdfs:domain siri:EstimatedVehicleJourney ;
    rdfs:range [ owl:unionOf (siri:DatedCall siri:EstimatedCall siri:RecordedCall) ] .

siri:hasDepartureTime
    a owl:ObjectProperty ;
    rdfs:label "has departure time"@en ;
    rdfs:comment "Links a Call (DatedCall, EstimatedCall, RecordedCall) to its expected or recorded departure time."@en ;
    rdfs:domain [ owl:unionOf (siri:DatedCall siri:EstimatedCall siri:RecordedCall) ] ;
    rdfs:range [ owl:unionOf (siri:ExpectedDepartureTime siri:RecordedDepartureTime) ] .

siri:hasArrivalTime
    a owl:ObjectProperty ;
    rdfs:label "has arrival time"@en ;
    rdfs:comment "Links a Call (DatedCall, EstimatedCall, RecordedCall) to its expected or recorded arrival time."@en ;
    rdfs:domain [ owl:unionOf (siri:DatedCall siri:EstimatedCall siri:RecordedCall) ] ;
    rdfs:range [ owl:unionOf (siri:ExpectedArrivalTime siri:RecordedArrivalTime) ] .

siri:refersToStop
    a owl:ObjectProperty ;
    rdfs:label "refers to stop"@en ;
    rdfs:comment "Links a Call or MonitoredStopVisit to the stop point it refers to via StopPointName."@en ;
    rdfs:domain [ owl:unionOf (siri:DatedCall siri:EstimatedCall siri:RecordedCall siri:MonitoredStopVisit) ] ;
    rdfs:range siri:StopPointName .

siri:refersToJourney
    a owl:ObjectProperty ;
    rdfs:label "refers to journey"@en ;
    rdfs:comment "Links a MonitoredStopVisit to the EstimatedVehicleJourney it reports on."@en ;
    rdfs:domain siri:MonitoredStopVisit ;
    rdfs:range siri:EstimatedVehicleJourney .

siri:containsDeliveryPayload
    a owl:ObjectProperty ;
    rdfs:label "contains delivery payload"@en ;
    rdfs:comment "Links a Delivery type (EstimatedTimetableDelivery, VehicleMonitoringDelivery, StopMonitoringDelivery, SituationExchangeDelivery) to the elements it carries."@en ;
    rdfs:domain [ owl:unionOf (siri:EstimatedTimetableDelivery siri:VehicleMonitoringDelivery siri:StopMonitoringDelivery siri:SituationExchangeDelivery) ] ;
    rdfs:range owl:Thing .

siri:hasSituation
    a owl:ObjectProperty ;
    rdfs:label "has situation"@en ;
    rdfs:comment "Links a SituationExchangeDelivery to the PtSituationElement instances it carries."@en ;
    rdfs:domain siri:SituationExchangeDelivery ;
    rdfs:range siri:PtSituationElement .

siri:hasStatus
    a owl:ObjectProperty ;
    rdfs:label "has status"@en ;
    rdfs:comment "Links a Call or MonitoredStopVisit to its current status (DepartureStatus, ArrivalStatus, etc.)."@en ;
    rdfs:domain [ owl:unionOf (siri:DatedCall siri:EstimatedCall siri:RecordedCall siri:MonitoredStopVisit) ] ;
    rdfs:range owl:Thing .

#################################################################
# XSD-Extracted Concepts
#################################################################

siri:AbstractDiscoveryDelivery
    a owl:Class ;
    rdfs:label "Abstract Discovery Delivery"@en ;
    skos:prefLabel "abstract discovery delivery"@en ;
    skos:altLabel "abstract type for a discovery"@en ;
    skos:altLabel "abstractdiscoverydelivery"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_requests.xsd. Abstract type for a discovery delivery."@en ;
    skos:related siri:AbstractResponse .


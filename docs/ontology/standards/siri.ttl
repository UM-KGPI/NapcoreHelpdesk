siri:DataReadyAcknowledgement
    a owl:Class ;
    rdfs:label "Data Ready Acknowledgement"@en ;
    skos:prefLabel "data ready acknowledgement"@en ;
    skos:altLabel "datareadyacknowledgement"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_common_services.xsd. Response from Consumer to Producer to acknowledge to Producer that a DataReadyRequest has been received."@en ;

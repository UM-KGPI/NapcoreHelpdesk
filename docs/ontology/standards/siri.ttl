    rdfs:comment "Extracted from SIRI XSD source: siri/siri_common_services.xsd. Request from Producer to Consumer to notify that data update is ready to fetch. Answered with a DataReadyResponse."@en .

siri:DataReceivedAcknowledgement
    a owl:Class ;
    rdfs:label "Data Received Acknowledgement"@en ;
    skos:prefLabel "data received acknowledgement"@en ;
    skos:altLabel "datareceivedacknowledgement"@en ;
    rdfs:comment "Extracted from SIRI XSD source: siri/siri_common_services.xsd. Response from Consumer to Producer to acknowledge that data hase been received. Used as optioanl extra step if reliable delivery is needed. Answers a ServiceDelivery."@en ;
    skos:related siri:AbstractResponse .

siri:DataSupplyRequest
    a owl:Class ;
    rdfs:label "Data Supply Request"@en ;
    skos:prefLabel "data supply request"@en ;
    skos:altLabel "datasupplyrequest"@en ;
    skos:altLabel "request from consumer to producer"@en ;

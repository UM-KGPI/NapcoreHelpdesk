netex:JourneyPatternHeadway
    a owl:Class ;
    skos:definition "Headway interval information that is available for all the VEHICLE JOURNEYs running on the JOURNEY PATTERN. This is a default value that can be superseded by the VEHICLE JOURNEY HEADWAY on a specific journey. This information must be consistent with HEADWAY JOURNEY GROUP if available (HEADWAY JOURNEY GROUP being a more detailed way of describing headway services)."@en ;
    skos:prefLabel "headway interval information that is"@en ;
    skos:altLabel "journey pattern headway"@en ;
    skos:altLabel "journeypatternheadway"@en ;

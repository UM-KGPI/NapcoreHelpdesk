    rdfs:comment "Extracted from XSD schema"@en .

netex:GenericPathLink
    a owl:Class ;
    skos:definition "A link between any two places that represents a step in a possible route for pedestrians, cyclists or other out of vehicle passengers . Note: a place may be fixed PLACE, that is STOP PLACEs, ACCESS SPACE or QUAY, BOARDING POSITION, POINTs OF INTEREST etc or PATH JUNCTIONs, or a place within a DECK, e.g. DECK, SPACE, DECK ENTRANCE, DECK PATH JUNCTION etc."@en ;
    skos:prefLabel "generic path link"@en ;
    skos:altLabel "genericpathlink"@en ;
    skos:altLabel "link between any two"@en ;

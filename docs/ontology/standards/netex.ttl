    rdfs:subClassOf netex:ActivationAssignment ;
    rdfs:subClassOf netex:ActivationLink ;
    rdfs:subClassOf netex:ActivationPoint ;
    rdfs:subClassOf netex:ActualVehicleEquipment ;
    rdfs:subClassOf netex:AddressablePlace ;

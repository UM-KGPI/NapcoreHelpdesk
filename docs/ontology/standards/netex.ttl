<https://netex.org.uk/netex/2.0>
    a owl:Ontology ;
    dct:title "NETEX Ontology with Schema Relationships"@en ;
    dct:description "OWL ontology with extracted inheritance and composition relationships from XSD."@en ;
    owl:versionInfo "0.2-xsd-rebuild-with-relationships" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Concepts with Semantic Relationships
#################################################################

netex:AbstractGroupMember
    a owl:Class ;
    skos:definition "Abstract member of a GROUP OF ENTITY MEMBERs."@en ;
    skos:prefLabel "abstract group member"@en ;
    skos:altLabel "abstract member of a group"@en ;
    skos:altLabel "abstractgroupmember"@en ;
    rdfs:comment "Extracted from XSD schema"@en .


    rdfs:subClassOf netex:AccessibilityInfoFacility ;
    rdfs:subClassOf netex:AccessibilityInfoFacilityList ;
    rdfs:subClassOf netex:AccessibilityLimitation ;
    rdfs:subClassOf netex:AccessibilityTool ;
    rdfs:subClassOf netex:AccessibilityToolList ;
    rdfs:subClassOf netex:Accommodation ;
    rdfs:subClassOf netex:AccommodationAccess ;
    rdfs:subClassOf netex:AccommodationAccessList ;
    rdfs:subClassOf netex:AccommodationFacility ;

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix netex: <https://netex.org.uk/netex/2.0#> .

#################################################################
# Ontology Header
#################################################################

<https://netex.org.uk/netex/2.0>
    a owl:Ontology ;
    dct:title "NeTEx Conceptual Ontology"@en ;
    dct:description "NeTEx OWL ontology regenerated from local NeTEx XSD sources. It contains concept classes extracted from the full xsd tree."@en ;
    dct:creator "NeTEx / NAPCORE Community" ;
    dct:created "2026-05-07"^^xsd:date ;
    owl:versionIRI <https://netex.org.uk/netex/2.0> ;
    owl:versionInfo "0.2-xsd-rebuild" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# NeTEx Core Relationships
#################################################################

netex:hasServiceJourney
    a owl:ObjectProperty ;
    rdfs:label "has service journey"@en ;
    rdfs:comment "Links a TimetableFrame to ServiceJourney instances it contains."@en ;
    rdfs:domain netex:TimetableFrame ;
    rdfs:range netex:ServiceJourney .

netex:hasJourneyPattern
    a owl:ObjectProperty ;
    rdfs:label "has journey pattern"@en ;
    rdfs:comment "Links a ServiceJourney to its ServiceJourneyPattern."@en ;
    rdfs:domain netex:ServiceJourney ;
    rdfs:range netex:ServiceJourneyPattern .

netex:usesRoute
    a owl:ObjectProperty ;
    rdfs:label "uses route"@en ;
    rdfs:comment "Links a ServiceJourneyPattern to the Route it follows."@en ;
    rdfs:domain netex:ServiceJourneyPattern ;
    rdfs:range netex:Route .

netex:onLine
    a owl:ObjectProperty ;
    rdfs:label "on line"@en ;
    rdfs:comment "Links a Route to the Line it belongs to."@en ;
    rdfs:domain netex:Route ;
    rdfs:range netex:Line .

netex:hasPointInJourneyPattern
    a owl:ObjectProperty ;
    rdfs:label "has point in journey pattern"@en ;
    rdfs:comment "Links a JourneyPattern to PointInJourneyPattern members."@en ;
    rdfs:domain netex:JourneyPattern ;
    rdfs:range netex:PointInJourneyPattern .

netex:servesScheduledStopPoint
    a owl:ObjectProperty ;
    rdfs:label "serves scheduled stop point"@en ;
    rdfs:comment "Links a PointInJourneyPattern to the ScheduledStopPoint it serves."@en ;
    rdfs:domain netex:PointInJourneyPattern ;
    rdfs:range netex:ScheduledStopPoint .

netex:inStopPlace
    a owl:ObjectProperty ;
    rdfs:label "in stop place"@en ;
    rdfs:comment "Links a ScheduledStopPoint to its parent StopPlace."@en ;
    rdfs:domain netex:ScheduledStopPoint ;
    rdfs:range netex:StopPlace .

netex:hasTimetabledPassingTime
    a owl:ObjectProperty ;
    rdfs:label "has timetabled passing time"@en ;
    rdfs:comment "Links a ServiceJourney to TimetabledPassingTime records."@en ;
    rdfs:domain netex:ServiceJourney ;
    rdfs:range netex:TimetabledPassingTime .

netex:hasDayTypeAssignment
    a owl:ObjectProperty ;
    rdfs:label "has day type assignment"@en ;
    rdfs:comment "Links a ServiceJourney to DayTypeAssignment used for calendar applicability."@en ;
    rdfs:domain netex:ServiceJourney ;
    rdfs:range netex:DayTypeAssignment .

netex:appliesOnOperatingDay
    a owl:ObjectProperty ;
    rdfs:label "applies on operating day"@en ;
    rdfs:comment "Links a DayTypeAssignment to concrete OperatingDay instances."@en ;
    rdfs:domain netex:DayTypeAssignment ;
    rdfs:range netex:OperatingDay .

#################################################################
# Standard Root Concept
#################################################################

netex:NeTEx
    a owl:Class ;
    rdfs:label "NeTEx"@en ;
    skos:prefLabel "netex"@en ;
    skos:altLabel "network and timetable exchange"@en ;
    skos:altLabel "netex specification"@en ;
    rdfs:comment "Canonical root concept for the NeTEx technical specification, used for standard-level semantic anchoring."@en .


@prefix nch: <https://napcore.eu/ontology/helpdesk#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .
@prefix oa: <http://www.w3.org/ns/oa#> .

<https://napcore.eu/ontology/helpdesk>
    a owl:Ontology ;
    dcterms:title "NAPCORE Helpdesk Application Ontology"@en ;
    dcterms:description "Experimental ontology draft for the NAPCORE helpdesk application layer, reusing SKOS, PROV-O, and DCTERMS with a minimal set of application-specific extensions."@en ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.1.0-draft" ;
    owl:imports skos: , prov: .

nch:Standard
    a owl:Class ;
    rdfs:label "Standard"@en ;
    rdfs:comment "A standards family or standard specification within NAPCORE scope."@en .

nch:StandardArtifact
    a owl:Class ;
    rdfs:label "Standard artifact"@en ;
    rdfs:comment "A source artifact such as a guide, XSD, XML example, markdown note, or related file used as evidence."@en .

nch:ExampleArtifact
    a owl:Class ;
    rdfs:subClassOf nch:StandardArtifact ;
    rdfs:label "Example artifact"@en ;
    rdfs:comment "A source artifact intended to illustrate or exemplify an exchange pattern or concept."@en .

nch:Chunk
    a owl:Class ;
    rdfs:label "Chunk"@en ;
    rdfs:comment "A retrievable indexed text unit derived from a standard artifact."@en .

nch:QueryIntent
    a owl:Class ;
    rdfs:label "Query intent"@en ;
    rdfs:comment "A coarse-grained retrieval intent that can guide evidence preference, such as explanation or example lookup."@en .

nch:PublishedFAQPage
    a owl:Class ;
    rdfs:subClassOf schema:FAQPage ;
    rdfs:label "Published FAQ page"@en ;
    rdfs:comment "A published FAQ artifact aligned with schema.org FAQPage."@en .

nch:FAQQuestion
    a owl:Class ;
    rdfs:subClassOf schema:Question ;
    rdfs:label "FAQ question"@en ;
    rdfs:comment "A question resource aligned with schema.org Question."@en .

nch:FAQAnswer
    a owl:Class ;
    rdfs:subClassOf schema:Answer ;
    rdfs:label "FAQ answer"@en ;
    rdfs:comment "An answer resource aligned with schema.org Answer."@en .

nch:EvidenceAnnotation
    a owl:Class ;
    rdfs:subClassOf oa:Annotation ;
    rdfs:label "Evidence annotation"@en ;
    rdfs:comment "An annotation linking answer bodies to evidence targets using Web Annotation."@en .

nch:ExtractionActivity
    a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Extraction activity"@en ;
    rdfs:comment "Activity that extracts concepts, links, and evidence metadata from source artifacts."@en .

nch:AnswerGenerationActivity
    a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Answer generation activity"@en ;
    rdfs:comment "Activity that generates grounded answers from retrieved evidence."@en .

nch:EditorialReviewActivity
    a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Editorial review activity"@en ;
    rdfs:comment "Activity where an editor reviews and accepts or rejects answer content."@en .

nch:RetrieverAgent
    a owl:Class ;
    rdfs:subClassOf prov:SoftwareAgent ;
    rdfs:label "Retriever agent"@en ;
    rdfs:comment "Software agent performing retrieval and evidence assembly."@en .

nch:ReviewerAgent
    a owl:Class ;
    rdfs:subClassOf prov:Agent ;
    rdfs:label "Reviewer agent"@en ;
    rdfs:comment "Human or system reviewer associated with editorial decisions."@en .

nch:conceptInStandard
    a owl:ObjectProperty ;
    rdfs:label "concept in standard"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range nch:Standard ;
    rdfs:comment "Links a domain concept to the standard where it is defined or primarily used."@en .

nch:evidencedByArtifact
    a owl:ObjectProperty ;
    rdfs:label "evidenced by artifact"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range nch:StandardArtifact ;
    rdfs:comment "Links a concept to a citable artifact that provides direct evidence for it."@en .

nch:artifactHasChunk
    a owl:ObjectProperty ;
    rdfs:label "artifact has chunk"@en ;
    rdfs:domain nch:StandardArtifact ;
    rdfs:range nch:Chunk ;
    rdfs:comment "Links an artifact to the retrieval chunks generated from it."@en .

nch:preferredForIntent
    a owl:ObjectProperty ;
    rdfs:label "preferred for intent"@en ;
    rdfs:domain nch:StandardArtifact ;
    rdfs:range nch:QueryIntent ;
    rdfs:comment "Declares that an artifact type or artifact is preferred evidence for a given query intent."@en .

nch:mentionsConcept
    a owl:ObjectProperty ;
    rdfs:label "mentions concept"@en ;
    rdfs:domain nch:Chunk ;
    rdfs:range skos:Concept ;
    rdfs:comment "Links a retrieval chunk to a concept mentioned or described in it."@en .

nch:hasEvidenceAnnotation
    a owl:ObjectProperty ;
    rdfs:label "has evidence annotation"@en ;
    rdfs:domain nch:FAQAnswer ;
    rdfs:range nch:EvidenceAnnotation ;
    rdfs:comment "Links an answer to its Web Annotation evidence record."@en .

nch:derivedFromChunk
    a owl:ObjectProperty ;
    rdfs:label "derived from chunk"@en ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:domain nch:FAQAnswer ;
    rdfs:range nch:Chunk ;
    rdfs:comment "Declares that an answer was derived from one or more retrieval chunks."@en .

nch:generatedByActivity
    a owl:ObjectProperty ;
    rdfs:label "generated by activity"@en ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    rdfs:domain nch:FAQAnswer ;
    rdfs:range prov:Activity ;
    rdfs:comment "Links generated answer content to the generating activity."@en .

nch:usedEvidenceChunk
    a owl:ObjectProperty ;
    rdfs:label "used evidence chunk"@en ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain prov:Activity ;
    rdfs:range nch:Chunk ;
    rdfs:comment "Links an activity to the chunk resources it used."@en .

nch:wasReviewedBy
    a owl:ObjectProperty ;
    rdfs:label "was reviewed by"@en ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:domain prov:Activity ;
    rdfs:range nch:ReviewerAgent ;
    rdfs:comment "Links a review activity to the responsible reviewer."@en .

nch:hasStandardsFamily
    a owl:DatatypeProperty ;
    rdfs:label "has standards family"@en ;
    rdfs:domain nch:Standard ;
    rdfs:range xsd:string .

nch:hasSourcePath
    a owl:DatatypeProperty ;
    rdfs:label "has source path"@en ;
    rdfs:domain nch:StandardArtifact ;
    rdfs:range xsd:string .

nch:hasRepositoryUrl
    a owl:DatatypeProperty ;
    rdfs:label "has repository URL"@en ;
    rdfs:domain nch:StandardArtifact ;
    rdfs:range xsd:anyURI .

nch:hasChunkId
    a owl:DatatypeProperty ;
    rdfs:label "has chunk id"@en ;
    rdfs:domain nch:Chunk ;
    rdfs:range xsd:string .

nch:hasIntentName
    a owl:DatatypeProperty ;
    rdfs:label "has intent name"@en ;
    rdfs:domain nch:QueryIntent ;
    rdfs:range xsd:string .

nch:hasReviewDecision
    a owl:DatatypeProperty ;
    rdfs:label "has review decision"@en ;
    rdfs:domain nch:EditorialReviewActivity ;
    rdfs:range xsd:string .

nch:NAPCOREScheme
    a skos:ConceptScheme ;
    dcterms:title "NAPCORE concept scheme"@en ;
    skos:prefLabel "NAPCORE concept scheme"@en ;
    dcterms:description "Seed concept scheme for the NAPCORE semantic layer, starting from Transmodel-family standards and materials."@en .

nch:TransmodelFamily
    a nch:Standard ;
    rdfs:label "Transmodel family"@en ;
    nch:hasStandardsFamily "Transmodel" ;
    skos:prefLabel "Transmodel family"@en .

nch:NeTEx
    a nch:Standard ;
    rdfs:label "NeTEx"@en ;
    nch:hasStandardsFamily "Transmodel" ;
    skos:prefLabel "NeTEx"@en .

nch:SIRI
    a nch:Standard ;
    rdfs:label "SIRI"@en ;
    nch:hasStandardsFamily "Transmodel" ;
    skos:prefLabel "SIRI"@en .

nch:OJP
    a nch:Standard ;
    rdfs:label "OJP"@en ;
    nch:hasStandardsFamily "Transmodel" ;
    skos:prefLabel "OJP"@en .

nch:OpRa
    a nch:Standard ;
    rdfs:label "OpRa"@en ;
    nch:hasStandardsFamily "Transmodel" ;
    skos:prefLabel "OpRa"@en .

nch:DATEXII
    a nch:Standard ;
    rdfs:label "DATEX II"@en ;
    nch:hasStandardsFamily "DATEX II" ;
    skos:prefLabel "DATEX II"@en ;
    rdfs:comment "Declared early so later ontology phases can map DATEX II concepts into the same NAPCORE-wide namespace."@en .

nch:ExplanationIntent
    a nch:QueryIntent ;
    rdfs:label "Explanation intent"@en ;
    nch:hasIntentName "explanation" .

nch:ExampleIntent
    a nch:QueryIntent ;
    rdfs:label "Example intent"@en ;
    nch:hasIntentName "example" .

nch:JourneyStatistics
    a skos:Concept ;
    skos:inScheme nch:NAPCOREScheme ;
    skos:prefLabel "journey statistics"@en ;
    skos:definition "Statistics describing operational journey behavior such as delays or cancellations."@en ;
    nch:conceptInStandard nch:OpRa .

nch:DelayedJourney
    a skos:Concept ;
    skos:inScheme nch:NAPCOREScheme ;
    skos:prefLabel "delayed journey"@en ;
    skos:altLabel "late journey"@en ;
    skos:altLabel "late dated vehicle journey"@en ;
    skos:broader nch:JourneyStatistics ;
    skos:definition "A journey whose actual or expected operation occurs later than planned."@en ;
    nch:conceptInStandard nch:OpRa .

nch:CancelledJourney
    a skos:Concept ;
    skos:inScheme nch:NAPCOREScheme ;
    skos:prefLabel "cancelled journey"@en ;
    skos:altLabel "canceled journey"@en ;
    skos:broader nch:JourneyStatistics ;
    skos:definition "A journey that is scheduled but not operated."@en ;
    nch:conceptInStandard nch:OpRa .

nch:DelayClassification
    a skos:Concept ;
    skos:inScheme nch:NAPCOREScheme ;
    skos:prefLabel "delay classification"@en ;
    skos:definition "Classification used to categorize journey delay situations in operational reporting and exchange."@en ;
    skos:related nch:DelayedJourney ;
    nch:conceptInStandard nch:OpRa .

nch:DelayedAndCancelledJourneysWithEventsExample
    a nch:ExampleArtifact ;
    rdfs:label "DelayedAndCancelledJourneysWithEvents.xml"@en ;
    dcterms:title "Delayed and Cancelled Journeys With Events example"@en ;
    dcterms:identifier "examples/DelayedAndCancelledJourneysWithEvents.xml" ;
    nch:hasSourcePath "examples/DelayedAndCancelledJourneysWithEvents.xml" ;
    nch:hasRepositoryUrl "https://github.com/OpRa-CEN/OpRa"^^xsd:anyURI ;
    nch:preferredForIntent nch:ExampleIntent ;
    prov:wasDerivedFrom <https://github.com/OpRa-CEN/OpRa/blob/main/examples/DelayedAndCancelledJourneysWithEvents.xml> .

nch:OpRaDelayClassificationSchema
    a nch:StandardArtifact ;
    rdfs:label "opra_delayClassification_version.xsd"@en ;
    dcterms:identifier "xsd/opra_framework/opra_reusableComponents/opra_delayClassification_version.xsd" ;
    nch:hasSourcePath "xsd/opra_framework/opra_reusableComponents/opra_delayClassification_version.xsd" ;
    nch:hasRepositoryUrl "https://github.com/OpRa-CEN/OpRa"^^xsd:anyURI ;
    nch:preferredForIntent nch:ExplanationIntent ;
    prov:wasDerivedFrom <https://github.com/OpRa-CEN/OpRa/blob/main/xsd/opra_framework/opra_reusableComponents/opra_delayClassification_version.xsd> .

nch:DelayedJourney
    nch:evidencedByArtifact nch:DelayedAndCancelledJourneysWithEventsExample , nch:OpRaDelayClassificationSchema .

nch:CancelledJourney
    nch:evidencedByArtifact nch:DelayedAndCancelledJourneysWithEventsExample .

nch:DelayClassification
    nch:evidencedByArtifact nch:OpRaDelayClassificationSchema .

nch:Chunk_DelayedAndCancelledJourneysWithEvents_01
    a nch:Chunk ;
    nch:hasChunkId "opra-delayed-cancelled-journeys-01" ;
    nch:mentionsConcept nch:DelayedJourney , nch:CancelledJourney ;
    prov:wasDerivedFrom nch:DelayedAndCancelledJourneysWithEventsExample .

nch:FAQPage_DelayedJourneyStatistics
    a nch:PublishedFAQPage, schema:FAQPage ;
    dcterms:title "FAQ: Delayed and cancelled journey statistics exchange"@en ;
    schema:mainEntity nch:Q_DelayedJourneyStatisticsRepresentation .

nch:Q_DelayedJourneyStatisticsRepresentation
    a nch:FAQQuestion, schema:Question ;
    schema:text "How are delayed and cancelled journey statistics represented and exchanged in OpRa?"@en ;
    schema:acceptedAnswer nch:A_DelayedJourneyStatisticsRepresentation .

nch:A_DelayedJourneyStatisticsRepresentation
    a nch:FAQAnswer, schema:Answer ;
    schema:text "OpRa examples demonstrate delayed and cancelled journey statistics exchange using structured XML patterns aligned with OpRa schema components."@en ;
    nch:derivedFromChunk nch:Chunk_DelayedAndCancelledJourneysWithEvents_01 ;
    nch:generatedByActivity nch:Act_GenerateAnswer_DelayedJourneyStatistics ;
    nch:hasEvidenceAnnotation nch:Ann_DelayedJourneyStatistics_Evidence_01 .

nch:Ann_DelayedJourneyStatistics_Evidence_01
    a nch:EvidenceAnnotation, oa:Annotation ;
    oa:hasBody nch:A_DelayedJourneyStatisticsRepresentation ;
    oa:hasTarget <https://github.com/OpRa-CEN/OpRa/blob/main/examples/DelayedAndCancelledJourneysWithEvents.xml> ;
    dcterms:creator "nch-retriever" ;
    prov:wasGeneratedBy nch:Act_ExtractEvidence_DelayedJourneyStatistics .

nch:Act_ExtractEvidence_DelayedJourneyStatistics
    a nch:ExtractionActivity ;
    nch:usedEvidenceChunk nch:Chunk_DelayedAndCancelledJourneysWithEvents_01 ;
    prov:wasAssociatedWith nch:Agent_Retriever ;
    prov:used nch:DelayedAndCancelledJourneysWithEventsExample .

nch:Act_GenerateAnswer_DelayedJourneyStatistics
    a nch:AnswerGenerationActivity ;
    nch:usedEvidenceChunk nch:Chunk_DelayedAndCancelledJourneysWithEvents_01 ;
    prov:wasAssociatedWith nch:Agent_Retriever ;
    prov:used nch:Ann_DelayedJourneyStatistics_Evidence_01 .

nch:Act_ReviewAnswer_DelayedJourneyStatistics
    a nch:EditorialReviewActivity ;
    nch:hasReviewDecision "approved" ;
    nch:wasReviewedBy nch:Reviewer_EditorialBoard ;
    prov:used nch:A_DelayedJourneyStatisticsRepresentation .

nch:Agent_Retriever
    a nch:RetrieverAgent ;
    rdfs:label "Helpdesk retrieval agent"@en .

nch:Reviewer_EditorialBoard
    a nch:ReviewerAgent ;
    rdfs:label "Editorial board reviewer"@en .
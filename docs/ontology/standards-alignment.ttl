@prefix nits: <https://napcore.eu/ontology/nits#> .
@prefix netex: <https://napcore.eu/ontology/netex#> .
@prefix opra: <https://napcore.eu/ontology/opra#> .
@prefix siri: <https://napcore.eu/ontology/siri#> .
@prefix datex: <https://napcore.eu/ontology/datex#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://napcore.eu/ontology/standards-alignment>
    a owl:Ontology ;
    dcterms:title "NAPCORE Standards Alignment Ontology"@en ;
    dcterms:description "Alignment module generated from local glossary mappings across NeTEx, OpRa, SIRI, DATEX II, and NAPCORE ITS core concepts, including exact, close, and related cross-standard links."@en ;
    dcterms:created "2026-04-16"^^xsd:date ;
    owl:versionInfo "0.3.0" ;
    owl:imports <https://napcore.eu/ontology/napcore-its>,
                <https://napcore.eu/ontology/netex-federated>,
                <https://napcore.eu/ontology/opra-federated>,
                <https://napcore.eu/ontology/siri-federated>,
                <https://napcore.eu/ontology/datex-federated> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

# Core anchors (standard concept -> nits core concept)
netex:JourneyPattern skos:exactMatch nits:journey-pattern .
netex:Line skos:exactMatch nits:line .
netex:VehicleJourney skos:exactMatch nits:vehicle-journey .
opra:CancelledJourney skos:exactMatch nits:vehicle-journey .
opra:DelayStatistics skos:exactMatch nits:delay .
opra:DelayedJourney skos:exactMatch nits:vehicle-journey .
opra:LateDatedVehicleJourneyEntry skos:exactMatch nits:vehicle-journey .

# Cross-standard close matches (lexical/semantic synonym links)
opra:CancelledJourney skos:closeMatch netex:VehicleJourney .
opra:DelayedJourney skos:closeMatch netex:VehicleJourney .

# Cross-standard related matches (operational/contextual relations)
datex:TrafficEvent skos:relatedMatch netex:DestinationDisplay .
datex:TrafficEvent skos:relatedMatch netex:Line .
datex:TrafficEvent skos:relatedMatch netex:Network .
datex:TrafficEvent skos:relatedMatch netex:Operator .
datex:TrafficEvent skos:relatedMatch netex:ScheduledStopPoint .

@startuml rag-activity-graphdb
title Helpdesk Activity Flow

skinparam backgroundColor white
skinparam shadowing false
skinparam activity {
  BackgroundColor #eef6fb
  BorderColor #4f6b86
  FontColor #1f2b26
  DiamondBackgroundColor #e2eef8
  DiamondBorderColor #4f6b86
  StartColor #0f766e
  EndColor #9a3412
  BarColor #4f6b86
}

start

partition "User" {
  :Ask question in Helpdesk UI;
}

partition "Helpdesk" {
  :Receive question request;
  :Parse intent, scope, and concepts;
  :Try FAQ lookup;
  if (FAQ confidence above threshold?) then (yes)
    :Return FAQ answer with citations;
    :Set mode = faq;
  else (no)
    :Run retrieval on approved repositories;

    if (GraphRAG enabled?) then (yes)
      partition "GraphDB" {
        :Expand concepts and alignments
        using ontology graphs;
      }
      partition "Helpdesk" {
        :Merge vector/lexical results
        with graph expansion signals;
      }
    else (no)
    endif

    if (Evidence sufficient?) then (yes)
      :Generate grounded answer
      from retrieved evidence only;
      :Run policy and citation checks;
      if (Policy pass?) then (yes)
        :Set mode = rag;
      else (no)
        :Set mode = abstain;
      endif
    else (no)
      :Set mode = abstain;
      :Set reason = insufficient evidence;
    endif
  endif

  :Persist question event,
  retrieval traces,
  and evidence links;

  if (Review required?) then (yes)
    :Create editorial queue item;
  else (no)
  endif
}

partition "User" {
  :Receive answer or abstention
  with traceable citations;
}

stop
@enduml

@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Level 2 - NAPCORE Helpdesk Container Diagram

Person(pto, "PTO", "Public Transport Operator")
Person(pta, "PTA", "Public Transport Authority")
Person(dev, "Developer", "Implementation stakeholder")
Person(integrator, "ITS System Integrator", "Integration stakeholder")
Person(ticketing, "Ticketing Agent", "Ticketing stakeholder")

System_Ext(github, "Approved GitHub Repositories", "Authoritative standards sources and allowlisted companion docs")
System_Ext(llm, "LLM Provider API", "Optional grounded answer generation")

System_Boundary(boundary, "NAPCORE Helpdesk") {
  Container(gui, "Web GUI", "React + TypeScript + Vite", "Chat Session UX, operator console, references display, workflow controls")
  Container(api, "Question API / Orchestrator", "Django + DRF REST API", "FAQ-first decisioning, session-aware requests, and RAG fallback orchestration")
  Container(faq, "FAQ Service", "Service", "Canonical FAQ lookup and version management")
  Container(retrieval, "Retrieval Service", "Service", "Hybrid vector plus lexical search over indexed source chunks")
  Container(guardrails, "Generation & Guardrails", "Service", "Deterministic grounded generation, optional LLM provider adapter, citation checks, abstention policy")
  Container(editorial, "Editorial Workflow Service", "Service", "Draft, review, approve, publish flow")
  Container(ingest, "Ingestion Worker", "Worker", "Pull, parse, chunk, embed, and index allowlisted repositories")
  ContainerDb(pg, "Application Database", "PostgreSQL or SQLite local fallback", "FAQ, events, reviews, evidence links, source metadata")
  ContainerDb(vdb, "Vector Index", "pgvector or JSON fallback", "Chunk embeddings and retrieval metadata")
}

Rel(pto, gui, "Runs chat and standards queries")
Rel(pta, gui, "Runs chat and governance queries")
Rel(dev, gui, "Runs technical integration queries")
Rel(integrator, gui, "Runs interoperability and deployment queries")
Rel(ticketing, gui, "Runs ticketing integration queries")

Rel(gui, api, "Submits question, session context, and generation profile", "HTTPS/JSON")
Rel(api, faq, "High-confidence FAQ lookup")
Rel(api, retrieval, "Fallback retrieval request")
Rel(api, guardrails, "Grounded generation request")
Rel(api, editorial, "Route low-confidence or flagged answers")
Rel(api, pg, "Store question events and outcomes")

Rel(faq, pg, "Read/write FAQ entries and versions")
Rel(retrieval, vdb, "Top-k semantic retrieval")
Rel(retrieval, pg, "Store retrieval events")
Rel(guardrails, llm, "Generate from retrieved context only when llm-ready mode is enabled")
Rel(guardrails, pg, "Store evidence links and policy results")
Rel(editorial, pg, "Store review decisions")
Rel(ingest, github, "Pull primary and companion allowlisted repositories")
Rel(ingest, vdb, "Upsert embeddings")
Rel(ingest, pg, "Store source metadata")

' Top layer: actors horizontally
Lay_R(pto, pta)
Lay_R(pta, dev)
Lay_R(dev, integrator)
Lay_R(integrator, ticketing)
' Middle: helpdesk system below actors
Lay_D(pto, gui)
' Bottom layer: external systems below helpdesk boundary
Lay_D(boundary, github)
Lay_D(boundary, llm)
Lay_R(github, llm)

note right of llm
Top layer: Users.
Bottom layer: Approved source repositories and LLM.
end note

SHOW_LEGEND()

@enduml

@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Level 2 - NAPCORE Helpdesk Container Diagram

Person(nap_mgr, "NAP Manager", "Manages a national access point and ensures data publisher compliance")
Person(transport_authority, "Transport Authority", "Sets policy and oversees multimodal standards adoption")
Person(transport_operator, "Transport Operator", "Publishes journey, stop, and timetable data using NeTEx, SIRI, or OpRa")
Person(road_authority, "Road Authority", "Publishes road network and traffic data using DATEX II")
Person(implementer, "Standards Implementer", "Developer or engineer implementing NeTEx, SIRI, DATEX II, or OpRa integrations")
Person(integrator, "ITS System Integrator", "Integrates across standards and deploys interoperability solutions")

System_Ext(github, "Approved GitHub Repositories", "Authoritative standards sources and allowlisted companion docs")
System_Ext(controller_runtime, "Controller Model Runtime", "Local or remote runtime for intent, routing, and SPARQL planning")
System_Ext(narration_runtime, "Narration Model Runtime", "Local or remote runtime for grounded answer composition")

System_Boundary(boundary, "NAPCORE Helpdesk") {
  Container(gui, "Web GUI", "React + TypeScript + Vite", "Chat Session UX, operator console, references display, workflow controls")
  Container(api, "Question API / Orchestrator", "Django + DRF REST API", "FAQ-first decisioning, session-aware requests, and RAG fallback orchestration")
  Container(controller, "Controller LLM Service", "Service", "Intent detection, route selection, and SPARQL/query plan drafting")
  Container(faq, "FAQ Service", "Service", "Canonical FAQ lookup and version management")
  Container(retrieval, "Retrieval Service", "Service", "Hybrid vector plus lexical search over indexed source chunks")
  Container(narration, "Narration LLM Service", "Service", "Grounded answer composition from evidence pack and citations")
  Container(guardrails, "Policy Guardrails Service", "Service", "SPARQL allowlist checks, citation checks, abstention policy, and source-policy enforcement")
  Container(editorial, "Editorial Workflow Service", "Service", "Draft, review, approve, publish flow")
  Container(ingest, "Ingestion Worker", "Worker", "Pull, parse, chunk, embed, and index allowlisted repositories")
  ContainerDb(pg, "Application Database", "PostgreSQL or SQLite local fallback", "FAQ, events, reviews, evidence links, source metadata")
  ContainerDb(vdb, "Vector Index", "pgvector or JSON fallback", "Chunk embeddings and retrieval metadata")
  ContainerDb(sdb, "Semantic Graph Store", "GraphDB (RDF/OWL + SPARQL)", "Ontology modules, alignments, and provenance-backed concept expansion")
}

Rel(nap_mgr, gui, "Runs NAP compliance and publishing queries")
Rel(transport_authority, gui, "Runs governance and policy adoption queries")
Rel(transport_operator, gui, "Runs publishing and implementation queries")
Rel(road_authority, gui, "Runs road data and DATEX II queries")
Rel(implementer, gui, "Runs technical integration queries")
Rel(integrator, gui, "Runs interoperability and deployment queries")

Rel(gui, api, "Submits question, session context, and generation profile", "HTTPS/JSON")
Rel(api, controller, "Intent + routing + query planning request")
Rel(api, faq, "Canonical FAQ lookup when controller selects FAQ path")
Rel(api, retrieval, "Retrieval request when controller selects RAG path")
Rel(api, narration, "Grounded narration request with evidence pack")
Rel(api, guardrails, "Validate query plans and final answer policy compliance")
Rel(api, editorial, "Route low-confidence or flagged answers")
Rel(api, pg, "Store question events and outcomes")

Rel(controller, controller_runtime, "Run intent/routing/SPARQL planning prompt")
Rel(controller, guardrails, "Preflight SPARQL and tool policy validation")
Rel(controller, retrieval, "Issue retrieval plan and constraints")
Rel(controller, sdb, "Plan and run constrained graph queries when graph mode is enabled", "SPARQL/HTTP")

Rel(faq, pg, "Read/write FAQ entries and versions")
Rel(retrieval, vdb, "Top-k semantic retrieval")
Rel(retrieval, sdb, "Graph concept expansion and reranking when GRAPH_RAG_ENABLED and GRAPHDB_ENABLED", "SPARQL/HTTP")
Rel(retrieval, pg, "Store retrieval events")
Rel(narration, narration_runtime, "Compose answer from evidence pack only")
Rel(narration, guardrails, "Request citation and policy validation")
Rel(narration, pg, "Store rendered answer, citations, and confidence")
Rel(guardrails, pg, "Store policy checks and abstention reasons")
Rel(editorial, pg, "Store review decisions")
Rel(ingest, github, "Pull primary and companion allowlisted repositories")
Rel(ingest, vdb, "Upsert embeddings")
Rel(ingest, sdb, "Load ontology, alignments, and extraction outputs for semantic retrieval")
Rel(ingest, pg, "Store source metadata")

' Top layer: actors horizontally
Lay_R(nap_mgr, transport_authority)
Lay_R(transport_authority, transport_operator)
Lay_R(transport_operator, road_authority)
Lay_R(road_authority, implementer)
Lay_R(implementer, integrator)
' Middle: helpdesk system below actors
Lay_D(nap_mgr, gui)
' Bottom layer: external systems below helpdesk boundary
Lay_D(boundary, github)
Lay_D(boundary, controller_runtime)
Lay_D(boundary, narration_runtime)
Lay_R(github, controller_runtime)
Lay_R(controller_runtime, narration_runtime)

note right of narration_runtime
Top layer: Users.
Bottom layer: Approved source repositories and model runtimes.
end note

note right of sdb
Graph-backed semantic expansion is active only when graph flags are enabled.
Non-graph retrieval remains available as deterministic fallback.
end note

SHOW_LEGEND()

@enduml

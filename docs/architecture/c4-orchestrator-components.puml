@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title C4 Level 3 - Question API / Orchestrator Components

Person(user, "End User", "PTO/PTA/Developer/ITS Integrator/Ticketing Agent")
Container(gui, "Web GUI", "Web App", "Chat Session UX and operator console")
ContainerDb(pg, "Application Database", "PostgreSQL or SQLite local fallback", "Events, FAQ, reviews, evidence links")
Container(vdb, "Vector Index", "pgvector or JSON fallback", "Embeddings and metadata")
ContainerDb(graphdb, "Semantic Graph Store", "GraphDB", "Ontology/alignment graph and concept expansion data")
System_Ext(llm, "LLM Provider API", "Optional grounded generation")

Container_Boundary(orchestrator, "Question API / Orchestrator") {
  Component(router, "Request Router", "REST Controller", "Validates request and starts answer pipeline")
  Component(parser, "Semantic Query Parser", "Domain Component", "Extracts candidate standards, concepts, and ambiguity signals")
  Component(faqmatcher, "FAQ Matcher", "Domain Component", "Finds high-confidence canonical FAQ answer")
  Component(retrievalgw, "Retrieval Gateway", "Domain Component", "Executes top-k retrieval from allowlisted sources")
  Component(graphadapter, "Semantic Graph Adapter", "Domain Component", "Runs GraphDB-backed concept expansion when graph mode is enabled")
  Component(generation, "Generation Adapter", "Domain Component", "Chooses deterministic grounded or provider-backed LLM generation")
  Component(policy, "Policy Guard", "Domain Component", "Enforces citation/support checks and abstention policy")
  Component(ruleengine, "Semantic Rule Engine", "Domain Component", "Evaluates semantic competency rules against retrieved evidence")
  Component(ontologyregistry, "Ontology Registry", "Domain Component", "Provides ontology version metadata for trace payload")
  Component(evidence, "Evidence Mapper", "Domain Component", "Maps claims to source chunk evidence links")
  Component(logger, "Event Logger", "Domain Component", "Writes question and retrieval telemetry")
  Component(editorialroute, "Editorial Router", "Domain Component", "Routes low-confidence/flagged answers")
}

Rel(user, gui, "Asks question")
Rel(gui, router, "POST /api/v1/questions/answer with sessionId, scope, and generationProfile")
Rel(router, parser, "Parse semantic intent and scope")
Rel(router, faqmatcher, "FAQ-first check")
Rel(router, retrievalgw, "Fallback retrieval")
Rel(router, generation, "Generate answer")
Rel(router, policy, "Validate output")
Rel(router, ruleengine, "Evaluate semantic rules for RAG responses")
Rel(router, ontologyregistry, "Attach ontology versions to trace")
Rel(router, evidence, "Persist evidence links")
Rel(router, logger, "Persist events")
Rel(router, editorialroute, "Queue if needed")

Rel(parser, retrievalgw, "Send effective scope and semantic cues")
Rel(faqmatcher, pg, "Read FAQ entries/versions")
Rel(retrievalgw, graphadapter, "Request graph concept expansion")
Rel(retrievalgw, vdb, "Query top-k chunks")
Rel(retrievalgw, pg, "Store retrieval events")
Rel(graphadapter, graphdb, "Query ontology/alignments and expansion paths", "SPARQL/HTTP")
Rel(generation, llm, "Generate from retrieved context only when llm-ready mode is enabled")
Rel(policy, pg, "Store policy outcomes")
Rel(evidence, pg, "Store answer_evidence_links")
Rel(logger, pg, "Store question_events")
Rel(editorialroute, pg, "Store queue/review records")

SHOW_LEGEND()

@enduml

@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title C4 Level 1 - NAPCORE Helpdesk System Context

Person(pto, "PTO", "Public Transport Operator")
Person(pta, "PTA", "Public Transport Authority")
Person(dev, "Developer", "Implements standards and integrations")
Person(integrator, "ITS System Integrator", "Integrates transport and ITS systems")
Person(ticketing, "Ticketing Agent", "Implements and operates ticketing workflows")

System(helpdesk, "NAPCORE Helpdesk", "Chat-style FAQ-first + RAG helpdesk for multimodal standards")
System_Ext(github, "Approved GitHub Repositories", "NeTEx-CEN/NeTEx plus allowlisted companion repositories")
System_Ext(graphdb, "GraphDB Semantic Store", "Ontology and alignment graph queried for semantic expansion and provenance")
System_Ext(llm, "LLM Provider API", "Default provider-backed generation with grounded-only prompt contract")

Rel(pto, helpdesk, "Asks standards implementation questions", "Chat Session / Web GUI")
Rel(pta, helpdesk, "Asks governance and policy implementation questions", "Chat Session / Web GUI")
Rel(dev, helpdesk, "Asks technical integration questions", "Chat Session / Web GUI")
Rel(integrator, helpdesk, "Asks interoperability and deployment questions", "Chat Session / Web GUI")
Rel(ticketing, helpdesk, "Asks ticketing integration questions", "Chat Session / Web GUI")

Rel(helpdesk, github, "Indexes approved source content and companion documentation", "Git clone/fetch + indexing")
Rel(helpdesk, graphdb, "Queries ontology/alignments for graph-aware retrieval and traceability", "SPARQL/HTTP")
Rel(helpdesk, llm, "Generates answer from retrieved evidence only", "OpenAI-compatible API")

UpdateRelStyle(helpdesk, llm, $textColor="black", $lineColor="#38598A")

UpdateElementStyle(pto, $fontColor="#1F2F4A")
UpdateElementStyle(pta, $fontColor="#1F2F4A")
UpdateElementStyle(dev, $fontColor="#1F2F4A")
UpdateElementStyle(integrator, $fontColor="#1F2F4A")
UpdateElementStyle(ticketing, $fontColor="#1F2F4A")

' Top layer: actors horizontally
Lay_R(pto, pta)
Lay_R(pta, dev)
Lay_R(dev, integrator)
Lay_R(integrator, ticketing)
' Middle: helpdesk below actors
Lay_D(pto, helpdesk)
' Bottom layer: external systems below helpdesk
Lay_D(helpdesk, github)
Lay_D(helpdesk, graphdb)
Lay_D(helpdesk, llm)
Lay_R(github, graphdb)
Lay_R(graphdb, llm)

note right of llm
Top layer: Users.
Bottom layer: Approved source repositories and LLM.
end note

SHOW_LEGEND()

@enduml

FROM ghcr.io/ggml-org/llama.cpp:full AS llama_cpp_full

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Copy Linux llama.cpp CLI and shared libraries for subprocess controller mode.
RUN mkdir -p /opt/llama.cpp-linux
COPY --from=llama_cpp_full /app/llama-cli /opt/llama.cpp-linux/llama-cli
COPY --from=llama_cpp_full /app/libggml*.so* /opt/llama.cpp-linux/
COPY --from=llama_cpp_full /app/libllama*.so* /opt/llama.cpp-linux/
COPY --from=llama_cpp_full /app/libmtmd*.so* /opt/llama.cpp-linux/

COPY . /app/backend

EXPOSE 8000

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]

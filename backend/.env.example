DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
ALLOWED_SOURCE_REPOSITORIES=https://github.com/NeTEx-CEN/NeTEx,https://github.com/NeTEx-CEN/test-Profile-Documentation
INDEX_SCHEDULE_REPO_URL=
INDEX_SCHEDULE_REPO_PATH=
INDEX_SCHEDULE_PROFILE=netex
LLM_ENABLED=False
LLM_PROVIDER=openai-compatible
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2
# PostgreSQL-first baseline (set True for local SQLite fallback only)
DJANGO_USE_SQLITE=False
POSTGRES_DB=napcore_helpdesk
POSTGRES_USER=napcore
POSTGRES_PASSWORD=napcore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

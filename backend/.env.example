DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
ALLOWED_SOURCE_REPOSITORIES=https://github.com/TransmodelEcosystem/NeTEx,https://github.com/NeTEx-CEN/test-Profile-Documentation
INDEX_SCHEDULE_REPO_URL=
INDEX_SCHEDULE_REPO_PATH=
INDEX_SCHEDULE_PROFILE=netex
GITHUB_API_TOKEN=
GITHUB_API_VERIFY_SSL=True
GITHUB_CA_BUNDLE=
LLM_ENABLED=False
LLM_PROVIDER=openai-compatible
# GitHub Models (OpenAI-compatible endpoint)
LLM_API_BASE_URL=https://models.inference.ai.azure.com
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_VERIFY_SSL=True
LLM_CA_BUNDLE=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2
EMBEDDING_ENABLED=False
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=30
GRAPH_RAG_ENABLED=False
SEMANTIC_LOW_CONFIDENCE_THRESHOLD=0.60
EVIDENCE_GATE_ENABLED=False
EVIDENCE_GATE_MIN_ALIGNMENT=0.30
EVIDENCE_GATE_MIN_CHUNKS=1
EVIDENCE_GATE_MIN_REPOSITORIES_MULTI_SCOPE=2
POLICY_STRICT_CLAIM_GUARD=False
GRAPHDB_ENABLED=False
GRAPHDB_SPARQL_ENDPOINT=
GRAPHDB_REPOSITORY=
GRAPHDB_USER=
GRAPHDB_PASSWORD=
GRAPHDB_TIMEOUT_SECONDS=5
GRAPH_EXPANSION_MAX_CONCEPTS=64
GRAPH_EXPANSION_MAX_CANDIDATE_CHUNKS=40
RETRIEVAL_DIVERSITY_ENABLED=True
RETRIEVAL_MAX_SAME_SOURCE_PATH=2
RETRIEVAL_MMR_LAMBDA=0.92
RETRIEVAL_KEYWORD_TRAP_PENALTY=0.60
# If True, fail fast when ontology YAML schema is invalid (recommended for CI)
NAPCORE_ONTOLOGY_STRICT_VALIDATION=False
# PostgreSQL-first baseline (set True for local SQLite fallback only)
DJANGO_USE_SQLITE=False
POSTGRES_DB=napcore_helpdesk
POSTGRES_USER=napcore
POSTGRES_PASSWORD=napcore
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Shared Docker PostgreSQL mode (used by docker-compose.external-postgres.yml):
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5432
# Keep app-specific names when sharing one PostgreSQL instance across multiple apps:
# POSTGRES_DB=napcore_helpdesk
# POSTGRES_USER=napcore
# POSTGRES_PASSWORD=change-me
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

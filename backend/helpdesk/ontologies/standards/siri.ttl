    skos:altLabel "connectiontimetabledelivery"@en ;
    skos:altLabel "delivery for connection timetable service"@en ;
    rdfs:subClassOf siri:AbstractFunctionalServiceDelivery ;
    rdfs:comment "Extracted from XSD schema"@en .


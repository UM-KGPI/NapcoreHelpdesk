siri:ConnectionMonitoringServiceCapabilities
    a owl:Class ;
    skos:definition "Capabilities of Connection Monitoring Service."@en ;
    skos:prefLabel "capabilities of connection monitoring service"@en ;
    skos:altLabel "connection monitoring service capabilities"@en ;
    skos:altLabel "connectionmonitoringservicecapabilities"@en ;

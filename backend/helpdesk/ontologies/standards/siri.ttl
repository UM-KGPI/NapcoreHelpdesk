    skos:prefLabel "capabilities for connection timetable service"@en ;
    skos:altLabel "connection timetable capabilities response"@en ;
    skos:altLabel "connectiontimetablecapabilitiesresponse"@en ;
    rdfs:subClassOf siri:AbstractFunctionalServiceCapabilitiesResponse ;

    skos:prefLabel "connection timetable request"@en ;
    skos:altLabel "connectiontimetablerequest"@en ;
    skos:altLabel "request for information about timetabled"@en ;
    rdfs:subClassOf siri:AbstractFunctionalServiceRequest ;

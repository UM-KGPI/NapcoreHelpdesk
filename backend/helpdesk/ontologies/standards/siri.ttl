@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix netex: <https://netex.org.uk/netex/2.0#> .
@prefix opra: <https://transmodel-cen.eu/opra/1.0#> .
@prefix siri: <https://siri.org.uk/siri/1.3#> .
@prefix transmodel: <https://transmodel-cen.eu/6.2/> .
@prefix nits: <https://napcore.eu/ontology/nits#> .

<https://siri.org.uk/siri/1.3>
    a owl:Ontology ;
    dct:title "SIRI Ontology with Schema Relationships"@en ;
    dct:description "OWL ontology with extracted inheritance and composition relationships from XSD."@en ;
    owl:versionInfo "0.2-xsd-rebuild-with-relationships" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Concepts with Semantic Relationships
#################################################################

siri:AbstractDiscoveryDelivery
    a owl:Class ;
    skos:definition "Abstract type for a discovery delivery."@en ;
    skos:prefLabel "abstract discovery delivery"@en ;
    skos:altLabel "abstract type for a discovery"@en ;
    skos:altLabel "abstractdiscoverydelivery"@en ;
    rdfs:subClassOf siri:AbstractResponse ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractDiscoveryRequest
    a owl:Class ;
    skos:definition "Abstract Discovery request."@en ;
    skos:prefLabel "abstract discovery request"@en ;
    skos:altLabel "abstractdiscoveryrequest"@en ;
    rdfs:subClassOf siri:AuthenticatedRequest ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractFunctionalServiceCapabilitiesRequest
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI Functional Service Capabiloitiesequest."@en ;
    skos:prefLabel "abstract functional service capabilities request"@en ;
    skos:altLabel "abstractfunctionalservicecapabilitiesrequest"@en ;
    rdfs:subClassOf siri:AbstractServiceRequest ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractFunctionalServiceCapabilitiesResponse
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI Functional Service Capabiloitiesequest."@en ;
    skos:prefLabel "abstract functional service capabilities response"@en ;
    skos:altLabel "abstractfunctionalservicecapabilitiesresponse"@en ;
    rdfs:subClassOf siri:AbstractResponse ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractFunctionalServiceDelivery
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI Functional Service request."@en ;
    skos:prefLabel "abstract functional service delivery"@en ;
    skos:altLabel "abstractfunctionalservicedelivery"@en ;
    rdfs:subClassOf siri:AbstractResponse ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractFunctionalServiceRequest
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI Functional Service request."@en ;
    skos:prefLabel "abstract functional service request"@en ;
    skos:altLabel "abstractfunctionalservicerequest"@en ;
    rdfs:subClassOf siri:AbstractServiceRequest ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractFunctionalServiceSubscriptionRequest
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI Functional Service subscription request."@en ;
    skos:prefLabel "abstract functional service subscription request"@en ;
    skos:altLabel "abstractfunctionalservicesubscriptionrequest"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractRequest
    a owl:Class ;
    skos:definition "Subsititutable type for a timestamped SIRI request."@en ;
    skos:prefLabel "abstract request"@en ;
    skos:altLabel "abstractrequest"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractResponse
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI response."@en ;
    skos:prefLabel "abstract response"@en ;
    skos:altLabel "abstractresponse"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractServiceRequest
    a owl:Class ;
    skos:definition "Substitutable type for a SIRI Functional Service request."@en ;
    skos:prefLabel "abstract service request"@en ;
    skos:altLabel "abstractservicerequest"@en ;
    rdfs:subClassOf siri:AbstractRequest ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AbstractTrackedRequest
    a owl:Class ;
    skos:definition "Subsititutable type for a SIRI request with requestor dteials tracked."@en ;
    skos:prefLabel "abstract tracked request"@en ;
    skos:altLabel "abstracttrackedrequest"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AccessFacility
    a owl:Class ;
    skos:definition "Classification of Access Facility."@en ;
    skos:prefLabel "access facility"@en ;
    skos:altLabel "accessfacility"@en ;
    skos:altLabel "classification of access facility"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AccessNotAllowedError
    a owl:Class ;
    skos:definition "Error: Requestor is not authorised to the service or data requested."@en ;
    skos:prefLabel "access not allowed error"@en ;
    skos:altLabel "accessnotallowederror"@en ;
    skos:altLabel "error requestor is not authorised"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AccommodationFacility
    a owl:Class ;
    skos:definition "Classification of Accomodation Facility type - Tpeg pti23."@en ;
    skos:prefLabel "accommodation facility"@en ;
    skos:altLabel "accommodationfacility"@en ;
    skos:altLabel "classification of accomodation facility type"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ActualArrivalTime
    a owl:Class ;
    skos:definition "Observed time of arrival of VEHICLE at stop."@en ;
    skos:prefLabel "actual arrival time"@en ;
    skos:altLabel "actualarrivaltime"@en ;
    skos:altLabel "observed time of arrival of"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ActualDepartureTime
    a owl:Class ;
    skos:definition "Observed time of departure of VEHICLE from stop."@en ;
    skos:prefLabel "actual departure time"@en ;
    skos:altLabel "actualdeparturetime"@en ;
    skos:altLabel "observed time of departure of"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ActualHeadwayInterval
    a owl:Class ;
    skos:definition "For frequency based services, observed interval between vehicles at stop."@en ;
    skos:prefLabel "actual headway interval"@en ;
    skos:altLabel "actualheadwayinterval"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedArrivalTime
    a owl:Class ;
    skos:definition "Target arrival time of VEHICLE at stop according to latest working timetable."@en ;
    skos:prefLabel "aimed arrival time"@en ;
    skos:altLabel "aimedarrivaltime"@en ;
    skos:altLabel "target arrival time of vehicle"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedArrivalTimeOfFeeder
    a owl:Class ;
    skos:definition "Planned time at which feeder VEHICLE is scheduled to arrive. (since SIRI 2.1)"@en ;
    skos:prefLabel "aimed arrival time of feeder"@en ;
    skos:altLabel "aimedarrivaltimeoffeeder"@en ;
    skos:altLabel "planned time at which feeder"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedDepartureTime
    a owl:Class ;
    skos:definition "Target departure time of VEHICLE from stop according to latest working timetable."@en ;
    skos:prefLabel "aimed departure time"@en ;
    skos:altLabel "aimeddeparturetime"@en ;
    skos:altLabel "target departure time of vehicle"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedDepartureTimeOfDistributor
    a owl:Class ;
    skos:definition "Planned time at which distributor VEHICLE is scheduled to depart. (since SIRI 2.1)"@en ;
    skos:prefLabel "aimed departure time of distributor"@en ;
    skos:altLabel "aimeddeparturetimeofdistributor"@en ;
    skos:altLabel "planned time at which distributor"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedFlexibleArea
    a owl:Class ;
    skos:definition "Area that encompasses the scheduled flexible stop locations according to the planned timetable. (since SIRI 2.1)"@en ;
    skos:prefLabel "aimed flexible area"@en ;
    skos:altLabel "aimedflexiblearea"@en ;
    skos:altLabel "area that encompasses the scheduled"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedHeadwayInterval
    a owl:Class ;
    skos:definition "For frequency based services, target interval between vehicles at stop."@en ;
    skos:prefLabel "aimed headway interval"@en ;
    skos:altLabel "aimedheadwayinterval"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedLatestPassengerAccessTime
    a owl:Class ;
    skos:definition "Latest target time at which a PASSENGER should aim to arrive at the STOP PLACE containing the stop. This time may be earlier than the VEHICLE departure times and may include time for processes such as checkin, security, etc.(As specified by CHECK CONSTRAINT DELAYs in the underlying data). If absent assume to be the same as Earliest expected departure time. (since SIRI 2.0)"@en ;
    skos:prefLabel "aimed latest passenger access time"@en ;
    skos:altLabel "aimedlatestpassengeraccesstime"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AimedLocationName
    a owl:Class ;
    skos:definition "Name or description (e.g. address) of the scheduled location or flexible area. (since SIRI 2.1)"@en ;
    skos:prefLabel "aimed location name"@en ;
    skos:altLabel "aimedlocationname"@en ;
    skos:altLabel "name or description eg address"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AirSubmode
    a owl:Class ;
    skos:definition "TPEG Pti08 and Pts108 \"AirService\" submodes."@en ;
    skos:prefLabel "air submode"@en ;
    skos:altLabel "airsubmode"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AllowAll
    a owl:Class ;
    skos:definition "Allow access to all topics known to the service."@en ;
    skos:prefLabel "allow access to all topics"@en ;
    skos:altLabel "allow all"@en ;
    skos:altLabel "allowall"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AllowedResourceUsageExceededError
    a owl:Class ;
    skos:definition "Error: Valid request was made but request would exceed the permitted resource usage of the client."@en ;
    skos:prefLabel "allowed resource usage exceeded error"@en ;
    skos:altLabel "allowedresourceusageexceedederror"@en ;
    skos:altLabel "error valid request was made"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalBoardingActivity
    a owl:Class ;
    skos:definition "Type of alighting allowed at stop. Default is 'Alighting'."@en ;
    skos:prefLabel "arrival boarding activity"@en ;
    skos:altLabel "arrivalboardingactivity"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalCancellationReason
    a owl:Class ;
    skos:definition "Text annotation to be used in cases where ArrivalStatus is set to 'cancelled'. (since SIRI 2.1)"@en ;
    skos:prefLabel "arrival cancellation reason"@en ;
    skos:altLabel "arrivalcancellationreason"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalFormationAssignment
    a owl:Class ;
    skos:definition "Assignment of a TRAIN formation to a physical QUAY (platform or sectors thereof). If not given, assume same as for departure. (since SIRI 2.1)"@en ;
    skos:prefLabel "arrival formation assignment"@en ;
    skos:altLabel "arrivalformationassignment"@en ;
    skos:altLabel "assignment of a train formation"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalOrientationRelativeToQuay
    a owl:Class ;
    skos:definition "Indication of the direction of travel of the vehicle (e.g. TRAIN formation) with respect to the platform, or more precisely the QUAY. Unbounded to allow multiple languages. (since SIRI 2.1) Examples: - \"towards A\" or \"towards sector A\" if the QUAY is separated into sub-QUAYs or so called sectors. This would be equivalent to the vehicle arriving at sector A first when approaching the QUAY with sectors A-B-C-D. If the arriving vehicle is represented as an arrow, \"towards A\" would be abstracted as \"=> A-B-C-D\". - \"towards 0\" or \"towards reference point 0\" if sectors are not available or the QUAY has a reference point, e.g. for measuring the length of the QUAY, identified by \"0\". This would be equivalent to the vehicle arriving at this reference point first when approaching the QUAY. If the arriving vehicle is represented as an arrow, \"towards 0\" would be abstracted as \"=> 0...100\". \"100\" (as in percent) could denote the opposite side of the QUAY (measured at the full length of the QUAY with respect to the reference point). It is advised to specify a reference point that is meaningful for passengers on location."@en ;
    skos:prefLabel "arrival orientation relative to quay"@en ;
    skos:altLabel "arrivalorientationrelativetoquay"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalPlatformName
    a owl:Class ;
    skos:definition "Bay or platform (QUAY) name to show passenger i.e. expected platform for vehicle to arrive at.  Inheritable property. Can be omitted if the same as the DeparturePlatformName If there no arrival platform name separate from the departure platform name, the precedence is: (i) any arrival platform on any related dated timetable element,  (ii) any departure platform name on this estimated element; (iii) any departure platform name on any related dated timetable CALL."@en ;
    skos:prefLabel "arrival platform name"@en ;
    skos:altLabel "arrivalplatformname"@en ;
    skos:altLabel "bay or platform quay name"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalProximityText
    a owl:Class ;
    skos:definition "Arbitrary text string to show to indicate the status of the departure of the VEHICLE for example, “Enroute”, “5 Km”, “Approaching”. May depend on the policy of the OPERATOR, for example show “Approaching” if less than 200metres away from stop. (since SIRI 2.0)"@en ;
    skos:prefLabel "arbitrary text string to show"@en ;
    skos:altLabel "arrival proximity text"@en ;
    skos:altLabel "arrivalproximitytext"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ArrivalStatus
    a owl:Class ;
    skos:definition "Classification of the timeliness of the visit according to a fixed list of values. If not specified, same as DepartureStatus."@en ;
    skos:prefLabel "arrival status"@en ;
    skos:altLabel "arrivalstatus"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AssistanceFacility
    a owl:Class ;
    skos:definition "Classification of Assistance Facility."@en ;
    skos:prefLabel "assistance facility"@en ;
    skos:altLabel "assistancefacility"@en ;
    skos:altLabel "classification of assistance facility"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:AuthenticatedRequest
    a owl:Class ;
    skos:definition "Subsititutable type for an authenticated request Authenticated."@en ;
    skos:prefLabel "authenticated request"@en ;
    skos:altLabel "authenticatedrequest"@en ;
    skos:altLabel "subsititutable type for an authenticated"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:BeyondDataHorizon
    a owl:Class ;
    skos:definition "Error: Data period or subscription period is outside of period covered by service."@en ;
    skos:prefLabel "beyond data horizon"@en ;
    skos:altLabel "beyonddatahorizon"@en ;
    skos:altLabel "error data period or subscription"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:BusSubmode
    a owl:Class ;
    skos:definition "TPEG Pti05 and Pts105 \"BusService\" submodes."@en ;
    skos:prefLabel "bus submode"@en ;
    skos:altLabel "bussubmode"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CapabilitiesRequest
    a owl:Class ;
    skos:definition "Requests a the current capabilities of the server. Answred with a CpabailitiesResponse."@en ;
    skos:prefLabel "capabilities request"@en ;
    skos:altLabel "capabilitiesrequest"@en ;
    skos:altLabel "requests a the current capabilities"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CapabilitiesResponse
    a owl:Class ;
    skos:definition "Responses with the capabilities of an implementation."@en ;
    skos:prefLabel "capabilities response"@en ;
    skos:altLabel "capabilitiesresponse"@en ;
    skos:altLabel "responses with the capabilities of"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CapabilityNotSupportedError
    a owl:Class ;
    skos:definition "Error: Service does not support the requested capability."@en ;
    skos:prefLabel "capability not supported error"@en ;
    skos:altLabel "capabilitynotsupportederror"@en ;
    skos:altLabel "error service does not support"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CheckStatusRequest
    a owl:Class ;
    skos:definition "Request from Consumer to Producer to check whether services is working. Answers a CheckStatusRequest."@en ;
    skos:prefLabel "check status request"@en ;
    skos:altLabel "checkstatusrequest"@en ;
    skos:altLabel "request from consumer to producer"@en ;
    rdfs:subClassOf siri:AbstractTrackedRequest ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CheckStatusResponse
    a owl:Class ;
    skos:definition "Response from Producer to Consumer to inform whether services is working. Answers a CheckStatusRequest."@en ;
    skos:prefLabel "check status response"@en ;
    skos:altLabel "checkstatusresponse"@en ;
    skos:altLabel "response from producer to consumer"@en ;
    rdfs:subClassOf siri:AbstractResponse ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CoachSubmode
    a owl:Class ;
    skos:definition "TPEG Pti03 and Pts103 \"CoachService\" submodes."@en ;
    skos:prefLabel "coach submode"@en ;
    skos:altLabel "coachsubmode"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:CompoundTrain
    a owl:Class ;
    skos:definition "Groups of carriages may be managed as sections by composing TRAINs into a COMPOUND TRAIN, for example if a TRAIN joins (or splits from) another TRAIN. (since SIRI 2.1) TRAINs within a COMPOUND TRAIN may have different origins and destinations due to joining/splitting. A COMPOUND TRAIN may be stable for one or multiple JOURNEY PARTs and change at a certain STOP POINT due to planned joining/splitting, despatching alterations or a situation."@en ;
    skos:prefLabel "compound train"@en ;
    skos:altLabel "compoundtrain"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:Condition
    a owl:Class ;
    skos:definition "Classification of effect on service. TPEG PTS043 ServiceStatus"@en ;
    skos:prefLabel "condition"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ConnectionLinkPermissions
    a owl:Class ;
    skos:definition "The CONNECTION links that the participant may access."@en ;
    skos:prefLabel "connection link permissions"@en ;
    skos:altLabel "connection links that the"@en ;
    skos:altLabel "connectionlinkpermissions"@en ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ConnectionLinksDelivery
    a owl:Class ;
    skos:definition "Returns the CONNECTION LINKs covered by a web service. Answers a LINEsRequest. (since SIRI 2.0)"@en ;
    skos:prefLabel "connection links delivery"@en ;
    skos:altLabel "connectionlinksdelivery"@en ;
    skos:altLabel "returns the connection links covered"@en ;
    rdfs:subClassOf siri:AbstractDiscoveryDelivery ;
    rdfs:comment "Extracted from XSD schema"@en .

siri:ConnectionLinksRequest
    a owl:Class ;
    skos:definition "Requests a list of the CONNECTION LINKs covered by a Producer. (since SIRI 2.0)"@en ;
    skos:prefLabel "connection links request"@en ;
    skos:altLabel "connectionlinksrequest"@en ;
    rdfs:subClassOf siri:AbstractDiscoveryRequest ;
    rdfs:comment "Extracted from XSD schema"@en .


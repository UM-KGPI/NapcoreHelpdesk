# Production environment template
# Copy to .env.prod and fill in actual values on the production server

DJANGO_SECRET_KEY=<change-me-to-random-string>
DJANGO_DEBUG=False
SERVICE_NAME=napcore-helpdesk
SERVICE_BUILD_REF=production
DJANGO_ALLOWED_HOSTS=kgpi.fgpa.um.si

JWT_SECRET_KEY=<change-me-to-random-string>
JWT_ALGORITHM=HS256

ALLOWED_SOURCE_REPOSITORIES=https://github.com/TransmodelEcosystem/NeTEx,https://github.com/TransmodelEcosystem/SIRI,https://github.com/OpRa-CEN/OpRa

GITHUB_API_TOKEN=<your-github-token>
GITHUB_API_VERIFY_SSL=True

# LLM Configuration (CRITICAL: qwen36-35b-a3b is a reasoning model with large thinking overhead)
LLM_ENABLED=True
LLM_PROVIDER=openai-compatible
LLM_API_BASE_URL=https://litellm.lhrs.si/v1
LLM_API_KEY=<your-litellm-api-key>
LLM_MODEL=qwen36-35b-a3b
LLM_VERIFY_SSL=False
LLM_TIMEOUT_SECONDS=30
# IMPORTANT: Reasoning models need substantial tokens for thinking overhead
# Minimum 2000 to leave room for both reasoning (486+ chars) and actual answer
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.2
LLM_MAX_EVIDENCE_CHUNKS=4
LLM_MAX_EVIDENCE_CHARS_PER_CHUNK=1200

# Controller LLM (routing decisions, smaller model)
CONTROLLER_LLM_ENABLED=True
CONTROLLER_LLM_PROVIDER=openai-compatible
CONTROLLER_LLM_API_BASE_URL=https://litellm.lhrs.si/v1
CONTROLLER_LLM_API_KEY=<your-litellm-api-key>
CONTROLLER_LLM_API_MODEL=qwen36-35b-a3b
CONTROLLER_LLM_VERIFY_SSL=False

# Graph RAG
GRAPH_RAG_ENABLED=True
GRAPHDB_ENABLED=True
GRAPHDB_SPARQL_ENDPOINT=http://graphdb:7200/repositories/napcore-helpdesk
GRAPHDB_REPOSITORY=napcore-helpdesk
GRAPHDB_TIMEOUT_SECONDS=3
GRAPH_EXPANSION_MAX_CONCEPTS=8
GRAPH_EXPANSION_MAX_CANDIDATE_CHUNKS=12

# Database (use Docker service names in production)
POSTGRES_DB=napcore_helpdesk
POSTGRES_USER=napcore
POSTGRES_PASSWORD=<strong-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (use Docker service names in production)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=https://kgpi.fgpa.um.si/napcore-helpdesk
